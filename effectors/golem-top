#!/usr/bin/env python3
"""golem-top — show running golem processes, like top for golems.

Usage:
    golem-top              # show all running golem processes
    golem-top --watch      # refresh every 5 seconds
    golem-top --json       # machine-readable JSON output
"""
from __future__ import annotations

import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path


def get_golem_processes() -> list[dict]:
    """Parse ps output and return list of golem process dicts.

    Each dict has: pid, ppid, provider, task, started, elapsed, cpu, mem, command
    """
    try:
        result = subprocess.run(
            ["ps", "aux"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return []

    lines = result.stdout.strip().split("\n")
    processes: list[dict] = []

    for line in lines[1:]:  # skip header
        if "golem" not in line.lower():
            continue
        # Skip this script itself and grep
        if "golem-top" in line and "python" in line:
            parts = line.split()
            # Keep only if it's not our own process
            cmdline = " ".join(parts[10:])
            if "golem-top" in cmdline and "grep" not in line:
                continue
        if "grep" in line and "golem" in line:
            continue

        proc = _parse_ps_line(line)
        if proc and proc.get("task"):
            processes.append(proc)

    return processes


def _parse_ps_line(line: str) -> dict | None:
    """Parse a single ps aux line into a process dict."""
    parts = line.split(None, 10)
    if len(parts) < 11:
        return None

    user, pid_str, cpu, mem, vsz, rss, tty, stat, started, elapsed, command = parts

    try:
        pid = int(pid_str)
    except ValueError:
        return None

    # Extract provider from --provider flag
    provider = _extract_provider(command)

    # Extract task description (the quoted argument or trailing text)
    task = _extract_task(command)

    return {
        "pid": pid,
        "user": user,
        "cpu_pct": cpu,
        "mem_pct": mem,
        "stat": stat,
        "started": started,
        "elapsed": elapsed,
        "provider": provider,
        "task": task,
        "command": command,
    }


def _extract_provider(command: str) -> str:
    """Extract --provider value from command string."""
    m = re.search(r"--provider\s+(\S+)", command)
    return m.group(1) if m else "default"


def _extract_task(command: str) -> str:
    """Extract the human-readable task description from a golem command.

    Looks for quoted strings first, then falls back to text after
    the last flag argument.
    """
    # Prefer quoted task strings
    quotes = re.findall(r'"([^"]+)"', command)
    if quotes:
        # Return the last quoted string (the actual task, not any inner quotes)
        return quotes[-1][:80]

    # For unquoted tasks: find text after the last --flag value
    # Match the golem command pattern: flags then task
    m = re.match(
        r"(?:/[\w/.-]+/)?(?:bash|sh)\s+(?:/[\w/.-]+/)?golem\s+.*?(?:--\S+\s+\S+\s+)*(.+)",
        command,
    )
    if m:
        task = m.group(1).strip()
        # Remove any remaining flags
        task = re.sub(r"--\S+\s+\S+", "", task).strip()
        return task[:80] if task else ""

    return ""


def _parse_elapsed(elapsed: str) -> str:
    """Normalize elapsed time display."""
    return elapsed if elapsed else "?"


def format_table(processes: list[dict]) -> str:
    """Format process list as a human-readable table."""
    if not processes:
        return "No running golem processes.\n"

    # Group deduplicated tasks — a single golem invocation produces
    # multiple processes (sh -c, bash golem, bash golem again).
    # Deduplicate by task text, keeping the first PID.
    seen_tasks: dict[str, dict] = {}
    for proc in processes:
        key = proc["task"]
        if key not in seen_tasks:
            seen_tasks[key] = proc

    procs = list(seen_tasks.values())

    # Column widths
    pid_w = max(len(str(p["pid"])) for p in procs)
    prov_w = max(len(p["provider"]) for p in procs)
    task_w = 60
    elapsed_w = max(len(p.get("elapsed", "?")) for p in procs)

    header = (
        f"{'PID':>{pid_w}}  {'PROVIDER':<{prov_w}}  "
        f"{'ELAPSED':>{elapsed_w}}  {'CPU':>4}  {'MEM':>4}  "
        f"{'TASK':<{task_w}}"
    )
    sep = "-" * len(header)

    lines = [f"golem-top — {len(procs)} running golem task(s)", sep, header, sep]

    for p in procs:
        task_display = p["task"]
        if len(task_display) > task_w:
            task_display = task_display[: task_w - 1] + "…"
        lines.append(
            f"{p['pid']:>{pid_w}}  {p['provider']:<{prov_w}}  "
            f"{_parse_elapsed(p.get('elapsed', '?')):>{elapsed_w}}  "
            f"{p['cpu_pct']:>4}  {p['mem_pct']:>4}  "
            f"{task_display:<{task_w}}"
        )

    lines.append(sep)
    return "\n".join(lines) + "\n"


def main() -> None:
    args = sys.argv[1:]

    as_json = "--json" in args
    watch = "--watch" in args

    if watch:
        interval = 5
        try:
            while True:
                procs = get_golem_processes()
                os.system("clear" if os.name != "nt" else "cls")
                print(format_table(procs))
                print(f"Refreshing every {interval}s — Ctrl+C to stop")
                time.sleep(interval)
        except KeyboardInterrupt:
            sys.exit(0)
    elif as_json:
        procs = get_golem_processes()
        print(json.dumps(procs, indent=2))
    else:
        procs = get_golem_processes()
        print(format_table(procs))


if __name__ == "__main__":
    main()

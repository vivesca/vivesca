#!/usr/bin/env python3
"""diapedesis — stateful browser automation wrapper over agent-browser.

Handles session hygiene (socket cleanup, profile), routing (headed vs headless),
and common interaction patterns (Element UI, form bypass).

Usage:
  diapedesis open <url>              # Open with profile, auto-cleanup
  diapedesis open --headed <url>     # Visible browser for payment/CAPTCHA
  diapedesis reset                   # Kill daemons, clean sockets
  diapedesis snap [path]             # Accessibility snapshot (interactive refs)
  diapedesis click <ref>             # Click element by @ref
  diapedesis fill <ref> <text>       # Fill input
  diapedesis select-el <text>        # Select Element UI dropdown option by visible text
  diapedesis cart-add <css>          # Click add-to-cart button by CSS selector
  diapedesis submit [--follow]       # Submit current form natively (bypass Vue)
  diapedesis screenshot [path]       # Screenshot to file
  diapedesis url                     # Print current URL
  diapedesis title                   # Print current page title
"""

import argparse
import glob
import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

AB = "agent-browser"
PROFILE = Path.home() / ".agent-browser-profile"
SOCKET_DIR = Path.home() / ".agent-browser"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _run(args: list[str], timeout: int = 15) -> tuple[bool, str, str]:
    """Run command, return (ok, stdout, stderr)."""
    try:
        r = subprocess.run(args, capture_output=True, text=True, timeout=timeout)
        return r.returncode == 0, r.stdout.strip(), r.stderr.strip()
    except subprocess.TimeoutExpired:
        return False, "", "timeout"
    except FileNotFoundError:
        return False, "", f"{args[0]} not found"


def ab(*args: str, timeout: int = 15) -> tuple[bool, str]:
    """Run agent-browser command. Returns (ok, output)."""
    ok, out, err = _run([AB, *args], timeout=timeout)
    return ok, out if ok else err


def _cleanup_sockets():
    """Remove stale socket and pid files."""
    for pattern in ["*.sock", "*.pid"]:
        for f in glob.glob(str(SOCKET_DIR / pattern)):
            try:
                os.remove(f)
            except OSError:
                pass


def _kill_daemons():
    """Kill any running agent-browser daemon and Chrome for Testing."""
    subprocess.run(
        ["pkill", "-f", "agent-browser-darwin"],
        capture_output=True, timeout=5,
    )
    subprocess.run(
        ["pkill", "-f", "Chrome for Testing"],
        capture_output=True, timeout=5,
    )
    time.sleep(1)


def _ensure_session(headed: bool = False):
    """Ensure a clean agent-browser session with profile."""
    # Check if daemon is responsive
    ok, _ = ab("get", "url", timeout=5)
    if ok:
        return  # Already running and responsive

    # Not responsive — full reset
    _kill_daemons()
    _cleanup_sockets()
    time.sleep(1)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_reset(_args):
    """Kill daemons, clean sockets, fresh state."""
    _kill_daemons()
    _cleanup_sockets()
    print("Reset complete.")


def cmd_open(args):
    """Open URL with profile and auto-cleanup."""
    _ensure_session(headed=args.headed)

    flags = ["--profile", str(PROFILE)]
    if args.headed:
        flags.append("--headed")

    # Close existing session to apply profile/headed flags
    ab("close", timeout=5)
    time.sleep(1)

    ok, out = ab(*flags, "open", args.url, timeout=30)
    if ok:
        print(out or f"Opened: {args.url}")
    else:
        print(f"Error: {out}", file=sys.stderr)
        sys.exit(1)


def cmd_snap(args):
    """Accessibility snapshot."""
    flag = "-i" if not args.full else ""
    cmd = ["snapshot"]
    if flag:
        cmd.append(flag)
    ok, out = ab(*cmd, timeout=10)
    print(out if ok else f"Error: {out}")


def cmd_click(args):
    """Click element by ref."""
    ok, out = ab("click", args.ref, timeout=10)
    print("Done." if ok else f"Error: {out}")


def cmd_fill(args):
    """Fill input by ref."""
    ok, out = ab("fill", args.ref, args.text, timeout=10)
    print("Done." if ok else f"Error: {out}")


def cmd_select_el(args):
    """Select Element UI dropdown option by visible text.

    Pattern: open the wrapper, then call Vue's internal click handler
    on the matching option.
    """
    js = f"""
    (function() {{
        var text = {json.dumps(args.text)};
        var items = document.querySelectorAll('.el-select-dropdown__item');
        var found = false;
        items.forEach(function(item) {{
            if (item.textContent.trim() === text && !found) {{
                item.classList.remove('is-disabled');
                if (item._vei && item._vei.onClick) {{
                    item._vei.onClick(new MouseEvent('click', {{bubbles: true}}));
                }} else {{
                    item.dispatchEvent(new MouseEvent('mouseenter', {{bubbles: true}}));
                    item.click();
                }}
                found = true;
            }}
        }});
        found ? 'selected: ' + text : 'not found: ' + text;
    }})()
    """
    ok, out = ab("eval", js.strip(), timeout=10)
    print(out if ok else f"Error: {out}")


def cmd_cart_add(args):
    """Click add-to-cart button by CSS selector."""
    js = f"""
    (function() {{
        var btn = document.querySelector({json.dumps(args.selector)});
        if (btn) {{ btn.click(); 'added'; }}
        else {{ 'button not found: ' + {json.dumps(args.selector)}; }}
    }})()
    """
    ok, out = ab("eval", js.strip(), timeout=10)
    print(out if ok else f"Error: {out}")


def cmd_submit(args):
    """Build hidden form from current page inputs and submit natively.

    Bypasses Vue/React validation. Browser follows redirects.
    """
    # Collect all form field values from the page
    js = """
    (function() {
        var csrf = '';
        var meta = document.querySelector('meta[name=csrf-token]');
        if (meta) csrf = meta.content;

        var fields = {};
        document.querySelectorAll('input, select, textarea').forEach(function(el) {
            if (!el.name) return;
            if (el.type === 'radio' && !el.checked) return;
            if (el.type === 'checkbox' && !el.checked) return;
            fields[el.name] = el.value;
        });
        if (csrf) fields['_csrf'] = csrf;

        // Build and submit hidden form
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = window.location.href;
        form.style.display = 'none';
        Object.keys(fields).forEach(function(name) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = name;
            input.value = fields[name];
            form.appendChild(input);
        });
        document.body.appendChild(form);
        form.submit();
        'submitted ' + Object.keys(fields).length + ' fields';
    })()
    """
    ok, out = ab("eval", js.strip(), timeout=15)
    if ok:
        print(out)
        if args.follow:
            time.sleep(3)
            _, url = ab("get", "url", timeout=5)
            print(f"Redirected to: {url}")
    else:
        print(f"Error: {out}", file=sys.stderr)


def cmd_screenshot(args):
    """Take screenshot."""
    path = args.path or os.path.expanduser("~/tmp/diapedesis-screenshot.png")
    ok, out = ab("screenshot", path, timeout=15)
    print(path if ok else f"Error: {out}")


def cmd_url(_args):
    """Print current URL."""
    ok, out = ab("get", "url", timeout=5)
    print(out if ok else f"Error: {out}")


def cmd_title(_args):
    """Print current page title."""
    ok, out = ab("get", "title", timeout=5)
    print(out if ok else f"Error: {out}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Stateful browser automation — agent-browser wrapper"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # open
    p = sub.add_parser("open", help="Open URL with profile")
    p.add_argument("url")
    p.add_argument("--headed", action="store_true", help="Visible browser")
    p.set_defaults(func=cmd_open)

    # reset
    p = sub.add_parser("reset", help="Kill daemons, clean sockets")
    p.set_defaults(func=cmd_reset)

    # snap
    p = sub.add_parser("snap", help="Accessibility snapshot")
    p.add_argument("--full", action="store_true", help="Full tree (no -i)")
    p.set_defaults(func=cmd_snap)

    # click
    p = sub.add_parser("click", help="Click element by ref")
    p.add_argument("ref", help="Element ref e.g. @e42")
    p.set_defaults(func=cmd_click)

    # fill
    p = sub.add_parser("fill", help="Fill input by ref")
    p.add_argument("ref")
    p.add_argument("text")
    p.set_defaults(func=cmd_fill)

    # select-el
    p = sub.add_parser("select-el", help="Select Element UI option by text")
    p.add_argument("text", help="Visible option text")
    p.set_defaults(func=cmd_select_el)

    # cart-add
    p = sub.add_parser("cart-add", help="Click add-to-cart by CSS selector")
    p.add_argument("selector", help="CSS selector e.g. #core-add-button")
    p.set_defaults(func=cmd_cart_add)

    # submit
    p = sub.add_parser("submit", help="Submit form natively (bypass JS validation)")
    p.add_argument("--follow", action="store_true", help="Print redirect URL")
    p.set_defaults(func=cmd_submit)

    # screenshot
    p = sub.add_parser("screenshot", help="Take screenshot")
    p.add_argument("path", nargs="?", default="")
    p.set_defaults(func=cmd_screenshot)

    # url
    p = sub.add_parser("url", help="Current URL")
    p.set_defaults(func=cmd_url)

    # title
    p = sub.add_parser("title", help="Current page title")
    p.set_defaults(func=cmd_title)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()

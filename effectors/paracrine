"""
paracrine — lateral inhibition for feedback memories.

Reads all feedback memory files, clusters by behavioral axis,
detects tension pairs, and proposes reconciliation via LLM.

Usage:
  paracrine              show tension report (deterministic only)
  paracrine --reconcile  run LLM reconciliation on tension pairs
  paracrine --cluster    show clusters only
  paracrine --json       output as JSON
"""

import subprocess
import sys
from pathlib import Path

import yaml

# Claude Code memory dir: path-encodes the project root
_CLAUDE_PROJ_DIR = Path.home() / ".claude" / "projects"
_HOME_STEM = str(Path.home()).strip("/").replace("/", "-")
MEMORY_DIR = _CLAUDE_PROJ_DIR / f"-{_HOME_STEM}" / "memory"

# Behavioral axes — feedbacks that pull on the same dimension
AXES = {
    "autonomy": [
        "autonomous",
        "ask",
        "confirm",
        "permission",
        "just do",
        "stop asking",
        "act and report",
        "gated",
        "hold",
        "judgment",
        "taste",
        "calibrat",
    ],
    "verbosity": [
        "terse",
        "concise",
        "verbose",
        "summary",
        "summariz",
        "detail",
        "explain",
        "brief",
        "short",
    ],
    "speed_vs_quality": [
        "two-minute",
        "immediately",
        "quick",
        "fast",
        "careful",
        "thorough",
        "verify",
        "validate",
        "check",
        "research before",
    ],
    "scope": [
        "full scope",
        "comprehensive",
        "minimal",
        "simple",
        "over-engineer",
        "scope",
        "cautious",
        "aggressive",
        "hedge",
    ],
    "routing": [
        "sonnet",
        "opus",
        "haiku",
        "opencode",
        "gemini",
        "codex",
        "delegate",
        "subagent",
        "model",
    ],
    "capture_vs_flow": [
        "capture",

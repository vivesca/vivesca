DEFAULT_PROVIDER_LIMIT = 4


def compute_drain_velocity(
    all_records: list[dict],
    pending_by_provider: dict[str, int],
    window_minutes: int = 60,
) -> str:
    """Assess whether queue is growing, draining, stable, or done.

    Compares recent completion rate against pending count.
    Returns a human-readable indicator string.
    """
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return "✓ empty"

    if not all_records:
        return "↑ ? pending"

    # Count completions in window
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    completions = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= cutoff and r.get("exit") == 0
    )
    completion_rate = completions / window_minutes  # per minute

    if completion_rate <= 0:
        return f"↑ {total_pending} pending"

    # Time to drain at current rate
    drain_minutes = total_pending / completion_rate

    # Heuristic: if drain time < window, we're clearly draining
    if drain_minutes < window_minutes * 0.5:
        return f"↓ draining {completion_rate:.1f}/min"
    elif drain_minutes < window_minutes:
        return f"↘ slow {completion_rate:.1f}/min"
    else:
        return f"↑ growing ({total_pending} left, {completion_rate:.1f}/min)"


def compute_throughput_acceleration(
    all_records: list[dict],
    recent_minutes: int = 10,
    baseline_minutes: int = 30,
    window_minutes: int | None = None,
) -> str | float:
    """Compare recent throughput vs baseline. Returns a trend indicator.

    When window_minutes is given, returns a human-readable string:
    "→stable", "↑accelerating", "↓slowing", or "—".
    Otherwise returns the raw rate difference (float).
    """
    if not all_records:
        return "—" if window_minutes is not None else 0.0
    now = datetime.now(UTC)

    # When window_minutes is given, use it as baseline; scale recent proportionally
    effective_recent = recent_minutes
    effective_baseline = baseline_minutes
    if window_minutes is not None:
        effective_baseline = window_minutes
        effective_recent = max(window_minutes // 6, 5)

    recent_cutoff = now - timedelta(minutes=effective_recent)
    baseline_cutoff = now - timedelta(minutes=effective_baseline)

    recent_count = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= recent_cutoff and r.get("exit") == 0
    )
    baseline_count = sum(
        1
        for r in all_records
        if parse_ts(r.get("ts", "")) >= baseline_cutoff and r.get("exit") == 0
    )

    recent_rate = recent_count / effective_recent if effective_recent > 0 else 0.0
    baseline_rate = baseline_count / effective_baseline if effective_baseline > 0 else 0.0

    raw_diff = recent_rate - baseline_rate

    if window_minutes is not None:
        total = baseline_count
        if total < 3:
            return "—"
        if raw_diff > 0.02:
            return "↑accelerating"
        elif raw_diff < -0.02:
            return "↓slowing"
        else:
            return "→stable"

    return raw_diff


def compute_time_since_last_event(
    all_records: list[dict],
    exit_code: int = 0,
) -> float:
    """Seconds since the most recent record with the given exit code.

    Returns -1.0 if no matching record found.
    """
    now = datetime.now(UTC)
    latest_ts = None
    for rec in all_records:
        if rec.get("exit") != exit_code:
            continue
        ts = parse_ts(rec.get("ts", ""))
        if ts != datetime.min.replace(tzinfo=UTC) and (latest_ts is None or ts > latest_ts):
            latest_ts = ts
    if latest_ts is None:
        return -1.0
    delta = (now - latest_ts).total_seconds()
    return max(0.0, delta)


def compute_task_health(
    elapsed: float,
    avg_duration: float,
    provider_success_rate: float = 1.0,
) -> str:
    """Categorize running task health.

    Returns one of: "on-track", "slow", "stalled".
    - on-track: elapsed < 1.5x avg duration and provider success rate >= 50%
    - slow: elapsed >= 1.5x avg but < 2.5x avg
    - stalled: elapsed >= 2.5x avg, or provider success rate < 50% and elapsed > avg
    """
    if avg_duration <= 0:
        return "on-track"  # no data to judge against
    ratio = elapsed / avg_duration
    if ratio >= 2.5:
        return "stalled"
    if ratio >= 1.5:
        return "slow"
    if provider_success_rate < 0.5 and ratio >= 1.0:
        return "stalled"
    return "on-track"


def compute_drain_rate(
    all_records: list[dict],
    window_minutes: int = 10,
) -> float:
    """Compute current drain rate in tasks/min over the given window."""
    if not all_records:
        return 0.0
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    count = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= cutoff and r.get("exit") == 0
    )
    return count / window_minutes if window_minutes > 0 else 0.0


def compute_drain_eta_bounds(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> tuple[float, float, float]:
    """Compute optimistic/median/pessimistic drain ETA in seconds.

    Returns (optimistic, median, pessimistic) where:
    - optimistic: assumes fastest recent throughput sustained
    - median: same as compute_eta (baseline throughput)
    - pessimistic: assumes half the baseline throughput
    """
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return (0.0, 0.0, 0.0)

    now = datetime.now(UTC)

    # Recent (10min) throughput for optimistic
    recent_cutoff = now - timedelta(minutes=10)
    recent_count = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= recent_cutoff and r.get("exit") == 0
    )

    # Baseline (60min) throughput for median
    baseline_cutoff = now - timedelta(hours=1)
    baseline_count = sum(
        1
        for r in all_records
        if parse_ts(r.get("ts", "")) >= baseline_cutoff and r.get("exit") == 0
    )

    # Optimistic: use recent rate (10min window), at least 1 completion
    if recent_count > 0:
        optimistic_rate = recent_count / 10.0  # per minute
        optimistic = total_pending / optimistic_rate * 60  # to seconds
    else:
        optimistic = float("inf")

    # Median: use baseline rate (60min window)
    if baseline_count > 0:
        median = (total_pending / baseline_count) * 3600
    else:
        # Fallback to avg duration
        durations = [
            r.get("duration", 0)
            for r in all_records
            if r.get("exit") == 0 and r.get("duration", 0) > 0
        ]
        if durations:
            avg_duration = sum(durations) / len(durations)
            total_active = sum(s.get("active", 0) for s in stats.values())
            if total_active > 0:
                median = (total_pending / total_active) * avg_duration
            else:
                median = float("inf")
        else:
            median = float("inf")

    # Pessimistic: half the baseline rate
    pessimistic = median * 2.0 if baseline_count > 0 else float("inf")

    return (optimistic, median, pessimistic)


def compute_provider_utilization(
    stats: dict[str, dict],
    limits: dict[str, int],
) -> dict[str, float]:
    """Compute active/limit ratio per provider."""
    result: dict[str, float] = {}
    for prov, s in stats.items():
        active = s.get("active", 0)
        limit = limits.get(prov, DEFAULT_PROVIDER_LIMIT)
        if limit > 0:
            result[prov] = active / limit
        else:
            result[prov] = 0.0
    return result


def fmt_utilization_bar(ratio: float, width: int = 6) -> str:
    """Format utilization as a mini progress bar with percentage."""
    filled = min(int(ratio * width), width)
    bar_str = "█" * filled + "░" * (width - filled)
    return f"{bar_str} {ratio:.0%}"


def update_task_first_seen(running: list[dict]) -> None:
    """Track first-seen timestamps for running tasks to compute elapsed time."""
    global _task_first_seen
    now = time.time()
    current_ids = set()
    for task in running:
        tid = task.get("task_id", "")
        current_ids.add(tid)
        if tid and tid not in _task_first_seen:
            _task_first_seen[tid] = now
    # Prune tasks no longer running
    _task_first_seen = {k: v for k, v in _task_first_seen.items() if k in current_ids}


def compute_elapsed(task_id: str) -> float:
    """Return elapsed seconds since we first saw this task_id."""
    first = _task_first_seen.get(task_id)
    if first is None:
        return 0.0
    return time.time() - first


def compute_provider_stats(
    window_records: list[dict],
    running: list[dict],
) -> dict[str, dict]:
    """Compute per-provider statistics from window records and running tasks."""
    stats: dict[str, dict] = {}

    # Initialize from running tasks
    for task in running:
        prov = task.get("provider", "unknown")
        if prov not in stats:
            stats[prov] = {
                "active": 0,
                "completed": 0,
                "failed": 0,
                "rate_limited": 0,
                "killed": 0,
                "total_duration": 0.0,
                "success_count": 0,
                "total_count": 0,
            }
        stats[prov]["active"] += 1

    # Aggregate from jsonl records
    for rec in window_records:
        prov = rec.get("provider", "unknown")
        if prov not in stats:
            stats[prov] = {
                "active": 0,
                "completed": 0,
                "failed": 0,
                "rate_limited": 0,
                "killed": 0,
                "total_duration": 0.0,
                "success_count": 0,
                "total_count": 0,
            }
        exit_code = rec.get("exit", -1)
        duration = rec.get("duration", 0)
        stats[prov]["total_count"] += 1
        stats[prov]["total_duration"] += duration

        if exit_code == 0:
            stats[prov]["completed"] += 1
            stats[prov]["success_count"] += 1
        elif exit_code == 137:
            stats[prov]["killed"] += 1
        elif is_rate_limited(rec):
            stats[prov]["rate_limited"] += 1
        else:
            stats[prov]["failed"] += 1

    return stats


def compute_per_provider_eta(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> dict[str, float]:
    """Estimate time to drain per-provider queue."""
    now = datetime.now(UTC)
    one_hour_ago = now - timedelta(hours=1)
    result: dict[str, float] = {}

    for prov in set(list(stats.keys()) + list(pending_by_provider.keys())):
        queue = pending_by_provider.get(prov, 0)
        if queue == 0:
            result[prov] = 0.0
            continue

        # Count completions for this provider in last hour
        recent = sum(
            1
            for r in all_records
            if parse_ts(r.get("ts", "")) >= one_hour_ago
            and r.get("exit") == 0
            and r.get("provider") == prov
        )

        if recent > 0:
            result[prov] = (queue / recent) * 3600
        else:
            # Fallback: avg duration * queue / active workers
            s = stats.get(prov, {})
            total_count = s.get("total_count", 0)
            total_duration = s.get("total_duration", 0)
            active = s.get("active", 0)
            if total_count > 0 and active > 0:
                avg_dur = total_duration / total_count
                result[prov] = (queue / active) * avg_dur
            else:
                result[prov] = float("inf")

    return result


def compute_eta(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> float:
    """Estimate overall time to drain the queue based on recent throughput."""
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return 0.0

    # Count completions in the last hour across all providers
    now = datetime.now(UTC)
    one_hour_ago = now - timedelta(hours=1)
    recent_completed = 0
    for rec in all_records:
        ts = parse_ts(rec.get("ts", ""))
        if ts >= one_hour_ago and rec.get("exit") == 0:
            recent_completed += 1

    if recent_completed == 0:
        # No completions in the last hour; use avg duration from all records
        durations = [
            r.get("duration", 0)
            for r in all_records
            if r.get("exit") == 0 and r.get("duration", 0) > 0
        ]
        if durations:
            avg_duration = sum(durations) / len(durations)
            total_active = sum(s["active"] for s in stats.values())
            if total_active > 0:
                return (total_pending / total_active) * avg_duration
        return float("inf")

    throughput_per_hour = recent_completed
    return (total_pending / throughput_per_hour) * 3600


def compute_throughput_trend(all_records: list[dict], bucket_minutes: int = 10) -> list[int]:
    """Compute completions per time bucket for sparkline."""
    now = datetime.now(UTC)
    buckets: list[int] = []
    for i in range(6):
        bucket_end = now - timedelta(minutes=bucket_minutes * i)
        bucket_start = bucket_end - timedelta(minutes=bucket_minutes)
        count = sum(
            1
            for r in all_records
            if bucket_start <= parse_ts(r.get("ts", "")) < bucket_end and r.get("exit") == 0
        )
        buckets.append(count)
    buckets.reverse()
    return buckets


def sparkline(values: list[int]) -> str:
    """Render a Unicode sparkline from a list of ints."""
    chars = "▁▂▃▄▅▆▇█"
    if not values or max(values) == 0:
        return "▁" * len(values) if values else ""
    mx = max(values)
    return "".join(chars[min(int(v / mx * (len(chars) - 1)), len(chars) - 1)] for v in values)


def spinner_char() -> str:
    """Return a braille spinner character that cycles based on current time."""
    chars = "⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏"
    idx = int(time.time() * 2) % len(chars)
    return chars[idx]


def compute_recent_events(records: list[dict], n: int = 5) -> list[dict]:
    """Classify the last N records as recent events with outcome, age, and task_id.

    Returns list of dicts sorted oldest-first, each with:
      - outcome: "success" | "failed" | "rate_limited" | "killed"
      - provider: str
      - age_seconds: float (seconds since event)
      - task_id: str (if present in record)
    """
    if not records:
        return []
    now = datetime.now(UTC)
    events: list[dict] = []
    for rec in records:
        ts = parse_ts(rec.get("ts", ""))
        if ts == datetime.min.replace(tzinfo=UTC):
            age = 0.0
        else:
            age = max(0.0, (now - ts).total_seconds())
        exit_code = rec.get("exit", -1)
        if exit_code == 0:
            outcome = "success"
        elif exit_code == 137:
            outcome = "killed"
        elif is_rate_limited(rec):
            outcome = "rate_limited"
        else:
            outcome = "failed"
        ev: dict = {
            "outcome": outcome,
            "provider": rec.get("provider", "unknown"),
            "age_seconds": age,
        }
        if "task_id" in rec:
            ev["task_id"] = rec["task_id"]
        events.append(ev)
    return events[-n:]


def sort_running_by_completion(
    running: list[dict],
    avg_durs: dict[str, float],
) -> list[dict]:
    """Sort running tasks by estimated remaining time (soonest first).

    Tasks with no avg duration for their provider are sorted last.
    """
    if not running:
        return []

    def _remaining(task: dict) -> float:
        tid = task.get("task_id", "")
        prov = task.get("provider", "")
        avg = avg_durs.get(prov, 0)
        if avg <= 0:
            return float("inf")
        elapsed = compute_elapsed(tid)
        return max(0.0, avg - elapsed)

    return sorted(running, key=_remaining)


def build_drain_timeline(
    per_provider_eta: dict[str, float],
    pending: dict[str, int],
) -> Table | None:
    """Build a per-provider drain timeline table.

    Returns None if no pending tasks.
    """
    if not pending or sum(pending.values()) == 0:
        return None
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title="[bold]Drain Timeline[/bold]",
    )
    table.add_column("Provider", style="bold", min_width=10)
    table.add_column("Queue", justify="right", style="cyan", min_width=6)
    table.add_column("ETA", justify="right", min_width=9)
    table.add_column("Finishes", justify="right", min_width=8)

    for prov in sorted(pending.keys(), key=lambda p: per_provider_eta.get(p, float("inf"))):
        queue = pending[prov]
        if queue == 0:
            continue
        eta = per_provider_eta.get(prov, float("inf"))
        eta_str = fmt_eta(eta) if eta != float("inf") else "∞"
        finishes_str = fmt_wallclock_eta(eta)
        table.add_row(prov, str(queue), eta_str, finishes_str)

    return table


def build_recent_events_table(events: list[dict]) -> Table:
    """Build a compact table showing recent task events."""
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title="[bold]Recent Events[/bold]",
    )
    table.add_column("Outcome", min_width=12)
    table.add_column("Provider", min_width=10)
    table.add_column("Age", justify="right", min_width=7)
    table.add_column("TaskID", style="dim", min_width=9)

    outcome_styles = {
        "success": "[green]success[/green]",
        "failed": "[red]failed[/red]",
        "rate_limited": "[yellow]rate_limited[/yellow]",
        "killed": "[dim red]killed[/dim red]",
    }
    for ev in reversed(events):
        outcome_str = outcome_styles.get(ev["outcome"], ev["outcome"])
        age_str = fmt_duration(ev["age_seconds"])
        tid = ev.get("task_id", "—")
        table.add_row(outcome_str, ev["provider"], age_str, tid)

    return table


def build_json_snapshot(window_minutes: int = 60) -> dict:
    """Build a JSON-serializable snapshot of the dashboard state.

    Used by --json output mode for programmatic consumption.
    """
    window_records = dash_load_jsonl(window_minutes)
    running = load_running()
    pending_by_provider = count_pending_by_provider()
    total_pending = sum(pending_by_provider.values())
    total_completed_queue = count_total_completed()

    update_task_first_seen(running)
    all_records = load_all_jsonl()

    stats = compute_provider_stats(window_records, running)
    eta_seconds = compute_eta(stats, pending_by_provider, all_records)
    drain_rate = compute_drain_rate(all_records, window_minutes=10)
    recent_events = compute_recent_events(all_records, n=10)

    # Build per-task progress for running tasks
    avg_durs = compute_avg_duration_by_provider(all_records)
    running_tasks = []
    for task in running:
        tid = task.get("task_id", "")
        prov = task.get("provider", "")
        elapsed = compute_elapsed(tid)
        avg = avg_durs.get(prov, 0)
        remaining = estimate_task_completion(elapsed, avg)
        running_tasks.append(
            {
                "task_id": tid,
                "provider": prov,
                "elapsed": elapsed,
                "progress": estimate_task_progress(elapsed, avg),
                "eta_remaining": remaining,
            }
        )

    return {
        "pending": total_pending,
        "completed": total_completed_queue,
        "eta_seconds": eta_seconds if eta_seconds != float("inf") else None,
        "drain_rate": drain_rate,
        "providers": stats,
        "pending_by_provider": dict(pending_by_provider),
        "recent_events": recent_events,
        "running_tasks": running_tasks,
    }


def build_running_tasks_table(
    running: list[dict],
    avg_duration_by_provider: dict[str, float] | None = None,
    provider_stats: dict[str, dict] | None = None,
) -> Table:
    """Build a table showing each running task with elapsed time, progress, and health."""
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title="[bold]Running Tasks[/bold]",
    )
    table.add_column("TaskID", style="cyan", min_width=9)
    table.add_column("Provider", min_width=8)
    table.add_column("Health", min_width=9)
    table.add_column("Progress", justify="right", min_width=14)
    table.add_column("ETA", justify="right", min_width=7)
    table.add_column("Finishes", justify="right", min_width=8)
    table.add_column("Elapsed", justify="right", min_width=7)
    table.add_column("Through", style="dim", min_width=10)
    table.add_column("Prompt", style="dim", min_width=30, max_width=50, no_wrap=True)

    avg_map = avg_duration_by_provider or {}
    pstats = provider_stats or {}

    for task in running:
        tid = task.get("task_id", "?")
        prov = task.get("provider", "?")
        dispatch = task.get("dispatch_provider", "")
        elapsed = compute_elapsed(tid)
        cmd = task.get("cmd", "")

        # Extract prompt snippet from cmd
        prompt_match = re.search(r'"(.+)', cmd)
        prompt = prompt_match.group(0).rstrip('"')[:48] if prompt_match else cmd[:48]

        through_str = f"→ {dispatch}" if dispatch and dispatch != prov else ""

        elapsed_str = fmt_duration(elapsed)
        if elapsed > 600:
            elapsed_str = f"[red]{elapsed_str}[/red]"
        elif elapsed > 300:
            elapsed_str = f"[yellow]{elapsed_str}[/yellow]"

        # Progress bar based on avg duration for this provider
        avg_dur = avg_map.get(prov, 0)
        pct = estimate_task_progress(elapsed, avg_dur)
        bar_w = 8
        filled = int(pct * bar_w)
        bar_str = "█" * filled + "░" * (bar_w - filled)
        if pct >= 1.0:
            progress_str = f"[yellow]{bar_str} {pct:.0%}[/yellow]"
        elif pct >= 0.5:
            progress_str = f"[cyan]{bar_str} {pct:.0%}[/cyan]"
        else:
            progress_str = f"[dim]{bar_str} {pct:.0%}[/dim]"

        # Per-task ETA (estimated time to complete)
        remaining = estimate_task_completion(elapsed, avg_dur)
        if remaining < 0:
            eta_str = "[dim]?[/dim]"
        elif remaining == 0:
            eta_str = "[yellow]soon[/yellow]"
        else:
            eta_str = fmt_duration(remaining)

        # Wall-clock finish time
        finishes_str = fmt_wallclock_completion(remaining)

        # Task health
        ps = pstats.get(prov, {})
        total_count = ps.get("total_count", 0)
        success_count = ps.get("success_count", 0)
        prov_success_rate = success_count / total_count if total_count > 0 else 1.0
        health = compute_task_health(elapsed, avg_dur, prov_success_rate)
        health_styles = {
            "on-track": "[green]on-track[/green]",
            "slow": "[yellow]slow[/yellow]",
            "stalled": "[red]stalled[/red]",
        }
        health_str = health_styles.get(health, health)

        table.add_row(
            tid,
            prov,
            health_str,
            progress_str,
            eta_str,
            finishes_str,
            elapsed_str,
            through_str,
            prompt,
        )

    return table


def build_drain_progress(
    total_pending: int,
    total_completed: int,
    eta_seconds: float,
    drain_rate: float = 0.0,
    eta_bounds: tuple[float, float, float] | None = None,
    acceleration: float | str = 0.0,
) -> Text:
    """Build drain progress bar with ETA, rate, bounds, and wall-clock time."""
    total = total_pending + total_completed
    if total == 0:
        return Text("  No tasks in queue", style="dim")

    pct = total_completed / total
    bar_width = 30
    filled = int(pct * bar_width)
    bar_str = "█" * filled + "░" * (bar_width - filled)

    line = Text()
    line.append("  Drain: ", style="bold")
    line.append(f"[{bar_str}] ", style="cyan")
    line.append(f"{pct:.0%} ", style="bold cyan")
    line.append(f"({total_completed}/{total}) ", style="dim")

    # Drain rate
    if drain_rate > 0:
        line.append(f"rate: {drain_rate:.1f}/min ", style="green")
    else:
        line.append("rate: —/min ", style="dim")

    # Acceleration indicator (supports both string and float)
    if isinstance(acceleration, str):
        if "accelerating" in acceleration:
            line.append(f"▲ {acceleration} ", style="green")
        elif "slowing" in acceleration:
            line.append(f"▼ {acceleration} ", style="red")
        elif "stable" in acceleration:
            line.append(f"→ {acceleration} ", style="dim")
        else:
            line.append(f"· {acceleration} ", style="dim")
    elif acceleration > 0.05:
        line.append("▲ ", style="green")
    elif acceleration < -0.05:
        line.append("▼ ", style="red")
    else:
        line.append("· ", style="dim")

    # ETA with bounds
    line.append(f"ETA: {fmt_eta(eta_seconds)} ", style="bold yellow")
    wallclock = fmt_wallclock_eta(eta_seconds)
    line.append(f"(~{wallclock})", style="cyan")

    if eta_bounds:
        optimistic, _, pessimistic = eta_bounds
        if optimistic != float("inf") and pessimistic != float("inf"):
            opt_wc = fmt_wallclock_eta(optimistic)
            pess_wc = fmt_wallclock_eta(pessimistic)
            line.append(f" [{opt_wc}-{pess_wc}]", style="dim")

    return line


def build_dashboard(
    window_minutes: int = 60,
    all_records_cache: list[dict] | None = None,
) -> Panel:
    """Build the full dashboard as a Rich renderable."""
    window_records = dash_load_jsonl(window_minutes)
    running = load_running()
    cooldowns = load_cooldowns()
    pending_by_provider = count_pending_by_provider()
    total_pending = sum(pending_by_provider.values())
    total_completed_queue = count_total_completed()

    # Track first-seen for running tasks
    update_task_first_seen(running)

    # Use cached all-records for ETA if provided (avoids re-reading on every refresh)
    all_records = all_records_cache if all_records_cache is not None else load_all_jsonl()

    stats = compute_provider_stats(window_records, running)
    eta_seconds = compute_eta(stats, pending_by_provider, all_records)
    per_provider_eta = compute_per_provider_eta(stats, pending_by_provider, all_records)
    trend = compute_throughput_trend(all_records)
    spark = sparkline(trend)
    drain_velocity = compute_drain_velocity(all_records, pending_by_provider)
    utilization = compute_provider_utilization(stats, PROVIDER_LIMITS)
    drain_rate = compute_drain_rate(all_records, window_minutes=10)
    compute_throughput_acceleration(all_records)
    acceleration = compute_throughput_acceleration(all_records, window_minutes=60)
    time_since_last = compute_time_since_last_event(all_records, exit_code=0)
    eta_bounds = compute_drain_eta_bounds(stats, pending_by_provider, all_records)

    # === Header ===
    now_str = datetime.now().strftime("%H:%M:%S")
    header = Text()
    header.append("⬡ Ribosome Dashboard", style="bold cyan")
    header.append(f"  {now_str}", style="dim")
    header.append(f"  window={window_minutes}m", style="dim")
    header.append(
        f"  queue={total_pending} pending / {total_completed_queue} done", style="yellow"
    )
    header.append(f"  drain: {drain_rate:.1f}/min", style="green" if drain_rate > 0 else "dim")
    if time_since_last >= 0:
        header.append(f"  last✓: {fmt_duration(time_since_last)}", style="dim")
    header.append(f"  throughput: {spark}", style="green")
    header.append(f"  {drain_velocity}", style="bold")

    # === Provider table ===
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title=None,
    )
    table.add_column("Provider", style="bold", min_width=10)
    table.add_column("Active", justify="right", min_width=6)
    table.add_column("Cap", justify="right", min_width=8)
    table.add_column("✓", justify="right", style="green", min_width=5)
    table.add_column("✗", justify="right", style="red", min_width=5)
    table.add_column("⏳", justify="right", style="yellow", min_width=5)
    table.add_column("☠", justify="right", style="dim red", min_width=5)
    table.add_column("Rate", justify="right", min_width=8)
    table.add_column("AvgDur", justify="right", min_width=7)
    table.add_column("tasks/hr", justify="right", min_width=8)
    table.add_column("Queue", justify="right", style="cyan", min_width=6)
    table.add_column("Drain ETA", justify="right", min_width=9)
    table.add_column("Status", min_width=10)

    provider_order = ["zhipu", "infini", "volcano", "codex", "gemini"]
    for prov in sorted(
        stats.keys(), key=lambda p: provider_order.index(p) if p in provider_order else 99
    ):
        s = stats[prov]
        total = s["completed"] + s["failed"] + s["rate_limited"] + s["killed"]
        rate = s["success_count"] / total * 100 if total > 0 else 0.0

        avg_dur = s["total_duration"] / s["total_count"] if s["total_count"] > 0 else 0
        queue = pending_by_provider.get(prov, 0)
        prov_eta = per_provider_eta.get(prov, 0.0)

        # Rate coloring
        if rate >= 80:
            rate_str = f"[green]{rate:.0f}%[/green]"
        elif rate >= 50:
            rate_str = f"[yellow]{rate:.0f}%[/yellow]"
        elif total > 0:
            rate_str = f"[red]{rate:.0f}%[/red]"
        else:
            rate_str = "[dim]—[/dim]"

        # Status
        if prov in cooldowns:
            status = "[red]COOLDOWN[/red]"
        elif s["active"] > 0:
            status = f"[green]running ({s['active']})[/green]"
        elif queue > 0:
            status = "[yellow]queued[/yellow]"
        else:
            status = "[dim]idle[/dim]"

        eta_str = fmt_eta(prov_eta) if queue > 0 else "[dim]—[/dim]"
        throughput = compute_throughput_per_hour(all_records, provider=prov)
        throughput_str = f"{throughput:.0f}" if throughput > 0 else "[dim]—[/dim]"

        # Capacity utilization
        util = utilization.get(prov, 0.0)
        util_str = fmt_utilization_bar(util, width=4)

        table.add_row(
            prov,
            str(s["active"]),
            util_str,
            str(s["completed"]),
            str(s["failed"]),
            str(s["rate_limited"]),
            str(s["killed"]),
            rate_str,
            fmt_duration(avg_dur),
            throughput_str,
            str(queue),
            eta_str,
            status,
        )

    # === Summary line ===
    total_active = sum(s["active"] for s in stats.values())
    total_completed_window = sum(s["completed"] for s in stats.values())
    total_failed_window = sum(s["failed"] for s in stats.values())
    total_rl_window = sum(s["rate_limited"] for s in stats.values())
    window_total = total_completed_window + total_failed_window + total_rl_window
    window_rate = (total_completed_window / window_total * 100) if window_total > 0 else 0.0

    summary = Text()
    summary.append(f"  Workers: {total_active}  ", style="bold")
    summary.append(f"Done(window): {total_completed_window}  ", style="green")
    summary.append(f"Failed: {total_failed_window}  ", style="red")
    summary.append(f"RateLimited: {total_rl_window}  ", style="yellow")
    summary.append(
        f"Success: {window_rate:.0f}%  ",
        style="bold green" if window_rate >= 80 else "bold yellow",
    )

    # ETA with wall-clock time and confidence
    confidence = compute_eta_confidence(all_records)
    conf_style = {"high": "green", "medium": "yellow", "low": "red"}[confidence]
    wallclock = fmt_wallclock_eta(eta_seconds)
    summary.append(f"ETA: {fmt_eta(eta_seconds)} ", style="bold cyan")
    summary.append(f"(~{wallclock}) ", style="cyan")
    summary.append(f"[{confidence}]", style=conf_style)

    # === Drain progress ===
    drain_progress = build_drain_progress(
        total_pending,
        total_completed_queue,
        eta_seconds,
        drain_rate=drain_rate,
        eta_bounds=eta_bounds,
        acceleration=acceleration,
    )

    # === Running tasks table ===
    components = [header, table, summary, drain_progress]
    avg_durs = compute_avg_duration_by_provider(all_records)
    if running:
        # Sort running tasks by soonest completion
        sorted_running = sort_running_by_completion(running, avg_durs)
        components.append(build_running_tasks_table(sorted_running, avg_durs, stats))

        # === Stale task warnings ===
        stale = detect_stale_tasks(running, avg_durs)
        if stale:
            stale_text = Text()
            stale_text.append("  Stale tasks:\n", style="bold red")
            for s in stale:
                stale_text.append(
                    f"    {s['task_id']} ({s['provider']}) "
                    f"elapsed={fmt_duration(s['elapsed'])} vs avg={fmt_duration(s['avg'])}\n",
                    style="red",
                )
            components.append(stale_text)

    # === Drain timeline (per-provider) ===
    drain_timeline = build_drain_timeline(per_provider_eta, pending_by_provider)
    if drain_timeline is not None:
        components.append(drain_timeline)

    # === Recent events ===
    recent_events = compute_recent_events(all_records, n=8)
    if recent_events:
        components.append(build_recent_events_table(recent_events))

    # === Cooldown info ===
    cooldown_lines = []
    now_utc = datetime.now(UTC)
    for prov, expires_str in cooldowns.items():
        if expires_str:
            exp = parse_ts(expires_str)
            remaining = (exp - now_utc).total_seconds()
            if remaining > 0:
                cooldown_lines.append(f"  {prov}: cooldown {fmt_duration(remaining)} remaining")

    cooldown_text = Text()
    if cooldown_lines:
        cooldown_text.append("Cooldowns:\n", style="bold yellow")
        for cl in cooldown_lines:
            cooldown_text.append(cl + "\n", style="yellow")
        components.append(cooldown_text)

    return Panel(
        Group(*components),
        title="[bold]Ribosome Task Monitor[/bold]",
        border_style="blue",
        padding=(1, 2),
    )


def tail_jsonl(file_path: Path, from_byte: int = 0):
    """Yield new lines from jsonl file as they appear (tail -f style)."""
    try:
        with open(file_path) as f:
            f.seek(from_byte)
            while True:
                line = f.readline()
                if line:
                    yield line.strip()
                else:
                    time.sleep(0.5)
    except OSError, KeyboardInterrupt:
        return


def cmd_dash():
    import argparse

    parser = argparse.ArgumentParser(description="Ribosome task queue dashboard")
    parser.add_argument("--once", action="store_true", help="Single snapshot, no live refresh")
    parser.add_argument(
        "--window", type=int, default=60, help="Rolling window in minutes (default: 60)"
    )
    args = parser.parse_args()

    if not JSONL_PATH.exists():
        print(f"No data file found at {JSONL_PATH}", file=sys.stderr)
        print("Start ribosome-daemon first.", file=sys.stderr)
        sys.exit(1)

    if args.once:
        panel = build_dashboard(window_minutes=args.window)
        from rich.console import Console

        Console().print(panel)
        return

    # Live mode: pre-load all records once for ETA caching, then tail for new entries
    all_records_cache = load_all_jsonl()
    initial_byte = JSONL_PATH.stat().st_size if JSONL_PATH.exists() else 0

    with Live(
        build_dashboard(window_minutes=args.window, all_records_cache=all_records_cache),
        refresh_per_second=0.5,
        screen=False,
    ) as live:
        # Refresh from tail -f
        current_byte = initial_byte
        while True:
            try:
                # Check if file was rotated (truncated)
                if JSONL_PATH.exists():
                    new_size = JSONL_PATH.stat().st_size
                    if new_size < current_byte:
                        # File was rotated
                        all_records_cache = load_all_jsonl()
                        current_byte = 0
                    elif new_size > current_byte:
                        # Read new records
                        with open(JSONL_PATH, errors="replace") as f:
                            f.seek(current_byte)
                            new_lines = f.readlines()
                        for line in new_lines:
                            line = line.strip()
                            if line:
                                with contextlib.suppress(json.JSONDecodeError, ValueError):
                                    all_records_cache.append(json.loads(line))
                        current_byte = new_size
                        # Periodically trim cache to prevent unbounded growth (keep last 10k)
                        if len(all_records_cache) > 10000:
                            all_records_cache = all_records_cache[-5000:]

                live.update(
                    build_dashboard(
                        window_minutes=args.window,
                        all_records_cache=all_records_cache,
                    )
                )
                time.sleep(2)
            except KeyboardInterrupt:
                break


# ══════════════════════════════════════════════════════════════════════
# ══ argparse dispatch
# ══════════════════════════════════════════════════════════════════════


def main():
    parser = argparse.ArgumentParser(
        prog="ribosome-tools",
        description="Consolidated ribosome CLI subcommands.",
    )
    sub = parser.add_subparsers(dest="command")

    # dash
    p = sub.add_parser("dash", help="Live dashboard for ribosome task queue")
    p.add_argument("--once", action="store_true")
    p.add_argument("--window", type=int, default=60)
    p.add_argument("--json", action="store_true")

    # health
    p = sub.add_parser("health", help="Health check for ribosome providers")
    p.add_argument("--provider", choices=list(PROVIDERS.keys()))
    p.add_argument("--json", action="store_true")

    # status
    p = sub.add_parser("status", help="Provider readiness: health + usage + quota")
    p.add_argument("--json", action="store_true")
    p.add_argument("--compact", action="store_true")

    # report
    p = sub.add_parser("report", help="Analytics report from ribosome task logs")
    p.add_argument("--date", type=str, default=None)
    p.add_argument("--json", action="store_true")

    # review
    p = sub.add_parser("review", help="Review ribosome output, diagnose failures")
    p.add_argument("--auto-requeue", action="store_true")
    p.add_argument("--since", type=str, default="30m")
    p.add_argument("--check-consulting", type=str, default=None, metavar="DIR")
    p.add_argument("--once", action="store_true")

    # reviewer
    p = sub.add_parser("reviewer", help="Monitor ribosome output, auto-review quality")
    p.add_argument("--once", action="store_true")

    # top
    p = sub.add_parser("top", help="Show running ribosome processes")
    p.add_argument("--json", action="store_true")
    p.add_argument("--watch", action="store_true")

    # validate
    p = sub.add_parser("validate", help="Validate Python files for ribosome quality")
    p.add_argument("files", nargs="*")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(2)

    # Dispatch: translate argparse Namespace into the calling convention
    # expected by each cmd_* function.  cmd_validate and cmd_health accept
    # an explicit argv; the others read sys.argv internally, so we set it
    # before calling.
    if args.command == "validate":
        files = args.files or []
        if not files:
            print("Usage: ribosome-tools validate <file.py> [...]")
            print()
            print("Validate Python files for ribosome output quality.")
            return 2
        return cmd_validate(files)

    if args.command == "health":
        argv: list[str] = []
        if args.provider:
            argv += ["--provider", args.provider]
        if args.json:
            argv += ["--json"]
        return cmd_health(argv)

    if args.command == "status":
        argv = []
        if args.json:
            argv += ["--json"]
        if args.compact:
            argv += ["--compact"]
        return cmd_status(argv)

    if args.command == "report":
        argv = ["ribosome-report"]
        if args.date:
            argv += ["--date", args.date]
        if args.json:
            argv += ["--json"]
        sys.argv = argv
        return cmd_report()

    if args.command == "top":
        argv = ["ribosome-top"]
        if args.json:
            argv += ["--json"]
        if args.watch:
            argv += ["--watch"]
        sys.argv = argv
        return cmd_top()

    if args.command == "reviewer":
        argv = ["ribosome-reviewer"]
        if args.once:
            argv += ["--once"]
        sys.argv = argv
        return cmd_reviewer()

    if args.command == "review":
        argv = ["ribosome-review"]
        if args.auto_requeue:
            argv += ["--auto-requeue"]
        if args.since and args.since != "30m":
            argv += ["--since", args.since]
        if args.check_consulting:
            argv += ["--check-consulting", args.check_consulting]
        sys.argv = argv
        return cmd_review()

    if args.command == "dash":
        argv = ["ribosome-dash"]
        if args.once:
            argv += ["--once"]
        if args.window != 60:
            argv += ["--window", str(args.window)]
        sys.argv = argv
        return cmd_dash()

    parser.print_help()
    return 2


if __name__ == "__main__":
    sys.exit(main())

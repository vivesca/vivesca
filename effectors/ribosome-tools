@dataclass
class HealthResult:
    provider: str
    status: str  # "OK", "FAIL", "ERROR"
    latency_ms: int
    model: str
    exit_code: int
    has_output: bool
    error: str | None = None


def source_env_file(env_file: Path) -> dict[str, str]:
    """Source a shell env file and return the environment variables."""
    if not env_file.exists():
        return {}

    # Use bash to source the file and print env
    cmd = f'set -a && source "{env_file}" && env'
    result = subprocess.run(
        ["bash", "-c", cmd],
        capture_output=True,
        text=True,
        timeout=10,
    )

    env = {}
    for line in result.stdout.splitlines():
        if "=" in line:
            key, _, value = line.partition("=")
            env[key] = value
    return env


def check_provider(
    provider: str,
    env: dict[str, str],
    ribosome_path: Path,
) -> HealthResult:
    """Run health check for a single provider."""
    if provider not in PROVIDERS:
        return HealthResult(
            provider=provider,
            status="ERROR",
            latency_ms=0,
            model="unknown",
            exit_code=1,
            has_output=False,
            error=f"Unknown provider: {provider}",
        )

    config = PROVIDERS[provider]
    model = config["model"]
    key_var = config["key_var"]

    # Check if API key is available
    if key_var not in env:
        return HealthResult(
            provider=provider,
            status="FAIL",
            latency_ms=0,
            model=model,
            exit_code=1,
            has_output=False,
            error=f"{key_var} not set",
        )

    # Run ribosome with minimal invocation
    start = time.perf_counter()
    try:
        result = subprocess.run(
            [str(ribosome_path), "--provider", provider, "echo hello"],
            capture_output=True,
            text=True,
            timeout=300,
            env=env,
        )
        latency_ms = int((time.perf_counter() - start) * 1000)

        has_output = bool(result.stdout.strip())
        status = "OK" if result.returncode == 0 and has_output else "FAIL"
        error = None
        if result.returncode != 0:
            error = result.stderr.strip()[:100] if result.stderr else "non-zero exit"
        elif not has_output:
            error = "no output"

        return HealthResult(
            provider=provider,
            status=status,
            latency_ms=latency_ms,
            model=model,
            exit_code=result.returncode,
            has_output=has_output,
            error=error,
        )
    except subprocess.TimeoutExpired:
        latency_ms = int((time.perf_counter() - start) * 1000)
        return HealthResult(
            provider=provider,
            status="FAIL",
            latency_ms=latency_ms,
            model=model,
            exit_code=-1,
            has_output=False,
            error="timeout",
        )
    except Exception as e:
        latency_ms = int((time.perf_counter() - start) * 1000)
        return HealthResult(
            provider=provider,
            status="ERROR",
            latency_ms=latency_ms,
            model=model,
            exit_code=-1,
            has_output=False,
            error=str(e)[:100],
        )


def print_table(results: list[HealthResult]) -> None:
    """Print results as a formatted table."""
    header = f"{'Provider':<10} | {'Status':<6} | {'Latency':>10} | {'Model':<18}"
    separator = "-" * 52
    print(header)
    print(separator)

    for r in results:
        latency = f"{r.latency_ms}ms" if r.latency_ms > 0 else "-"
        row = f"{r.provider:<10} | {r.status:<6} | {latency:>10} | {r.model:<18}"
        print(row)
        if r.error:
            print(f"           └─ {r.error}")


def print_json(results: list[HealthResult]) -> None:
    """Print results as JSON."""
    data = [
        {
            "provider": r.provider,
            "status": r.status,
            "latency_ms": r.latency_ms,
            "model": r.model,
            "exit_code": r.exit_code,
            "has_output": r.has_output,
            "error": r.error,
        }
        for r in results
    ]
    print(json.dumps(data, indent=2))


def cmd_health(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Health check for ribosome providers.")
    parser.add_argument(
        "--provider",
        choices=list(PROVIDERS.keys()),
        help="Check only this provider (default: all)",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Output as JSON",
    )
    args = parser.parse_args(argv)

    # Find ribosome
    ribosome_path = Path(__file__).parent / "ribosome"
    if not ribosome_path.exists():
        print(f"Error: ribosome not found at {ribosome_path}", file=sys.stderr)
        return 1

    # Source env file
    env = os.environ.copy()
    if ENV_FILE.exists():
        sourced = source_env_file(ENV_FILE)
        env.update(sourced)

    # Determine providers to check
    providers_to_check = [args.provider] if args.provider else list(PROVIDERS.keys())

    # Run health checks
    results: list[HealthResult] = []
    for provider in providers_to_check:
        print(f"Checking {provider}...", file=sys.stderr)
        result = check_provider(provider, env, ribosome_path)
        results.append(result)

    # Output results
    if args.json:
        print_json(results)
    else:
        print_table(results)

    # Return non-zero if any failed
    if any(r.status != "OK" for r in results):
        return 1
    return 0



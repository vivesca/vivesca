    cutoff = datetime.now(UTC) - timedelta(minutes=window_minutes)
    records = []
    try:
        with open(JSONL_PATH, errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                    ts = parse_ts(rec.get("ts", ""))
                    if ts >= cutoff:
                        records.append(rec)
                except json.JSONDecodeError, ValueError:
                    continue
    except OSError:
        pass
    return records



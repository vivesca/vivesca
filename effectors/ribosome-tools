# ── parse_since ────────────────────────────────────────────────────────


def parse_since(arg: str) -> timedelta:
    """Parse time-duration string: '30m', '2h', '45s', '1d'.

    Bare number treated as minutes. Invalid returns 30 minutes.
    """
    if not arg or not isinstance(arg, str):
        return timedelta(minutes=30)
    arg = arg.strip()
    m = re.match(r"^(\d+)([smhd])$", arg)
    if m:
        val, unit = int(m.group(1)), m.group(2)
        return {
            "s": timedelta(seconds=val),
            "m": timedelta(minutes=val),
            "h": timedelta(hours=val),
            "d": timedelta(days=val),
        }[unit]
    if arg.isdigit():
        return timedelta(minutes=int(arg))
    return timedelta(minutes=30)


# ── parse_log_timestamp ────────────────────────────────────────────────


def parse_log_timestamp(ts_str: str | None) -> datetime | None:
    """Parse '2026-03-31 14:00:00'. Returns datetime or None."""
    if not ts_str:
        return None
    try:
        return datetime.strptime(ts_str.strip(), "%Y-%m-%d %H:%M:%S")
    except ValueError, AttributeError:
        return None


# ── scan_log ───────────────────────────────────────────────────────────


def scan_log(since: timedelta) -> dict:
    """Read daemon log, return {completed, failed, timeouts, start_time}.

    Each entry is a tuple: (timestamp, command[, tail]).
    Filters to entries within the `since` window from now (UTC).
    """
    result = {"completed": [], "failed": [], "timeouts": [], "start_time": None}

    if not LOGFILE.exists():
        return result

    try:
        content = LOGFILE.read_text()
    except PermissionError, OSError, UnicodeDecodeError:
        return result

    cutoff = datetime.now(UTC).replace(tzinfo=None) - since

    for line in content.splitlines():
        m = re.match(r"^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] (.+)$", line)
        if not m:
            continue
        ts_str, msg = m.group(1), m.group(2)
        ts = parse_log_timestamp(ts_str)
        if ts is None or ts < cutoff:
            continue

        if result["start_time"] is None or ts < result["start_time"]:
            result["start_time"] = ts

        if re.match(r"Finished \(\d+s, exit=0\)", msg):
            cmd_m = re.match(r"Finished \(\d+s, exit=\d+\): (.+)", msg)
            cmd = cmd_m.group(1).rstrip(".") if cmd_m else msg
            result["completed"].append((ts, cmd))
        elif re.match(r"Finished \(\d+s, exit=[^0]\)", msg):
            cmd_m = re.match(r"Finished \(\d+s, exit=\d+\): (.+)", msg)
            cmd = cmd_m.group(1).rstrip(".") if cmd_m else msg
            result["failed"].append((ts, cmd, ""))
        elif msg.startswith("FAILED"):
            cmd_m = re.match(r"FAILED \(exit=\d+\): (.+)", msg)
            cmd = cmd_m.group(1).rstrip(".") if cmd_m else msg
            result["failed"].append((ts, cmd, ""))
        elif msg.startswith("TIMEOUT"):
            cmd_m = re.match(r"TIMEOUT \(\d+s\): (.+)", msg)
            cmd = cmd_m.group(1).rstrip(".") if cmd_m else msg
            result["timeouts"].append((ts, cmd))

    return result


# ── get_recent_files ───────────────────────────────────────────────────


def get_recent_files(head_range: int = 5) -> list[str]:
    """Get files changed in last N commits via git diff."""
    try:
        r = subprocess.run(
            f"git -C {GERMLINE} diff --name-only HEAD~{head_range} 2>/dev/null",
            shell=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if r.returncode != 0 or not r.stdout.strip():
            return []
        return [f for f in r.stdout.strip().splitlines() if f.strip()]
    except Exception:
        return []


# ── run_pytest_on_files ────────────────────────────────────────────────


def run_pytest_on_files(files: list[str]) -> dict:
    """Run pytest on each file. Returns {files, total_passed, total_failed, total_errors}.

    files is list of (path, passed, failed, errors) tuples.
    """
    result = {"files": [], "total_passed": 0, "total_failed": 0, "total_errors": 0}
    if not files:
        return result

    for f in files:
        try:
            r = subprocess.run(
                ["uv", "run", "pytest", f, "-q", "--tb=line", "--no-header"],
                capture_output=True,
                text=True,
                timeout=120,
                cwd=str(GERMLINE),
            )
            output = r.stdout + r.stderr
            passed = failed = errors = 0
            m = re.search(r"(\d+) passed", output)
            if m:
                passed = int(m.group(1))
            m = re.search(r"(\d+) failed", output)
            if m:
                failed = int(m.group(1))
            m = re.search(r"(\d+) error", output)
            if m:
                errors = int(m.group(1))
            result["files"].append((f, passed, failed, errors))
            result["total_passed"] += passed
            result["total_failed"] += failed
            result["total_errors"] += errors
        except subprocess.TimeoutExpired:
            result["files"].append((f, 0, 0, 1))
            result["total_errors"] += 1
        except Exception:
            result["files"].append((f, 0, 0, 1))
            result["total_errors"] += 1

    return result


# ── check_consulting_content ───────────────────────────────────────────


def _detect_section_keyword(lines: list[str], keywords: tuple[str, ...]) -> bool:
    """Check if any markdown heading contains one of the keywords."""
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("#"):
            heading_text = stripped.lstrip("#").strip().lower()
            if any(kw in heading_text for kw in keywords):
                return True
    return False


def _compute_quality_score(entry: dict) -> int:
    """Compute a 0-100 quality score from consulting content checks.

    Breakdown: words 20, headings 8, paragraphs 8, structure 8,
               intro 8, conclusion 8, min_sections_ok 8,
               section_count 8, heading_hierarchy 8,
               no broken sections -4, filler penalty -8.
    """
    score = 0
    wc = entry.get("word_count", 0)
    score += min(20, int(wc / 500 * 20)) if wc > 0 else 0
    if entry.get("has_headings"):
        score += 8
    if entry.get("has_paragraphs"):
        score += 8
    if entry.get("has_structure_elements"):
        score += 8
    if entry.get("has_introduction"):
        score += 8
    if entry.get("has_conclusion"):
        score += 8
    if entry.get("min_sections_ok"):
        score += 8
    if entry.get("has_proper_heading_hierarchy"):
        score += 8
    # Section count bonus: 2+ = 4, 4+ = 8
    sec = entry.get("section_count", 0)
    if sec >= 4:
        score += 8
    elif sec >= 2:
        score += 4
    # Penalty: broken sections reduce score
    broken = entry.get("broken_sections", 0)
    score -= min(4, broken * 2)
    # Penalty: filler content
    if entry.get("has_filler_content"):
        score -= 8
    return max(0, score)


def _verdict_from_score(score: int) -> str:
    """Map quality score to a verdict string."""
    if score >= 80:
        return "excellent"
    if score >= 60:
        return "good"
    if score >= 40:
        return "needs_work"
    return "poor"


def _count_sections(lines: list[str]) -> tuple[int, int]:
    """Count (total_sections, broken_sections).

    A section is a heading line (# ...). A broken section is a heading
    followed only by blank lines or another heading (no body text).
    """
    sections: list[tuple[str, bool]] = []  # (heading_text, has_body)
    current_has_body = False

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("#"):
            # Save previous section
            if sections is not None and sections:
                sections[-1] = (sections[-1][0], sections[-1][1] or current_has_body)
            sections.append((stripped, False))
            current_has_body = False
        elif stripped == "":
            continue
        else:
            current_has_body = True

    # Finalize last section
    if sections:
        sections[-1] = (sections[-1][0], sections[-1][1] or current_has_body)

    total = len(sections)
    broken = sum(1 for _, has_body in sections if not has_body)
    return total, broken


def _check_heading_hierarchy(lines: list[str]) -> bool:
    """Return True if heading levels don't skip (e.g. H1 → H4 is bad).

    Allows starting at any level and increasing by 1, but not jumping
    more than 1 level at a time.
    """
    prev_level = 0
    for line in lines:
        stripped = line.strip()
        if not stripped.startswith("#"):
            continue
        level = len(stripped) - len(stripped.lstrip("#"))
        if level < 1:
            continue
        if prev_level == 0:
            prev_level = level
            continue
        if level > prev_level + 1:
            return False
        prev_level = level
    return True


def _check_filler_content(text: str) -> bool:
    """Return True if the text appears to be filler (repetitive content).

    Checks for: same sentence repeated >3 times, or >50% of unique
    sentences are very short (<5 words).
    """
    sentences = re.split(r"[.!?]+", text)
    sentences = [s.strip() for s in sentences if s.strip() and len(s.strip()) > 2]
    if len(sentences) < 4:
        return False
    # Check for repeated sentences (>3 identical)
    counts = Counter(s.lower() for s in sentences)
    for cnt in counts.values():
        if cnt > 3:
            return True
    # Check if >50% of unique sentences are very short (<5 words)
    short_count = sum(1 for s in set(sentences) if len(s.split()) < 5)
    unique_count = len(set(sentences))
    return bool(unique_count > 0 and short_count / unique_count > 0.5)


def _compute_paragraph_stats(lines: list[str]) -> float:
    """Return average word count per paragraph block.

    A paragraph is a contiguous block of non-blank, non-heading lines.
    Returns 0.0 if no paragraphs found.
    """
    paragraphs: list[int] = []
    current_words = 0
    for line in lines:
        stripped = line.strip()
        if stripped == "" or stripped.startswith("#"):
            if current_words > 0:
                paragraphs.append(current_words)
                current_words = 0
            continue
        current_words += len(stripped.split())
    if current_words > 0:
        paragraphs.append(current_words)
    if not paragraphs:
        return 0.0
    return sum(paragraphs) / len(paragraphs)


def check_consulting_content(files: list[str]) -> list[dict]:
    """Check each file: exists? adequate word count (>200)? proper structure?

    Returns list of {file, exists, word_count, adequate,
                     has_headings, has_paragraphs, has_structure_elements,
                     structure_ok, has_introduction, has_conclusion,
                     section_count, broken_sections, min_sections_ok,
                     has_proper_heading_hierarchy, avg_paragraph_word_count,
                     has_filler_content, overall_quality_pass,
                     quality_score, verdict}.
    """
    results = []
    for rel_path in files:
        full_path = GERMLINE / rel_path
        entry: dict = {
            "file": rel_path,
            "exists": False,
            "word_count": 0,
            "adequate": False,
            "has_headings": False,
            "has_paragraphs": False,
            "has_structure_elements": False,
            "structure_ok": False,
            "has_introduction": False,
            "has_conclusion": False,
            "section_count": 0,
            "broken_sections": 0,
            "min_sections_ok": False,
            "has_proper_heading_hierarchy": True,
            "avg_paragraph_word_count": 0.0,
            "has_filler_content": False,
            "overall_quality_pass": False,
            "quality_score": 0,
            "verdict": "poor",
        }

        if not full_path.exists():
            results.append(entry)
            continue

        entry["exists"] = True
        try:
            text = full_path.read_text()
        except PermissionError, OSError, UnicodeDecodeError:
            results.append(entry)
            continue

        wc = len(text.split())
        entry["word_count"] = wc
        entry["adequate"] = wc > 200

        # Structure checks
        lines = text.splitlines()
        entry["has_headings"] = any(
            stripped.startswith("#") for stripped in (ln.strip() for ln in lines) if stripped
        )

        # Paragraphs: count non-blank blocks (excluding heading-only blocks)
        paragraph_count = 0
        block_lines: list[str] = []
        for line in lines:
            if line.strip() == "":
                if block_lines:
                    non_heading = [bl for bl in block_lines if not bl.strip().startswith("#")]
                    if non_heading:
                        paragraph_count += 1
                    block_lines = []
            else:
                block_lines.append(line)
        # Handle last block
        if block_lines:
            non_heading = [bl for bl in block_lines if not bl.strip().startswith("#")]
            if non_heading:
                paragraph_count += 1
        entry["has_paragraphs"] = paragraph_count >= 2

        # Structure elements: lists, code blocks, bold text, tables
        has_list = any(ln.strip().startswith(("- ", "* ", "1. ", "2. ")) for ln in lines)
        has_code = "```" in text
        has_bold = "**" in text
        has_table = any("|" in ln and "---" in ln for ln in lines)
        entry["has_structure_elements"] = has_list or has_code or has_bold or has_table

        # Section analysis
        section_count, broken_sections = _count_sections(lines)
        entry["section_count"] = section_count
        entry["broken_sections"] = broken_sections
        entry["min_sections_ok"] = section_count >= 2 and broken_sections == 0

        # Overall structure: needs headings + at least one of paragraphs/structure elements
        entry["structure_ok"] = entry["has_headings"] and (
            entry["has_paragraphs"] or entry["has_structure_elements"]
        )

        # Introduction / conclusion detection via heading keywords
        entry["has_introduction"] = _detect_section_keyword(
            lines,
            ("introduction", "intro", "overview", "background", "context"),
        )
        entry["has_conclusion"] = _detect_section_keyword(
            lines,
            ("conclusion", "summary", "recommendations", "next steps", "takeaways"),
        )

        # Heading hierarchy
        entry["has_proper_heading_hierarchy"] = _check_heading_hierarchy(lines)

        # Paragraph stats
        entry["avg_paragraph_word_count"] = _compute_paragraph_stats(lines)

        # Filler detection
        entry["has_filler_content"] = _check_filler_content(text)

        # Quality score and verdict
        entry["quality_score"] = _compute_quality_score(entry)
        entry["verdict"] = _verdict_from_score(entry["quality_score"])

        # Overall quality pass: adequate words, proper structure, no filler, hierarchy ok
        entry["overall_quality_pass"] = (
            entry["adequate"]
            and entry["structure_ok"]
            and not entry["has_filler_content"]
            and entry["has_proper_heading_hierarchy"]
        )

        results.append(entry)

    return results


# ── scan_consulting_dirs ───────────────────────────────────────────────


def scan_consulting_dirs(base_dir: Path | None = None) -> list[str]:
    """Recursively find .md files in consulting subdirectories.

    Scans CONSULTING_SUBDIRS under base_dir (or EPIGENOME) and returns
    relative paths as strings. Excludes reviewer-cycle- files.
    """
    root = base_dir or EPIGENOME
    if not root.exists():
        return []

    files: list[str] = []
    # Check both the flat consulting/ subdirs and nested chromatin/euchromatin/consulting/
    search_dirs = [
        root / "consulting",
        root / "chromatin" / "euchromatin" / "consulting",
    ]

    for consulting_dir in search_dirs:
        if not consulting_dir.exists():
            continue
        for subdir_name in CONSULTING_SUBDIRS:
            subdir = consulting_dir / subdir_name
            if not subdir.exists():
                continue
            for md_file in sorted(subdir.glob("*.md")):
                if md_file.name.startswith("reviewer-cycle-"):
                    continue
                rel = md_file.relative_to(root)
                files.append(str(rel))

    return files


# ── compute_consulting_summary ─────────────────────────────────────────


def compute_consulting_summary(results: list[dict]) -> dict:
    """Compute aggregate consulting quality stats from check_consulting_content results.

    Returns {total, passed, failed, missing, avg_word_count,
             avg_quality_score, pass_rate, verdicts}.
    Missing files (exists=False) are counted in total but not in pass/fail.
    """
    total = len(results)
    if total == 0:
        return {
            "total": 0,
            "passed": 0,
            "failed": 0,
            "missing": 0,
            "avg_word_count": 0.0,
            "avg_quality_score": 0.0,
            "pass_rate": 0.0,
            "verdicts": {},
        }

    existing = [r for r in results if r.get("exists")]
    missing = [r for r in results if not r.get("exists")]
    passed = [r for r in existing if r.get("overall_quality_pass")]
    failed = [r for r in existing if not r.get("overall_quality_pass")]

    avg_wc = sum(r.get("word_count", 0) for r in existing) / len(existing) if existing else 0.0
    avg_score = (
        sum(r.get("quality_score", 0) for r in existing) / len(existing) if existing else 0.0
    )
    pass_rate = len(passed) / len(existing) if existing else 0.0

    verdicts: dict[str, int] = {}
    for r in existing:
        v = r.get("verdict", "poor")
        verdicts[v] = verdicts.get(v, 0) + 1

    return {
        "total": total,
        "passed": len(passed),
        "failed": len(failed),
        "missing": len(missing),
        "avg_word_count": round(avg_wc, 1),
        "avg_quality_score": round(avg_score, 1),
        "pass_rate": round(pass_rate, 3),
        "verdicts": verdicts,
    }


# ── diagnose_failure ───────────────────────────────────────────────────


def diagnose_failure(cmd: str, output: str) -> str:
    """Diagnose a failure from command and output. Returns diagnosis string.

    One of: import_error, syntax_error, path_issue, timeout,
    permission_error, command_error, assertion_error, unknown.
    """
    combined = (cmd + " " + output).lower()
    text = cmd + " " + output

    if "modulenotfounderror" in combined or "importerror" in combined:
        return "import_error"
    if "syntaxerror" in combined:
        return "syntax_error"
    if MAC_HOME_PREFIX.lower() in combined:
        return "path_issue"
    if "timeout" in combined:
        return "timeout"
    if "permissionerror" in combined or "permission denied" in combined:
        return "permission_error"
    if "exit=2" in combined or "exit_code=2" in combined:
        return "command_error"
    if re.search(r"\bassert\b", text):
        return "assertion_error"
    return "unknown"


# ── read_log_tail ──────────────────────────────────────────────────────


def read_log_tail(n: int = 50) -> str:
    """Read last N lines of daemon log."""
    if not LOGFILE.exists():
        return ""
    try:
        lines = LOGFILE.read_text().splitlines()
        return "\n".join(lines[-n:]) if n > 0 else ""
    except PermissionError, OSError, UnicodeDecodeError:
        return ""


# ── count_pending_tasks ────────────────────────────────────────────────


def count_pending_tasks() -> int:
    """Count [ ] and [!!] pending tasks in queue (not [x], [!])."""
    if not QUEUE_FILE.exists():
        return 0
    try:
        content = QUEUE_FILE.read_text()
    except PermissionError, OSError, UnicodeDecodeError:
        return 0
    count = 0
    for line in content.splitlines():
        stripped = line.strip()
        if stripped.startswith("- [ ] ") or stripped.startswith("- [!!] "):
            count += 1
    return count


# ── find_untested_modules ──────────────────────────────────────────────


def find_untested_modules() -> list[str]:
    """Find effectors without corresponding test files."""
    if not EFFECTORS_DIR.exists():
        return []

    tested_names = set()
    if ASSAYS_DIR.exists():
        for f in ASSAYS_DIR.glob("test_*.py"):
            name = f.stem[5:]  # strip test_
            tested_names.add(name)
            tested_names.add(name.replace("_", "-"))
            tested_names.add(name.replace("-", "_"))

    untested = []
    for f in sorted(EFFECTORS_DIR.iterdir()):
        if not f.is_file():
            continue
        if f.name.startswith(".") or f.name.startswith("__"):
            continue
        normalized = f.name.replace("-", "_").replace(".py", "").replace(".sh", "")
        if f.name in tested_names or normalized in tested_names:
            continue
        if any(t.replace("-", "_") == normalized for t in tested_names):
            continue
        untested.append(f.name)

    return untested


# ── generate_queue_tasks ───────────────────────────────────────────────


def generate_queue_tasks(modules: list[str], count: int) -> list[str]:
    """Generate ribosome queue task lines for modules, rotating providers.

    Returns list of '- [ ] `ribosome --provider X ...`' lines.
    """
    if not modules:
        return []

    tasks = []
    for i, mod in enumerate(modules[:count]):
        provider = _PROVIDERS[i % len(_PROVIDERS)]
        test_name = f"test_{mod.replace('-', '_')}"
        tasks.append(
            f"- [ ] `ribosome --provider {provider} --max-turns 50 "
            f'"Write assays/{test_name}.py for effectors/{mod}. '
            f'Run uv run pytest assays/{test_name}.py -v --tb=short."`'
        )

    return tasks


# ── append_tasks_to_queue ──────────────────────────────────────────────


def append_tasks_to_queue(task_lines: list[str]) -> int:
    """Append task lines to the queue file. Returns count added."""
    if not task_lines:
        return 0

    QUEUE_FILE.parent.mkdir(parents=True, exist_ok=True)

    if QUEUE_FILE.exists():
        try:
            content = QUEUE_FILE.read_text()
        except PermissionError, OSError, UnicodeDecodeError:
            content = "## Pending\n\n## Done\n"
    else:
        content = "## Pending\n\n## Done\n"

    for line in task_lines:
        if "## Done" in content:
            content = content.replace("## Done", line + "\n\n## Done", 1)
        else:
            content = content.rstrip() + "\n" + line + "\n"

    try:
        QUEUE_FILE.write_text(content)
    except PermissionError, OSError:
        return 0

    return len(task_lines)


# ── write_fixed_tasks ──────────────────────────────────────────────────


def write_fixed_tasks(failed_tasks: list[dict]) -> int:
    """Write fixed task entries based on failure diagnoses.

    Each failed_task: {cmd, diagnosis}. Returns count written.
    """
    if not failed_tasks:
        return 0

    lines = []
    for t in failed_tasks:
        t.get("cmd", "")
        diag = t.get("diagnosis", "unknown")

        if "path_issue" in diag:
            lines.append(
                "- [ ] `ribosome --provider infini --max-turns 50 "
                '"Fix path_issue: replace hardcoded home paths with Path.home(). '
                'Run tests after."`'
            )
        elif "import_error" in diag:
            lines.append(
                "- [ ] `ribosome --provider infini --max-turns 50 "
                '"Fix import_error: use exec(open(path).read(), ns) pattern '
                "instead of import. "
                'Check module exists or needs install. Run tests."`'
            )
        elif "syntax_error" in diag:
            lines.append(
                "- [ ] `ribosome --provider infini --max-turns 50 "
                '"Fix syntax_error: run ast.parse() on changed .py files. '
                'Run tests after."`'
            )
        elif "timeout" in diag:
            lines.append(
                "- [ ] `ribosome --provider infini --max-turns 30 "
                '"Retry with lower turns. Break into smaller tasks. '
                'Run tests."`'
            )
        else:
            lines.append(
                f"- [ ] `ribosome --provider infini --max-turns 50 "
                f'"Retry task (diagnosis: {diag}). Run tests."`'
            )

    return append_tasks_to_queue(lines)


# ── generate_review ────────────────────────────────────────────────────


def generate_review(
    activity: dict,
    recent_files: list[str],
    test_results: dict,
    consulting_results: list[dict],
    failed_diagnoses: list[dict],
    pending_count: int,
    auto_requeue: bool,
    queued_count: int,
    fixed_count: int,
    consulting_summary: dict | None = None,
) -> str:
    """Generate a review summary markdown string."""
    ts = datetime.now(UTC).strftime("%Y-%m-%d %H:%M UTC")
    lines = [f"# Ribosome Review — {ts}", ""]

    # Activity summary
    lines.append("## Activity Summary")
    completed = activity.get("completed", [])
    failed = activity.get("failed", [])
    timeouts = activity.get("timeouts", [])
    lines.append(f"- Completed tasks: {len(completed)}")
    lines.append(f"- Failed tasks: {len(failed)}")
    lines.append(f"- Timeouts: {len(timeouts)}")
    lines.append("")

    if completed:
        lines.append("### Completed tasks")
        for entry in completed:
            cmd = entry[1] if len(entry) >= 2 else str(entry)
            lines.append(f"- {cmd[:100]}")
        lines.append("")

    if failed:
        lines.append("### Failed Tasks")
        for entry in failed:
            cmd = entry[1] if len(entry) >= 2 else str(entry)
            lines.append(f"- {cmd[:100]}")
        lines.append("")

    if timeouts:
        lines.append("### Timeouts")
        for entry in timeouts:
            cmd = entry[1] if len(entry) >= 2 else str(entry)
            lines.append(f"- {cmd[:100]}")
        lines.append("")

    # Recent files
    lines.append("## Recent Files")
    for f in recent_files:
        lines.append(f"- `{f}`")
    if not recent_files:
        lines.append("- (none)")
    lines.append("")

    # Test results
    lines.append("## Test Results")
    for entry in test_results.get("files", []):
        f, passed, failed_n, errors = entry[0], entry[1], entry[2], entry[3]
        status = "PASS" if failed_n == 0 and errors == 0 else "FAIL"
        lines.append(f"- [{status}] {f}: {passed} passed, {failed_n} failed, {errors} errors")
    lines.append(
        f"- Total: {test_results.get('total_passed', 0)} passed, "
        f"{test_results.get('total_failed', 0)} failed, "
        f"{test_results.get('total_errors', 0)} errors"
    )
    lines.append("")

    # Consulting content
    if consulting_results:
        lines.append("## Consulting Content")
        for r in consulting_results:
            wc = r.get("word_count", 0)
            status = "OK" if r.get("adequate") else "TOO SHORT"
            exists = "exists" if r.get("exists") else "MISSING"
            struct = "structured" if r.get("structure_ok") else "UNSTRUCTURED"
            heads = "H" if r.get("has_headings") else "_"
            paras = "P" if r.get("has_paragraphs") else "_"
            elems = "S" if r.get("has_structure_elements") else "_"
            intro = "I" if r.get("has_introduction") else "_"
            concl = "C" if r.get("has_conclusion") else "_"
            score = r.get("quality_score", 0)
            verdict = r.get("verdict", "poor")
            sec_count = r.get("section_count", 0)
            broken = r.get("broken_sections", 0)
            min_ok = "M" if r.get("min_sections_ok") else "_"
            hier = "↕" if r.get("has_proper_heading_hierarchy") else "⚠"
            avg_p = r.get("avg_paragraph_word_count", 0.0)
            filler = "FILLER" if r.get("has_filler_content") else ""
            pass_mark = "✓" if r.get("overall_quality_pass") else "✗"
            lines.append(
                f"- [{status}|{struct}] {r['file']}: {wc} words ({exists}) "
                f"[{heads}{paras}{elems}{intro}{concl}{min_ok}] "
                f"secs={sec_count}(broken:{broken}) {hier} "
                f"avg_p={avg_p:.0f}w {filler} "
                f"score={score} ({verdict}) {pass_mark}"
            )
        lines.append("")

    # Consulting quality summary
    if consulting_summary:
        lines.append("## Consulting Quality Summary")
        lines.append(
            f"- {consulting_summary['total']} files checked: "
            f"{consulting_summary['passed']} passed, "
            f"{consulting_summary['failed']} failed, "
            f"{consulting_summary['missing']} missing"
        )
        lines.append(f"- Average word count: {consulting_summary['avg_word_count']:.0f}")
        lines.append(f"- Average quality score: {consulting_summary['avg_quality_score']:.0f}/100")
        lines.append(f"- Pass rate: {consulting_summary['pass_rate']:.0%}")
        verdicts = consulting_summary.get("verdicts", {})
        if verdicts:
            parts = [f"{k}: {v}" for k, v in sorted(verdicts.items())]
            lines.append(f"- Verdicts: {', '.join(parts)}")
        lines.append("")

    # Failure diagnoses
    if failed_diagnoses:
        lines.append("## Failure Diagnoses")
        for d in failed_diagnoses:
            lines.append(f"- **{d.get('diagnosis', 'unknown')}**: {d.get('cmd', '')[:80]}")
        lines.append("")

    # Auto-requeue actions
    if auto_requeue:
        lines.append("## Auto-Requeue Actions")
        lines.append(f"- {fixed_count} fixed")
        lines.append(f"- {queued_count} new tasks generated")
        lines.append(f"- Queue now has {pending_count} pending tasks")
        lines.append("")

    return "\n".join(lines)


# ── run_review ─────────────────────────────────────────────────────────


def run_review(auto_requeue: bool = False, since: timedelta = timedelta(minutes=30)) -> int:
    """Run a single review cycle. Returns 0 on success."""
    # 1. Scan log
    activity = scan_log(since)

    # 2. Get recent files
    recent_files = get_recent_files(head_range=5)

    # 3. Run tests on new test files
    test_files = [f for f in recent_files if f.startswith("assays/test_") and f.endswith(".py")]
    test_results = run_pytest_on_files(test_files)

    # 4. Check consulting content
    content_files = [
        f
        for f in recent_files
        if f.startswith("loci/copia/")
        and f.endswith(".md")
        and not Path(f).name.startswith("reviewer-cycle-")
    ]
    consulting_results = check_consulting_content(content_files)

    # 4b. Also check epigenome consulting content directories
    consulting_dir_files = scan_consulting_dirs()
    if consulting_dir_files:
        epigenome_results = check_consulting_content(consulting_dir_files)
        consulting_results.extend(epigenome_results)
    consulting_summary = compute_consulting_summary(consulting_results)

    # 5. Diagnose failures
    failed_diagnoses = []
    for entry in activity.get("failed", []):
        cmd = entry[1] if len(entry) >= 2 else "unknown"
        tail = entry[2] if len(entry) >= 3 else ""
        diag = diagnose_failure(cmd, tail)
        failed_diagnoses.append({"cmd": cmd, "diagnosis": diag})

    for entry in activity.get("timeouts", []):
        cmd = entry[1] if len(entry) >= 2 else "unknown"
        failed_diagnoses.append({"cmd": cmd, "diagnosis": "timeout"})

    # 6. Auto-requeue
    fixed_count = 0
    if auto_requeue and failed_diagnoses:
        fixed_count = write_fixed_tasks(failed_diagnoses)

    # 7. Auto-generate disabled — queue is manually curated
    queued_count = 0
    pending = count_pending_tasks()

    # 8. Write review
    review = generate_review(
        activity=activity,
        recent_files=recent_files,
        test_results=test_results,
        consulting_results=consulting_results,
        failed_diagnoses=failed_diagnoses,
        pending_count=pending + queued_count,
        auto_requeue=auto_requeue,
        queued_count=queued_count,

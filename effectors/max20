#!/usr/bin/env python3
"""max20 — claude --print via Max20 subscription.

Strips CLAUDECODE and ANTHROPIC_API_KEY so claude uses Max20 OAuth auth
instead of API billing. Works in scripts and LaunchAgents (unlike aliases).

Usage:
    max20 sonnet -p "prompt"
    max20 haiku -p "prompt"
    max20 sonnet -p "prompt" --max-tokens 4096
    echo "prompt" | max20 sonnet
"""

import os
import sys

CLAUDE = "/Users/terry/.local/bin/claude"
MODELS = {
    "sonnet": "sonnet",
    "haiku": "haiku",
    "opus": "opus",
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__.strip())
        sys.exit(0)

    model = sys.argv[1]
    if model not in MODELS:
        print(f"Unknown model: {model}. Choose from: {', '.join(MODELS)}", file=sys.stderr)
        sys.exit(1)

    env = {k: v for k, v in os.environ.items() if k not in ("CLAUDECODE", "ANTHROPIC_API_KEY")}
    args = [CLAUDE, "--print", "--model", MODELS[model]] + sys.argv[2:]
    os.execve(CLAUDE, args, env)


if __name__ == "__main__":
    main()

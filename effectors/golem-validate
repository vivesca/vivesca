#!/usr/bin/env python3
"""golem-validate — validate Python files for golem output quality.

Checks each .py file for:
  1. Syntax validity (ast.parse)
  2. Hardcoded /Users/terry/ paths
  3. TODO / FIXME / stub markers
  4. If test file (test_*.py): pytest --co collectability

Usage:
    golem-validate file1.py file2.py ...
"""
from __future__ import annotations

import ast
import re
import subprocess
import sys
from pathlib import Path

BAD_PATH_RE = re.compile(r'/Users/terry/')
TODO_RE = re.compile(r'\b(TODO|FIXME|stub)\b', re.IGNORECASE)


def validate_file(path: Path) -> tuple[str, list[str]]:
    """Return (status, [issues]) for a single file.

    status is 'PASS' or 'FAIL'.
    """
    issues: list[str] = []

    # --- 1. Syntax check ---
    try:
        source = path.read_text(encoding="utf-8")
    except OSError as exc:
        return "FAIL", [f"unreadable: {exc}"]

    try:
        ast.parse(source, filename=str(path))
    except SyntaxError as exc:
        issues.append(f"SyntaxError: line {exc.lineno}: {exc.msg}")

    # --- 2. Hardcoded /Users/terry/ ---
    for lineno, line in enumerate(source.splitlines(), start=1):
        if BAD_PATH_RE.search(line):
            issues.append(f"hardcoded /Users/terry/ at line {lineno}")
            break  # one report is enough

    # --- 3. TODO / FIXME / stub ---
    for lineno, line in enumerate(source.splitlines(), start=1):
        if TODO_RE.search(line):
            issues.append(f"marker '{TODO_RE.search(line).group(1)}' at line {lineno}")
            break  # one report is enough

    # --- 4. Test collectability ---
    if path.name.startswith("test_") and path.suffix == ".py":
        result = subprocess.run(
            ["pytest", "--co", "-q", str(path)],
            capture_output=True,
            text=True,
            timeout=30,
        )
        if result.returncode != 0:
            # Collect only first few lines of error to keep output tidy
            err_lines = result.stderr.strip().splitlines()
            summary = "; ".join(err_lines[:3]) if err_lines else "unknown collection error"
            issues.append(f"pytest --co failed: {summary}")

    status = "PASS" if not issues else "FAIL"
    return status, issues


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]

    if not args:
        print("Usage: golem-validate <file.py> [...]", file=sys.stderr)
        return 2

    all_pass = True
    for raw in args:
        path = Path(raw).resolve()
        status, issues = validate_file(path)
        issue_str = "; ".join(issues) if issues else ""
        print(f"{path} | {status} | {issue_str}")
        if status == "FAIL":
            all_pass = False

    return 0 if all_pass else 1


if __name__ == "__main__":
    raise SystemExit(main())

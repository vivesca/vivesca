#!/usr/bin/env python3
"""effector-usage — scan golem logs for effector mentions and report usage stats.

Scans golem.jsonl and golem-daemon.log for references to effectors/.
Reports: most used, never used, recently broken.

Usage:
    effector-usage              # full report (most-used, never-used, recently-broken)
    effector-usage --json       # machine-readable JSON output
    effector-usage --top N      # show top N most-used (default 20)
    effector-usage --broken     # show only recently broken effectors
    effector-usage --unused     # show only never-used effectors
"""
from __future__ import annotations

import json
import re
import sys
from collections import Counter, defaultdict
from datetime import datetime, timedelta, timezone
from pathlib import Path

EFFECTORS_DIR = Path.home() / "germline" / "effectors"
JSONL_FILE = Path.home() / ".local" / "share" / "vivesca" / "golem.jsonl"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
ROTATED_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log.1"
DEFAULT_TOP = 20
RECENT_DAYS = 7

# Match "effectors/<name>" where name ends at a word boundary
# (whitespace, quote, parenthesis, comma, period, end-of-string)
# This prevents matching truncated names like "gole..." or "tes..."
RE_EFFECTOR = re.compile(
    r"effectors/([a-zA-Z0-9][a-zA-Z0-9_.+-]+)"
    r"(?=[\s\"'),;:!?\]}>]|$)"
)
# Daemon log timestamp: [2026-03-31 10:53:29]
RE_LOG_TS = re.compile(r"^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] (.+)$")
# Failure line patterns (applied to message after "] ")
RE_FAILED = re.compile(r"^FAILED \(exit=(\d+)\)")
RE_TIMEOUT = re.compile(r"^TIMEOUT \((\d+)s\)")
# JSONL timestamp and exit code
RE_JSONL_TS = re.compile(r'"ts"\s*:\s*"([^"]+)"')
RE_EXIT = re.compile(r'"exit"\s*:\s*(\d+)')


def list_effectors() -> set[str]:
    """Return set of all effector file names in the effectors/ directory."""
    if not EFFECTORS_DIR.exists():
        return set()
    return {
        p.name
        for p in EFFECTORS_DIR.iterdir()
        if p.is_file()
        and not p.name.startswith(".")
        and not p.name.endswith(".pyc")
        and p.name != "__pycache__"
    }


def _clean_name(raw: str) -> str:
    """Strip trailing punctuation from a captured effector name."""
    return raw.rstrip(".,;:!?)\"' ")


def scan_jsonl(path: Path) -> tuple[Counter, Counter, dict[str, str]]:
    """Scan golem.jsonl for effector mentions.

    Returns:
        mention_counts: effector name -> mention count
        fail_counts: effector name -> failure count (exit != 0)
        last_seen: effector name -> ISO timestamp of last mention
    """
    mentions: Counter = Counter()
    fails: Counter = Counter()
    last_seen: dict[str, str] = {}

    if not path.exists():
        return mentions, fails, last_seen

    content = path.read_text(errors="replace")
    decoder = json.JSONDecoder()
    pos = 0
    while pos < len(content):
        while pos < len(content) and content[pos] in "\n\r\t ":
            pos += 1
        if pos >= len(content):
            break
        try:
            obj, end = decoder.raw_decode(content, pos)
            pos = end
        except json.JSONDecodeError:
            next_nl = content.find("\n", pos)
            if next_nl == -1:
                break
            pos = next_nl + 1
            continue

        prompt = obj.get("prompt", "")
        ts = obj.get("ts", "")
        exit_code = obj.get("exit", 0)

        for m in RE_EFFECTOR.finditer(prompt):
            name = _clean_name(m.group(1))
            mentions[name] += 1
            if ts > last_seen.get(name, ""):
                last_seen[name] = ts
            if exit_code != 0:
                fails[name] += 1

    return mentions, fails, last_seen


def scan_daemon_log(path: Path) -> tuple[Counter, Counter, dict[str, str]]:
    """Scan golem-daemon.log for effector mentions.

    Returns:
        mention_counts: effector name -> mention count
        fail_counts: effector name -> failure count (FAILED/TIMEOUT lines)
        last_seen: effector name -> ISO timestamp of last mention
    """
    mentions: Counter = Counter()
    fails: Counter = Counter()
    last_seen: dict[str, str] = {}

    if not path.exists():
        return mentions, fails, last_seen

    try:
        lines = path.read_text(errors="replace").splitlines()
    except OSError:
        return mentions, fails, last_seen

    for line in lines:
        m = RE_LOG_TS.match(line)
        if not m:
            continue
        ts_raw = m.group(1)
        msg = m.group(2)

        try:
            dt = datetime.strptime(ts_raw, "%Y-%m-%d %H:%M:%S")
            ts = dt.strftime("%Y-%m-%dT%H:%M:%SZ")
        except ValueError:
            ts = ""

        is_fail = bool(RE_FAILED.match(msg) or RE_TIMEOUT.match(msg))

        for em in RE_EFFECTOR.finditer(line):
            name = _clean_name(em.group(1))
            mentions[name] += 1
            if ts > last_seen.get(name, ""):
                last_seen[name] = ts
            if is_fail:
                fails[name] += 1

    return mentions, fails, last_seen


def merge_results(
    *results: tuple[Counter, Counter, dict[str, str]],
) -> tuple[Counter, Counter, dict[str, str]]:
    """Merge multiple scan results."""
    merged_m: Counter = Counter()
    merged_f: Counter = Counter()
    merged_l: dict[str, str] = {}

    for ments, fls, ls in results:
        merged_m.update(ments)
        merged_f.update(fls)
        for name, ts in ls.items():
            if ts > merged_l.get(name, ""):
                merged_l[name] = ts

    return merged_m, merged_f, merged_l


def compute_report(
    top_n: int = DEFAULT_TOP,
    recent_days: int = RECENT_DAYS,
    jsonl_path: Path | None = None,
    log_path: Path | None = None,
    rotated_path: Path | None = None,
) -> dict:
    """Compute full usage report.

    Returns dict with keys:
        most_used: list of dicts (name, mentions, failures, last_seen)
        never_used: sorted list of effector names not mentioned in any log
        recently_broken: list of dicts for effectors with recent failures
        total_effectors: int
        total_mentions: int
    """
    all_eff = list_effectors()

    jp = jsonl_path or JSONL_FILE
    lp = log_path or DAEMON_LOG
    rp = rotated_path or ROTATED_LOG

    results = [scan_jsonl(jp), scan_daemon_log(lp)]
    if rp.exists():
        results.append(scan_daemon_log(rp))

    mentions, fails, last_seen = merge_results(*results)

    all_mentioned = set(mentions.keys())
    most_used_names = sorted(
        all_mentioned,
        key=lambda n: (mentions[n], last_seen.get(n, "")),
        reverse=True,
    )
    most_used = [
        {
            "name": name,
            "mentions": mentions[name],
            "failures": fails.get(name, 0),
            "last_seen": last_seen.get(name, "never"),
        }
        for name in most_used_names[:top_n]
    ]

    never_used = sorted(all_eff - all_mentioned)

    # Recently broken: failures seen within the recent window
    cutoff_dt = datetime.now(timezone.utc) - timedelta(days=recent_days)
    cutoff = cutoff_dt.strftime("%Y-%m-%dT%H:%M:%SZ")
    recently_broken = sorted(
        [
            {
                "name": name,
                "failures": fails[name],
                "last_seen": last_seen.get(name, "unknown"),
            }
            for name in all_mentioned
            if fails.get(name, 0) > 0 and last_seen.get(name, "") >= cutoff
        ],
        key=lambda x: (-x["failures"], x["name"]),
    )

    return {
        "most_used": most_used,
        "never_used": never_used,
        "recently_broken": recently_broken,
        "total_effectors": len(all_eff),
        "total_mentions": sum(mentions.values()),
    }


def format_report(report: dict) -> str:
    """Format report as human-readable text."""
    lines: list[str] = []

    lines.append("=" * 60)
    lines.append("EFFECTOR USAGE REPORT")
    lines.append("=" * 60)
    lines.append(
        f"  Effectors: {report['total_effectors']} registered  "
        f"Mentions: {report['total_mentions']}"
    )
    lines.append("")

    # Most used
    lines.append(f"-- Most Used (top {len(report['most_used'])}) --")
    if report["most_used"]:
        name_w = max(len(e["name"]) for e in report["most_used"])
        for entry in report["most_used"]:
            fail_str = f"  ({entry['failures']} fail)" if entry["failures"] else ""
            ls = entry["last_seen"][:10] if entry["last_seen"] != "never" else "never"
            lines.append(
                f"  {entry['name']:<{name_w}}  {entry['mentions']:>4}x  "
                f"last: {ls}{fail_str}"
            )
    else:
        lines.append("  (none found)")
    lines.append("")

    # Never used
    lines.append(f"-- Never Used ({len(report['never_used'])}) --")
    if report["never_used"]:
        col_w = max(len(n) for n in report["never_used"]) + 2
        cols = max(1, 60 // col_w)
        for i in range(0, len(report["never_used"]), cols):
            row = report["never_used"][i : i + cols]
            lines.append("  " + "  ".join(n.ljust(col_w) for n in row).rstrip())
    else:
        lines.append("  (all effectors have been referenced)")
    lines.append("")

    # Recently broken
    lines.append(f"-- Recently Broken ({len(report['recently_broken'])}) --")
    if report["recently_broken"]:
        for entry in report["recently_broken"]:
            ls = entry["last_seen"][:10] if entry["last_seen"] != "unknown" else "unknown"
            lines.append(
                f"  {entry['name']:<24}  {entry['failures']:>3} failures  last: {ls}"
            )
    else:
        lines.append("  (none)")
    lines.append("")

    lines.append("=" * 60)
    return "\n".join(lines)


def main() -> int:
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0

    as_json = "--json" in args
    show_broken = "--broken" in args
    show_unused = "--unused" in args

    top_n = DEFAULT_TOP
    for i, arg in enumerate(args):
        if arg == "--top" and i + 1 < len(args):
            try:
                top_n = int(args[i + 1])
            except ValueError:
                pass

    report = compute_report(top_n=top_n)

    if as_json:
        print(json.dumps(report, indent=2))
    elif show_broken:
        if report["recently_broken"]:
            print(f"Recently broken effectors ({len(report['recently_broken'])}):")
            for entry in report["recently_broken"]:
                print(
                    f"  {entry['name']:<24}  {entry['failures']:>3} failures  "
                    f"last: {entry['last_seen'][:10]}"
                )
        else:
            print("No recently broken effectors.")
    elif show_unused:
        if report["never_used"]:
            print(f"Never used effectors ({len(report['never_used'])}):")
            for name in report["never_used"]:
                print(f"  {name}")
        else:
            print("All effectors have been referenced.")
    else:
        print(format_report(report))

    return 0


if __name__ == "__main__":
    sys.exit(main())

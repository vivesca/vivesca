#!/usr/bin/env python3
"""effector-usage — scan golem logs for effector mentions and report usage stats.

Scans golem.jsonl and golem-daemon.log for references to effectors/.
Reports: most used, never used, recently broken.

Usage:
    effector-usage              # full report (most-used, never-used, recently-broken)
    effector-usage --json       # machine-readable JSON output
    effector-usage --top N      # show top N most-used (default 20)
    effector-usage --broken     # show only recently broken effectors
    effector-usage --unused     # show only never-used effectors
"""
from __future__ import annotations

import json
import os
import re
import sys
from collections import Counter, defaultdict
from datetime import datetime, timedelta
from pathlib import Path

EFFECTORS_DIR = Path.home() / "germline" / "effectors"
JSONL_FILE = Path.home() / ".local" / "share" / "vivesca" / "golem.jsonl"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
DEFAULT_TOP = 20
RECENT_DAYS = 7


def list_effectors() -> set[str]:
    """Return set of all effector names (files in effectors/ dir, excluding dirs)."""
    if not EFFECTORS_DIR.exists():
        return set()
    return {
        p.name
        for p in EFFECTORS_DIR.iterdir()
        if p.is_file() and not p.name.startswith(".") and p.name != "__pycache__"
    }


def parse_jsonl_mentions() -> tuple[Counter, Counter, dict[str, str]]:
    """Parse golem.jsonl for effector mentions.

    Returns:
        (mention_counts, fail_counts, last_seen_ts)
        - mention_counts: Counter mapping effector name -> number of mentions
        - fail_counts: Counter mapping effector name -> number of failed invocations
        - last_seen_ts: dict mapping effector name -> ISO timestamp of last mention
    """
    mention_counts: Counter = Counter()
    fail_counts: Counter = Counter()
    last_seen_ts: dict[str, str] = {}

    if not JSONL_FILE.exists():
        return mention_counts, fail_counts, last_seen_ts

    decoder = json.JSONDecoder()
    try:
        content = JSONL_FILE.read_text(errors="replace")
    except OSError:
        return mention_counts, fail_counts, last_seen_ts

    pos = 0
    while pos < len(content):
        # Skip whitespace/newlines
        while pos < len(content) and content[pos] in "\n\r\t ":
            pos += 1
        if pos >= len(content):
            break
        try:
            obj, end = decoder.raw_decode(content, pos)
            pos = end
        except json.JSONDecodeError:
            # Skip to next line
            next_nl = content.find("\n", pos)
            if next_nl == -1:
                break
            pos = next_nl + 1
            continue

        prompt = obj.get("prompt", "")
        ts = obj.get("ts", "")
        exit_code = obj.get("exit", 0)

        # Find effector references: effectors/<name>
        for m in re.finditer(r"effectors/([a-zA-Z0-9][a-zA-Z0-9_.-]*)", prompt):
            name = m.group(1)
            mention_counts[name] += 1
            if ts > last_seen_ts.get(name, ""):
                last_seen_ts[name] = ts
            if exit_code != 0:
                fail_counts[name] += 1

    return mention_counts, fail_counts, last_seen_ts


def parse_daemon_log_mentions() -> tuple[Counter, Counter, dict[str, str]]:
    """Parse golem-daemon.log for effector mentions.

    Looks at Starting/Finished/FAILED lines and extracts effector names
    from quoted task prompts.

    Returns:
        (mention_counts, fail_counts, last_seen_ts)
    """
    mention_counts: Counter = Counter()
    fail_counts: Counter = Counter()
    last_seen_ts: dict[str, str] = {}

    if not DAEMON_LOG.exists():
        return mention_counts, fail_counts, last_seen_ts

    # Pattern for Starting/Finished/FAILED lines
    line_re = re.compile(
        r"^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] "
        r"(?:Starting|Finished|FAILED|TIMEOUT|ERROR)"
    )
    effector_re = re.compile(r"effectors/([a-zA-Z0-9][a-zA-Z0-9_.-]*)")

    try:
        with open(DAEMON_LOG, errors="replace") as f:
            for line in f:
                m = line_re.match(line)
                if not m:
                    continue
                ts_raw = m.group(1)
                # Convert to ISO format
                try:
                    dt = datetime.strptime(ts_raw, "%Y-%m-%d %H:%M:%S")
                    ts = dt.strftime("%Y-%m-%dT%H:%M:%SZ")
                except ValueError:
                    ts = ""

                is_fail = "FAILED" in line or "TIMEOUT" in line or "ERROR" in line

                for em in effector_re.finditer(line):
                    name = em.group(1)
                    mention_counts[name] += 1
                    if ts > last_seen_ts.get(name, ""):
                        last_seen_ts[name] = ts
                    if is_fail:
                        fail_counts[name] += 1
    except OSError:
        pass

    return mention_counts, fail_counts, last_seen_ts


def merge_results(
    *results: tuple[Counter, Counter, dict[str, str]],
) -> tuple[Counter, Counter, dict[str, str]]:
    """Merge multiple parse results (jsonl + daemon log)."""
    merged_mentions: Counter = Counter()
    merged_fails: Counter = Counter()
    merged_last: dict[str, str] = {}

    for mentions, fails, last_seen in results:
        merged_mentions.update(mentions)
        merged_fails.update(fails)
        for name, ts in last_seen.items():
            if ts > merged_last.get(name, ""):
                merged_last[name] = ts

    return merged_mentions, merged_fails, merged_last


def compute_report(
    top_n: int = DEFAULT_TOP,
    recent_days: int = RECENT_DAYS,
) -> dict:
    """Compute full usage report.

    Returns dict with keys:
        most_used: list of (name, count, last_seen, fail_count)
        never_used: list of effector names not mentioned in any log
        recently_broken: list of (name, fail_count, last_seen) for recent failures
        total_effectors: int
        total_mentions: int
    """
    all_effectors = list_effectors()

    jsonl_result = parse_jsonl_mentions()
    daemon_result = parse_daemon_log_mentions()
    mentions, fails, last_seen = merge_results(jsonl_result, daemon_result)

    # Most used: sorted by mention count descending
    all_mentioned = set(mentions.keys())
    most_used = sorted(
        all_mentioned,
        key=lambda n: (mentions[n], last_seen.get(n, "")),
        reverse=True,
    )
    most_used_data = [
        {
            "name": name,
            "mentions": mentions[name],
            "failures": fails.get(name, 0),
            "last_seen": last_seen.get(name, "never"),
        }
        for name in most_used[:top_n]
    ]

    # Never used: effectors in dir but not in any log
    never_used = sorted(all_effectors - all_mentioned)

    # Recently broken: mentioned effectors with failures in last N days
    cutoff = (datetime.utcnow() - timedelta(days=recent_days)).strftime("%Y-%m-%dT%H:%M:%SZ")
    recently_broken = sorted(
        [
            {
                "name": name,
                "failures": fails[name],
                "last_seen": last_seen.get(name, "unknown"),
            }
            for name in all_mentioned
            if fails.get(name, 0) > 0
            and last_seen.get(name, "") >= cutoff
        ],
        key=lambda x: (-x["failures"], x["name"]),
    )

    return {
        "most_used": most_used_data,
        "never_used": never_used,
        "recently_broken": recently_broken,
        "total_effectors": len(all_effectors),
        "total_mentions": sum(mentions.values()),
    }


def format_report(report: dict) -> str:
    """Format report as human-readable text."""
    lines: list[str] = []

    lines.append("═══ Effector Usage Report ═══")
    lines.append(
        f"Effectors: {report['total_effectors']} registered  "
        f"Total mentions: {report['total_mentions']}"
    )
    lines.append("")

    # Most used
    lines.append(f"── Most Used (top {len(report['most_used'])}) ──")
    if report["most_used"]:
        name_w = max(len(e["name"]) for e in report["most_used"])
        for entry in report["most_used"]:
            fail_str = f" ({entry['failures']} fail)" if entry["failures"] else ""
            lines.append(
                f"  {entry['name']:<{name_w}}  {entry['mentions']:>4} mentions  "
                f"last: {entry['last_seen'][:10]}{fail_str}"
            )
    else:
        lines.append("  (none found)")

    lines.append("")

    # Never used
    lines.append(f"── Never Used ({len(report['never_used'])}) ──")
    if report["never_used"]:
        # Print in columns
        col_w = 24
        for i in range(0, len(report["never_used"]), 3):
            row = report["never_used"][i : i + 3]
            lines.append("  " + "  ".join(f"{n:<{col_w}}" for n in row).rstrip())
    else:
        lines.append("  (all effectors have been referenced)")

    lines.append("")

    # Recently broken
    lines.append(f"── Recently Broken ({len(report['recently_broken'])}) ──")
    if report["recently_broken"]:
        for entry in report["recently_broken"]:
            lines.append(
                f"  {entry['name']:<24}  {entry['failures']:>3} failures  "
                f"last: {entry['last_seen'][:10]}"
            )
    else:
        lines.append("  (none)")

    return "\n".join(lines) + "\n"


def main() -> int:
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0

    as_json = "--json" in args
    show_broken = "--broken" in args
    show_unused = "--unused" in args

    # Parse --top N
    top_n = DEFAULT_TOP
    for i, arg in enumerate(args):
        if arg == "--top" and i + 1 < len(args):
            try:
                top_n = int(args[i + 1])
            except ValueError:
                pass

    report = compute_report(top_n=top_n)

    if as_json:
        print(json.dumps(report, indent=2))
    elif show_broken:
        if report["recently_broken"]:
            print(f"Recently broken effectors ({len(report['recently_broken'])}):")
            for entry in report["recently_broken"]:
                print(
                    f"  {entry['name']:<24}  {entry['failures']:>3} failures  "
                    f"last: {entry['last_seen'][:10]}"
                )
        else:
            print("No recently broken effectors.")
    elif show_unused:
        if report["never_used"]:
            print(f"Never used effectors ({len(report['never_used'])}):")
            for name in report["never_used"]:
                print(f"  {name}")
        else:
            print("All effectors have been referenced.")
    else:
        print(format_report(report))

    return 0


if __name__ == "__main__":
    sys.exit(main())

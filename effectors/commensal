#!/usr/bin/env python3
"""commensal ‚ÄĒ route a coding task to opencode (GLM-5, free).

Usage:
  delegate "add a pre-commit hook that scans for API keys"
  delegate -b gemini "refactor this function"
  delegate --cwd ~/code/myrepo "fix the failing test"
"""

import argparse
import contextlib
import os
import pty
import re
import select
import subprocess
import time
from pathlib import Path

HOME = Path.home()

BACKENDS = {
    "opencode": ["opencode", "--prompt"],
    "gemini": ["gemini", "-p"],
    "codex": [
        "codex",
        "--dangerously-bypass-approvals-and-sandbox",
        "-q",
        "--skip-git-repo-check",
    ],
}
PTY_BACKENDS = {"opencode", "codex"}
TIMEOUT_FLOOR = {"opencode": 180, "gemini": 120, "codex": 180}

_ANSI_RE = re.compile(r"\x1b\[[^a-zA-Z]*[a-zA-Z]|\x1b\][^\x07]*\x07|\x1b[()][^a-zA-Z]*[a-zA-Z]?")
_CTRL_RE = re.compile(r"[\x00-\x09\x0b-\x1f\x7f]")
_TUI_RE = re.compile(r"[‚Ėą‚ĖÄ‚ĖĄ‚Ėź‚ĖĎ‚ĖĆ‚Ėć‚Ėé‚ĖŹ‚ēĻ‚ēł‚ēļ‚ēĽ‚ĒÉ‚Ė†‚¨Ě]+")


def run_pty(cmd: list[str], cwd: str, timeout: int) -> tuple[str, int]:
    """Run a TUI CLI with PTY. Returns (clean_output, exit_code)."""
    master, slave = pty.openpty()
    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    proc = subprocess.Popen(
        cmd,
        stdin=slave,
        stdout=slave,
        stderr=slave,
        close_fds=True,
        env=env,
        cwd=cwd,
    )
    os.close(slave)
    output = b""
    deadline = time.time() + timeout
    while time.time() < deadline:
        r, _, _ = select.select([master], [], [], 1)
        if r:
            try:
                chunk = os.read(master, 4096)
                if not chunk:
                    break
                output += chunk
            except OSError:
                break
        if proc.poll() is not None:
            while True:
                r, _, _ = select.select([master], [], [], 0.5)
                if not r:
                    break
                try:
                    chunk = os.read(master, 4096)
                    if not chunk:
                        break
                    output += chunk
                except OSError:
                    break
            break
    with contextlib.suppress(OSError):
        os.close(master)
    if proc.poll() is None:
        proc.kill()
        proc.wait()

    clean = _ANSI_RE.sub("", output.decode("utf-8", errors="replace"))
    clean = _CTRL_RE.sub("", clean)
    clean = _TUI_RE.sub(" ", clean)
    clean = re.sub(r"\s+", " ", clean).strip()
    return clean, proc.returncode or 0


def run_direct(cmd: list[str], cwd: str, timeout: int) -> tuple[str, int]:
    """Run a direct CLI. Returns (output, exit_code)."""
    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    r = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=timeout,
        env=env,
        cwd=cwd,
    )
    return r.stdout.strip(), r.returncode


def main():
    parser = argparse.ArgumentParser(
        prog="commensal", description="Route coding task to a free model"
    )
    parser.add_argument("task", help="Task description")
    parser.add_argument(
        "-b",
        "--backend",
        default="opencode",
        choices=list(BACKENDS.keys()),
        help="Backend (default: opencode)",
    )
    parser.add_argument("--cwd", default=str(HOME / "germline"), help="Working directory")
    parser.add_argument("--timeout", type=int, default=180, help="Timeout in seconds")

    args = parser.parse_args()
    backend = args.backend
    cmd_base = BACKENDS[backend]
    timeout = max(args.timeout, TIMEOUT_FLOOR.get(backend, 0))
    cwd = args.cwd

    print(f"Routing to {backend} (CWD: {cwd})")
    print(f"Task: {args.task}")
    print()

    cmd = [*cmd_base, args.task]

    if backend in PTY_BACKENDS:
        output, code = run_pty(cmd, cwd, timeout)
    else:
        output, code = run_direct(cmd, cwd, timeout)

    # Check if files were modified
    try:
        diff = subprocess.run(
            ["git", "diff", "--stat"],
            capture_output=True,
            text=True,
            timeout=5,
            cwd=cwd,
        )
        if diff.stdout.strip():
            print("\nFiles modified:")
            print(diff.stdout.strip())
    except Exception:
        pass

    print(f"\nDone (exit {code})")
    if output and len(output) > 50:
        # Save output for review
        out_path = HOME / "tmp" / f"commensal-{backend}-{int(time.time())}.txt"
        out_path.write_text(output, encoding="utf-8")
        print(f"Output: {out_path}")


if __name__ == "__main__":
    main()

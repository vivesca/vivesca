#!/usr/bin/env python3
"""complement — one-line adversarial challenge via OpenRouter."""

import sys

from metabolon.symbiont import transduce as query

PROMPT = """You are a red-team critic. Your job is to find the single strongest counterargument to the claim below.

Rules:
- Exactly ONE sentence. No preamble, no hedging.
- Attack the weakest point, not the whole argument.
- Be specific, not generic. "This might not work" is useless. "This ignores X because Y" is useful.
- If the claim genuinely holds up and you can't find a real weakness, say: "No strong counter. This holds up."

Claim:
{claim}

Respond with ONLY the counterargument sentence. Nothing else."""


def main():
    if len(sys.argv) > 1:
        claim = " ".join(sys.argv[1:])
    else:
        claim = sys.stdin.read().strip()

    if not claim:
        print("Usage: complement <claim>  or  echo <claim> | redarguo", file=sys.stderr)
        sys.exit(1)

    prompt = PROMPT.format(claim=claim)

    try:
        response = query("gemini-flash", prompt, timeout=30)
    except Exception as e:
        print(f"🔴 complement failed: {e}", file=sys.stderr)
        sys.exit(1)

    if not response:
        print("🔴 complement failed to respond", file=sys.stderr)
        sys.exit(1)

    if "no strong counter" in response.lower() or "holds up" in response.lower():
        print(f"🟢 **No strong counter.** {response}")
    else:
        print(f"🔴 **Weakest point:** {response}")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""complement — innate immune cascade, deterministic health checks (no LLM).

Runs: receptor health, git health, proteostasis, docima benchmark.

Usage:
    complement              # run all checks
    complement --json       # JSON output
"""

from __future__ import annotations

import json
import subprocess
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path.home() / "germline"))

REPORTS_DIR = Path.home() / "epigenome" / "chromatin" / "immunity"

# Active repos to check (pruned 2026-03-29)
GIT_REPOS = [
    Path.home() / "germline",
    Path.home() / "epigenome",
    Path.home() / "code" / "sortase",
    Path.home() / "code" / "docima",
]


def _run(cmd: list[str], cwd: Path | None = None, timeout: int = 30) -> tuple[int, str]:
    try:
        r = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True, timeout=timeout)
        return r.returncode, (r.stdout + r.stderr).strip()
    except Exception as e:
        return 1, str(e)


def check_receptors() -> dict:
    code, output = _run(["vivesca", "receptor-health"], cwd=Path.home() / "germline")
    return {"name": "receptor-health", "ok": code == 0, "output": output[:500]}


def check_git() -> dict:
    issues = []
    for repo in GIT_REPOS:
        if not repo.exists():
            issues.append({"repo": str(repo), "status": "MISSING"})
            continue
        _, uncommitted = _run(["git", "status", "--short"], cwd=repo)
        _, unpushed = _run(["git", "log", "--branches", "--not", "--remotes", "--oneline"], cwd=repo)
        if uncommitted or unpushed:
            issues.append({
                "repo": repo.name,
                "uncommitted": len(uncommitted.splitlines()) if uncommitted else 0,
                "unpushed": len(unpushed.splitlines()) if unpushed else 0,
            })
    return {"name": "git-health", "ok": len(issues) == 0, "issues": issues}


def check_deps() -> dict:
    code, output = _run(["proteostasis", "--force"])
    return {"name": "proteostasis", "ok": code == 0, "output": output[:500] if output else "clean"}


def check_docima() -> dict:
    code, output = _run(
        ["uv", "run", "docima", "benchmark", "--daily", "-b", "markdown"],
        cwd=Path.home() / "code" / "docima",
        timeout=60,
    )
    return {"name": "docima-benchmark", "ok": code == 0, "output": output[:300] if code != 0 else "ok"}


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Nightly deterministic health checks")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    checks = [check_receptors(), check_git(), check_deps(), check_docima()]
    all_ok = all(c["ok"] for c in checks)

    if args.json:
        print(json.dumps({"date": datetime.now().isoformat(), "all_ok": all_ok, "checks": checks}, indent=2))
    else:
        for c in checks:
            status = "OK" if c["ok"] else "NEEDS_ATTENTION"
            print(f"[{status}] {c['name']}")
            if not c["ok"]:
                detail = c.get("issues") or c.get("output", "")
                if isinstance(detail, list):
                    for i in detail:
                        print(f"  {i}")
                else:
                    print(f"  {detail[:200]}")

    # Write report for morning dashboard
    REPORTS_DIR.mkdir(parents=True, exist_ok=True)
    report_path = REPORTS_DIR / "nightly-health.json"
    report_path.write_text(json.dumps({"date": datetime.now().isoformat(), "all_ok": all_ok, "checks": checks}, indent=2))

    sys.exit(0 if all_ok else 1)


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""Disaster recovery sync — backs up local-only state to officina (git-backed)."""

import argparse
import platform
import shutil
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
DEST = HOME / "officina" / "claude-backup"


def sync():
    # Claude Code settings
    for f in ["settings.json", "settings.local.json"]:
        src = HOME / ".claude" / f
        if src.exists():
            DEST.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, DEST / f)

    # Claude Code memory — discover project memory dirs dynamically
    projects_dir = HOME / ".claude" / "projects"
    mem_dst = DEST / "memory"
    if projects_dir.exists():
        for project_dir in sorted(projects_dir.iterdir()):
            mem_src = project_dir / "memory"
            if mem_src.is_dir():
                target = mem_dst / project_dir.name
                if target.exists():
                    shutil.rmtree(target)
                shutil.copytree(mem_src, target)

    # Shell env
    env_src = HOME / ".zshenv.local"
    if env_src.exists():
        shutil.copy2(env_src, DEST / "zshenv.local")

    # Synaxis config
    syn_src = HOME / ".config" / "synaxis" / "config.toml"
    syn_dst = DEST / "config" / "synaxis"
    syn_dst.mkdir(parents=True, exist_ok=True)
    if syn_src.exists():
        shutil.copy2(syn_src, syn_dst / "config.toml")

    # Brewfile refresh (macOS only)
    if platform.system() == "Darwin":
        subprocess.run(
            ["brew", "bundle", "dump", f"--file={HOME}/officina/Brewfile", "--force"],
            capture_output=True,
            timeout=60,
        )

    # Auto-commit if changes
    officina = HOME / "officina"
    if not officina.exists():
        print("DR sync: officina directory not found, skipping commit")
        return

    result = subprocess.run(
        ["git", "status", "--porcelain", "claude-backup/", "Brewfile"],
        capture_output=True,
        text=True,
        cwd=officina,
        timeout=30,
    )
    if result.stdout.strip():
        subprocess.run(["git", "add", "claude-backup/", "Brewfile"], cwd=officina, timeout=30)
        subprocess.run(
            ["git", "commit", "-m", "DR sync: update backup"],
            cwd=officina,
            timeout=60,
        )
        subprocess.run(["git", "push"], cwd=officina, timeout=120)
        print("DR sync: committed and pushed")
    else:
        print("DR sync: no changes")


def main():
    parser = argparse.ArgumentParser(
        description="Disaster recovery sync — backs up local-only state to officina (git-backed).",
    )
    parser.parse_args()
    sync()


if __name__ == "__main__":
    main()

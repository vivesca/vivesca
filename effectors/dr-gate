#!/usr/bin/env bash
# dr-gate — Mac DR-side wrapper.
#
# Wraps a Mac LaunchAgent command. Exits 0 immediately if soma is alive
# (we're standby), exec's the command if soma is unreachable (we're failover).
#
# Architecture:
#   Soma (Fly Tokyo) = primary
#   Ganglion (OCI ARM) = Temporal worker
#   Mac = hot standby DR — runs jobs only when soma is unreachable
#
# Usage in plist:
#   <key>ProgramArguments</key>
#   <array>
#     <string>/Users/terry/germline/effectors/dr-gate</string>
#     <string>/path/to/original/command</string>
#     <string>arg1</string>
#     ...
#   </array>
#
# OR direct script invocation:
#   dr-gate python3 ~/germline/effectors/some-task --flag
#
# Logging: writes a single-line marker to ~/tmp/dr-gate.log when standby/active.

set -u

LOG="$HOME/tmp/dr-gate.log"
mkdir -p "$(dirname "$LOG")"

job_label="${DR_JOB_LABEL:-$(basename "$1" 2>/dev/null || echo unknown)}"

# Check soma via Tailscale — 2s timeout, no DNS dependency
if ping -c1 -W2 soma >/dev/null 2>&1; then
  printf '[%s] standby :: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$job_label" >> "$LOG"
  exit 0
fi

# Double-check via SSH (ping might be blocked)
if ssh -o ConnectTimeout=3 -o BatchMode=yes soma true >/dev/null 2>&1; then
  printf '[%s] standby :: %s (ssh fallback)\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$job_label" >> "$LOG"
  exit 0
fi

# Soma is dead — take over
printf '[%s] ACTIVE  :: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$job_label" >> "$LOG"
exec "$@"

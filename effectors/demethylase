#!/usr/bin/env python3
"""demethylase — active memory erasure CLI.

Usage:
    demethylase                    # dry-run sweep (default)
    demethylase --execute          # actually delete stale marks
    demethylase --threshold 60     # custom staleness threshold (days)
    demethylase --json             # JSON output
    demethylase --consolidate      # run consolidation only (no erasure)
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path.home() / "germline"))

from metabolon.organelles.demethylase import consolidate, format_report, sweep


def main():
    parser = argparse.ArgumentParser(description="Active memory erasure — scan and remove stale marks")
    parser.add_argument("--execute", action="store_true", help="Actually delete stale marks (default: dry-run)")
    parser.add_argument("--threshold", type=int, default=90, help="Days before methyl marks are stale (default: 90)")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--consolidate", action="store_true", help="Run chromatin remodeling only (no erasure)")
    args = parser.parse_args()

    if args.consolidate:
        report = consolidate()
        if args.json:
            print(json.dumps({
                "today_marks": [m.path.name for m in report.today_marks],
                "clusters_found": report.clusters_found[:10],
                "strengthened": [m.path.name for m in report.strengthened],
                "methylome_updated": report.methylome_updated,
            }, indent=2))
        else:
            print(f"[CONSOLIDATE] Sleep consolidation complete.")
            print(f"  Today's marks:  {len(report.today_marks)}")
            print(f"  Clusters found: {len(report.clusters_found)}")
            print(f"  Strengthened:   {len(report.strengthened)}")
            print(f"  Methylome:      {'updated' if report.methylome_updated else 'unchanged'}")
        return

    report = sweep(threshold_days=args.threshold, dry_run=not args.execute)

    if args.json:
        print(json.dumps({
            "total": report.total_marks,
            "methyl": report.methyl_marks,
            "acetyl": report.acetyl_marks,
            "protected": report.protected_marks,
            "stale": len(report.stale_candidates),
            "sources": report.source_distribution,
            "types": report.type_distribution,
            "clusters": report.mark_clusters[:10],
            "stale_files": [m.path.name for m in report.stale_candidates],
            "executed": not args.execute,
        }, indent=2))
    else:
        mode = "EXECUTE" if args.execute else "DRY-RUN"
        print(f"[{mode}] {format_report(report)}")
        if args.execute and report.stale_candidates:
            print(f"\nDeleted {len(report.stale_candidates)} stale marks.")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""pinocytosis — deterministic web content extraction.

Parallel fast tier (defuddle + jina + microlink) → firecrawl → agent-browser → error.

Usage:
  pinocytosis <url>              # Extract text from URL
  pinocytosis --screenshot <url> # Screenshot to ~/tmp/
  pinocytosis --json <url>       # Structured output
  pinocytosis --method jina <url> # Force specific method
"""

import argparse
import json
import platform
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor, as_completed


def _run(cmd: list[str], timeout: int = 30) -> tuple[bool, str]:
    """Run command, return (success, output)."""
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.returncode == 0, r.stdout.strip()
    except subprocess.TimeoutExpired, FileNotFoundError:
        return False, ""


# Domains where specific tools are known-best (from benchmark)
DOMAIN_HINTS = {
    # Paywalled — skip straight to Firecrawl
    "ft.com": "firecrawl",
    "bloomberg.com": "firecrawl",
    "wsj.com": "firecrawl",
    # Government — defuddle is cleanest, no need for Jina's noise
    "hkma.gov.hk": "defuddle",
    "sfc.hk": "defuddle",
    "mas.gov.sg": "defuddle",
    # Evident — Firecrawl gets date + more links
    "evidentinsights.com": "firecrawl",
    # Substack — defuddle fails (returns audio tag only), skip to jina
    "latent.space": "jina",
    "substack.com": "jina",
}


def _defuddle(url: str) -> str:
    """Extract clean markdown via defuddle CLI."""
    ok, text = _run(["npx", "defuddle", "parse", "--markdown", url], timeout=30)
    if ok and text and len(text) > 100:
        # Check for auth-gate signals
        lower = text.lower()
        auth_signals = ["sign in", "log in", "create account", "please login"]
        if any(s in lower for s in auth_signals):
            return ""  # Auth-gated, escalate
        return text
    return ""


def _jina(url: str) -> str:
    """Extract via Jina Reader API (free, no auth needed)."""
    import urllib.request

    req = urllib.request.Request(
        f"https://r.jina.ai/{url}",
        headers={"Accept": "text/markdown", "User-Agent": "pinocytosis/1.0"},
    )
    try:
        with urllib.request.urlopen(req, timeout=20) as resp:
            text = resp.read().decode("utf-8")
        # Strip Jina metadata header
        import re

        text = re.sub(
            r"^(?:Title|URL Source|Markdown Content):.*\n?", "", text, flags=re.MULTILINE
        )
        if len(text) > 100:
            return text
    except Exception:
        pass
    return ""


def _microlink(url: str) -> str:
    """Extract via Microlink API (free, no auth, 50 req/day)."""
    import urllib.parse
    import urllib.request

    try:
        req = urllib.request.Request(
            f"https://api.microlink.io?url={urllib.parse.quote(url, safe='')}&data.markdown.attr=markdown",
            headers={"User-Agent": "pinocytosis/1.0"},
        )
        with urllib.request.urlopen(req, timeout=20) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        text = (
            data.get("data", {}).get("markdown") or data.get("data", {}).get("description") or ""
        )
        if len(text) > 100:
            return text
    except Exception:
        pass
    return ""


def _firecrawl(url: str) -> str:
    """Extract via Firecrawl API (1 credit/page). Reserved for paywalled/JS-heavy sites."""
    try:
        key = (
            subprocess.check_output(
                [
                    "op",
                    "item",
                    "get",
                    "Firecrawl",
                    "--vault",
                    "Agents",
                    "--fields",
                    "credential",
                    "--reveal",
                ],
                timeout=10,
            )
            .decode()
            .strip()
        )
        if not key:
            return ""
        from firecrawl import FirecrawlApp

        fc = FirecrawlApp(api_key=key)
        doc = fc.scrape(url, formats=["markdown"])
        return doc.markdown or ""
    except Exception:
        return ""


def _agent_browser_eval(url: str, wait_ms: int = 5000) -> str:
    """Extract text via agent-browser eval innerText."""
    _run(["agent-browser", "close"], timeout=5)
    time.sleep(1)

    ok, _ = _run(["agent-browser", "open", url], timeout=15)
    if not ok:
        return ""

    _run(["agent-browser", "wait", str(wait_ms)], timeout=max(wait_ms // 1000 + 5, 15))

    ok, text = _run(["agent-browser", "eval", "document.body.innerText"], timeout=10)
    if ok and text and len(text) > 50:
        return text

    ok, text = _run(["agent-browser", "get", "text"], timeout=10)
    if ok and text:
        return text

    return ""


def _screenshot(url: str, output: str) -> bool:
    """Screenshot via agent-browser."""
    _run(["agent-browser", "close"], timeout=5)
    time.sleep(1)
    ok, _ = _run(["agent-browser", "open", url], timeout=15)
    if not ok:
        return False
    _run(["agent-browser", "wait", "3000"], timeout=10)
    if platform.system() == "Darwin":
        _run(["caffeinate", "-u", "-t", "2"], timeout=5)
    ok, _ = _run(["agent-browser", "screenshot", output], timeout=10)
    return ok


def fetch_url(url: str, method: str | None = None) -> dict:
    """Fetch URL content. Parallel fast tier, then serial slow tier."""
    from urllib.parse import urlparse

    domain = urlparse(url).netloc.removeprefix("www.")

    all_methods = {
        "defuddle": _defuddle,
        "jina": _jina,
        "microlink": _microlink,
        "firecrawl": _firecrawl,
        "agent-browser": _agent_browser_eval,
    }

    # Manual override: use only the specified method
    if method:
        if method not in all_methods:
            return {
                "success": False,
                "text": "",
                "method": "none",
                "url": url,
                "error": f"Unknown method: {method}",
            }
        text = all_methods[method](url)
        if text:
            return {"success": True, "text": text, "method": method, "url": url}
        return {
            "success": False,
            "text": "",
            "method": "none",
            "url": url,
            "error": f"{method} returned no content",
        }

    # Check domain hints — if hint points to a slow-tier tool, run it first
    hint = None
    for pattern, tool in DOMAIN_HINTS.items():
        if domain.endswith(pattern):
            hint = tool
            break

    if hint and hint in ("firecrawl", "agent-browser"):
        text = all_methods[hint](url)
        if text:
            return {"success": True, "text": text, "method": hint, "url": url}

    # Tier 1: parallel fast HTTP calls (free, no browser)
    fast_tier = [("defuddle", _defuddle), ("jina", _jina), ("microlink", _microlink)]

    # If hint is a fast-tier tool, prioritise it in results but still run all
    results = {}
    with ThreadPoolExecutor(max_workers=3) as pool:
        futures = {pool.submit(fn, url): name for name, fn in fast_tier}
        for future in as_completed(futures):
            name = futures[future]
            try:
                results[name] = future.result()
            except Exception:
                results[name] = ""

    # Pick richest non-empty result; prefer hint if tied
    candidates = [(name, text) for name, text in results.items() if text]
    if candidates:
        if hint and any(name == hint for name, _ in candidates):
            best = next((name, text) for name, text in candidates if name == hint)
        else:
            best = max(candidates, key=lambda x: len(x[1]))
        return {"success": True, "text": best[1], "method": best[0], "url": url}

    # Tier 2: firecrawl (costs credits)
    text = _firecrawl(url)
    if text:
        return {"success": True, "text": text, "method": "firecrawl", "url": url}

    # Tier 3: agent-browser (slow, last resort)
    text = _agent_browser_eval(url)
    if text:
        return {"success": True, "text": text, "method": "agent-browser", "url": url}

    return {
        "success": False,
        "text": "",
        "method": "none",
        "url": url,
        "error": "All extraction methods failed",
    }


def main():
    parser = argparse.ArgumentParser(description="Web content extraction")
    parser.add_argument("url", help="URL to fetch")
    parser.add_argument("--screenshot", action="store_true", help="Screenshot mode")
    parser.add_argument("--output", "-o", default="", help="Output path for screenshot")
    parser.add_argument("--json", action="store_true", help="JSON output")
    parser.add_argument(
        "--method",
        "-m",
        choices=["defuddle", "jina", "microlink", "firecrawl", "agent-browser"],
        help="Force specific extraction method",
    )
    args = parser.parse_args()

    if args.screenshot:
        output = args.output or f"{__import__('os').path.expanduser('~/tmp')}/screenshot.png"
        ok = _screenshot(args.url, output)
        result = {"success": ok, "path": output, "url": args.url}
    else:
        result = fetch_url(args.url, method=args.method)

    if args.json:
        print(json.dumps(result, ensure_ascii=False))
    else:
        if result.get("success"):
            print(result.get("text") or result.get("path", ""))
        else:
            print(f"Error: {result.get('error', 'extraction failed')}", file=sys.stderr)
            sys.exit(1)


if __name__ == "__main__":
    main()

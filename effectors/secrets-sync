#!/usr/bin/env python3
"""secrets-sync — copy API keys, SSH keys, and git config to a remote host.

Reads ~/.env.fly (export KEY=VALUE lines), ~/.ssh/id_ed25519*, and ~/.gitconfig,
then transfers them to <target> via SSH / scp. Never logs secret values.

Usage:
    secrets-sync --target <ssh-host> [--dry-run]
"""

from __future__ import annotations

import argparse
import re
import subprocess
import sys
from pathlib import Path

HOME = Path.home()

ENV_FILE = HOME / ".env.fly"
SSH_KEY_GLOBS = ["id_ed25519", "id_ed25519.pub"]
GITCONFIG = HOME / ".gitconfig"

ENV_REMOTE_PATH = ".env.fly"
SSH_REMOTE_DIR = ".ssh"
GITCONFIG_REMOTE_PATH = ".gitconfig"


def parse_env_file(path: Path) -> list[tuple[str, str]]:
    """Extract (key, value) pairs from export lines. Skips blanks/comments."""
    pairs: list[tuple[str, str]] = []
    if not path.exists():
        return pairs
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        m = re.match(r'^export\s+([A-Za-z_][A-Za-z0-9_]*)=(.*)$', line)
        if m:
            pairs.append((m.group(1), m.group(2).strip().strip('"').strip("'")))
    return pairs


def local_ssh_keys() -> list[Path]:
    """Return paths to existing ed25519 SSH keys."""
    ssh_dir = HOME / ".ssh"
    found: list[Path] = []
    for name in SSH_KEY_GLOBS:
        p = ssh_dir / name
        if p.exists():
            found.append(p)
    return found


def ssh_cmd(target: str, command: str, dry_run: bool = False) -> str:
    """Run a remote command via SSH. Returns stdout. No-op in dry-run."""
    if dry_run:
        print(f"  [dry-run] ssh {target} {command!r}")
        return ""
    result = subprocess.run(
        ["ssh", target, command],
        capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        raise RuntimeError(f"SSH command failed: {result.stderr.strip()}")
    return result.stdout


def scp_file(target: str, local: Path, remote: str, dry_run: bool = False) -> None:
    """Copy a local file to target:remote via scp."""
    if dry_run:
        print(f"  [dry-run] scp {local} {target}:{remote}")
        return
    result = subprocess.run(
        ["scp", "-q", str(local), f"{target}:{remote}"],
        capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        raise RuntimeError(f"scp failed for {local.name}: {result.stderr.strip()}")


def write_remote_env(target: str, pairs: list[tuple[str, str]], dry_run: bool = False) -> None:
    """Build env file content and write it to remote ~/.env.fly via stdin."""
    lines = [f'export {k}="{v}"' for k, v in pairs]
    content = "\n".join(lines) + "\n"
    if dry_run:
        print(f"  [dry-run] would write {len(pairs)} keys to {target}:{ENV_REMOTE_PATH}")
        print(f"  [dry-run] keys: {', '.join(k for k, _ in pairs)}")
        return
    result = subprocess.run(
        ["ssh", target, f"cat > {ENV_REMOTE_PATH}"],
        input=content, capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        raise RuntimeError(f"Failed to write env on remote: {result.stderr.strip()}")
    print(f"  wrote {len(pairs)} keys to {target}:{ENV_REMOTE_PATH}")
    print(f"  keys: {', '.join(k for k, _ in pairs)}")


def sync(target: str, dry_run: bool = False) -> None:
    """Main sync routine."""
    print(f"=== secrets-sync → {target} {'(dry-run)' if dry_run else ''} ===")

    # 1. Env file
    pairs = parse_env_file(ENV_FILE)
    if pairs:
        print(f"\n[env] {len(pairs)} keys from {ENV_FILE.name}:")
        for k, _ in pairs:
            print(f"  - {k}")
        write_remote_env(target, pairs, dry_run)
    else:
        print(f"\n[env] no keys found in {ENV_FILE}")

    # 2. SSH keys
    keys = local_ssh_keys()
    if keys:
        print(f"\n[ssh] {len(keys)} key files:")
        for kp in keys:
            print(f"  - {kp.name}")
            remote = f"{SSH_REMOTE_DIR}/{kp.name}"
            scp_file(target, kp, remote, dry_run)
        # Ensure correct permissions on remote
        ssh_cmd(target, "chmod 600 ~/.ssh/id_ed25519 2>/dev/null; chmod 644 ~/.ssh/id_ed25519.pub 2>/dev/null", dry_run)
    else:
        print("\n[ssh] no ed25519 keys found")

    # 3. Git config
    if GITCONFIG.exists():
        print(f"\n[git] syncing .gitconfig")
        scp_file(target, GITCONFIG, GITCONFIG_REMOTE_PATH, dry_run)
    else:
        print("\n[git] no .gitconfig found")

    print(f"\n=== sync complete ===")


def main() -> None:
    parser = argparse.ArgumentParser(description="Sync secrets to a remote host")
    parser.add_argument("--target", required=True, help="SSH target (user@host)")
    parser.add_argument("--dry-run", action="store_true", help="Show what would be done")
    args = parser.parse_args()
    sync(args.target, args.dry_run)


if __name__ == "__main__":
    main()

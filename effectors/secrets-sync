#!/usr/bin/env python3
"""secrets-sync — sync API keys, SSH keys, and git config to a new host.

Reads ~/.env.fly (export KEY=VALUE lines), SSHes to target, writes them.
Also syncs: ~/.ssh/id_ed25519*, ~/.gitconfig.

Usage:
    secrets-sync --target <ssh-host> [--dry-run]

NEVER logs secret values — only key names.
"""
from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
ENV_FILE = HOME / ".env.fly"
SSH_KEY_GLOBS = ["id_ed25519", "id_ed25519.pub"]
GITCONFIG = HOME / ".gitconfig"

# Pattern: export KEY="value" or export KEY='value' or export KEY=value
_EXPORT_RE = re.compile(r"""^export\s+(\w+)=['"]?(.+?)['"]?\s*$""")


def parse_env_exports(path: Path) -> list[tuple[str, str]]:
    """Parse export KEY=VALUE lines from an env file. Returns (key, value) pairs."""
    pairs: list[tuple[str, str]] = []
    if not path.exists():
        return pairs
    for line in path.read_text().splitlines():
        line = line.strip()
        m = _EXPORT_RE.match(line)
        if m:
            pairs.append((m.group(1), m.group(2)))
    return pairs


def find_ssh_keys() -> list[Path]:
    """Find ed25519 SSH key files that exist."""
    ssh_dir = HOME / ".ssh"
    keys: list[Path] = []
    for name in SSH_KEY_GLOBS:
        p = ssh_dir / name
        if p.exists():
            keys.append(p)
    return keys


def read_gitconfig() -> str | None:
    """Read gitconfig content if it exists."""
    if GITCONFIG.exists():
        return GITCONFIG.read_text()
    return None


def _scp_file(local: Path, remote_path: str, target: str, dry_run: bool) -> None:
    """SCP a local file to target:remote_path."""
    cmd = ["scp", str(local), f"{target}:{remote_path}"]
    print(f"  + {remote_path}")
    if dry_run:
        return
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"  ERROR: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)


def _ssh_exec(target: str, command: str, dry_run: bool) -> str | None:
    """Execute a command on the remote host via SSH. Returns stdout or None on dry run."""
    cmd = ["ssh", target, command]
    if dry_run:
        print(f"  $ ssh {target} {command}")
        return None
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"  ERROR: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return result.stdout


def sync(target: str, dry_run: bool = False) -> None:
    """Main sync routine."""
    print(f"=== secrets-sync → {target} {'(dry-run)' if dry_run else ''} ===\n")

    # --- 1. Env vars ---
    pairs = parse_env_exports(ENV_FILE)
    if pairs:
        key_names = [k for k, _ in pairs]
        print(f"[env] {len(pairs)} keys from {ENV_FILE.name}: {', '.join(key_names)}")
        # Build remote env file content
        env_content = "\n".join(f"export {k}='{v}'" for k, v in pairs) + "\n"
        if dry_run:
            print("  (dry-run: would write to ~/.env.fly on target)")
        else:
            # Write via stdin to avoid command-line secret exposure
            cmd = ["ssh", target, "cat > ~/.env.fly"]
            result = subprocess.run(cmd, input=env_content, capture_output=True, text=True)
            if result.returncode != 0:
                print(f"  ERROR: {result.stderr.strip()}", file=sys.stderr)
                sys.exit(1)
            print("  ✓ written to ~/.env.fly")
    else:
        print(f"[env] no export lines found in {ENV_FILE}")

    # --- 2. SSH keys ---
    ssh_keys = find_ssh_keys()
    if ssh_keys:
        key_names = [k.name for k in ssh_keys]
        print(f"\n[ssh] {len(ssh_keys)} keys: {', '.join(key_names)}")
        # Ensure .ssh dir on remote
        _ssh_exec(target, "mkdir -p ~/.ssh && chmod 700 ~/.ssh", dry_run)
        for key in ssh_keys:
            _scp_file(key, f"~/.ssh/{key.name}", target, dry_run)
        # Fix permissions
        _ssh_exec(target, "chmod 600 ~/.ssh/id_ed25519 2>/dev/null; chmod 644 ~/.ssh/id_ed25519.pub 2>/dev/null", dry_run)
    else:
        print("\n[ssh] no ed25519 keys found")

    # --- 3. Git config ---
    gitcfg = read_gitconfig()
    if gitcfg:
        print(f"\n[git] syncing .gitconfig")
        if dry_run:
            print("  (dry-run: would write to ~/.gitconfig on target)")
        else:
            cmd = ["ssh", target, "cat > ~/.gitconfig"]
            result = subprocess.run(cmd, input=gitcfg, capture_output=True, text=True)
            if result.returncode != 0:
                print(f"  ERROR: {result.stderr.strip()}", file=sys.stderr)
                sys.exit(1)
            print("  ✓ written to ~/.gitconfig")
    else:
        print("\n[git] no .gitconfig found")

    print(f"\n=== sync complete ===")


def main() -> None:
    parser = argparse.ArgumentParser(description="Sync secrets to a new host")
    parser.add_argument("--target", required=True, help="SSH target (user@host)")
    parser.add_argument("--dry-run", action="store_true", help="Show what would be done")
    args = parser.parse_args()

    if not args.target:
        parser.error("--target is required")

    sync(args.target, dry_run=args.dry_run)


if __name__ == "__main__":
    main()

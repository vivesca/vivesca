#!/usr/bin/env python3
"""secrets-sync — Sync API keys and secrets from this gemmule to a target host.

Reads ~/.env.fly (export KEY=VALUE lines), syncs SSH keys
(~/.ssh/id_ed25519*), and ~/.gitconfig to a remote host via SSH/SCP.

Usage:
    secrets-sync --target <ssh-host> [--dry-run]

Never logs secret values — only key names.
"""
from __future__ import annotations

import argparse
import re
import subprocess
import sys
from pathlib import Path

# Paths
ENV_FLY = Path.home() / ".env.fly"
SSH_DIR = Path.home() / ".ssh"
GITCONFIG = Path.home() / ".gitconfig"

# Patterns
EXPORT_RE = re.compile(r'^export\s+([A-Za-z_][A-Za-z0-9_]*)=(.*)$')


def parse_env_file(path: Path) -> list[tuple[str, str]]:
    """Parse export KEY=VALUE lines from an env file.

    Returns list of (key, value) pairs. Skips blank lines and comments.
    """
    pairs: list[tuple[str, str]] = []
    if not path.exists():
        return pairs
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        m = EXPORT_RE.match(line)
        if m:
            key, val = m.group(1), m.group(2)
            # Strip surrounding quotes if present
            if (val.startswith('"') and val.endswith('"')) or (
                val.startswith("'") and val.endswith("'")
            ):
                val = val[1:-1]
            pairs.append((key, val))
    return pairs


def ssh_key_files() -> list[Path]:
    """Return list of id_ed25519 key files that exist."""
    files: list[Path] = []
    for pattern in ["id_ed25519", "id_ed25519.pub"]:
        p = SSH_DIR / pattern
        if p.exists():
            files.append(p)
    return files


def run_remote(cmd: list[str], dry_run: bool = False) -> subprocess.CompletedProcess:
    """Run a command. If dry_run, print and return a mock success."""
    if dry_run:
        print(f"  [dry-run] {' '.join(cmd)}")
        return subprocess.CompletedProcess(cmd, 0, "", "")
    return subprocess.run(cmd, capture_output=True, text=True)


def sync_env(target: str, pairs: list[tuple[str, str]], dry_run: bool) -> bool:
    """Sync env vars to remote ~/.env.fly via SSH. Returns True on success."""
    if not pairs:
        print("No env vars found in ~/.env.fly")
        return True

    key_names = [k for k, _ in pairs]
    print(f"Syncing {len(pairs)} env vars: {', '.join(key_names)}")

    # Build remote file content
    lines = [f"export {k}=\"{v}\"" for k, v in pairs]
    content = "\n".join(lines) + "\n"

    # Use ssh + cat to write remotely (avoids temp file on remote)
    ssh_cmd = ["ssh", target, "cat > ~/.env.fly"]
    if dry_run:
        print(f"  [dry-run] ssh {target} 'cat > ~/.env.fly'")
        print(f"  [dry-run] would write {len(lines)} lines (keys: {', '.join(key_names)})")
        return True

    result = subprocess.run(
        ["ssh", target, "cat > ~/.env.fly"],
        input=content,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(f"  ERROR writing env: {result.stderr.strip()}", file=sys.stderr)
        return False
    print(f"  OK: wrote {len(lines)} env vars to {target}:~/.env.fly")
    return True


def sync_ssh_keys(target: str, key_files: list[Path], dry_run: bool) -> bool:
    """Sync SSH key files to remote via scp. Returns True on success."""
    if not key_files:
        print("No SSH key files (id_ed25519*) found")
        return True

    names = [f.name for f in key_files]
    print(f"Syncing SSH keys: {', '.join(names)}")

    if dry_run:
        for f in key_files:
            print(f"  [dry-run] scp {f} {target}:~/.ssh/{f.name}")
        return True

    # Ensure remote .ssh dir exists
    run_remote(["ssh", target, "mkdir -p ~/.ssh && chmod 700 ~/.ssh"])

    for f in key_files:
        result = subprocess.run(
            ["scp", str(f), f"{target}:~/.ssh/{f.name}"],
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            print(f"  ERROR copying {f.name}: {result.stderr.strip()}", file=sys.stderr)
            return False
        print(f"  OK: {f.name} -> {target}:~/.ssh/{f.name}")

    # Set permissions on private key
    for f in key_files:
        if not f.name.endswith(".pub"):
            run_remote(["ssh", target, f"chmod 600 ~/.ssh/{f.name}"])
    return True


def sync_gitconfig(target: str, dry_run: bool) -> bool:
    """Sync ~/.gitconfig to remote via SSH. Returns True on success."""
    if not GITCONFIG.exists():
        print("No ~/.gitconfig found")
        return True

    print("Syncing ~/.gitconfig")

    if dry_run:
        print(f"  [dry-run] scp {GITCONFIG} {target}:~/.gitconfig")
        return True

    content = GITCONFIG.read_text()
    result = subprocess.run(
        ["ssh", target, "cat > ~/.gitconfig"],
        input=content,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(f"  ERROR writing gitconfig: {result.stderr.strip()}", file=sys.stderr)
        return False
    print(f"  OK: ~/.gitconfig -> {target}:~/.gitconfig")
    return True


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Sync secrets from this gemmule to a target host."
    )
    parser.add_argument(
        "--target", required=True, help="SSH target (e.g. user@host)"
    )
    parser.add_argument(
        "--dry-run", action="store_true", help="Print actions without executing"
    )
    args = parser.parse_args(argv)

    target = args.target
    dry_run = args.dry_run
    ok = True

    print(f"=== secrets-sync → {target} {'(dry-run)' if dry_run else ''}===")

    # 1. Env vars
    pairs = parse_env_file(ENV_FLY)
    if not sync_env(target, pairs, dry_run):
        ok = False

    # 2. SSH keys
    keys = ssh_key_files()
    if not sync_ssh_keys(target, keys, dry_run):
        ok = False

    # 3. Git config
    if not sync_gitconfig(target, dry_run):
        ok = False

    if ok:
        print("=== sync complete ===")
    else:
        print("=== sync completed with errors ===", file=sys.stderr)
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main())

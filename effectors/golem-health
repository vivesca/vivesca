# ///
"""
Health check for golem providers.

Sources ~/.env.fly, then runs a minimal golem invocation for each provider.
Measures exit code, output presence, and latency.

Usage:
    golem-health                  # Check all providers
    golem-health --provider zhipu # Check specific provider
    golem-health --json           # Output as JSON
"""

import argparse
import json
import os
import subprocess
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Optional

ENV_FILE = Path.home() / ".env.fly"

PROVIDERS = {
    "zhipu": {
        "model": "GLM-5.1",
        "key_var": "ZHIPU_API_KEY",
    },
    "infini": {
        "model": "glm-5",
        "key_var": "INFINI_API_KEY",
    },
    "volcano": {
        "model": "ark-code-latest",
        "key_var": "VOLCANO_API_KEY",
    },
}


@dataclass
class HealthResult:
    provider: str
    status: str  # "OK", "FAIL", "ERROR"
    latency_ms: int
    model: str
    exit_code: int
    has_output: bool
    error: Optional[str] = None


def source_env_file(env_file: Path) -> dict[str, str]:
    """Source a shell env file and return the environment variables."""
    if not env_file.exists():
        return {}

    # Use bash to source the file and print env
    cmd = f'source "{env_file}" && env'
    result = subprocess.run(
        ["bash", "-c", cmd],
        capture_output=True,
        text=True,
        timeout=10,
    )

    env = {}
    for line in result.stdout.splitlines():
        if "=" in line:
            key, _, value = line.partition("=")
            env[key] = value
    return env


def check_provider(
    provider: str,
    env: dict[str, str],
    golem_path: Path,
) -> HealthResult:
    """Run health check for a single provider."""
    if provider not in PROVIDERS:
        return HealthResult(
            provider=provider,
            status="ERROR",
            latency_ms=0,
            model="unknown",
            exit_code=1,
            has_output=False,
            error=f"Unknown provider: {provider}",
        )

    config = PROVIDERS[provider]
    model = config["model"]
    key_var = config["key_var"]

    # Check if API key is available
    if key_var not in env:
        return HealthResult(
            provider=provider,
            status="FAIL",
            latency_ms=0,
            model=model,
            exit_code=1,
            has_output=False,
            error=f"{key_var} not set",
        )

    # Run golem with minimal invocation
    start = time.perf_counter()
    try:
        result = subprocess.run(
            [str(golem_path), "--provider", provider, "--max-turns", "1", "Say hello"],
            capture_output=True,
            text=True,
            timeout=60,
            env=env,
        )
        latency_ms = int((time.perf_counter() - start) * 1000)

        has_output = bool(result.stdout.strip())
        status = "OK" if result.returncode == 0 and has_output else "FAIL"
        error = None
        if result.returncode != 0:
            error = result.stderr.strip()[:100] if result.stderr else "non-zero exit"
        elif not has_output:
            error = "no output"

        return HealthResult(
            provider=provider,
            status=status,
            latency_ms=latency_ms,
            model=model,
            exit_code=result.returncode,
            has_output=has_output,
            error=error,
        )
    except subprocess.TimeoutExpired:
        latency_ms = int((time.perf_counter() - start) * 1000)
        return HealthResult(
            provider=provider,
            status="FAIL",
            latency_ms=latency_ms,
            model=model,
            exit_code=-1,
            has_output=False,
            error="timeout",
        )
    except Exception as e:
        latency_ms = int((time.perf_counter() - start) * 1000)
        return HealthResult(
            provider=provider,
            status="ERROR",
            latency_ms=latency_ms,
            model=model,
            exit_code=-1,
            has_output=False,
            error=str(e)[:100],
        )


def print_table(results: list[HealthResult]) -> None:
    """Print results as a formatted table."""
    header = f"{'Provider':<10} | {'Status':<6} | {'Latency':>10} | {'Model':<18}"
    separator = "-" * 52
    print(header)
    print(separator)

    for r in results:
        latency = f"{r.latency_ms}ms" if r.latency_ms > 0 else "-"
        row = f"{r.provider:<10} | {r.status:<6} | {latency:>10} | {r.model:<18}"
        print(row)
        if r.error:
            print(f"           └─ {r.error}")


def print_json(results: list[HealthResult]) -> None:
    """Print results as JSON."""
    data = [
        {
            "provider": r.provider,
            "status": r.status,
            "latency_ms": r.latency_ms,
            "model": r.model,
            "exit_code": r.exit_code,
            "has_output": r.has_output,
            "error": r.error,
        }
        for r in results
    ]
    print(json.dumps(data, indent=2))


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Health check for golem providers."
    )
    parser.add_argument(
        "--provider",
        choices=list(PROVIDERS.keys()),
        help="Check only this provider (default: all)",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Output as JSON",
    )
    args = parser.parse_args(argv)

    # Find golem
    golem_path = Path(__file__).parent / "golem"
    if not golem_path.exists():
        print(f"Error: golem not found at {golem_path}", file=sys.stderr)
        return 1

    # Source env file
    env = os.environ.copy()
    if ENV_FILE.exists():
        sourced = source_env_file(ENV_FILE)
        env.update(sourced)

    # Determine providers to check
    providers_to_check = (
        [args.provider] if args.provider else list(PROVIDERS.keys())
    )

    # Run health checks
    results: list[HealthResult] = []
    for provider in providers_to_check:
        print(f"Checking {provider}...", file=sys.stderr)
        result = check_provider(provider, env, golem_path)
        results.append(result)

    # Output results
    if args.json:
        print_json(results)
    else:
        print_table(results)

    # Return non-zero if any failed
    if any(r.status != "OK" for r in results):
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())

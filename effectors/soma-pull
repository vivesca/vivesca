#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Pull all vivesca repos from GitHub. Run on iMac every 15 mins via LaunchAgent.

Repos are pulled quietly. Failures logged but don't block other repos.
Safe to run concurrently — git pull uses fast-forward only.

Usage:
    soma-pull              # Pull all repos
    soma-pull --help       # Show this help
"""

import subprocess
import sys
from datetime import datetime
from pathlib import Path

REPOS = [
    Path.home() / "germline",
    Path.home() / "epigenome",
    Path.home() / "code" / "gemmule",
    Path.home() / "code" / "oghma",
]

LOG = Path.home() / "tmp" / "soma-pull.log"


def _git(repo: Path, *args: str, timeout: int = 30) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", *args],
        cwd=repo,
        capture_output=True,
        text=True,
        timeout=timeout,
    )


def pull(repo: Path) -> tuple[str, bool]:
    """Pull with --rebase --autostash so daemon writes don't block sync.

    History: prior --ff-only version silently failed for weeks when daemons left
    uncommitted writes in Tonus.md / loci/antisera/* (Mac germline went 116 commits
    behind on 2026-04-28). Two-step stash-then-pull races with continuous writers
    because the stash + pull aren't atomic. ``--rebase --autostash`` is git's
    built-in atomic version of that pattern.

    Safety: if local has commits ahead of origin (forked history), refuse and log
    rather than silently rebase. Per genome rule: empty/forked merge-base → STOP,
    investigate. We catch this BEFORE the pull so no rebase ever runs on forked
    state.
    """
    if not (repo / ".git").exists():
        return f"{repo.name}: not a git repo", False
    try:
        # Forked-history guard. Determine current branch + upstream, count divergence.
        branch_proc = _git(repo, "rev-parse", "--abbrev-ref", "HEAD", timeout=10)
        if branch_proc.returncode != 0:
            return f"{repo.name}: ERROR cannot determine branch", False
        branch = branch_proc.stdout.strip()

        # Fetch first so divergence count is accurate against latest remote.
        fetch_proc = _git(repo, "fetch", "--quiet", "origin", branch, timeout=30)
        if fetch_proc.returncode != 0:
            return f"{repo.name}: FAIL fetch: {fetch_proc.stderr.strip()[:80]}", False

        ahead_proc = _git(
            repo,
            "rev-list",
            "--left-right",
            "--count",
            f"origin/{branch}...HEAD",
            timeout=10,
        )
        if ahead_proc.returncode != 0:
            return f"{repo.name}: ERROR rev-list: {ahead_proc.stderr.strip()[:80]}", False
        try:
            behind_str, ahead_str = ahead_proc.stdout.strip().split()
            ahead = int(ahead_str)
        except (ValueError, IndexError):
            return f"{repo.name}: ERROR parsing rev-list output", False

        if ahead > 0:
            # Local has commits remote doesn't — refuse to rebase blindly.
            return (
                f"{repo.name}: SKIP {ahead} local commits ahead — manual merge needed",
                False,
            )

        result = _git(repo, "pull", "--rebase", "--autostash", "--quiet")
        if result.returncode == 0:
            changed = "Already up to date" not in result.stdout
            status = "updated" if changed else "ok"
            return f"{repo.name}: {status}", True
        return f"{repo.name}: FAIL {result.stderr.strip()[:100]}", False
    except subprocess.TimeoutExpired:
        return f"{repo.name}: TIMEOUT", False
    except Exception as e:
        return f"{repo.name}: ERROR {e}", False


def main():
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    results = [pull(r) for r in REPOS]

    failures = [msg for msg, ok in results if not ok]
    lines = [f"[{timestamp}] " + " | ".join(msg for msg, _ in results)]

    LOG.parent.mkdir(parents=True, exist_ok=True)
    with open(LOG, "a") as f:
        f.write(lines[0] + "\n")

    # Keep log under 500 lines
    if LOG.exists():
        all_lines = LOG.read_text().splitlines()
        if len(all_lines) > 500:
            LOG.write_text("\n".join(all_lines[-251:]) + "\n")

    if failures:
        print(f"WARN: {len(failures)} repos failed", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        sys.exit(0)
    main()

#!/usr/bin/env -S uv run --script --python 3.13
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""
methylation-review — weekly crystallization review for the vivesca organism.

Gathers:
  1. Proposals from the methylation effector (repairs & gaps)
  2. Recent observations from methylation.jsonl (crystallize, structural, architectural)
  3. Synthesizes into a single review for human judgment.
"""

import argparse
import json
import subprocess
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

HOME = Path.home()
GERMLINE = HOME / "germline"
METHYLATION_JSONL = GERMLINE / "methylation.jsonl"
METHYLATION_EFFECTOR = GERMLINE / "effectors" / "methylation"
TMP_DIR = HOME / "tmp"
CHANNEL = GERMLINE / "effectors" / "channel"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def log(msg: str):
    print(f"[*] {msg}", flush=True)

def run_cmd(cmd: list[str], timeout: int = 180) -> tuple[int, str, str]:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.returncode, r.stdout, r.stderr
    except Exception as e:
        return -1, "", str(e)

# ---------------------------------------------------------------------------
# Data Gathering
# ---------------------------------------------------------------------------

def gather_effector_proposals() -> str:
    log("Running methylation effector...")
    code, out, err = run_cmd([str(METHYLATION_EFFECTOR)])
    if code != 0:
        log(f"WARN: methylation effector failed: {err}")
    
    date_str = datetime.now().strftime("%Y-%m-%d")
    prop_path = TMP_DIR / f"methylation-proposal-{date_str}.md"
    hyb_path = TMP_DIR / f"hybridization-proposals-{date_str}.md"
    
    content = []
    if prop_path.exists():
        content.append(prop_path.read_text())
    if hyb_path.exists():
        content.append(hyb_path.read_text())
        
    return "\n\n".join(content)

def gather_jsonl_observations(days: int = 7) -> str:
    if not METHYLATION_JSONL.exists():
        return "(no methylation.jsonl found)"
    
    cutoff = datetime.now(timezone.utc) - timedelta(days=days)
    observations = []
    
    try:
        lines = METHYLATION_JSONL.read_text().splitlines()
        for line in lines:
            if not line.strip(): continue
            try:
                ev = json.loads(line)
                ts_str = ev.get("ts", "")
                # Handle ISO format with or without 'Z'
                if ts_str.endswith("Z"):
                    ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
                else:
                    ts = datetime.fromisoformat(ts_str)
                
                if ts.tzinfo is None:
                    ts = ts.replace(tzinfo=timezone.utc)
                
                if ts >= cutoff:
                    observations.append(line)
            except Exception:
                continue
    except Exception as e:
        return f"(error reading jsonl: {e})"
        
    return "\n".join(observations) if observations else "(no recent observations)"

# ---------------------------------------------------------------------------
# Synthesis
# ---------------------------------------------------------------------------

REVIEW_PROMPT = """\
You are the organism's weekly methylation reviewer. Read the following raw proposals and observations. 
Create a 'Weekly Methylation Review' document that groups them into:

1.  **Mechanical (Safe to apply):** Naming fixes, simple probes, invariants, sensors.
2.  **Architectural (Human judgment needed):** New subsystems, systemic changes.
3.  **Stale References:** Broken symlinks, old path references, dead code.

Include a 'Decision Required' section for the architectural items.
Format: markdown.

--- Raw Proposals ---
{proposals}

--- Recent JSONL Observations ---
{observations}
"""

def synthesize_review(proposals: str, observations: str) -> str:
    log("Synthesizing review via Opus...")
    prompt = REVIEW_PROMPT.format(proposals=proposals, observations=observations)
    
    code, out, err = run_cmd([str(CHANNEL), "opus", "-p", prompt])
    if code != 0:
        log(f"ERROR: synthesis failed: {err}")
        return f"Error: Synthesis failed.\n\nRaw Proposals:\n{proposals}\n\nRaw Observations:\n{observations}"
    
    return out.strip()

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Weekly crystallization review for the vivesca organism."
    )
    parser.parse_args()

    date_str = datetime.now().strftime("%Y-%m-%d")
    review_path = TMP_DIR / f"methylation-review-{date_str}.md"

    proposals = gather_effector_proposals()
    observations = gather_jsonl_observations()

    review_content = synthesize_review(proposals, observations)

    review_path.write_text(review_content)
    log(f"Review written to {review_path}")
    print(f"\nSaved to {review_path}")
    print("\n--- Summary ---\n")
    # Print the first part of the review for immediate feedback
    print("\n".join(review_content.splitlines()[:20]))

if __name__ == "__main__":
    main()

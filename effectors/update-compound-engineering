#!/usr/bin/env bash
# Auto-update compound-engineering plugin for OpenCode and Codex

set -e

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: update-compound-engineering"
    echo ""
    echo "Update the compound-engineering plugin for:"
    echo "  - OpenCode (~/.config/opencode/)"
    echo "  - Codex    (~/.codex/)"
    echo ""
    echo "Requires: bunx or npx"
    exit 0
fi

# Use bunx if available, fall back to npx
if command -v bunx &>/dev/null; then
    RUNNER=bunx
elif command -v npx &>/dev/null; then
    RUNNER=npx
else
    echo "Error: neither bunx nor npx found. Install bun or node." >&2
    exit 1
fi

echo "🔄 Updating compound-engineering plugin..."
echo ""

echo "📦 Updating OpenCode installation..."
$RUNNER @every-env/compound-plugin install compound-engineering --to opencode

echo ""
echo "📦 Updating Codex installation..."
$RUNNER @every-env/compound-plugin install compound-engineering --to codex

echo ""
echo "✅ Update complete!"
echo ""
echo "Updated locations:"
echo "  - OpenCode: ~/.config/opencode/"
echo "  - Codex:    ~/.codex/"

#!/usr/bin/env python3
"""Universal LLM CLI for vivesca. Routes prompts to a configured backend.

Usage:
    synthase "classify this email"
    echo "compress this" | synthase
    synthase --model sonnet "review this code"
    synthase --backend openrouter "translate this"
"""

import argparse
import json
import os
import subprocess
import sys
import urllib.request

CONFIG_PATH = os.path.expanduser("~/.config/vivesca/config.yaml")

OPENROUTER_MODEL_MAP = {
    "haiku": "anthropic/claude-haiku-4-5-20251001",
    "sonnet": "anthropic/claude-sonnet-4-6",
    "opus": "anthropic/claude-opus-4-6",
}


def _load_config() -> dict:
    try:
        import yaml

        with open(CONFIG_PATH) as f:
            data = yaml.safe_load(f) or {}
        return data.get("llm", {})
    except FileNotFoundError:
        return {}
    except Exception as e:
        print(f"Warning: could not read config: {e}", file=sys.stderr)
        return {}


def _backend_channel(prompt: str, model: str, timeout: int) -> str:
    channel = _which("channel")
    if not channel:
        raise RuntimeError("channel not found on PATH")
    result = subprocess.run(
        [channel, model, "-p", prompt],
        capture_output=True,
        text=True,
        timeout=timeout,
    )
    output = result.stdout.strip()
    if not output:
        err = result.stderr.strip() or "no output"
        raise RuntimeError(f"channel error: {err}")
    return output


def _backend_openrouter(prompt: str, model: str, api_key_env: str, timeout: int) -> str:
    api_key = os.environ.get(api_key_env, "")
    if not api_key:
        raise RuntimeError(f"Environment variable {api_key_env} not set")
    or_model = OPENROUTER_MODEL_MAP.get(model, model)
    payload = json.dumps(
        {
            "model": or_model,
            "messages": [{"role": "user", "content": prompt}],
        }
    ).encode()
    req = urllib.request.Request(
        "https://openrouter.ai/api/v1/chat/completions",
        data=payload,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        data = json.loads(resp.read())
    return data["choices"][0]["message"]["content"].strip()


def _backend_anthropic(prompt: str, model: str, timeout: int) -> str:
    try:
        import anthropic
    except ImportError:
        raise RuntimeError("anthropic package not installed")
    or_model = OPENROUTER_MODEL_MAP.get(model, model)
    client = anthropic.Anthropic()
    response = client.messages.create(
        model=or_model,
        max_tokens=1024,
        messages=[{"role": "user", "content": prompt}],
    )
    return response.content[0].text.strip()


def _which(name: str) -> str | None:
    import shutil

    return shutil.which(name)


def main():
    parser = argparse.ArgumentParser(
        description="Universal LLM CLI — routes prompts to configured backend."
    )
    parser.add_argument("prompt", nargs="?", help="Prompt text (or pipe via stdin)")
    parser.add_argument("--model", help="Model override (haiku/sonnet/opus or full id)")
    parser.add_argument("--backend", help="Backend override (channel/openrouter/anthropic)")
    parser.add_argument("--timeout", type=int, default=60, help="Timeout in seconds")
    args = parser.parse_args()

    # Resolve prompt from arg or stdin
    if args.prompt:
        prompt = args.prompt
    elif not sys.stdin.isatty():
        prompt = sys.stdin.read().strip()
    else:
        print("Error: provide a prompt as argument or pipe via stdin", file=sys.stderr)
        sys.exit(1)

    if not prompt:
        print("Error: empty prompt", file=sys.stderr)
        sys.exit(1)

    cfg = _load_config()
    backend = args.backend or cfg.get("backend", "openrouter")
    model = args.model or cfg.get("default_model", "haiku")
    api_key_env = cfg.get("api_key_env", "OPENROUTER_API_KEY")

    try:
        if backend == "channel":
            output = _backend_channel(prompt, model, args.timeout)
        elif backend == "openrouter":
            output = _backend_openrouter(prompt, model, api_key_env, args.timeout)
        elif backend == "anthropic":
            output = _backend_anthropic(prompt, model, args.timeout)
        else:
            print(f"Error: unknown backend '{backend}'", file=sys.stderr)
            sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    print(output)


if __name__ == "__main__":
    main()

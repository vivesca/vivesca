#!/usr/bin/env python3
"""soma-watchdog — system health monitor. Runs under supervisor.

Every 60 seconds:
1. Disk space: auto-clean if <2GB, kill golems if <1GB
2. Log rotation: rotate files >10MB
3. Runaway processes: kill golem processes >30min or >2GB RSS
4. Root filesystem: clean /tmp if <500MB free
"""
from __future__ import annotations

import json
import os
import shutil
import signal
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

POLL = 60  # seconds
HOME = Path.home()
GERMLINE = HOME / "germline"
LOG = HOME / "tmp" / "soma-watchdog.log"

# Observability paths
JSONL_PATH = HOME / "epigenome" / "chromatin" / "telemetry" / "soma-resources.jsonl"
ALERT_STAMP = HOME / "tmp" / "soma-alert-last.txt"

# Thresholds
DISK_WARN_GB = 2.0
DISK_CRIT_GB = 1.0
ROOT_WARN_MB = 500
LOG_MAX_MB = 10
GOLEM_MAX_SECONDS = 2400  # 40 min
GOLEM_MAX_RSS_MB = 2048   # 2GB


def log(msg: str):
    LOG.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    with open(LOG, "a") as f:
        f.write(line + "\n")


def free_gb(path: Path) -> float:
    try:
        u = shutil.disk_usage(str(path))
        return u.free / (1024**3)
    except Exception:
        return 999.0


def free_mb(path: Path) -> float:
    return free_gb(path) * 1024


def clean_temps():
    """Remove known temp directories."""
    cleaned = 0
    for d in [
        GERMLINE / "pytest-of-terry",
        Path("/tmp/pytest-of-terry"),
        Path("/tmp/pytest-vivesca"),
    ]:
        if d.exists():
            shutil.rmtree(d, ignore_errors=True)
            cleaned += 1

    # Claude Code session temps
    for d in Path("/tmp").glob("claude-*"):
        if d.is_dir():
            shutil.rmtree(d, ignore_errors=True)
            cleaned += 1

    # Python cache in germline
    subprocess.run(
        f"find {GERMLINE} -name __pycache__ -type d -exec rm -rf {{}} + 2>/dev/null",
        shell=True, timeout=30
    )

    return cleaned


def rotate_log(path: Path, max_mb: float = LOG_MAX_MB):
    """Rotate log file if too large."""
    if not path.exists():
        return
    size_mb = path.stat().st_size / (1024 * 1024)
    if size_mb > max_mb:
        rotated = path.with_suffix(path.suffix + ".1")
        if rotated.exists():
            rotated.unlink()
        path.rename(rotated)
        log(f"Rotated {path.name} ({size_mb:.1f}MB)")


def kill_runaway_golems():
    """Kill golem/claude processes that exceed time or memory limits."""
    killed = 0
    try:
        result = subprocess.run(
            "ps -eo pid,etimes,rss,comm --no-headers | grep claude",
            shell=True, capture_output=True, text=True, timeout=10
        )
        for line in result.stdout.strip().splitlines():
            parts = line.split()
            if len(parts) < 4:
                continue
            pid, elapsed_s, rss_kb = int(parts[0]), int(parts[1]), int(parts[2])
            rss_mb = rss_kb / 1024

            if elapsed_s > GOLEM_MAX_SECONDS:
                os.kill(pid, signal.SIGTERM)
                log(f"KILLED runaway PID {pid}: {elapsed_s}s elapsed (max {GOLEM_MAX_SECONDS})")
                killed += 1
            elif rss_mb > GOLEM_MAX_RSS_MB:
                os.kill(pid, signal.SIGTERM)
                log(f"KILLED memory hog PID {pid}: {rss_mb:.0f}MB RSS (max {GOLEM_MAX_RSS_MB})")
                killed += 1
    except Exception as e:
        log(f"kill_runaway error: {e}")
    return killed


def log_resources():
    """Append one JSON line per tick to JSONL_PATH with system metrics."""
    JSONL_PATH.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().isoformat()

    # cpu_1m from /proc/loadavg field 1
    try:
        loadavg = Path("/proc/loadavg").read_text().split()
        cpu_1m = float(loadavg[0])
    except Exception:
        cpu_1m = 0.0

    # mem_pct from /proc/meminfo MemAvailable/MemTotal
    try:
        mem_total = mem_avail = 0
        for line in Path("/proc/meminfo").read_text().splitlines():
            parts = line.split()
            if parts and parts[0] == "MemTotal:":
                mem_total = int(parts[1])
            elif parts and parts[0] == "MemAvailable:":
                mem_avail = int(parts[1])
        mem_pct = (mem_avail / mem_total * 100.0) if mem_total else 0.0
    except Exception:
        mem_pct = 0.0

    # disk_pct and disk_free_gb from shutil.disk_usage
    try:
        u = shutil.disk_usage(str(HOME))
        disk_pct = u.used / u.total * 100.0
        disk_free_gb = u.free / (1024 ** 3)
    except Exception:
        disk_pct = 0.0
        disk_free_gb = 0.0

    # golem_count from pgrep -c -f golem
    try:
        r = subprocess.run(
            ["pgrep", "-c", "-f", "golem"],
            capture_output=True, text=True, timeout=5,
        )
        golem_count = int(r.stdout.strip()) if r.returncode == 0 else 0
    except Exception:
        golem_count = 0

    record = {
        "ts": ts,
        "cpu_1m": round(cpu_1m, 2),
        "mem_pct": round(mem_pct, 2),
        "disk_pct": round(disk_pct, 2),
        "disk_free_gb": round(disk_free_gb, 2),
        "golem_count": golem_count,
    }
    with open(JSONL_PATH, "a") as f:
        f.write(json.dumps(record) + "\n")


def alert_on_crit(health_json: dict):
    """If any health check has status==crit, alert via deltos. Dedup 15 min."""
    crit_names = [
        name for name, check in health_json.items()
        if isinstance(check, dict) and check.get("status") == "crit"
    ]
    if not crit_names:
        return

    # Dedup: skip if ALERT_STAMP mtime < 15 min ago
    if ALERT_STAMP.exists():
        elapsed = time.time() - ALERT_STAMP.stat().st_mtime
        if elapsed < 15 * 60:
            return

    msg = f"soma-watchdog CRIT: {', '.join(crit_names)}"
    subprocess.run(["deltos", msg], capture_output=True, timeout=10)

    # Write stamp after sending
    ALERT_STAMP.parent.mkdir(parents=True, exist_ok=True)
    ALERT_STAMP.write_text(datetime.now().isoformat())


def check_cycle():
    """One watchdog cycle. Returns health dict."""
    health: dict = {}
    vol_free = free_gb(HOME)
    root_free = free_mb(Path("/tmp"))

    # Disk: volume
    if vol_free < DISK_WARN_GB:
        cleaned = clean_temps()
        vol_after = free_gb(HOME)
        log(f"DISK WARN: volume {vol_free:.1f}GB → {vol_after:.1f}GB (cleaned {cleaned})")

        if vol_after < DISK_CRIT_GB:
            health["disk_volume"] = {"status": "crit", "free_gb": vol_after}
            # Emergency: kill all golems to stop disk writes
            subprocess.run("pkill -f 'claude.*--print' 2>/dev/null", shell=True, timeout=300)
            log(f"DISK CRITICAL: killed all golems. Volume at {vol_after:.1f}GB")
        else:
            health["disk_volume"] = {"status": "warn", "free_gb": vol_after}
    else:
        health["disk_volume"] = {"status": "ok", "free_gb": vol_free}

    # Disk: root
    if root_free < ROOT_WARN_MB:
        health["root_fs"] = {"status": "warn", "free_mb": root_free}
        clean_temps()
        root_after = free_mb(Path("/tmp"))
        log(f"ROOT WARN: /tmp {root_free:.0f}MB → {root_after:.0f}MB")
    else:
        health["root_fs"] = {"status": "ok", "free_mb": root_free}

    # Log rotation
    for logfile in [
        HOME / "tmp" / "golem-daemon-supervisor.log",
        HOME / "tmp" / "mcp-server.log",
        HOME / "tmp" / "golem-reviewer.log",
        HOME / "tmp" / "supervisord.log",
        HOME / ".local" / "share" / "vivesca" / "golem-daemon.log",
        HOME / ".local" / "share" / "vivesca" / "golem.jsonl",
        HOME / ".local" / "share" / "vivesca" / "golem-reviewer.log",
        LOG,
    ]:
        rotate_log(logfile)

    # Runaway processes
    kill_runaway_golems()

    return health


def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        return 0
    log("Watchdog started")
    try:
        while True:
            health = check_cycle()
            log_resources()
            alert_on_crit(health)
            time.sleep(POLL)
    except KeyboardInterrupt:
        log("Watchdog stopped")
    return 0


if __name__ == "__main__":
    sys.exit(main())

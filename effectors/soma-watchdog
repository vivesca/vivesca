#!/usr/bin/env python3
"""soma-watchdog — system health monitor. Runs under supervisor.

Every 60 seconds:
1. Disk space: auto-clean if <2GB, kill ribosomes if <1GB
2. Log rotation: rotate files >10MB (size-based, Fly native handles 30-day history)
3. Runaway processes: kill ribosome processes >30min or >2GB RSS
4. Root filesystem: clean /tmp if <500MB free
5. Tailscale: verify connected, warn 30 days before key expiry
"""

from __future__ import annotations

import json
import os
import shutil
import signal
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

POLL = 60  # seconds
HOME = Path(os.environ.get("HOME", Path.home()))
GERMLINE = HOME / "germline"
LOG = HOME / "tmp" / "soma-watchdog.log"

ALERT_STAMP = HOME / "tmp" / "soma-alert-last.txt"

# Thresholds
DISK_WARN_GB = 2.0
DISK_CRIT_GB = 1.0
ROOT_WARN_MB = 500
LOG_MAX_MB = 10
RIBOSOME_MAX_SECONDS = 2400  # 40 min
RIBOSOME_MAX_RSS_MB = 2048  # 2GB
CACHE_MAX_MB = 300  # per-cache budget
TS_PING_FAILURES = 0  # consecutive ping failures
TS_PING_FAIL_THRESHOLD = 3  # restart after N consecutive failures
TS_RESTART_COOLDOWN = 300  # seconds between restart attempts
_ts_last_restart = 0.0


def log(msg: str):
    LOG.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    with open(LOG, "a") as f:
        f.write(line + "\n")


def free_gb(path: Path) -> float:
    try:
        u = shutil.disk_usage(str(path))
        return u.free / (1024**3)
    except Exception:
        return 999.0


def free_mb(path: Path) -> float:
    return free_gb(path) * 1024


def clean_temps():
    """Remove known temp directories."""
    cleaned = 0
    for d in [
        GERMLINE / "pytest-of-terry",
        Path("/tmp/pytest-of-terry"),
        Path("/tmp/pytest-vivesca"),
    ]:
        if d.exists():
            shutil.rmtree(d, ignore_errors=True)
            cleaned += 1

    # Claude Code session temps
    for d in Path("/tmp").glob("claude-*"):
        if d.is_dir():
            shutil.rmtree(d, ignore_errors=True)
            cleaned += 1

    # Python cache in germline
    subprocess.run(
        f"find {GERMLINE} -name __pycache__ -type d -exec rm -rf {{}} + 2>/dev/null",
        shell=True,
        timeout=30,
    )

    return cleaned


def _dir_size_mb(path: Path) -> float:
    """Get directory size in MB using du -sb (fast, with timeout)."""
    try:
        r = subprocess.run(
            ["du", "-sb", str(path)],
            capture_output=True,
            text=True,
            timeout=15,
        )
        if r.returncode == 0:
            return int(r.stdout.split()[0]) / (1024 * 1024)
    except Exception:
        pass
    return 0.0


def prune_caches():
    """Proactive cache pruning — runs every cycle, not just on disk pressure.

    Uses du with timeout instead of Python rglob (which hangs on stressed I/O).
    Skips playwright (browser binaries needed at runtime) and .local/share/uv
    (Python installs, needed at runtime).
    """
    pruned = 0

    # (relative_path, budget_mb)
    # path is relative to HOME. Budgets per-cache based on regeneration cost.
    #
    # DO NOT add ~/.local/share/claude or ~/.local/share/opencode here.
    # Those are INSTALL directories (claude versions/X.Y.Z ships the Node
    # bundle there; opencode state lives there too), NOT caches. On 2026-04-10
    # the watchdog wholesale-rmtree'd ~/.local/share/claude when the Node
    # bundle exceeded 400MB, leaving a dangling ~/.local/bin/claude symlink
    # and breaking every new CC session on soma. Claude Code session state
    # lives at ~/.claude/, which is never pruned.
    #
    # DO NOT add ~/.cache/pre-commit here either. It holds live hook
    # environments (Go builds for gitleaks, Python venvs for ruff/ty, etc.)
    # that are actively used during every `git commit`. On 2026-04-10 the
    # watchdog pruned it four times in five minutes under a 300MB budget
    # while commits were in flight, each prune killing the in-progress
    # hook install and making `git commit`/`git push` fail in a loop.
    # Use `pre-commit gc` (tool-native) if cleanup is ever needed.
    targets = [
        (".cache/uv", 300),
        (".cache/pip", 200),
        (".cache/go-build", 200),
        (".cache/node-gyp", 200),
        (".npm", 500),  # npm global cache — regrows on install
        (".cargo/registry", 400),  # cargo package cache — regrows from Cargo.toml
    ]

    for rel_path, budget_mb in targets:
        cache_dir = HOME / rel_path
        if not cache_dir.exists():
            continue
        size_mb = _dir_size_mb(cache_dir)
        if size_mb > budget_mb:
            shutil.rmtree(cache_dir, ignore_errors=True)
            log(f"Pruned {rel_path} ({size_mb:.0f}MB > {budget_mb}MB)")
            pruned += 1
    return pruned


def rotate_log(path: Path, max_mb: float = LOG_MAX_MB):
    """Rotate log file if too large."""
    if not path.exists():
        return
    size_mb = path.stat().st_size / (1024 * 1024)
    if size_mb > max_mb:
        rotated = path.with_suffix(path.suffix + ".1")
        if rotated.exists():
            rotated.unlink()
        path.rename(rotated)
        log(f"Rotated {path.name} ({size_mb:.1f}MB)")


def kill_runaway_ribosomes():
    """Kill ribosome/claude processes that exceed time or memory limits.

    Skip interactive CC sessions (those attached to a TTY) — only target
    headless ribosomes (tty == '?').
    """
    killed = 0
    try:
        result = subprocess.run(
            "ps -eo pid,etimes,rss,tty,comm --no-headers | grep claude",
            shell=True,
            capture_output=True,
            text=True,
            timeout=10,
        )
        for line in result.stdout.strip().splitlines():
            parts = line.split()
            if len(parts) < 5:
                continue
            pid, elapsed_s, rss_kb = int(parts[0]), int(parts[1]), int(parts[2])
            tty = parts[3]
            rss_mb = rss_kb / 1024

            # Interactive CC sessions have a TTY (pts/N) — never kill those
            if tty != "?":
                continue

            if elapsed_s > RIBOSOME_MAX_SECONDS:
                os.kill(pid, signal.SIGTERM)
                log(
                    f"KILLED runaway PID {pid}: {elapsed_s}s elapsed (max {RIBOSOME_MAX_SECONDS}), tty={tty}"
                )
                killed += 1
            elif rss_mb > RIBOSOME_MAX_RSS_MB:
                os.kill(pid, signal.SIGTERM)
                log(
                    f"KILLED memory hog PID {pid}: {rss_mb:.0f}MB RSS (max {RIBOSOME_MAX_RSS_MB}), tty={tty}"
                )
                killed += 1
    except Exception as e:
        log(f"kill_runaway error: {e}")
    return killed


METRICS_PATH = HOME / ".local" / "share" / "vivesca" / "soma-resources.jsonl"


def log_resources():
    """Append one JSON line per tick to metrics file."""
    try:
        METRICS_PATH.parent.mkdir(parents=True, exist_ok=True)
        ts = datetime.now().isoformat()

        # cpu_1m from /proc/loadavg field 1
        try:
            loadavg = Path("/proc/loadavg").read_text().split()
            cpu_1m = float(loadavg[0])
        except Exception:
            cpu_1m = 0.0

        # mem_pct from /proc/meminfo MemAvailable/MemTotal
        try:
            mem_total = mem_avail = 0.0
            for line in Path("/proc/meminfo").read_text().splitlines():
                parts = line.split()
                if parts and parts[0] == "MemTotal:":
                    mem_total = float(parts[1])
                elif parts and parts[0] == "MemAvailable:":
                    mem_avail = float(parts[1])
            mem_pct = (mem_avail / mem_total * 100.0) if mem_total else 0.0
        except Exception:
            mem_pct = 0.0

        # disk_pct and disk_free_gb from shutil.disk_usage
        try:
            u = shutil.disk_usage(str(HOME))
            disk_pct = u.used / u.total * 100.0
            disk_free_gb = u.free / (1024**3)
        except Exception:
            disk_pct = 0.0
            disk_free_gb = 0.0

        # ribosome_count from pgrep", "-c", "-f", "ribosome
        try:
            r = subprocess.run(
                ["pgrep", "-c", "-f", "ribosome"],
                capture_output=True,
                text=True,
                timeout=5,
            )
            ribosome_count = int(r.stdout.strip()) if r.returncode == 0 else 0
        except Exception:
            ribosome_count = 0

        record = {
            "ts": ts,
            "cpu_1m": round(cpu_1m, 2),
            "mem_pct": round(mem_pct, 2),
            "disk_pct": round(disk_pct, 2),
            "disk_free_gb": round(disk_free_gb, 2),
            "ribosome_count": ribosome_count,
        }
        with open(METRICS_PATH, "a") as f:
            f.write(json.dumps(record) + "\n")
    except Exception as e:
        log(f"log_resources error: {e}")


def alert_on_unhealthy(health_json: dict):
    """Alert via deltos on warn or crit. Dedup: warn 60min, crit 15min.

    Apr 7-10 freeze had warn state for 3 days with no alert — only crit
    triggered alerts, but disk never dropped below 1GB CRIT threshold.
    """
    try:
        crit_names = [
            k for k, v in health_json.items() if isinstance(v, dict) and v.get("status") == "crit"
        ]
        warn_names = [
            k for k, v in health_json.items() if isinstance(v, dict) and v.get("status") == "warn"
        ]
        if not (crit_names or warn_names):
            return

        level = "CRIT" if crit_names else "WARN"
        dedup_seconds = 900 if crit_names else 3600  # warn dedups at 1hr
        names = crit_names or warn_names

        if ALERT_STAMP.exists():
            try:
                elapsed = time.time() - ALERT_STAMP.stat().st_mtime
                if elapsed < dedup_seconds:
                    return
            except OSError:
                pass

        deltos = shutil.which("deltos")
        if not deltos:
            log(f"alert_on_unhealthy: deltos not found on PATH ({level}: {names})")
            return

        message = f"[soma-watchdog] {level}: {', '.join(names)}"
        subprocess.run([deltos, message], timeout=30)

        ALERT_STAMP.parent.mkdir(parents=True, exist_ok=True)
        ALERT_STAMP.write_text(datetime.now().isoformat())
        log(f"alert sent: {message}")
    except Exception as e:
        log(f"alert_on_unhealthy error: {e}")


TS_KEY_WARN_DAYS = 30


def _restart_tailscale() -> bool:
    """Restart tailscaled and re-up. Returns True on success."""
    global _ts_last_restart
    now = time.time()
    if now - _ts_last_restart < TS_RESTART_COOLDOWN:
        log("Tailscale: restart cooldown active, skipping")
        return False
    _ts_last_restart = now
    log("Tailscale: CONNMARK wedge detected — restarting tailscaled")
    # Kill tailscaled (supervisor or fly will not auto-restart it, so we do it manually)
    subprocess.run(["sudo", "pkill", "-x", "tailscaled"], timeout=5)
    time.sleep(2)
    # Start tailscaled
    subprocess.Popen(
        ["sudo", "tailscaled", "--state=/home/vivesca/.tailscale/tailscaled.state"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    time.sleep(3)
    # Bring up with correct flags (no --ssh, netfilter off for Fly)
    r = subprocess.run(
        ["sudo", "tailscale", "up", "--hostname=soma", "--ssh=false", "--netfilter-mode=off"],
        capture_output=True,
        text=True,
        timeout=30,
    )
    if r.returncode == 0:
        log("Tailscale: restart succeeded")
        return True
    log(f"Tailscale: restart failed: {r.stderr.strip()}")
    return False


def check_tailscale() -> dict:
    """Check Tailscale connectivity via real ping, restart on wedge."""
    global TS_PING_FAILURES
    try:
        r = subprocess.run(
            ["tailscale", "status", "--json"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if r.returncode != 0:
            log("Tailscale: status command failed")
            return {"status": "crit", "reason": "status_failed"}

        data = json.loads(r.stdout)
        self_node = data.get("Self", {})

        # Check backend state
        backend = data.get("BackendState", "")
        if backend != "Running":
            log(f"Tailscale: backend state {backend}")
            return {"status": "crit", "reason": f"backend_{backend}"}

        # Real connectivity test: ping self via Tailscale IP
        self_ip = self_node.get("TailscaleIPs", [""])[0]
        if self_ip:
            ping = subprocess.run(
                ["tailscale", "ping", "--timeout=5s", "--c=1", self_ip],
                capture_output=True,
                text=True,
                timeout=10,
            )
            if ping.returncode != 0:
                TS_PING_FAILURES += 1
                log(f"Tailscale: ping failed ({TS_PING_FAILURES}/{TS_PING_FAIL_THRESHOLD})")
                if TS_PING_FAILURES >= TS_PING_FAIL_THRESHOLD:
                    if _restart_tailscale():
                        TS_PING_FAILURES = 0
                        return {"status": "warn", "reason": "restarted_after_wedge"}
                    return {"status": "crit", "reason": "restart_failed"}
                return {"status": "warn", "reason": "ping_failed"}
            else:
                TS_PING_FAILURES = 0

        # Check key expiry
        expiry_str = self_node.get("KeyExpiry", "")
        if expiry_str:
            expiry = datetime.fromisoformat(expiry_str)
            now = datetime.now(expiry.tzinfo)
            days_left = (expiry - now).days
            if days_left < TS_KEY_WARN_DAYS:
                log(f"Tailscale: key expires in {days_left} days")
                return {"status": "warn", "days_until_expiry": days_left}

        return {"status": "ok"}
    except Exception as e:
        log(f"check_tailscale error: {e}")
        return {"status": "warn", "reason": str(e)}


def kill_orphan_build_processes():
    """Kill esbuild/astro processes that outlived their parent ribosome.

    These are child processes spawned by ribosome builds (terryli-hm, etc.)
    that survive after the parent claude process is killed or wall-limited.
    Legitimate builds finish in <10min; anything >15min is orphaned.
    """
    killed = 0
    max_seconds = 900  # 15 minutes
    try:
        result = subprocess.run(
            "ps -eo pid,etimes,tty,args --no-headers"
            " | grep -E 'esbuild --service|astro.*\\.(check|build)'"
            " | grep -v grep",
            shell=True,
            capture_output=True,
            text=True,
            timeout=10,
        )
        for line in result.stdout.strip().splitlines():
            parts = line.split(None, 3)
            if len(parts) < 4:
                continue
            pid, elapsed_s, tty = int(parts[0]), int(parts[1]), parts[2]
            # Only kill detached (no TTY) processes — interactive runs are safe
            if tty != "?" or elapsed_s <= max_seconds:
                continue
            os.kill(pid, signal.SIGKILL)
            log(
                f"KILLED orphan build PID {pid}: {elapsed_s}s elapsed"
                f" (max {max_seconds}), cmd={parts[3][:80]}"
            )
            killed += 1
    except Exception as exc:
        log(f"kill_orphan_build error: {exc}")
    return killed


def check_cycle():
    """One watchdog cycle. Returns health dict."""
    health: dict = {}
    vol_free = free_gb(HOME)
    root_free = free_mb(Path("/tmp"))

    # Disk: volume
    if vol_free < DISK_WARN_GB:
        cleaned = clean_temps()
        vol_after = free_gb(HOME)
        log(f"DISK WARN: volume {vol_free:.1f}GB → {vol_after:.1f}GB (cleaned {cleaned})")

        if vol_after < DISK_CRIT_GB:
            health["disk_volume"] = {"status": "crit", "free_gb": vol_after}
            # Emergency: kill all ribosomes to stop disk writes
            subprocess.run("pkill -f 'claude.*--print' 2>/dev/null", shell=True, timeout=300)
            log(f"DISK CRITICAL: killed all ribosomes. Volume at {vol_after:.1f}GB")
        else:
            health["disk_volume"] = {"status": "warn", "free_gb": vol_after}
    else:
        health["disk_volume"] = {"status": "ok", "free_gb": vol_free}

    # Disk: root
    if root_free < ROOT_WARN_MB:
        health["root_fs"] = {"status": "warn", "free_mb": root_free}
        clean_temps()
        root_after = free_mb(Path("/tmp"))
        log(f"ROOT WARN: /tmp {root_free:.0f}MB → {root_after:.0f}MB")
    else:
        health["root_fs"] = {"status": "ok", "free_mb": root_free}

    # Log/JSONL rotation (size-based; Fly native covers 30-day searchable history)
    for logfile in [
        HOME / "tmp" / "ribosome-daemon-supervisor.log",
        HOME / "tmp" / "mcp-server.log",
        HOME / "tmp" / "ribosome-reviewer.log",
        HOME / "tmp" / "supervisord.log",
        HOME / ".local" / "share" / "vivesca" / "ribosome-daemon.log",
        HOME / ".local" / "share" / "vivesca" / "ribosome-reviewer.log",
        HOME / ".local" / "share" / "vivesca" / "ribosome.jsonl",
        HOME / ".local" / "share" / "vivesca" / "infections.jsonl",
        HOME / ".local" / "share" / "vivesca" / "signal-history.jsonl",
        HOME / ".local" / "share" / "vivesca" / "usage-history.jsonl",
        HOME / ".local" / "share" / "vivesca" / "soma-resources.jsonl",
        HOME / ".local" / "share" / "rheotaxis" / "runs.jsonl",
        HOME / ".local" / "share" / "sortase" / "log.jsonl",
        HOME / ".local" / "share" / "translocon" / "log.jsonl",
        HOME / ".local" / "share" / "translocon" / "metrics.jsonl",
        LOG,
    ]:
        rotate_log(logfile)

    # Proactive cache pruning (every cycle, not just on disk pressure)
    prune_caches()

    # Runaway processes
    kill_runaway_ribosomes()
    kill_orphan_build_processes()

    # Tailscale
    health["tailscale"] = check_tailscale()

    return health


def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        return 0
    log("Watchdog started")
    try:
        while True:
            health = check_cycle()
            log_resources()
            alert_on_unhealthy(health)
            time.sleep(POLL)
    except KeyboardInterrupt:
        log("Watchdog stopped")
    return 0


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env bash
# op-resolve-secrets — resolve 1Password references to ~/.env.resolved
# Run manually or via LaunchAgent. Reads env.op (or env-mac.op), writes flat cache.
set -euo pipefail

BOOTSTRAP="$HOME/.env.bootstrap"
RESOLVED="$HOME/.env.resolved"
RESOLVED_TMP="${RESOLVED}.tmp"

# Determine which env.op to use
if [[ "$(uname)" == "Darwin" ]]; then
    ENV_OP="$HOME/germline/loci/env-mac.op"
else
    ENV_OP="$HOME/germline/loci/env.op"
fi

if [[ ! -f "$BOOTSTRAP" ]]; then
    echo "Missing $BOOTSTRAP" >&2; exit 1
fi
if [[ ! -f "$ENV_OP" ]]; then
    echo "Missing $ENV_OP" >&2; exit 1
fi

# Load bootstrap token
set -a; source "$BOOTSTRAP"; set +a

if ! command -v op &>/dev/null; then
    echo "op CLI not found" >&2; exit 1
fi

# Resolve each line from env.op
> "$RESOLVED_TMP"
while IFS='=' read -r key ref; do
    # Skip comments and blanks
    [[ -z "$key" || "$key" == \#* ]] && continue
    # Non-op:// values pass through as-is
    if [[ "$ref" != op://* ]]; then
        echo "${key}=${ref}" >> "$RESOLVED_TMP"
        continue
    fi
    val=$(op read "$ref" 2>/dev/null) || { echo "WARN: failed to resolve $key" >&2; continue; }
    echo "${key}=${val}" >> "$RESOLVED_TMP"
done < "$ENV_OP"

chmod 600 "$RESOLVED_TMP"
mv "$RESOLVED_TMP" "$RESOLVED"
echo "Resolved $(grep -c '=' "$RESOLVED") secrets to $RESOLVED"

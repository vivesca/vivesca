#!/usr/bin/env python3
"""golem-review — meta-golem that reviews other golem output and queues more work.

Analyzes golem-daemon.log for recently completed tasks, validates their output,
diagnoses common failures, and writes a review summary. Optionally auto-requeues
failed tasks and generates new work when the queue runs low.

Usage:
    golem-review [--auto-requeue] [--since 30m] [--once]
    golem-review --help
"""
from __future__ import annotations

import os
import re
import subprocess
import sys
from datetime import datetime, timedelta
from pathlib import Path

GERMLINE = Path.home() / "germline"
QUEUE_FILE = GERMLINE / "loci" / "golem-queue.md"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
REVIEW_DIR = GERMLINE / "loci" / "copia"


# ── Utility helpers ─────────────────────────────────────────────────────


def parse_since_arg(since: str) -> int:
    """Parse a time-delta string like '30m' or '2h' into minutes."""
    since = since.strip()
    m = re.match(r"^(\d+)(m|h)$", since)
    if not m:
        return 30
    value = int(m.group(1))
    if m.group(2) == "h":
        return value * 60
    return value


def count_words(filepath: str) -> int:
    """Count words in a file. Returns 0 if file doesn't exist."""
    try:
        text = Path(filepath).read_text()
        return len(text.split())
    except (FileNotFoundError, OSError):
        return 0


def check_file_exists(filepath: str) -> bool:
    """Check if a file exists."""
    return Path(filepath).exists()


def run_cmd(cmd: str, cwd: str | None = None, timeout: int = 120) -> tuple[int, str]:
    """Run a shell command, return (exit_code, output)."""
    try:
        r = subprocess.run(
            cmd, shell=True, capture_output=True, text=True,
            timeout=timeout, cwd=cwd or str(GERMLINE),
        )
        return r.returncode, (r.stdout + r.stderr).strip()
    except subprocess.TimeoutExpired:
        return 124, "timeout"
    except Exception as e:
        return 1, str(e)


# ── Core functions ──────────────────────────────────────────────────────


def parse_completed_tasks(log_text: str, since_minutes: int = 30) -> list[dict]:
    """Parse daemon log text for tasks that completed within the time window.

    Returns list of dicts:
        cmd: str, exit_code: int, duration_s: int, timestamp: str, log_line: str
    """
    if not log_text:
        return []

    now = datetime.now()
    cutoff = now - timedelta(minutes=since_minutes)
    tasks = []

    for line in log_text.splitlines():
        # Match "Finished (Ns, exit=X): golem ..."
        m = re.match(
            r"^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] Finished \((\d+)s, exit=(\d+)\): (.+?)\.\.\.$",
            line,
        )
        if not m:
            continue

        ts_str, duration_s, exit_code, cmd = m.group(1), m.group(2), m.group(3), m.group(4)
        try:
            ts = datetime.strptime(ts_str, "%Y-%m-%d %H:%M:%S")
        except ValueError:
            continue

        if ts < cutoff:
            continue

        tasks.append({
            "cmd": cmd.strip(),
            "exit_code": int(exit_code),
            "duration_s": int(duration_s),
            "timestamp": ts_str,
            "log_line": line,
        })

    return tasks


def diagnose_failure(cmd: str, output_tail: str, exit_code: int = 1) -> dict:
    """Diagnose a common failure pattern from log tail.

    Returns dict with:
        diagnosis: str, fixed_task: str, notes: str
    """
    output_lower = output_tail.lower()

    if exit_code == 2:
        return {
            "diagnosis": "usage_error",
            "fixed_task": cmd,
            "notes": "Command usage/config error (exit 2) — check spec",
        }

    if "timeout" in output_lower or "timed out" in output_lower:
        # Reduce max-turns for retry
        if "--max-turns" in cmd:
            m = re.search(r"--max-turns\s+(\d+)", cmd)
            if m:
                old_turns = int(m.group(1))
                new_turns = max(10, old_turns // 2)
                fixed = cmd.replace(f"--max-turns {old_turns}", f"--max-turns {new_turns}")
            else:
                fixed = cmd
        else:
            fixed = cmd + " --max-turns 20"
        return {
            "diagnosis": "timeout",
            "fixed_task": fixed,
            "notes": "Task timed out — retrying with fewer turns",
        }

    if "importerror" in output_lower or "modulenotfounderror" in output_lower:
        return {
            "diagnosis": "import_error",
            "fixed_task": cmd,
            "notes": "Import error — likely hallucinated import or missing module",
        }

    if "/users/terry/" in output_lower:
        return {
            "diagnosis": "path_issue",
            "fixed_task": cmd,
            "notes": "Hardcoded macOS path (/Users/terry/) — should use Path.home()",
        }

    if "syntaxerror" in output_lower:
        return {
            "diagnosis": "syntax_error",
            "fixed_task": cmd,
            "notes": "Syntax error in generated code",
        }

    return {
        "diagnosis": "unknown",
        "fixed_task": cmd,
        "notes": f"Unclassified failure (exit={exit_code})",
    }


def run_pytest_on_file(filepath: str) -> tuple[int, int]:
    """Run pytest on a single file. Returns (passed, failed) counts."""
    try:
        r = subprocess.run(
            f"uv run pytest {filepath} -q --tb=line 2>&1",
            shell=True, capture_output=True, text=True,
            timeout=120, cwd=str(GERMLINE),
        )
        output = r.stdout + r.stderr
        m_pass = re.search(r"(\d+) passed", output)
        m_fail = re.search(r"(\d+) failed", output)
        passed = int(m_pass.group(1)) if m_pass else 0
        failed = int(m_fail.group(1)) if m_fail else 0
        return passed, failed
    except subprocess.TimeoutExpired:
        return 0, 0
    except Exception:
        return 0, 0


def check_new_files(last_n_commits: int = 5) -> list[str]:
    """Get files changed in the last N commits."""
    code, out = run_cmd(f"git diff --name-only HEAD~{last_n_commits} 2>/dev/null")
    if code != 0 or not out.strip():
        return []
    return [f for f in out.strip().splitlines() if f.strip()]


def build_review_summary(
    completed: list[dict],
    failed: list[dict],
    test_results: list[dict],
    content_results: list[dict],
    requeue_count: int,
) -> str:
    """Build the review summary markdown."""
    now_str = datetime.now().strftime("%Y-%m-%d %H:%M")
    lines = [
        f"# Golem Review — {now_str}",
        "",
        "## Summary",
        f"- Tasks completed: {len(completed)}",
        f"- Tasks failed: {len(failed)}",
        f"- Tests run: {len(test_results)}",
        f"- Content files checked: {len(content_results)}",
        f"- Tasks re-queued: {requeue_count}",
        "",
    ]

    if completed:
        lines.append("## Completed Tasks")
        for t in completed:
            cmd_short = t["cmd"][:80]
            lines.append(f"- **{t['exit_code']}** ({t['duration_s']}s): `{cmd_short}`")
        lines.append("")

    if failed:
        lines.append("## Failed Tasks")
        for t in failed:
            diag = t.get("diagnosis", "unknown")
            cmd_short = t["cmd"][:80]
            lines.append(f"- **{diag}**: `{cmd_short}`")
            if t.get("notes"):
                lines.append(f"  - _{t['notes']}_")
        lines.append("")

    if test_results:
        lines.append("## Test Results")
        total_pass = sum(r["passed"] for r in test_results)
        total_fail = sum(r["failed"] for r in test_results)
        lines.append(f"Total: {total_pass} passed, {total_fail} failed")
        for r in test_results:
            status = "PASS" if r["failed"] == 0 else "FAIL"
            lines.append(f"- [{status}] {r['file']}: {r['passed']}P/{r['failed']}F")
        lines.append("")

    if content_results:
        lines.append("## Content Quality")
        for r in content_results:
            status = "OK" if r["word_count"] >= 200 else "SHORT"
            lines.append(f"- [{status}] {r['file']}: {r['word_count']} words")
        lines.append("")

    return "\n".join(lines)


def generate_requeue_tasks(current_pending: int, max_total: int = 50) -> list[str]:
    """Generate requeue tasks for untested effectors if queue is below threshold.

    Returns list of golem command strings to append to the queue.
    """
    if current_pending >= max_total:
        return []

    slots = max_total - current_pending
    if slots <= 0:
        return []

    # Find effectors without corresponding test files
    eff_dir = GERMLINE / "effectors"
    assay_dir = GERMLINE / "assays"

    if not eff_dir.exists():
        return []

    # Get all test file base names (strip test_ prefix and .py suffix)
    tested = set()
    if assay_dir.exists():
        for f in assay_dir.iterdir():
            name = f.name
            if name.startswith("test_") and name.endswith(".py"):
                tested.add(name[5:-3])  # strip test_ and .py

    # Find untested effectors
    untested = []
    for f in sorted(eff_dir.iterdir()):
        if f.name.startswith(".") or f.name == "__pycache__":
            continue
        if not f.is_file():
            continue
        base = f.name.replace(".py", "")
        if base in tested or f.name in tested:
            continue
        # Skip files that are already test files
        if base.startswith("test"):
            continue
        untested.append(f.name)

    # Generate tasks
    tasks = []
    for eff_name in untested[:slots]:
        tasks.append(
            f'golem --provider zhipu --max-turns 30 "Write assays/test_{eff_name.replace(".py", "")}.py for effectors/{eff_name}. '
            f"Read the effector source, understand its functions, and write comprehensive tests. "
            f'Use exec(open(path).read(), ns) pattern. Path is /home/terry/germline/."'
        )

    return tasks


def count_pending_tasks() -> int:
    """Count pending [ ] and [!!] tasks in the queue file."""
    if not QUEUE_FILE.exists():
        return 0
    try:
        text = QUEUE_FILE.read_text()
    except (OSError, UnicodeDecodeError):
        return 0
    return len(re.findall(r"^- \[[ !]{1,2}\] `", text, re.MULTILINE))


def write_requeue_tasks(tasks: list[str]) -> int:
    """Append requeue tasks to the queue file. Returns count written."""
    if not tasks:
        return 0
    lines_to_add = []
    for task in tasks:
        lines_to_add.append(f"- [ ] `{task}`")
    try:
        with open(QUEUE_FILE, "a") as f:
            f.write("\n### Auto-generated by golem-review\n\n")
            for line in lines_to_add:
                f.write(line + "\n")
            f.write("\n")
    except OSError:
        return 0
    return len(tasks)


def main() -> int:
    """Main entry point."""
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0

    auto_requeue = "--auto-requeue" in args
    once = "--once" in args

    # Parse --since
    since_minutes = 30
    for i, a in enumerate(args):
        if a == "--since" and i + 1 < len(args):
            since_minutes = parse_since_arg(args[i + 1])

    # Step 1: Read daemon log
    try:
        log_text = DAEMON_LOG.read_text()
    except (FileNotFoundError, OSError):
        print("No daemon log found — nothing to review")
        return 0

    # Step 2: Parse completed tasks
    completed = parse_completed_tasks(log_text, since_minutes=since_minutes)
    successful = [t for t in completed if t["exit_code"] == 0]
    failed_raw = [t for t in completed if t["exit_code"] != 0]

    print(f"Found {len(completed)} tasks in last {since_minutes}m "
          f"({len(successful)} ok, {len(failed_raw)} failed)")

    # Step 3: Check output files
    new_files = check_new_files(last_n_commits=5)

    # Step 4: Run pytest on new test files
    test_results = []
    new_tests = [f for f in new_files if f.startswith("assays/test_") and f.endswith(".py")]
    for tf in new_tests:
        passed, failed = run_pytest_on_file(tf)
        test_results.append({"file": tf, "passed": passed, "failed": failed})
        print(f"  {tf}: {passed}P/{failed}F")

    # Step 5: Check consulting content (>200 words)
    content_results = []
    content_files = [
        f for f in new_files
        if f.startswith("loci/") and f.endswith(".md")
    ]
    for cf in content_files:
        wc = count_words(str(GERMLINE / cf))
        content_results.append({"file": cf, "word_count": wc})

    # Step 6: Diagnose failures and write fixed tasks to queue
    diagnosed = []
    for t in failed_raw:
        diag = diagnose_failure(t["cmd"], t.get("log_line", ""), t["exit_code"])
        diagnosed.append({**t, **diag})
        print(f"  FAIL [{diag['diagnosis']}]: {t['cmd'][:60]}...")

    requeue_count = 0
    if auto_requeue and diagnosed:
        fixed_tasks = []
        for d in diagnosed:
            if d["diagnosis"] not in ("usage_error",):
                fixed_tasks.append(d["fixed_task"])
        if fixed_tasks:
            requeue_count = write_requeue_tasks(fixed_tasks)
            print(f"Re-queued {requeue_count} fixed tasks")

    # Step 7: Auto-generate tasks if queue is low
    if auto_requeue:
        pending = count_pending_tasks()
        new_tasks = generate_requeue_tasks(pending)
        if new_tasks:
            added = write_requeue_tasks(new_tasks)
            print(f"Auto-generated {added} new tasks (queue had {pending} pending)")

    # Step 8: Write review summary
    REVIEW_DIR.mkdir(parents=True, exist_ok=True)
    summary = build_review_summary(
        completed=[{**t, "diagnosis": "success"} for t in successful],
        failed=diagnosed,
        test_results=test_results,
        content_results=content_results,
        requeue_count=requeue_count,
    )
    report_path = REVIEW_DIR / "golem-review-latest.md"
    report_path.write_text(summary)
    print(f"Review written to {report_path}")

    return 0


if __name__ == "__main__":
    sys.exit(main())

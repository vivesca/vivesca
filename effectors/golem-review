#!/usr/bin/env python3
"""golem-review — Meta-golem that reviews golem output and queues more work.

Reads golem-daemon.log to find recently completed tasks, validates their output,
diagnoses failures, and generates a review summary. Optionally auto-requeues
failed tasks and generates tasks for untested modules.

Usage:
    golem-review [--auto-requeue] [--since 30m]
    golem-review [--once] [--since 30m]
"""
from __future__ import annotations

import os
import re
import sys
import subprocess
import argparse
from pathlib import Path
from datetime import datetime, timedelta
from collections import Counter

# Paths
GERMLINE = Path.home() / "germline"
QUEUE_FILE = GERMLINE / "loci" / "golem-queue.md"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
JSONLFILE = Path.home() / ".local" / "share" / "vivesca" / "golem.jsonl"
REVIEW_FILE = GERMLINE / "loci" / "copia" / "golem-review-latest.md"
COPIA_DIR = GERMLINE / "loci" / "copia"
EFFECTORS_DIR = GERMLINE / "effectors"
ASSAYS_DIR = GERMLINE / "assays"

# Failure diagnosis patterns
PATH_ERROR_RE = re.compile(r"/Users/terry/|\\\\Users\\\\|C:\\\\Users|C:\\Users")
IMPORT_ERROR_RE = re.compile(r"ImportError|ModuleNotFoundError|No module named")
TIMEOUT_RE = re.compile(r"timeout|TIMEOUT|timed out")
SYNTAX_ERROR_RE = re.compile(r"SyntaxError")
PERMISSION_ERROR_RE = re.compile(r"PermissionError|Permission denied")
ASSERTION_ERROR_RE = re.compile(r"AssertionError|assert ")


def parse_since_arg(since_str: str | None) -> int:
    """Parse --since argument to minutes.

    Accepts: '30m', '2h', '60' (plain number = minutes), None (default 30).
    Returns minutes as int.
    """
    if since_str is None:
        return 30
    since_str = since_str.strip()
    m = re.match(r'^(\d+)m$', since_str)
    if m:
        return int(m.group(1))
    m = re.match(r'^(\d+)h$', since_str)
    if m:
        return int(m.group(1)) * 60
    try:
        return int(since_str)
    except ValueError:
        return 30


def parse_log_timestamp(ts_str: str | None) -> datetime | None:
    """Parse a log timestamp like '2026-03-31 10:53:29' into a datetime."""
    if ts_str is None:
        return None
    try:
        return datetime.strptime(ts_str.strip(), "%Y-%m-%d %H:%M:%S")
    except (ValueError, TypeError, AttributeError):
        return None


def parse_completed_tasks(log_text: str, since_minutes: int = 30) -> list[dict]:
    """Parse daemon log text, return tasks completed within the time window.

    Returns list of dicts with keys: cmd, exit_code, duration_s, timestamp.
    """
    cutoff = datetime.now() - timedelta(minutes=since_minutes)
    tasks: list[dict] = []

    for line in log_text.splitlines():
        # Match: [2026-03-31 18:56:52] Finished (670s, exit=0): golem ...
        m = re.match(
            r'^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] '
            r'Finished \((\d+)s, exit=(\d+)\): (.+)$',
            line,
        )
        if not m:
            continue
        ts_str, dur_str, exit_str, cmd = m.groups()
        ts = parse_log_timestamp(ts_str)
        if ts is None or ts < cutoff:
            continue
        tasks.append({
            "cmd": cmd.strip(),
            "exit_code": int(exit_str),
            "duration_s": int(dur_str),
            "timestamp": ts_str,
        })

    return tasks


def check_file_exists(path: str) -> bool:
    """Check if a file exists at the given path."""
    return Path(path).exists()


def count_words(path: str) -> int:
    """Count words in a file. Returns 0 if file does not exist."""
    p = Path(path)
    if not p.exists():
        return 0
    try:
        text = p.read_text()
        return len(text.split())
    except (PermissionError, OSError, UnicodeDecodeError):
        return 0


def run_pytest_on_file(test_file: str, timeout: int = 120) -> tuple[int, int]:
    """Run pytest on a single test file, return (passed, failed).

    Parses pytest output for pass/fail counts.
    """
    try:
        result = subprocess.run(
            f"cd {GERMLINE} && uv run pytest {test_file} -q --tb=line 2>&1",
            shell=True,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        output = result.stdout
        if isinstance(result.stderr, str):
            output += result.stderr

        passed = 0
        failed = 0
        pass_match = re.search(r'(\d+) passed', output)
        fail_match = re.search(r'(\d+) failed', output)
        if pass_match:
            passed = int(pass_match.group(1))
        if fail_match:
            failed = int(fail_match.group(1))
        return (passed, failed)
    except subprocess.TimeoutExpired:
        return (0, 0)
    except Exception:
        return (0, 0)


def diagnose_failure(cmd: str, tail_text: str, exit_code: int = 1) -> dict:
    """Diagnose a failed task from its command and log tail.

    Returns dict with keys: diagnosis, fixed_task.
    Diagnosis categories: timeout, import_error, path_issue, syntax_error,
                          usage_error, unknown.
    """
    combined = cmd + " " + tail_text
    diagnosis = "unknown"
    fixed_suffix = ""

    if PATH_ERROR_RE.search(combined):
        diagnosis = "path_issue"
        fixed_suffix = " IMPORTANT: use Path.home() not /Users/terry/. This is Linux."
    elif TIMEOUT_RE.search(combined):
        diagnosis = "timeout"
    elif IMPORT_ERROR_RE.search(combined):
        diagnosis = "import_error"
        fixed_suffix = " IMPORTANT: use exec(open(path).read(), ns) to load effectors."
    elif SYNTAX_ERROR_RE.search(combined):
        diagnosis = "syntax_error"
        fixed_suffix = " Run ast.parse() on all .py files after editing."
    elif PERMISSION_ERROR_RE.search(combined):
        diagnosis = "permission_error"
    elif exit_code == 2:
        diagnosis = "usage_error"
        fixed_suffix = " Check command syntax."

    # Build fixed task command
    # Extract the prompt from cmd
    prompt_match = re.search(r'"(.+)"', cmd)
    provider_match = re.search(r'--provider\s+(\w+)', cmd)
    turns_match = re.search(r'--max-turns\s+(\d+)', cmd)

    provider = provider_match.group(1) if provider_match else "zhipu"
    original_prompt = prompt_match.group(1) if prompt_match else ""

    if diagnosis == "timeout":
        old_turns = int(turns_match.group(1)) if turns_match else 25
        new_turns = max(old_turns - 10, 15)
        fixed_task = (
            f'golem --provider {provider} --max-turns {new_turns} '
            f'"{original_prompt} — simplified, focus on core requirements"'
        )
    elif fixed_suffix:
        fixed_prompt = original_prompt + fixed_suffix
        fixed_task = (
            f'golem --provider {provider} --max-turns 30 "{fixed_prompt}"'
        )
    else:
        fixed_task = (
            f'golem --provider {provider} --max-turns 30 "{original_prompt} (retry)"'
        )

    return {"diagnosis": diagnosis, "fixed_task": fixed_task}


def build_review_summary(
    completed: list[dict],
    failed: list[dict],
    test_results: list[dict],
    content_results: list[dict],
    requeue_count: int,
) -> str:
    """Build the review summary markdown string.

    Args:
        completed: list of dicts with cmd, exit_code, duration_s
        failed: list of dicts with cmd, exit_code, duration_s
        test_results: list of dicts with file, passed, failed
        content_results: list of dicts with file, word_count
        requeue_count: number of tasks requeued

    Returns markdown string.
    """
    now = datetime.now().strftime("%Y-%m-%d %H:%M")
    lines = [
        f"# Golem Review Summary",
        "",
        f"**Generated:** {now}",
        "",
        "## Completed Tasks",
        "",
    ]

    if completed:
        for task in completed:
            cmd_short = task["cmd"][:80]
            lines.append(f"- {cmd_short}")
    else:
        lines.append("- (none)")

    lines.extend(["", "## Failed Tasks", ""])
    if failed:
        for task in failed:
            cmd_short = task["cmd"][:80]
            lines.append(f"- [exit={task['exit_code']}] {cmd_short}")
    else:
        lines.append("- (none)")

    lines.extend(["", "## Test Results", ""])
    if test_results:
        for tr in test_results:
            lines.append(f"- {tr['file']}: {tr['passed']} passed, {tr['failed']} failed")
    else:
        lines.append("- (no new test files)")

    lines.extend(["", "## Content Quality", ""])
    if content_results:
        for cr in content_results:
            status = "adequate" if cr["word_count"] >= 200 else "thin"
            lines.append(f"- {cr['file']}: {cr['word_count']} words ({status})")
    else:
        lines.append("- (no new content files)")

    lines.extend(["", "## Actions", ""])
    lines.append(f"- Requeued: {requeue_count} tasks")
    lines.extend(["", "---", f"*Generated by golem-review at {now}*", ""])

    return "\n".join(lines)


def count_pending_tasks() -> int:
    """Count pending ([ ] and [!!]) tasks in the queue file."""
    if not QUEUE_FILE.exists():
        return 0
    try:
        text = QUEUE_FILE.read_text()
    except (PermissionError, OSError, UnicodeDecodeError):
        return 0
    pending = 0
    for line in text.splitlines():
        if re.match(r'^- \[( |!!)\] `golem ', line):
            pending += 1
    return pending


def find_untested_effectors() -> list[str]:
    """Find effectors that lack corresponding test files."""
    effectors: list[str] = []
    if EFFECTORS_DIR.exists():
        for p in EFFECTORS_DIR.iterdir():
            if p.is_file() and not p.name.startswith('.') and not p.name.endswith('.pyc'):
                effectors.append(p.name)

    tested: set[str] = set()
    if ASSAYS_DIR.exists():
        for p in ASSAYS_DIR.iterdir():
            if p.is_file() and p.name.startswith('test_') and p.name.endswith('.py'):
                stem = p.name[5:-3]  # strip test_ prefix and .py suffix
                tested.add(stem)
                tested.add(stem.replace('_', '-'))
                tested.add(stem.replace('-', '_'))

    untested: list[str] = []
    for eff in sorted(effectors):
        stem = eff.replace('.py', '').replace('.sh', '')
        if stem not in tested and eff not in tested:
            untested.append(eff)
    return untested


def generate_requeue_tasks(current_pending: int = 0) -> list[str]:
    """Auto-generate tasks for untested effectors when queue is low.

    Returns list of golem command strings (without - [ ] prefix).
    If current_pending >= 50, returns empty list.
    """
    if current_pending >= 50:
        return []

    needed = 50 - current_pending
    untested = find_untested_effectors()
    providers = ["zhipu", "volcano", "infini"]
    tasks: list[str] = []

    for i, mod in enumerate(untested[:needed]):
        provider = providers[i % len(providers)]
        safe_mod = mod.replace('"', '\\"')
        test_name = mod.replace("-", "_").replace(".py", "").replace(".sh", "")
        tasks.append(
            f'- [ ] `golem --provider {provider} --max-turns 30 '
            f'"Write tests for effectors/{safe_mod}. Read the effector first. '
            f'Write assays/test_{test_name}.py using exec(open(path).read(), ns) pattern. '
            f'Run uv run pytest assays/test_{test_name}.py -v --tb=short."`'
        )

    return tasks


def append_tasks_to_queue(tasks: list[str]) -> int:
    """Append new task lines to the golem queue file.

    Returns the number of tasks appended.
    """
    if not tasks:
        return 0

    QUEUE_FILE.parent.mkdir(parents=True, exist_ok=True)

    try:
        existing = QUEUE_FILE.read_text() if QUEUE_FILE.exists() else ""
    except (PermissionError, OSError, UnicodeDecodeError):
        return 0

    if existing and not existing.endswith("\n"):
        existing += "\n"

    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    new_section = (
        f"\n### Auto-queued by golem-review ({ts})\n\n"
        + "\n".join(tasks)
        + "\n"
    )

    try:
        QUEUE_FILE.write_text(existing + new_section)
    except (PermissionError, OSError):
        return 0

    return len(tasks)


def run_review(auto_requeue: bool = False, since: timedelta | None = None) -> int:
    """Main review logic. Returns exit code.

    Steps:
        1. Scan log for recent activity
        2. Check recent git changes
        3. Test new test files
        4. Check consulting content
        5. Diagnose failures
        6. Write review summary
        7. Optionally auto-requeue
    """
    if since is None:
        since = timedelta(minutes=30)

    since_minutes = int(since.total_seconds() / 60)

    # Step 1: Read and parse log
    log_text = ""
    if DAEMON_LOG.exists():
        try:
            log_text = DAEMON_LOG.read_text()
        except (PermissionError, OSError, UnicodeDecodeError):
            pass

    all_tasks = parse_completed_tasks(log_text, since_minutes=since_minutes)
    completed = [t for t in all_tasks if t["exit_code"] == 0]
    failed = [t for t in all_tasks if t["exit_code"] != 0]

    # Step 2: Recent files via git
    recent_files: list[str] = []
    try:
        result = subprocess.run(
            f"git -C {GERMLINE} diff --name-only HEAD~5",
            shell=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if result.returncode == 0:
            recent_files = [f for f in result.stdout.strip().splitlines() if f.strip()]
    except Exception:
        pass

    # Step 3: Run pytest on new test files
    new_test_files = [f for f in recent_files if f.startswith("assays/test_") and f.endswith(".py")]
    test_results: list[dict] = []
    for tf in new_test_files:
        passed, failed_count = run_pytest_on_file(tf)
        test_results.append({"file": tf, "passed": passed, "failed": failed_count})

    # Step 4: Check consulting content
    consulting_files = [f for f in recent_files if "consulting" in f and f.endswith(".md")]
    content_results: list[dict] = []
    for cf in consulting_files:
        full = str(GERMLINE / cf)
        wc = count_words(full)
        content_results.append({"file": cf, "word_count": wc})

    # Step 5: Diagnose failures and generate fixes
    requeue_count = 0
    fixed_commands: list[str] = []
    if failed:
        log_tail = ""
        if DAEMON_LOG.exists():
            try:
                tail_lines = DAEMON_LOG.read_text().splitlines()
                log_tail = "\n".join(tail_lines[-30:])
            except (PermissionError, OSError, UnicodeDecodeError):
                pass

        for task in failed:
            diag = diagnose_failure(task["cmd"], log_tail, exit_code=task["exit_code"])
            fixed_commands.append(f"- [ ] `{diag['fixed_task']}`")

    # Step 6: Write review summary
    summary = build_review_summary(
        completed=completed,
        failed=failed,
        test_results=test_results,
        content_results=content_results,
        requeue_count=requeue_count,
    )

    COPIA_DIR.mkdir(parents=True, exist_ok=True)
    try:
        REVIEW_FILE.write_text(summary)
    except (PermissionError, OSError):
        print(f"Warning: could not write review to {REVIEW_FILE}", file=sys.stderr)

    # Step 7: Auto-requeue
    if auto_requeue:
        # Write fixed tasks
        if fixed_commands:
            requeue_count = append_tasks_to_queue(fixed_commands)

        # Top up queue if needed
        pending_count = count_pending_tasks()
        if pending_count < 50:
            new_tasks = generate_requeue_tasks(current_pending=pending_count)
            if new_tasks:
                append_tasks_to_queue(new_tasks)

        # Regenerate review with updated counts
        summary = build_review_summary(
            completed=completed,
            failed=failed,
            test_results=test_results,
            content_results=content_results,
            requeue_count=requeue_count,
        )
        try:
            REVIEW_FILE.write_text(summary)
        except (PermissionError, OSError):
            pass

    print(summary)
    return 0


def main():
    parser = argparse.ArgumentParser(
        description="Meta-golem: review golem output and queue more work"
    )
    parser.add_argument(
        "--auto-requeue",
        action="store_true",
        help="Automatically requeue failed tasks and top up queue to 50",
    )
    parser.add_argument(
        "--once",
        action="store_true",
        help="Run review once and exit (default behavior)",
    )
    parser.add_argument(
        "--since",
        default="30m",
        help="Look back duration (default: 30m). Supports m/h suffixes.",
    )
    args = parser.parse_args()

    since_minutes = parse_since_arg(args.since)
    since = timedelta(minutes=since_minutes)
    return run_review(auto_requeue=args.auto_requeue, since=since)


if __name__ == "__main__":
    sys.exit(main())

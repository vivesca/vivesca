#!/usr/bin/env python3
"""golem-review — Meta-golem that reviews other golem output and queues more work.

Reads golem-daemon.log, finds recently completed tasks, validates output,
diagnoses failures, writes review summary. Optionally auto-requeues and
generates new tasks from untested effectors.

Usage:
    golem-review [--auto-requeue] [--since 30m]
"""
from __future__ import annotations

import os
import re
import sys
import subprocess
from pathlib import Path
from datetime import datetime, timedelta, timezone

# Paths
GERMLINE = Path.home() / "germline"
QUEUE_FILE = GERMLINE / "loci" / "golem-queue.md"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
REVIEW_FILE = GERMLINE / "loci" / "copia" / "golem-review-latest.md"
COPIA_DIR = GERMLINE / "loci" / "copia"
EFFECTORS_DIR = GERMLINE / "effectors"
ASSAYS_DIR = GERMLINE / "assays"


# ── Utility ────────────────────────────────────────────────────────────


def log(msg: str):
    """Print a timestamped log line to stdout."""
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{ts}] {msg}", file=sys.stderr)


def parse_since(since_str: str) -> timedelta:
    """Parse duration string (30m, 1h, 2d, 60s, or bare number=minutes)."""
    since_str = since_str.strip()
    m = re.match(r'^(\d+)([smhd]?)$', since_str)
    if not m:
        return timedelta(minutes=30)
    value = int(m.group(1))
    unit = m.group(2) or 'm'
    if unit == 's':
        return timedelta(seconds=value)
    elif unit == 'h':
        return timedelta(hours=value)
    elif unit == 'd':
        return timedelta(days=value)
    else:
        return timedelta(minutes=value)


def parse_log_timestamp(ts_str: str | None) -> datetime | None:
    """Parse '2026-03-31 10:53:29' into a datetime. Returns None on failure."""
    if ts_str is None:
        return None
    try:
        return datetime.strptime(ts_str.strip(), "%Y-%m-%d %H:%M:%S")
    except (ValueError, TypeError, AttributeError):
        return None


# ── Step 1: Scan log ───────────────────────────────────────────────────


def parse_completed_tasks(log_text: str, since_minutes: int = 30) -> list[dict]:
    """Parse daemon log text for Finished lines within the time window.

    Returns list of dicts: {cmd, exit_code, duration_s, timestamp}.
    """
    if not log_text or not log_text.strip():
        return []

    cutoff = datetime.now(timezone.utc) - timedelta(minutes=since_minutes)
    tasks: list[dict] = []

    for line in log_text.splitlines():
        m = re.match(
            r'^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] '
            r'Finished \((\d+)s, exit=(\d+)\): (.+)$',
            line,
        )
        if not m:
            continue
        ts_str, duration, exit_code, cmd = m.group(1), m.group(2), m.group(3), m.group(4)
        try:
            ts = datetime.strptime(ts_str, "%Y-%m-%d %H:%M:%S").replace(tzinfo=timezone.utc)
        except ValueError:
            continue
        if ts < cutoff:
            continue
        tasks.append({
            "cmd": cmd.strip().rstrip("."),
            "exit_code": int(exit_code),
            "duration_s": int(duration),
            "timestamp": ts_str,
        })

    return tasks


# ── Step 5: Diagnose failures ──────────────────────────────────────────


def diagnose_failure(cmd: str, output: str, exit_code: int = 1) -> dict:
    """Diagnose a failed golem task. Returns {diagnosis, fixed_task, notes}."""
    notes: list[str] = []

    if exit_code == 2:
        return {
            "diagnosis": "usage_error",
            "fixed_task": "",
            "notes": ["exit_code=2: command error, not requeued"],
        }

    if re.search(r'TIMEOUT|timeout after \d+s', output, re.IGNORECASE):
        notes.append("Task timed out")
        turns_match = re.search(r'--max-turns\s+(\d+)', cmd)
        if turns_match:
            old_turns = int(turns_match.group(1))
            new_turns = max(5, old_turns - 20)
            fixed = cmd.replace(f"--max-turns {old_turns}", f"--max-turns {new_turns}")
        else:
            fixed = cmd.replace("golem ", "golem --max-turns 30 ", 1)
        return {"diagnosis": "timeout", "fixed_task": fixed, "notes": notes}

    if re.search(r'ModuleNotFoundError|ImportError', output):
        notes.append("Import/module error detected")
        return {"diagnosis": "import_error", "fixed_task": cmd, "notes": notes}

    if "/Users/terry/" in output or "C:\\Users" in output:
        notes.append("Hardcoded macOS/Windows path detected")
        return {"diagnosis": "path_issue", "fixed_task": cmd, "notes": notes}

    if re.search(r'SyntaxError:', output):
        notes.append("Python syntax error in output")
        return {"diagnosis": "syntax_error", "fixed_task": cmd, "notes": notes}

    notes.append(f"Unrecognized failure (exit={exit_code})")
    return {"diagnosis": "unknown", "fixed_task": cmd, "notes": notes}


# ── Steps 2-4: File helpers ────────────────────────────────────────────


def check_file_exists(path: str) -> bool:
    """Check if a file exists at the given path."""
    return Path(path).exists()


def count_words(path: str) -> int:
    """Count words in a file. Returns 0 if file doesn't exist or unreadable."""
    try:
        text = Path(path).read_text()
        return len(text.split())
    except (FileNotFoundError, PermissionError, OSError, UnicodeDecodeError):
        return 0


def run_pytest_on_file(test_file: str) -> tuple[int, int]:
    """Run pytest on a single test file. Returns (passed, failed)."""
    try:
        result = subprocess.run(
            ["uv", "run", "pytest", test_file, "-q", "--tb=line", "--no-header"],
            capture_output=True, text=True,
            timeout=120, cwd=str(GERMLINE),
        )
        output = result.stdout + result.stderr
    except subprocess.TimeoutExpired:
        return (0, 0)
    except Exception:
        return (0, 0)

    passed = failed = 0
    m = re.search(r'(\d+) passed', output)
    if m:
        passed = int(m.group(1))
    m = re.search(r'(\d+) failed', output)
    if m:
        failed = int(m.group(1))

    return (passed, failed)


# ── Review summary ─────────────────────────────────────────────────────


def build_review_summary(
    completed: list[dict],
    failed: list[dict],
    test_results: list[dict],
    content_results: list[dict],
    requeue_count: int,
) -> str:
    """Build a human-readable review summary markdown string."""
    now = datetime.now().strftime("%Y-%m-%d %H:%M")
    lines = ["# Golem Review Summary", "", f"**Generated:** {now}", ""]

    lines.append(f"## Completed ({len(completed)} tasks)")
    for t in completed:
        status = "OK" if t.get("exit_code") == 0 else "WARN"
        lines.append(f"- [{status}] {t.get('cmd', 'unknown')[:80]} ({t.get('duration_s', '?')}s)")
    if not completed:
        lines.append("- (none)")
    lines.append("")

    if failed:
        lines.append(f"## Failed ({len(failed)} tasks)")
        for t in failed:
            diag = t.get("diagnosis", "unknown")
            notes_text = "; ".join(t.get("notes", []))
            lines.append(f"- **{diag}**: {t.get('cmd', 'unknown')[:60]} — {notes_text[:80]}")
        lines.append("")

    lines.append("## Test Results")
    for r in test_results:
        status = "PASS" if r.get("failed", 0) == 0 else "FAIL"
        lines.append(f"- [{status}] {r.get('file', '?')}: {r.get('passed', 0)} passed, {r.get('failed', 0)} failed")
    if not test_results:
        lines.append("- (no new test files)")
    lines.append("")

    lines.append("## Content Quality")
    for r in content_results:
        wc = r.get("word_count", 0)
        status = "OK" if wc > 200 else "SHORT"
        lines.append(f"- [{status}] {r.get('file', '?')}: {wc} words")
    if not content_results:
        lines.append("- (no new content files)")
    lines.append("")

    lines.append(f"## Requeued: {requeue_count} tasks")
    lines.append("")
    lines.append(f"*Generated by golem-review at {now}*")
    lines.append("")
    return "\n".join(lines)


# ── Queue management ───────────────────────────────────────────────────


def count_pending_tasks() -> int:
    """Count pending ([ ], [!!], [!]) tasks in the queue file."""
    if not QUEUE_FILE.exists():
        return 0
    try:
        content = QUEUE_FILE.read_text()
    except (PermissionError, OSError, UnicodeDecodeError):
        return 0
    count = 0
    for line in content.splitlines():
        stripped = line.strip()
        if re.match(r'^- \[', stripped) and not stripped.startswith("- [x]"):
            count += 1
    return count


def generate_requeue_tasks(current_pending: int = 0) -> list[str]:
    """Generate golem tasks for untested effectors. Only if current_pending < 50."""
    if current_pending >= 50:
        return []

    if not EFFECTORS_DIR.exists():
        return []

    tested_names: set[str] = set()
    if ASSAYS_DIR.exists():
        for f in ASSAYS_DIR.glob("test_*.py"):
            name = f.stem[5:]  # strip test_
            tested_names.add(name)
            tested_names.add(name.replace("_", "-"))
            tested_names.add(name.replace("-", "_"))

    needed = 50 - current_pending
    tasks: list[str] = []

    for f in sorted(EFFECTORS_DIR.iterdir()):
        if len(tasks) >= needed:
            break
        if not f.is_file():
            continue
        if f.name.startswith(".") or f.name.startswith("__"):
            continue
        if f.name.startswith("test"):
            continue

        normalized = f.name.replace("-", "_").replace(".py", "").replace(".sh", "")
        if f.name in tested_names or normalized in tested_names:
            continue
        if any(t.replace("-", "_") == normalized for t in tested_names):
            continue

        test_name = f"test_{f.name.replace('-', '_')}"
        tasks.append(
            f'golem --provider infini --max-turns 50 '
            f'"Write assays/{test_name}.py for effectors/{f.name}. '
            f'Run uv run pytest assays/{test_name}.py -v --tb=short."'
        )

    return tasks


def write_task_to_queue(task_cmd: str, priority: str = "normal"):
    """Append a task to the golem queue file."""
    QUEUE_FILE.parent.mkdir(parents=True, exist_ok=True)

    marker = "- [!!]" if priority == "high" else "- [ ]"
    line = f"{marker} `{task_cmd}`"

    if QUEUE_FILE.exists():
        try:
            content = QUEUE_FILE.read_text()
        except (PermissionError, OSError, UnicodeDecodeError):
            content = "# Golem Task Queue\n\n## Pending\n\n## Done\n"
    else:
        content = "# Golem Task Queue\n\n## Pending\n\n## Done\n"

    if "## Done" in content:
        parts = content.split("## Done", 1)
        content = parts[0].rstrip() + "\n" + line + "\n\n## Done" + parts[1]
    else:
        content = content.rstrip() + "\n" + line + "\n"

    try:
        QUEUE_FILE.write_text(content)
    except (PermissionError, OSError) as e:
        log(f"ERROR: cannot write to queue: {e}")


# ── Main ───────────────────────────────────────────────────────────────


def run_review(auto_requeue: bool = False, since_str: str = "30m") -> int:
    """Run a single review cycle. Returns 0 on success."""
    since = parse_since(since_str)
    since_minutes = int(since.total_seconds() / 60)
    log(f"Review starting (since={since_str}, auto_requeue={auto_requeue})")

    # Step 1: Read daemon log
    if not DAEMON_LOG.exists():
        log("No daemon log found")
    log_text = ""
    if DAEMON_LOG.exists():
        try:
            log_text = DAEMON_LOG.read_text()
        except (PermissionError, OSError, UnicodeDecodeError):
            log("Cannot read daemon log")

    # Parse completed tasks
    all_tasks = parse_completed_tasks(log_text, since_minutes=since_minutes)
    completed = [t for t in all_tasks if t["exit_code"] == 0]
    failed_raw = [t for t in all_tasks if t["exit_code"] != 0]
    log(f"Found {len(completed)} completed, {len(failed_raw)} failed tasks")

    # Step 2: Get changed files
    changed: list[str] = []
    try:
        result = subprocess.run(
            f"git -C {GERMLINE} diff --name-only HEAD~5",
            shell=True, capture_output=True, text=True, timeout=30,
        )
        if result.returncode == 0:
            changed = [f for f in result.stdout.strip().splitlines() if f.strip()]
    except Exception:
        pass

    # Step 3: Run tests on new test files
    test_files = [f for f in changed if f.startswith("assays/test_") and f.endswith(".py")]
    test_results: list[dict] = []
    for tf in test_files:
        passed, failed = run_pytest_on_file(tf)
        test_results.append({"file": tf, "passed": passed, "failed": failed})
        log(f"  {tf}: {passed} passed, {failed} failed")

    # Step 4: Check consulting content
    content_files = [f for f in changed if f.startswith("loci/copia/") and f.endswith(".md")
                     and "reviewer-cycle-" not in f]
    content_results: list[dict] = []
    for cf in content_files:
        full = GERMLINE / cf
        wc = count_words(str(full))
        content_results.append({"file": cf, "word_count": wc})
        log(f"  {cf}: {wc} words")

    # Step 5: Diagnose failures and requeue
    failed_diagnosed: list[dict] = []
    requeue_count = 0
    for t in failed_raw:
        diag = diagnose_failure(t["cmd"], f"exit={t['exit_code']}", exit_code=t["exit_code"])
        t["diagnosis"] = diag["diagnosis"]
        t["notes"] = diag["notes"]
        failed_diagnosed.append(t)

        if auto_requeue and diag["fixed_task"]:
            write_task_to_queue(diag["fixed_task"])
            requeue_count += 1

    log(f"Diagnosed {len(failed_diagnosed)} failures, requeued {requeue_count}")

    # Step 6: Auto-generate tasks if queue low
    if auto_requeue:
        pending = count_pending_tasks()
        new_tasks = generate_requeue_tasks(current_pending=pending + requeue_count)
        for task in new_tasks:
            write_task_to_queue(task)
        if new_tasks:
            log(f"Auto-generated {len(new_tasks)} tasks from untested effectors")

    # Step 7: Build and write summary
    summary = build_review_summary(
        completed=[{**t, "diagnosis": "success"} for t in completed],
        failed=failed_diagnosed,
        test_results=test_results,
        content_results=content_results,
        requeue_count=requeue_count,
    )

    COPIA_DIR.mkdir(parents=True, exist_ok=True)
    try:
        REVIEW_FILE.write_text(summary)
    except (PermissionError, OSError):
        log(f"Warning: could not write review to {REVIEW_FILE}")

    print(summary)
    return 0


def main():
    """CLI entry point."""
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0

    auto_requeue = "--auto-requeue" in args
    since_str = "30m"

    for i, arg in enumerate(args):
        if arg == "--since" and i + 1 < len(args):
            since_str = args[i + 1]
        elif arg.startswith("--since="):
            since_str = arg.split("=", 1)[1]

    return run_review(auto_requeue=auto_requeue, since_str=since_str)


if __name__ == "__main__":
    sys.exit(main())

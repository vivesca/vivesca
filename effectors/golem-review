#!/usr/bin/env python3
"""golem-review — META-GOLEM: reviews other golem output, diagnoses failures, queues more work.

Reads golem-daemon.log to find completed tasks, validates output files,
runs tests on new test files, checks consulting content quality, diagnoses
common failure patterns, and auto-generates new tasks when the queue is low.

Usage:
    golem-review [--auto-requeue] [--since 30m] [--once]
    golem-review --help
"""
from __future__ import annotations

import os
import re
import subprocess
import sys
from datetime import UTC, datetime, timedelta
from pathlib import Path

# Paths
GERMLINE = Path.home() / "germline"
QUEUE_FILE = GERMLINE / "loci" / "golem-queue.md"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
REVIEW_SUMMARY = GERMLINE / "loci" / "copia" / "golem-review-latest.md"


# ── Utility functions ──────────────────────────────────────────────────


def log(msg: str):
    """Print timestamped message to stdout."""
    ts = datetime.now(UTC).strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{ts}] {msg}")


def _run(cmd: str, cwd: str | None = None, timeout: int = 120) -> tuple[int, str]:
    """Run a shell command, return (exit_code, combined_output)."""
    try:
        r = subprocess.run(
            cmd, shell=True, capture_output=True, text=True,
            timeout=timeout, cwd=cwd or str(GERMLINE),
        )
        return r.returncode, (r.stdout + r.stderr).strip()
    except subprocess.TimeoutExpired:
        return 124, "timeout"
    except Exception as e:
        return 1, str(e)


# ── Step 1: Parse time arguments ───────────────────────────────────────


def parse_since_arg(arg: str) -> timedelta:
    """Parse a time-duration string like '30m' or '2h'.

    Returns a timedelta. Defaults to 30 minutes for empty/invalid input.
    """
    if not arg:
        return timedelta(minutes=30)
    m = re.match(r'^(\d+)([mh])$', arg.strip())
    if not m:
        return timedelta(minutes=30)
    value = int(m.group(1))
    unit = m.group(2)
    if unit == "h":
        return timedelta(hours=value)
    return timedelta(minutes=value)


# ── Step 2: Find recently completed tasks ──────────────────────────────


def get_recent_completed(since: timedelta) -> list[str]:
    """Read golem-daemon.log, return tasks completed within the given window.

    Looks for lines matching: [timestamp] Finished (Ns, exit=0): cmd...
    """
    if not DAEMON_LOG.exists():
        return []

    try:
        content = DAEMON_LOG.read_text()
    except (PermissionError, OSError, UnicodeDecodeError):
        return []

    cutoff = datetime.now(UTC) - since
    completed = []

    for line in content.splitlines():
        # Match: [2026-03-31 19:30:00] Finished (120s, exit=0): task...
        m = re.match(
            r'^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] Finished \(\d+s, exit=(\d+)\): (.+)$',
            line,
        )
        if not m:
            continue
        ts_str, exit_code, task_desc = m.group(1), m.group(2), m.group(3)
        try:
            ts = datetime.strptime(ts_str, "%Y-%m-%d %H:%M:%S").replace(tzinfo=UTC)
        except ValueError:
            continue
        if ts >= cutoff:
            completed.append(task_desc.strip())

    return completed


# ── Step 3: Get changed files ──────────────────────────────────────────


def get_changed_files(head_range: int = 5) -> list[str]:
    """Get files changed in the last N commits via git diff.

    Returns list of relative file paths.
    """
    code, output = _run(f"git diff --name-only HEAD~{head_range} 2>/dev/null")
    if code != 0 or not output.strip():
        return []
    return [f for f in output.strip().splitlines() if f.strip()]


# ── Step 4: Classify changed files ─────────────────────────────────────


def classify_files(files: list[str]) -> dict[str, list[str]]:
    """Classify file paths into categories: tests, effectors, consulting, other.

    Tests: assays/test_*.py (flat only)
    Effectors: effectors/*
    Consulting: loci/copia/*.md (excluding reviewer-cycle-*)
    Other: everything else
    """
    tests = []
    effectors = []
    consulting = []
    other = []

    for f in files:
        if f.startswith("assays/test_") and f.endswith(".py") and f.count("/") == 1:
            tests.append(f)
        elif f.startswith("effectors/") and f.count("/") == 1:
            effectors.append(f)
        elif f.startswith("loci/copia/") and f.endswith(".md"):
            basename = Path(f).name
            if not basename.startswith("reviewer-cycle-"):
                consulting.append(f)
        else:
            other.append(f)

    return {"tests": tests, "effectors": effectors, "consulting": consulting, "other": other}


# ── Step 5: Run pytest on new test files ───────────────────────────────


def run_pytest_on_files(files: list[str]) -> dict:
    """Run pytest on the given test files, parse pass/fail counts.

    Returns dict with: passed, failed, errors, exit_code, raw_output.
    """
    if not files:
        return {"passed": 0, "failed": 0, "errors": 0, "exit_code": 0, "raw": ""}

    file_args = " ".join(files)
    code, output = _run(
        f"uv run pytest {file_args} -q --tb=line 2>&1 | tail -5",
        timeout=300,
    )

    passed = failed = errors = 0

    m = re.search(r'(\d+) passed', output)
    if m:
        passed = int(m.group(1))
    m = re.search(r'(\d+) failed', output)
    if m:
        failed = int(m.group(1))
    m = re.search(r'(\d+) error', output)
    if m:
        errors = int(m.group(1))

    return {
        "passed": passed,
        "failed": failed,
        "errors": errors,
        "exit_code": code,
        "raw": output,
    }


# ── Step 6: Check consulting content ───────────────────────────────────


def check_consulting_content(files: list[str]) -> list[dict]:
    """Check each consulting file exists and has >200 words.

    Returns list of dicts: {file, ok, word_count, reason}.
    """
    results = []
    for rel_path in files:
        full_path = GERMLINE / rel_path
        if not full_path.exists():
            results.append({
                "file": rel_path,
                "ok": False,
                "word_count": 0,
                "reason": "file not found",
            })
            continue

        try:
            text = full_path.read_text()
        except (PermissionError, OSError, UnicodeDecodeError) as e:
            results.append({
                "file": rel_path,
                "ok": False,
                "word_count": 0,
                "reason": str(e),
            })
            continue

        word_count = len(text.split())
        if word_count > 200:
            results.append({
                "file": rel_path,
                "ok": True,
                "word_count": word_count,
                "reason": "ok",
            })
        else:
            results.append({
                "file": rel_path,
                "ok": False,
                "word_count": word_count,
                "reason": f"too short ({word_count} words, need >200)",
            })

    return results


# ── Step 7: Diagnose failures ──────────────────────────────────────────


def diagnose_failure(log_tail: str) -> dict:
    """Diagnose common failure patterns from daemon log tail.

    Checks for: hardcoded_path, import_error, timeout, syntax_error.
    Returns {diagnosis, detail}.
    """
    if not log_tail or not log_tail.strip():
        return {"diagnosis": "empty", "detail": "no log output"}

    # Check for hardcoded macOS paths
    if "/Users/terry/" in log_tail:
        return {"diagnosis": "hardcoded_path", "detail": "contains /Users/terry/ (should use Path.home())"}

    # Check for import errors
    m = re.search(r'(?:ModuleNotFoundError|ImportError):\s*No module named [\'"]?(\S+?)[\'"]?', log_tail)
    if m:
        return {"diagnosis": "import_error", "detail": f"missing module: {m.group(1)}"}

    # Check for timeout
    if re.search(r'TIMEOUT\s+after\s+\d+s', log_tail):
        return {"diagnosis": "timeout", "detail": "golem task timed out"}

    # Check for syntax error
    if re.search(r'SyntaxError:', log_tail):
        return {"diagnosis": "syntax_error", "detail": "Python syntax error in output"}

    return {"diagnosis": "unknown", "detail": log_tail[:100]}


# ── Step 8: Write fixed tasks to queue ─────────────────────────────────


def write_fixed_task(task_cmd: str, priority: str = "normal"):
    """Append a fixed task to the golem queue file.

    Args:
        task_cmd: Full golem command to queue.
        priority: 'normal' for [ ] or 'high' for [!!].
    """
    QUEUE_FILE.parent.mkdir(parents=True, exist_ok=True)

    if priority == "high":
        marker = "- [!!]"
    else:
        marker = "- [ ]"

    line = f"{marker} `{task_cmd}`"

    if QUEUE_FILE.exists():
        try:
            content = QUEUE_FILE.read_text()
        except (PermissionError, OSError, UnicodeDecodeError):
            content = ""
    else:
        content = "# Golem Task Queue\n\n## Pending\n\n## Done\n"

    # Append before ## Done section, or at end if no ## Done
    if "## Done" in content:
        parts = content.split("## Done", 1)
        content = parts[0] + line + "\n\n## Done" + parts[1]
    else:
        content = content.rstrip() + "\n" + line + "\n"

    try:
        QUEUE_FILE.write_text(content)
    except (PermissionError, OSError) as e:
        log(f"ERROR: cannot write to queue: {e}")


# ── Step 9: Count pending tasks ────────────────────────────────────────


def count_pending_tasks() -> int:
    """Count pending ([ ] and [!!]) tasks in the queue file."""
    if not QUEUE_FILE.exists():
        return 0
    try:
        content = QUEUE_FILE.read_text()
    except (PermissionError, OSError, UnicodeDecodeError):
        return 0
    # Count lines starting with - [ ] or - [!!]
    count = 0
    for line in content.splitlines():
        stripped = line.strip()
        if stripped.startswith("- [ ] ") or stripped.startswith("- [!!] "):
            count += 1
    return count


# ── Step 10: Auto-generate tasks from untested effectors ───────────────


def auto_generate_tasks(target_count: int = 50) -> list[str]:
    """Scan for untested effectors/modules and generate test tasks.

    Returns list of golem commands to run.
    """
    effectors_dir = GERMLINE / "effectors"
    assays_dir = GERMLINE / "assays"

    if not effectors_dir.exists():
        return []

    # Build set of tested effector names
    tested_names = set()
    if assays_dir.exists():
        for f in assays_dir.glob("test_*.py"):
            # test_foo_bar.py -> foo-bar, foo_bar, foobar
            name = f.stem[5:]  # strip test_
            tested_names.add(name)
            tested_names.add(name.replace("_", "-"))

    # Find untested effectors
    untested = []
    for f in sorted(effectors_dir.iterdir()):
        if not f.is_file():
            continue
        if f.name.startswith(".") or f.name.startswith("__"):
            continue
        # Check if tested
        normalized = f.name.replace("-", "_").replace(".py", "").replace(".sh", "")
        if f.name in tested_names or normalized in tested_names:
            continue
        if any(t.replace("-", "_") == normalized for t in tested_names):
            continue
        untested.append(f.name)

    # Generate tasks
    tasks = []
    for name in untested[:target_count]:
        tasks.append(
            f'golem --provider infini --max-turns 50 "Write assays/test_{name.replace("-", "_")}.py for effectors/{name}. Run uv run pytest assays/test_{name.replace("-", "_")}.py -v --tb=short. Ensure all tests pass."'
        )

    return tasks


# ── Step 11: Generate review summary ───────────────────────────────────


def generate_review_summary(
    completed_tasks: list[str],
    changed_files: dict[str, list[str]],
    test_results: dict,
    consulting_results: list[dict],
    failures: list[str],
    failure_diagnoses: list[dict],
    new_tasks: list[str],
) -> Path:
    """Write a review summary to loci/copia/golem-review-latest.md.

    Returns the path to the written file.
    """
    REVIEW_SUMMARY.parent.mkdir(parents=True, exist_ok=True)

    ts = datetime.now(UTC).strftime("%Y-%m-%d %H:%M UTC")
    lines = [
        f"# Golem Review Summary ({ts})",
        "",
        "## Completed Tasks",
    ]

    if completed_tasks:
        for task in completed_tasks:
            lines.append(f"- {task[:100]}")
    else:
        lines.append("- (none in window)")

    lines.extend([
        "",
        "## Changed Files",
        f"- Tests: {len(changed_files.get('tests', []))}",
        f"- Effectors: {len(changed_files.get('effectors', []))}",
        f"- Consulting: {len(changed_files.get('consulting', []))}",
        f"- Other: {len(changed_files.get('other', []))}",
        "",
        "## Test Results",
        f"- Passed: {test_results.get('passed', 0)}",
        f"- Failed: {test_results.get('failed', 0)}",
        f"- Errors: {test_results.get('errors', 0)}",
        f"- Exit code: {test_results.get('exit_code', 0)}",
    ])

    if changed_files.get("tests"):
        lines.append("")
        lines.append("### New Test Files")
        for f in changed_files["tests"]:
            lines.append(f"- `{f}`")

    if consulting_results:
        lines.extend([
            "",
            "## Consulting Content",
        ])
        for r in consulting_results:
            status = "✓" if r["ok"] else "✗"
            lines.append(f"- {status} `{r['file']}` ({r.get('word_count', '?')} words)")

    if failures:
        lines.extend([
            "",
            "## Failures",
        ])
        for f in failures:
            lines.append(f"- {f[:100]}")

    if failure_diagnoses:
        lines.extend([
            "",
            "## Failure Diagnoses",
        ])
        for d in failure_diagnoses:
            lines.append(f"- **{d['diagnosis']}**: {d.get('detail', '')[:80]}")

    if new_tasks:
        lines.extend([
            "",
            "## New Tasks Generated",
        ])
        for t in new_tasks:
            lines.append(f"- `{t[:100]}`")

    lines.append("")
    content = "\n".join(lines)
    REVIEW_SUMMARY.write_text(content)
    return REVIEW_SUMMARY


# ── Step 12: Get failed task log tails ─────────────────────────────────


def get_failed_log_tails(since: timedelta) -> list[str]:
    """Read daemon log, return tail context for recently failed tasks.

    Looks for FAILED lines and collects surrounding context.
    """
    if not DAEMON_LOG.exists():
        return []

    try:
        content = DAEMON_LOG.read_text()
    except (PermissionError, OSError, UnicodeDecodeError):
        return []

    cutoff = datetime.now(UTC) - since
    failures = []

    log_lines = content.splitlines()
    for i, line in enumerate(log_lines):
        m = re.match(
            r'^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] FAILED',
            line,
        )
        if not m:
            continue
        try:
            ts = datetime.strptime(m.group(1), "%Y-%m-%d %H:%M:%S").replace(tzinfo=UTC)
        except ValueError:
            continue
        if ts < cutoff:
            continue
        # Collect context: this line + a few before
        start = max(0, i - 3)
        context = "\n".join(log_lines[start:i + 1])
        failures.append(context)

    return failures


# ── Main review function ───────────────────────────────────────────────


def run_review(auto_requeue: bool = False, since_str: str = "30m") -> int:
    """Run a single review cycle.

    Args:
        auto_requeue: If True, requeue failed tasks with fixes.
        since_str: Time window string like '30m' or '2h'.

    Returns:
        0 on success, 1 on error.
    """
    since = parse_since_arg(since_str)
    log(f"Review starting (since={since_str}, auto_requeue={auto_requeue})")

    # Step 1: Find completed tasks
    completed = get_recent_completed(since)
    log(f"Found {len(completed)} completed tasks")

    # Step 2: Check changed files
    changed = get_changed_files(head_range=5)
    classified = classify_files(changed)
    log(f"Changed: {len(classified['tests'])} tests, {len(classified['effectors'])} effectors, {len(classified['consulting'])} consulting")

    # Step 3: Run tests on new test files
    test_results = {"passed": 0, "failed": 0, "errors": 0, "exit_code": 0, "raw": ""}
    if classified["tests"]:
        log(f"Running pytest on {len(classified['tests'])} new test files...")
        test_results = run_pytest_on_files(classified["tests"])
        log(f"Tests: {test_results['passed']} passed, {test_results['failed']} failed")
    else:
        log("No new test files to check")

    # Step 4: Check consulting content
    consulting_results = []
    if classified["consulting"]:
        consulting_results = check_consulting_content(classified["consulting"])
        ok_count = sum(1 for r in consulting_results if r["ok"])
        log(f"Consulting: {ok_count}/{len(consulting_results)} pass quality check")
    else:
        log("No new consulting content")

    # Step 5: Diagnose failures
    failures = get_failed_log_tails(since)
    failure_diagnoses = []
    for tail in failures:
        diag = diagnose_failure(tail)
        failure_diagnoses.append(diag)
        log(f"Failure diagnosis: {diag['diagnosis']} — {diag['detail'][:60]}")

    # Step 5b: Auto-requeue failed tasks
    new_tasks = []
    if auto_requeue and failure_diagnoses:
        for diag in failure_diagnoses:
            if diag["diagnosis"] == "hardcoded_path":
                task = 'golem --provider infini "Fix hardcoded /Users/terry/ paths in effectors. Use Path.home() everywhere. Run tests after."'
                write_fixed_task(task, priority="high")
                new_tasks.append(task)
            elif diag["diagnosis"] == "import_error":
                mod = diag.get("detail", "").replace("missing module: ", "")
                task = f'golem --provider infini "Fix import error for {mod}. Check if module exists or needs install. Run tests."'
                write_fixed_task(task)
                new_tasks.append(task)
            elif diag["diagnosis"] == "syntax_error":
                task = 'golem --provider infini "Fix Python syntax errors in recently changed files. Run ast.parse() on each .py file."'
                write_fixed_task(task)
                new_tasks.append(task)
        if new_tasks:
            log(f"Auto-requeued {len(new_tasks)} fixed tasks")

    # Step 6: Check queue and auto-generate if low
    pending = count_pending_tasks()
    log(f"Queue: {pending} pending tasks")
    if pending < 50:
        needed = 50 - pending
        generated = auto_generate_tasks(target_count=needed)
        for task in generated:
            write_fixed_task(task)
        new_tasks.extend(generated)
        if generated:
            log(f"Auto-generated {len(generated)} tasks from untested effectors")

    # Step 7: Write review summary
    summary_path = generate_review_summary(
        completed_tasks=completed,
        changed_files=classified,
        test_results=test_results,
        consulting_results=consulting_results,
        failures=failures,
        failure_diagnoses=failure_diagnoses,
        new_tasks=new_tasks,
    )
    log(f"Review summary written to {summary_path}")

    return 0


def main():
    """CLI entry point."""
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0

    auto_requeue = "--auto-requeue" in args
    since_str = "30m"

    # Parse --since argument
    for i, arg in enumerate(args):
        if arg == "--since" and i + 1 < len(args):
            since_str = args[i + 1]
        elif arg.startswith("--since="):
            since_str = arg.split("=", 1)[1]

    once = "--once" in args

    if once:
        return run_review(auto_requeue=auto_requeue, since_str=since_str)

    # Default behavior: run once (no daemon loop for the meta-reviewer)
    return run_review(auto_requeue=auto_requeue, since_str=since_str)


if __name__ == "__main__":
    sys.exit(main())

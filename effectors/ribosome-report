#!/usr/bin/env python3
"""ribosome-report — Generate analytics report from ribosome task logs.

Reads ribosome.jsonl and translation-queue.md, outputs markdown report:
- Tasks completed today (or specified date)
- By provider breakdown
- Success rate, avg duration
- Rate-limit events
- Top 3 longest tasks
- Top 3 most-retried tasks

Usage:
    ribosome-report              # Report for today
    ribosome-report --date 2026-04-01   # Report for specific date
    ribosome-report --help
"""

from __future__ import annotations

import argparse
import json
import re
from collections import defaultdict
from datetime import UTC, datetime
from pathlib import Path

# Paths
JSONL_FILE = Path.home() / ".local" / "share" / "vivesca" / "ribosome.jsonl"
QUEUE_FILE = Path.home() / "germline" / "loci" / "translation-queue.md"

# Rate-limit detection patterns
RATE_LIMIT_PATTERNS = re.compile(
    r"429|AccountQuotaExceeded|rate.?limit|quota.?exceeded|20013|"
    r"request.?limit.?exceeded|API Error.*429|too many requests|TooManyRequests|"
    r"usage.?limit|hit your.*limit|quota will reset|try again at",
    re.IGNORECASE,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Generate analytics report from ribosome task logs"
    )
    parser.add_argument(
        "--date",
        type=str,
        default=None,
        help="Date for report (YYYY-MM-DD). Default: today",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Output as JSON instead of markdown",
    )
    return parser.parse_args()


def parse_timestamp(ts_str: str) -> datetime | None:
    """Parse ISO timestamp string to datetime."""
    for fmt in ("%Y-%m-%dT%H:%M:%SZ", "%Y-%m-%dT%H:%M:%S", "%Y-%m-%dT%H:%M:%S.%fZ"):
        try:
            return datetime.strptime(ts_str, fmt).replace(tzinfo=UTC)
        except ValueError:
            continue
    return None


def load_jsonl(date_filter: str | None) -> list[dict]:
    """Load JSONL records, optionally filtering by date."""
    if not JSONL_FILE.exists():
        return []

    records = []
    try:
        content = JSONL_FILE.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return []

    for line in content.strip().split("\n"):
        if not line.strip():
            continue
        try:
            rec = json.loads(line)
            ts = parse_timestamp(rec.get("ts", ""))
            if ts:
                rec["_dt"] = ts
                if date_filter:
                    rec_date = ts.strftime("%Y-%m-%d")
                    if rec_date != date_filter:
                        continue
                records.append(rec)
        except json.JSONDecodeError:
            continue
    return records


def extract_task_id(prompt: str) -> str:
    """Extract task ID from prompt if present."""
    m = re.search(r"\[t-[a-f0-9]+\]", prompt)
    if m:
        return m.group(0)
    return ""


def get_task_id(rec: dict) -> str:
    """Get task ID from record, checking both task_id field and prompt."""
    # First check the task_id field directly
    tid = rec.get("task_id", "")
    if tid:
        return f"[{tid}]" if not tid.startswith("[") else tid
    # Then try to extract from prompt
    return extract_task_id(rec.get("prompt", ""))


def is_rate_limited(rec: dict) -> bool:
    """Check if a record indicates rate limiting."""
    tail = rec.get("tail", "")
    if RATE_LIMIT_PATTERNS.search(tail):
        return True
    # Also check for exit=1 with empty tail (often rate limit)
    return bool(rec.get("exit") == 1 and not tail.strip() and rec.get("duration", 0) < 10)


def truncate_prompt(prompt: str, max_len: int = 60) -> str:
    """Truncate prompt for display."""
    # Remove coaching notes if present
    if "<coaching-notes>" in prompt:
        prompt = re.sub(r"<coaching-notes>.*?---\s*", "", prompt, flags=re.DOTALL)
    prompt = prompt.strip()
    if len(prompt) > max_len:
        return prompt[: max_len - 3] + "..."
    return prompt


def generate_report(records: list[dict], date_str: str) -> str:
    """Generate markdown report from records."""
    lines = []
    lines.append(f"# Ribosome Report — {date_str}")
    lines.append("")

    if not records:
        lines.append("*No tasks recorded for this date.*")
        return "\n".join(lines)

    # Overall stats
    total = len(records)
    succeeded = sum(1 for r in records if r.get("exit") == 0)
    failed = total - succeeded
    success_rate = (succeeded / total * 100) if total > 0 else 0
    durations = [r.get("duration", 0) for r in records if r.get("duration", 0) > 0]
    avg_duration = sum(durations) / len(durations) if durations else 0
    rate_limits = sum(1 for r in records if is_rate_limited(r))

    lines.append("## Summary")
    lines.append("")
    lines.append("| Metric | Value |")
    lines.append("|--------|-------|")
    lines.append(f"| Total tasks | {total} |")
    lines.append(f"| Succeeded | {succeeded} |")
    lines.append(f"| Failed | {failed} |")
    lines.append(f"| Success rate | {success_rate:.1f}% |")
    lines.append(f"| Avg duration | {avg_duration:.0f}s ({avg_duration / 60:.1f}m) |")
    lines.append(f"| Rate-limit events | {rate_limits} |")
    lines.append("")

    # By provider breakdown
    provider_stats = defaultdict(
        lambda: {"total": 0, "success": 0, "duration": 0, "rate_limits": 0}
    )
    for r in records:
        p = r.get("provider", "unknown")
        provider_stats[p]["total"] += 1
        if r.get("exit") == 0:
            provider_stats[p]["success"] += 1
        provider_stats[p]["duration"] += r.get("duration", 0)
        if is_rate_limited(r):
            provider_stats[p]["rate_limits"] += 1

    lines.append("## By Provider")
    lines.append("")
    lines.append("| Provider | Tasks | Success | Rate | Avg Duration | Rate Limits |")
    lines.append("|----------|-------|---------|------|--------------|-------------|")
    for p in sorted(provider_stats.keys()):
        s = provider_stats[p]
        rate = (s["success"] / s["total"] * 100) if s["total"] > 0 else 0
        avg_dur = s["duration"] / s["total"] if s["total"] > 0 else 0
        lines.append(
            f"| {p} | {s['total']} | {s['success']} | {rate:.0f}% | {avg_dur:.0f}s | {s['rate_limits']} |"
        )
    lines.append("")

    # Top 3 longest tasks
    sorted_by_duration = sorted(records, key=lambda r: r.get("duration", 0), reverse=True)
    lines.append("## Top 3 Longest Tasks")
    lines.append("")
    for i, r in enumerate(sorted_by_duration[:3], 1):
        dur = r.get("duration", 0)
        prov = r.get("provider", "?")
        prompt = truncate_prompt(r.get("prompt", ""))
        status = "✓" if r.get("exit") == 0 else "✗"
        lines.append(f"{i}. [{status}] **{prov}** — {dur}s ({dur / 60:.1f}m): {prompt}")
    lines.append("")

    # Top 3 most-retried tasks (by task_id occurrence)
    task_id_counts = defaultdict(list)
    for r in records:
        tid = get_task_id(r)
        if tid:
            task_id_counts[tid].append(r)

    sorted_by_retries = sorted(task_id_counts.items(), key=lambda x: len(x[1]), reverse=True)
    lines.append("## Top 3 Most-Retried Tasks")
    lines.append("")
    if not sorted_by_retries:
        lines.append("*No task IDs found in records.*")
    else:
        for i, (tid, recs) in enumerate(sorted_by_retries[:3], 1):
            count = len(recs)
            successes = sum(1 for r in recs if r.get("exit") == 0)
            prompt = truncate_prompt(recs[0].get("prompt", ""))
            lines.append(f"{i}. **{tid}** — {count} attempts, {successes} success: {prompt}")
    lines.append("")

    return "\n".join(lines)


def main() -> None:
    args = parse_args()

    # Determine date filter
    date_str = args.date or datetime.now().strftime("%Y-%m-%d")

    records = load_jsonl(date_str)

    if args.json:
        # Output as JSON
        output = {
            "date": date_str,
            "total": len(records),
            "records": records,
        }
        print(json.dumps(output, indent=2, default=str))
    else:
        report = generate_report(records, date_str)
        print(report)


if __name__ == "__main__":
    main()

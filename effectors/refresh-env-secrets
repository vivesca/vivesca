#!/usr/bin/env bash
# Refresh ~/.cache/env-secrets.sh — cached exports sourced by .zshenv.
#
# Why: .zshenv is evaluated for every zsh invocation (interactive and
# non-interactive). Inline `op read` calls there added ~4.5s to every
# shell start. This script batches the 1Password lookups into a file
# that .zshenv can source deterministically.
#
# Requires OP_SERVICE_ACCOUNT_TOKEN in the environment (set by .zshenv
# itself, or by the caller). Run on demand, from a daily cron, or after
# rotating any of the referenced 1Password items.
set -euo pipefail

: "${OP_SERVICE_ACCOUNT_TOKEN:?OP_SERVICE_ACCOUNT_TOKEN must be set}"

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
cache_file="$cache_dir/env-secrets.sh"
mkdir -p "$cache_dir"

read_secret() {
  op read "$1" 2>/dev/null | tr -d '\n'
}

openrouter_key=$(read_secret 'op://Agents/OpenRouter API Key/credential')
twitter_auth=$(read_secret  'op://Agents/Twitter CLI Cookies/auth_token')
twitter_ct0=$(read_secret   'op://Agents/Twitter CLI Cookies/ct0')
oura_token=$(read_secret    'op://Agents/oura-token/credential')

tmp=$(mktemp "$cache_file.XXXXXX")
trap 'rm -f "$tmp"' EXIT
{
  echo "# Generated by refresh-env-secrets on $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "# Do not edit — run refresh-env-secrets to regenerate."
  printf 'export OPENROUTER_API_KEY=%q\n' "$openrouter_key"
  printf 'export TWITTER_AUTH_TOKEN=%q\n' "$twitter_auth"
  printf 'export TWITTER_CT0=%q\n'        "$twitter_ct0"
  printf 'export OURA_TOKEN=%q\n'         "$oura_token"
} > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$cache_file"
trap - EXIT

echo "wrote $cache_file"

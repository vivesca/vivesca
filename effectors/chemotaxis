#!/usr/bin/env python3
"""chemotaxis — web search via Perplexity API.

Usage:
  chemotaxis <query>         # Quick search (sonar, ~$0.006)
  chemotaxis -d <query>      # Deep search (sonar-pro, ~$0.01)
  chemotaxis -r <query>      # Research (sonar-deep-research, ~$0.40)
  chemotaxis --json <query>  # Structured output
"""

import argparse
import json
import sys


def main():
    parser = argparse.ArgumentParser(description="Web search via Perplexity")
    parser.add_argument("query", nargs="+", help="Search query")
    parser.add_argument("-d", "--deep", action="store_true", help="Thorough search (~$0.01)")
    parser.add_argument("-r", "--research", action="store_true", help="Deep research (~$0.40)")
    parser.add_argument("--json", action="store_true", help="JSON output")
    args = parser.parse_args()

    query = " ".join(args.query)

    try:
        from metabolon.organelles.chemotaxis_engine import ask, recall, research

        if args.research:
            result = research(query)
            method = "research"
        elif args.deep:
            result = ask(query)
            method = "ask"
        else:
            result = recall(query)
            method = "search"
    except Exception as e:
        if args.json:
            print(json.dumps({"success": False, "error": str(e)}))
        else:
            print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    if args.json:
        print(json.dumps({"success": True, "text": result, "method": method}, ensure_ascii=False))
    else:
        print(result)


if __name__ == "__main__":
    main()

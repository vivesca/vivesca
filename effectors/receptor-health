#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""
Health check for membrane/receptors/*/SKILL.md files.

Validates YAML front matter, checks description length, and verifies
referenced companion files (recipe.yaml, relative links in body).

Usage:
    receptor-health              # Check all receptors, table output
    receptor-health --json       # JSON output
    receptor-health --dir DIR    # Scan a different directory
"""

import argparse
import json
import re
import sys
from dataclasses import dataclass, field
from pathlib import Path

import yaml

MIN_DESC_LEN = 10
MAX_DESC_LEN = 200

RECEPTORS_DIR = Path(__file__).resolve().parents[1] / "membrane" / "receptors"


def parse_front_matter(text: str) -> tuple[dict, str, str | None]:
    """Parse YAML front matter from a SKILL.md file.

    Returns (metadata_dict, body_text, error_string_or_None).
    """
    if not text.startswith("---"):
        return {}, text, "missing opening --- delimiter"

    # Find the closing ---
    rest = text[3:]
    if rest.startswith("\n"):
        rest = rest[1:]
    close_idx = rest.find("\n---")
    if close_idx == -1:
        return {}, text, "missing closing --- delimiter"

    yaml_text = rest[:close_idx]
    body = rest[close_idx + 4:].lstrip("\n")

    try:
        meta = yaml.safe_load(yaml_text)
    except yaml.YAMLError as e:
        return {}, body, f"invalid YAML: {e}"

    if meta is None:
        meta = {}
    if not isinstance(meta, dict):
        return {}, body, f"front matter is not a mapping (got {type(meta).__name__})"

    return meta, body, None


def validate_skill(dir_name: str, meta: dict, body: str) -> list[str]:
    """Validate a parsed SKILL.md. Returns list of error strings."""
    errors: list[str] = []

    # Required field: name
    if "name" not in meta or not meta["name"]:
        errors.append("missing required field 'name'")

    # Required field: description
    desc = meta.get("description", "")
    if not desc:
        errors.append("missing required field 'description'")
    elif not isinstance(desc, str):
        errors.append(f"'description' should be a string, got {type(desc).__name__}")
    else:
        desc_len = len(desc)
        if desc_len < MIN_DESC_LEN:
            errors.append(f"description too short ({desc_len} chars, minimum {MIN_DESC_LEN})")
        if desc_len > MAX_DESC_LEN:
            errors.append(f"description too long ({desc_len} chars, maximum {MAX_DESC_LEN})")

    return errors


def check_referenced_files(receptor_dir: Path, body: str) -> list[str]:
    """Check that companion/linked files exist. Returns list of error strings."""
    errors: list[str] = []

    # Check recipe.yaml exists and is valid YAML
    recipe_path = receptor_dir / "recipe.yaml"
    if not recipe_path.exists():
        errors.append("missing companion recipe.yaml")
    else:
        try:
            with open(recipe_path) as f:
                yaml.safe_load(f)
        except yaml.YAMLError as e:
            errors.append(f"recipe.yaml has invalid YAML: {e}")

    # Check relative file references in markdown body (e.g. [text](./file.md))
    for match in re.finditer(r"\[[^\]]*\]\((\.\/[^)]+)\)", body):
        ref = match.group(1)
        ref_path = receptor_dir / ref
        if not ref_path.exists():
            errors.append(f"referenced file not found: {ref}")

    return errors


def scan_receptors(receptors_dir: Path) -> list[dict]:
    """Scan all receptor directories and return health results."""
    results: list[dict] = []

    if not receptors_dir.exists():
        return results

    for skill_dir in sorted(receptors_dir.iterdir()):
        if not skill_dir.is_dir():
            continue
        skill_path = skill_dir / "SKILL.md"
        if not skill_path.exists():
            continue

        text = skill_path.read_text(encoding="utf-8")
        meta, body, parse_err = parse_front_matter(text)

        errors: list[str] = []
        name = skill_dir.name

        if parse_err:
            errors.append(parse_err)
        else:
            name = meta.get("name", skill_dir.name)
            errors.extend(validate_skill(skill_dir.name, meta, body))
            errors.extend(check_referenced_files(skill_dir, body))

        results.append({
            "name": name,
            "dir": skill_dir.name,
            "errors": errors,
        })

    return results


def print_table(results: list[dict]) -> None:
    """Print a human-readable table of results."""
    broken = [r for r in results if r["errors"]]
    healthy = [r for r in results if not r["errors"]]

    if healthy:
        print(f"\n  HEALTHY: {len(healthy)} receptors OK")

    if broken:
        print(f"\n  BROKEN: {len(broken)} receptors with issues\n")
        for r in broken:
            print(f"  ✗ {r['name']} ({r['dir']})")
            for e in r["errors"]:
                print(f"      - {e}")
    else:
        print(f"\n  All {len(results)} receptors healthy.")

    print(f"\n  Total: {len(results)} | Healthy: {len(healthy)} | Broken: {len(broken)}")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Validate receptor SKILL.md files"
    )
    parser.add_argument(
        "--json", action="store_true",
        help="Output results as JSON",
    )
    parser.add_argument(
        "--dir", type=Path, default=RECEPTORS_DIR,
        help="Receptors directory to scan",
    )
    args = parser.parse_args(argv)

    results = scan_receptors(args.dir)

    if args.json:
        print(json.dumps(results, indent=2))
    else:
        print_table(results)

    return 1 if any(r["errors"] for r in results) else 0


if __name__ == "__main__":
    raise SystemExit(main())

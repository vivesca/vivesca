#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""
Health check for membrane/receptors/*/SKILL.md files.

Validates YAML front matter, checks description length, and verifies
referenced companion files (recipe.yaml, relative links in body).

Usage:
    receptor-health              # Check all receptors, table output
    receptor-health --json       # JSON output
    receptor-health debridement  # Check a specific receptor
"""

import argparse
import json
import re
import sys
from dataclasses import dataclass, field
from pathlib import Path

import yaml

MAX_DESC_LEN = 500

RECEPTORS_DIR = Path(__file__).resolve().parents[1] / "membrane" / "receptors"


@dataclass
class Issue:
    """A single validation issue found in a receptor."""
    receptor: str
    severity: str   # "error" or "warn"
    check: str      # e.g. "frontmatter", "recipe_yaml", "description_length"
    detail: str


@dataclass
class ReceptorReport:
    """Validation report for a single receptor."""
    receptor: str
    ok: bool = True
    issues: list[Issue] = field(default_factory=list)


def parse_frontmatter(text: str) -> tuple[dict | None, str]:
    """Parse YAML front matter from a SKILL.md file.

    Returns (metadata_dict_or_None, error_string).
    """
    if not text.startswith("---"):
        return None, "no YAML frontmatter found"

    # Find the closing ---
    rest = text[3:]
    if rest.startswith("\n"):
        rest = rest[1:]
    close_idx = rest.find("\n---")
    if close_idx == -1:
        return None, "no YAML frontmatter found: missing closing ---"

    yaml_text = rest[:close_idx]

    try:
        meta = yaml.safe_load(yaml_text)
    except yaml.YAMLError as e:
        return None, f"YAML parse error: {e}"

    if meta is None:
        return None, "no YAML frontmatter found"
    if not isinstance(meta, dict):
        return None, f"frontmatter is not a mapping (got {type(meta).__name__})"

    return meta, ""


def check_frontmatter(name: str, meta: dict | None, report: ReceptorReport) -> None:
    """Check that frontmatter has required fields (name, description)."""
    if meta is None:
        report.ok = False
        report.issues.append(Issue(name, "error", "frontmatter", "no valid YAML frontmatter"))
        return

    if "name" not in meta or not meta["name"]:
        report.ok = False
        report.issues.append(Issue(name, "error", "frontmatter", "missing required field 'name'"))

    if "description" not in meta or not meta["description"]:
        report.ok = False
        report.issues.append(Issue(name, "error", "frontmatter", "missing required field 'description'"))


def check_description_length(name: str, meta: dict | None, report: ReceptorReport) -> None:
    """Warn if description is suspiciously long."""
    if meta is None:
        return
    desc = meta.get("description", "")
    if isinstance(desc, str) and len(desc) > MAX_DESC_LEN:
        report.issues.append(Issue(
            name, "warn", "description_length",
            f"description is {len(desc)} chars (>{MAX_DESC_LEN})"
        ))


def check_recipe_yaml(name: str, receptor_dir: Path, report: ReceptorReport) -> None:
    """Check recipe.yaml if it exists: valid YAML and required keys."""
    recipe_path = receptor_dir / "recipe.yaml"
    if not recipe_path.exists():
        return

    try:
        with open(recipe_path) as f:
            data = yaml.safe_load(f)
    except yaml.YAMLError as e:
        report.ok = False
        report.issues.append(Issue(name, "error", "recipe_yaml", f"invalid YAML: {e}"))
        return

    if not isinstance(data, dict):
        report.ok = False
        report.issues.append(Issue(name, "error", "recipe_yaml", "recipe.yaml is not a mapping"))
        return

    required_keys = {"name", "description", "instructions"}
    missing = required_keys - set(data.keys())
    if missing:
        report.ok = False
        report.issues.append(Issue(
            name, "error", "recipe_yaml",
            f"missing required keys: {', '.join(sorted(missing))}"
        ))


def check_referenced_files(name: str, receptor_dir: Path, report: ReceptorReport) -> None:
    """Check for filename case issues and referenced directories."""
    # Check for lowercase skill.md (should be SKILL.md)
    if (receptor_dir / "skill.md").exists() and not (receptor_dir / "SKILL.md").exists():
        report.ok = False
        report.issues.append(Issue(name, "error", "filename_case", "skill.md should be SKILL.md"))

    # Check if body mentions a references/ directory that doesn't exist
    skill_path = receptor_dir / "SKILL.md"
    if skill_path.exists():
        text = skill_path.read_text(encoding="utf-8")
        if "references/" in text or "references\\" in text:
            ref_dir = receptor_dir / "references"
            if not ref_dir.exists():
                report.ok = False
                report.issues.append(Issue(
                    name, "error", "referenced_files",
                    f"references directory mentioned but not found"
                ))


def check_receptor(receptor_dir: Path) -> ReceptorReport:
    """Run all checks on a single receptor directory."""
    name = receptor_dir.name
    report = ReceptorReport(receptor=name)

    skill_path = receptor_dir / "SKILL.md"
    if not skill_path.exists():
        report.ok = False
        report.issues.append(Issue(name, "error", "skill_missing", "SKILL.md not found"))
        return report

    text = skill_path.read_text(encoding="utf-8")
    meta, err = parse_frontmatter(text)

    if err:
        report.ok = False
        report.issues.append(Issue(name, "error", "frontmatter", err))
        # Still check recipe and referenced files
        check_recipe_yaml(name, receptor_dir, report)
        check_referenced_files(name, receptor_dir, report)
        return report

    check_frontmatter(name, meta, report)
    check_description_length(name, meta, report)
    check_recipe_yaml(name, receptor_dir, report)
    check_referenced_files(name, receptor_dir, report)

    return report


def format_table(reports: list[ReceptorReport]) -> str:
    """Format reports as a human-readable table string."""
    lines: list[str] = []
    broken = [r for r in reports if not r.ok]
    healthy = [r for r in reports if r.ok]

    lines.append(f"\n  HEALTHY: {len(healthy)} receptors OK")

    if broken:
        lines.append(f"\n  BROKEN: {len(broken)} receptors with issues\n")
        for r in broken:
            lines.append(f"  ✗ {r.receptor}")
            for i in r.issues:
                lines.append(f"      [{i.severity}] {i.check}: {i.detail}")
    else:
        lines.append(f"\n  All {len(reports)} receptors healthy.")

    lines.append(f"\n  Total: {len(reports)} | Healthy: {len(healthy)} | Broken: {len(broken)}")
    return "\n".join(lines)


def format_json(reports: list[ReceptorReport]) -> str:
    """Format reports as JSON string."""
    data = []
    for r in reports:
        data.append({
            "receptor": r.receptor,
            "ok": r.ok,
            "issues": [
                {"severity": i.severity, "check": i.check, "detail": i.detail}
                for i in r.issues
            ],
        })
    return json.dumps(data, indent=2)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Validate receptor SKILL.md files"
    )
    parser.add_argument(
        "receptors", nargs="*",
        help="Specific receptor names to check (default: all)",
    )
    parser.add_argument(
        "--json", action="store_true",
        help="Output results as JSON",
    )
    parser.add_argument(
        "--dir", type=Path, default=RECEPTORS_DIR,
        help="Receptors directory to scan",
    )
    args = parser.parse_args(argv)

    receptors_dir = args.dir

    if args.receptors:
        # Check specific receptors
        reports: list[ReceptorReport] = []
        for name in args.receptors:
            d = receptors_dir / name
            if not d.exists():
                print(f"receptor '{name}' not found in {receptors_dir}", file=sys.stderr)
                reports.append(ReceptorReport(receptor=name, ok=False, issues=[
                    Issue(name, "error", "not_found", f"directory not found: {d}")
                ]))
            else:
                reports.append(check_receptor(d))
    else:
        # Scan all
        reports = []
        for d in sorted(receptors_dir.iterdir()):
            if d.is_dir():
                reports.append(check_receptor(d))

    if args.json:
        print(format_json(reports))
    else:
        print(format_table(reports))

    return 1 if any(not r.ok for r in reports) else 0


if __name__ == "__main__":
    raise SystemExit(main())

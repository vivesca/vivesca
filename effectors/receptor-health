#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# ///
"""receptor-health — validate every membrane/receptors/*/SKILL.md and recipe.yaml.

Checks YAML parseability, required frontmatter fields, description length,
body size, auxiliary files, and referenced-file existence. Exits 0 when
all receptors pass, exits 1 with a report of broken ones.

Usage:
    receptor-health              # scan all active receptors
    receptor-health --json       # machine-readable output
    receptor-health sporulation   # check one receptor
"""

from __future__ import annotations

import json
import re
import sys
from pathlib import Path

import yaml

GERMLINE = Path(__file__).resolve().parent.parent
RECEPTORS = GERMLINE / "membrane" / "receptors"

MAX_DESC_LEN = 1024
MAX_BODY_LINES = 500
ALLOWED_FILES = {"SKILL.md", "recipe.yaml"}
ALLOWED_DIRS = {"scripts", "references", "agents"}

# ---------------------------------------------------------------------------
# Data classes
# ---------------------------------------------------------------------------


class Violation:
    """Single check failure."""

    __slots__ = ("check", "detail", "receptor")

    def __init__(self, receptor: str, check: str, detail: str) -> None:
        self.receptor = receptor
        self.check = check
        self.detail = detail

    def __repr__(self) -> str:
        return f"[{self.receptor}] {self.check}: {self.detail}"

    def to_dict(self) -> dict:
        return {"receptor": self.receptor, "check": self.check, "detail": self.detail}


# ---------------------------------------------------------------------------
# SKILL.md checks
# ---------------------------------------------------------------------------


def parse_frontmatter(text: str) -> tuple[dict | None, str, list[str]]:
    """Return (frontmatter_dict, body_text, errors)."""
    errors: list[str] = []
    if not text.startswith("---"):
        return None, text, ["no opening --- frontmatter delimiter"]

    # Find closing ---
    close = text.find("\n---", 3)
    if close == -1:
        return None, text, ["no closing --- frontmatter delimiter"]

    fm_raw = text[3:close]
    body = text[close + 4 :]

    try:
        fm = yaml.safe_load(fm_raw)
    except yaml.YAMLError as exc:
        return None, body, [f"YAML parse error: {exc}"]

    if not isinstance(fm, dict):
        return None, body, [f"frontmatter is {type(fm).__name__}, expected mapping"]

    return fm, body, errors


def check_skill_md(skill_path: Path, receptor: str) -> list[Violation]:
    """Validate a single SKILL.md. Returns list of violations."""
    v: list[Violation] = []

    if not skill_path.exists():
        v.append(Violation(receptor, "SKILL.md", "file missing"))
        return v

    text = skill_path.read_text(encoding="utf-8")
    fm, body, fm_errors = parse_frontmatter(text)

    for err in fm_errors:
        v.append(Violation(receptor, "frontmatter", err))

    if fm is not None:
        for field in ("name", "description"):
            val = fm.get(field)
            if not val or (isinstance(val, str) and not val.strip()):
                v.append(Violation(receptor, "missing-field", f"{field} is empty or absent"))

        desc = fm.get("description", "")
        if isinstance(desc, str) and len(desc) > MAX_DESC_LEN:
            v.append(
                Violation(
                    receptor, "description-length", f"{len(desc)} chars (max {MAX_DESC_LEN})"
                )
            )

    # Body line count (lines after frontmatter)
    body_lines = body.count("\n") + 1 if body else 0
    if body_lines > MAX_BODY_LINES:
        v.append(Violation(receptor, "body-size", f"{body_lines} lines (max {MAX_BODY_LINES})"))

    return v


# ---------------------------------------------------------------------------
# recipe.yaml checks
# ---------------------------------------------------------------------------


def check_recipe_yaml(recipe_path: Path, receptor: str) -> list[Violation]:
    """Validate recipe.yaml. Returns list of violations."""
    v: list[Violation] = []

    if not recipe_path.exists():
        # recipe.yaml is optional
        return v

    text = recipe_path.read_text(encoding="utf-8")
    try:
        data = yaml.safe_load(text)
    except yaml.YAMLError as exc:
        v.append(Violation(receptor, "recipe-yaml", f"parse error: {exc}"))
        return v

    if not isinstance(data, dict):
        v.append(
            Violation(receptor, "recipe-yaml", f"root is {type(data).__name__}, expected mapping")
        )
        return v

    for field in ("name", "description"):
        val = data.get(field)
        if not val or (isinstance(val, str) and not val.strip()):
            v.append(
                Violation(
                    receptor, "recipe-missing-field", f"{field} is empty or absent in recipe.yaml"
                )
            )

    # Check referenced extensions URIs — local file paths only
    extensions = data.get("extensions", [])
    if isinstance(extensions, list):
        for ext in extensions:
            if not isinstance(ext, dict):
                continue
            uri = ext.get("uri", "")
            if uri and not uri.startswith(("http://", "https://", "ws://", "wss://")):
                ref = (recipe_path.parent / uri).resolve()
                if not ref.exists():
                    v.append(
                        Violation(
                            receptor,
                            "reference-broken",
                            f"extension uri references missing: {uri}",
                        )
                    )

    # Check prompt field references to local paths
    prompt = data.get("prompt", "")
    if isinstance(prompt, str):
        # Look for ~/ or relative path references
        for match in re.finditer(r'[\s"\']([~/][\w./\-]+)', prompt):
            ref_str = match.group(1)
            if ref_str.startswith("~/"):
                ref = Path(ref_str).expanduser()
            else:
                ref = recipe_path.parent / ref_str
            if ref.exists():
                continue
            # Only flag if it looks like a deliberate file reference
            if ref_str.endswith((".py", ".sh", ".md", ".yaml", ".json")):
                v.append(
                    Violation(
                        receptor, "reference-broken", f"prompt references missing: {ref_str}"
                    )
                )

    return v


# ---------------------------------------------------------------------------
# Directory structure checks
# ---------------------------------------------------------------------------


def check_directory(receptor_dir: Path, receptor: str) -> list[Violation]:
    """Check for disallowed auxiliary files in receptor directory."""
    v: list[Violation] = []

    for child in receptor_dir.iterdir():
        if child.name.startswith("."):
            continue
        if child.is_file() and child.name not in ALLOWED_FILES:
            v.append(Violation(receptor, "auxiliary-file", f"unexpected file: {child.name}"))
        elif child.is_dir() and child.name not in ALLOWED_DIRS:
            v.append(Violation(receptor, "auxiliary-dir", f"unexpected directory: {child.name}"))

    return v


# ---------------------------------------------------------------------------
# Main scan
# ---------------------------------------------------------------------------


def scan_receptors(names: list[str] | None = None) -> list[Violation]:
    """Scan all (or named) receptors. Returns all violations."""
    violations: list[Violation] = []

    if not RECEPTORS.is_dir():
        print(f"ERROR: {RECEPTORS} is not a directory", file=sys.stderr)
        return [Violation("(root)", "config", f"{RECEPTORS} not found")]

    for child in sorted(RECEPTORS.iterdir()):
        if child.name.startswith("."):
            continue
        if not child.is_dir():
            continue
        if names and child.name not in names:
            continue

        receptor = child.name
        skill_path = child / "SKILL.md"
        recipe_path = child / "recipe.yaml"

        violations.extend(check_skill_md(skill_path, receptor))
        violations.extend(check_recipe_yaml(recipe_path, receptor))
        violations.extend(check_directory(child, receptor))

    return violations


def format_report(violations: list[Violation]) -> str:
    """Format violations into a human-readable report."""
    if not violations:
        return "All receptors healthy — no violations found."

    by_receptor: dict[str, list[Violation]] = {}
    for v in violations:
        by_receptor.setdefault(v.receptor, []).append(v)

    lines: list[str] = [f"Receptor Health Report — {len(violations)} violation(s)"]
    lines.append("=" * 50)

    for receptor, viols in sorted(by_receptor.items()):
        lines.append(f"\n## {receptor} ({len(viols)} issue(s))")
        for v in viols:
            lines.append(f"  [{v.check}] {v.detail}")

    lines.append(f"\nTotal: {len(violations)} violation(s) across {len(by_receptor)} receptor(s)")
    return "\n".join(lines)


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        sys.exit(0)
    args = sys.argv[1:]
    use_json = "--json" in args
    names = [a for a in args if not a.startswith("-")]

    violations = scan_receptors(names or None)

    if use_json:
        print(json.dumps([v.to_dict() for v in violations], indent=2))
    else:
        print(format_report(violations))

    sys.exit(1 if violations else 0)


if __name__ == "__main__":
    main()

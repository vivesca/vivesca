#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""
respirometry — Claude Code plan usage plus coding cost split.

Tries live Anthropic OAuth API first (requires Keychain access).
Falls back to cached JSONL history when Keychain is unavailable
(e.g. inside Claude Code sandbox).

Writes to history on every successful live fetch so the cache stays
fresh for sandbox callers.

Output for --json uses the canonical format:
  {seven_day: {utilization, resets_at}, seven_day_sonnet: {utilization, resets_at},
   stale: bool, stale_age_seconds: int|null, source: "live"|"history"|"watch",
   cost_tracking: {...}}
"""

import argparse
import json
import re
import subprocess
import sys
import urllib.request
from collections import Counter
from datetime import UTC, date, datetime, timedelta
from pathlib import Path
from typing import Any

HISTORY = Path.home() / ".local/share/respirometry/history.jsonl"
USAGE_HISTORY = Path.home() / ".local/share/vivesca/usage-history.jsonl"
# Also check respirometry-watch log (different format, written by LaunchAgent)
WATCH_LOG = Path.home() / "docs/respirometry-log.jsonl"
SORTASE_LOG = Path.home() / ".local/share/sortase/log.jsonl"
UTC = UTC
FLAT_RATE_TOOLS = {"goose", "droid", "cc-glm"}
COST_WINDOW_DAYS = 7
METERED_COST_PATTERN = re.compile(r"^\$(\d+(?:\.\d+)?)$")

# Data is considered fresh if less than this many seconds old
FRESH_THRESHOLD = 300  # 5 minutes


def format_age(seconds: float) -> str:
    if seconds < 60:
        return f"{int(seconds)}s ago"
    elif seconds < 3600:
        return f"{int(seconds / 60)}m ago"
    elif seconds < 86400:
        return f"{int(seconds / 3600)}h ago"
    else:
        return f"{int(seconds / 86400)}d ago"


# ---------------------------------------------------------------------------
# Live API fetch
# ---------------------------------------------------------------------------


def _get_oauth_token() -> str:
    """Read OAuth token from CC credentials file or macOS Keychain. Raises RuntimeError on failure."""
    # Try credentials file first (works from any context)
    creds_file = Path.home() / ".claude" / ".credentials.json"
    if creds_file.exists():
        data = json.loads(creds_file.read_text())
        oauth = data["claudeAiOauth"]
        now_ms = int(datetime.now(UTC).timestamp() * 1000)
        if oauth["expiresAt"] < now_ms:
            raise RuntimeError("OAuth token expired")
        return oauth["accessToken"]

    # Fallback to Keychain
    result = subprocess.run(
        ["security", "find-generic-password", "-s", "Claude Code-credentials", "-w"],
        capture_output=True,
        text=True,
        timeout=10,
    )
    if result.returncode != 0:
        raise RuntimeError("No credentials file or Keychain entry found")

    data = json.loads(result.stdout.strip())
    oauth = data["claudeAiOauth"]
    now_ms = int(datetime.now(UTC).timestamp() * 1000)
    if oauth["expiresAt"] < now_ms:
        raise RuntimeError("OAuth token expired")

    return oauth["accessToken"]


def _fetch_live() -> dict:
    """Fetch usage from Anthropic API. Returns raw API dict. Raises on failure."""
    token = _get_oauth_token()
    req = urllib.request.Request(
        "https://api.anthropic.com/api/oauth/usage",
        headers={
            "Authorization": f"Bearer {token}",
            "anthropic-beta": "oauth-2025-04-20",
            "User-Agent": "respirometry/2.0.0",
            "Accept": "application/json",
        },
    )
    with urllib.request.urlopen(req, timeout=15) as resp:
        return json.loads(resp.read())


def _write_history(usage: dict) -> None:
    """Persist a live fetch to history.jsonl."""
    HISTORY.parent.mkdir(parents=True, exist_ok=True)
    row = {
        "ts": datetime.now(UTC).isoformat(),
        "metrics": {
            k: usage[k]
            for k in ["seven_day", "seven_day_sonnet", "five_hour"]
            if k in usage
        },
    }
    with open(HISTORY, "a") as f:
        f.write(json.dumps(row) + "\n")


# ---------------------------------------------------------------------------
# Cache read
# ---------------------------------------------------------------------------


def _read_last_line(path: Path) -> dict[str, Any] | None:
    if not path.exists():
        return None
    lines = path.read_text().strip().splitlines()
    if not lines:
        return None
    return json.loads(lines[-1])


def _read_cache() -> tuple[dict[str, Any] | None, int | None]:
    """Read most recent cached entry. Returns (entry, age_seconds) or (None, None)."""
    for path in [HISTORY, WATCH_LOG]:
        entry = _read_last_line(path)
        if not entry:
            continue
        ts_str = entry.get("ts", "")
        try:
            ts = datetime.fromisoformat(ts_str)
            age = int((datetime.now(UTC) - ts.astimezone(UTC)).total_seconds())
        except (ValueError, TypeError):
            age = -1
        return entry, age if age >= 0 else None
    return None, None


def _normalise_cached(entry: dict[str, Any]) -> dict[str, Any]:
    """Convert cached entry to canonical seven_day/seven_day_sonnet format."""
    if "metrics" in entry:
        return entry["metrics"]
    # Old flat format
    return {
        "seven_day": {"utilization": entry.get("weekly_pct", 0)},
        "seven_day_sonnet": {"utilization": entry.get("sonnet_pct", 0)},
    }


# ---------------------------------------------------------------------------
# Main sense call
# ---------------------------------------------------------------------------


def _parse_metered_cost(cost_estimate: str) -> float | None:
    matched_cost = METERED_COST_PATTERN.match(cost_estimate.strip())
    if matched_cost is None:
        return None
    return float(matched_cost.group(1))


def _read_cost_rows(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        return []

    rows: list[dict[str, Any]] = []
    for line in path.read_text().splitlines():
        try:
            row = json.loads(line)
        except json.JSONDecodeError:
            continue
        if not isinstance(row, dict):
            continue
        timestamp = row.get("timestamp")
        if not isinstance(timestamp, str):
            continue
        try:
            row["_parsed_timestamp"] = datetime.fromisoformat(timestamp)
        except ValueError:
            continue
        rows.append(row)
    return rows


def _classify_cost_mode(row: dict[str, Any]) -> str:
    cost_estimate = str(row.get("cost_estimate", "")).strip()
    tool = str(row.get("tool", "")).strip()

    if tool in FLAT_RATE_TOOLS:
        # Older rows sometimes logged "$0.0000" instead of the flat-rate label.
        return "flat-rate"
    if "flat-rate" in cost_estimate:
        return "flat-rate"
    if _parse_metered_cost(cost_estimate) is not None:
        return "metered"
    if tool:
        return "metered"
    return "unknown"


def _tool_mix(counter: Counter[str]) -> dict[str, int]:
    return {tool: counter[tool] for tool in sorted(counter)}


def _summarize_cost_rows(rows: list[dict[str, Any]]) -> dict[str, Any]:
    flat_rate_tool_counts: Counter[str] = Counter()
    metered_tool_counts: Counter[str] = Counter()
    flat_rate_runs = 0
    metered_runs = 0
    unknown_runs = 0
    metered_cost_usd = 0.0
    total_duration_s = 0.0
    total_tasks = 0
    successful_runs = 0

    for row in rows:
        tool = str(row.get("tool", "")).strip() or "unknown"
        total_duration_s += float(row.get("duration_s", 0.0) or 0.0)
        total_tasks += int(row.get("tasks", 0) or 0)
        successful_runs += 1 if row.get("success") else 0

        mode = _classify_cost_mode(row)
        if mode == "flat-rate":
            flat_rate_runs += 1
            flat_rate_tool_counts[tool] += 1
            continue
        if mode == "metered":
            metered_runs += 1
            metered_tool_counts[tool] += 1
            cost_value = _parse_metered_cost(str(row.get("cost_estimate", "")))
            if cost_value is not None:
                metered_cost_usd += cost_value
            continue
        unknown_runs += 1

    classified_runs = flat_rate_runs + metered_runs
    flat_rate_pct = (flat_rate_runs / classified_runs * 100.0) if classified_runs else 0.0
    metered_pct = (metered_runs / classified_runs * 100.0) if classified_runs else 0.0

    return {
        "runs": len(rows),
        "successful_runs": successful_runs,
        "tasks": total_tasks,
        "duration_s": round(total_duration_s, 3),
        "duration_hours": round(total_duration_s / 3600.0, 2),
        "flat_rate_runs": flat_rate_runs,
        "metered_runs": metered_runs,
        "unknown_runs": unknown_runs,
        "metered_cost_usd": round(metered_cost_usd, 4),
        "flat_rate_pct": round(flat_rate_pct, 1),
        "metered_pct": round(metered_pct, 1),
        "flat_rate_tools": _tool_mix(flat_rate_tool_counts),
        "metered_tools": _tool_mix(metered_tool_counts),
    }


def get_cost_tracking(now: datetime | None = None) -> dict[str, Any]:
    rows = _read_cost_rows(SORTASE_LOG)
    if not rows:
        return {"available": False, "source": "sortase", "lookback_days": COST_WINDOW_DAYS}

    reference_time = now or datetime.now()
    current_start = reference_time - timedelta(days=COST_WINDOW_DAYS)
    previous_start = current_start - timedelta(days=COST_WINDOW_DAYS)

    current_rows = [
        row for row in rows if current_start <= row["_parsed_timestamp"] <= reference_time
    ]
    previous_rows = [
        row for row in rows if previous_start <= row["_parsed_timestamp"] < current_start
    ]

    current_summary = _summarize_cost_rows(current_rows)
    previous_summary = _summarize_cost_rows(previous_rows)
    trend = {
        "runs_delta": current_summary["runs"] - previous_summary["runs"],
        "tasks_delta": current_summary["tasks"] - previous_summary["tasks"],
        "duration_hours_delta": round(
            current_summary["duration_hours"] - previous_summary["duration_hours"], 2
        ),
        "flat_rate_runs_delta": current_summary["flat_rate_runs"] - previous_summary["flat_rate_runs"],
        "metered_runs_delta": current_summary["metered_runs"] - previous_summary["metered_runs"],
        "metered_cost_usd_delta": round(
            current_summary["metered_cost_usd"] - previous_summary["metered_cost_usd"], 4
        ),
    }
    return {
        "available": True,
        "source": "sortase",
        "lookback_days": COST_WINDOW_DAYS,
        "current_7d": current_summary,
        "previous_7d": previous_summary,
        "trend": trend,
    }


def get_usage() -> dict[str, Any]:
    """Fetch usage, trying live API first. Returns canonical dict.

    Keys: seven_day, seven_day_sonnet, stale, stale_age_seconds, source.
    """
    # Try live first
    try:
        live = _fetch_live()
        _write_history(live)
        return {
            "seven_day": live.get("seven_day", {}),
            "seven_day_sonnet": live.get("seven_day_sonnet", {}),
            "stale": False,
            "stale_age_seconds": None,
            "source": "live",
            "cost_tracking": get_cost_tracking(),
        }
    except Exception:
        pass

    # Fall back to cache
    entry, age = _read_cache()
    if entry is None:
        return {"error": "no cached data"}

    metrics = _normalise_cached(entry)
    stale = age is None or age > FRESH_THRESHOLD
    return {
        "seven_day": metrics.get("seven_day", {}),
        "seven_day_sonnet": metrics.get("seven_day_sonnet", {}),
        "stale": stale,
        "stale_age_seconds": age,
        "source": "cache",
        "cost_tracking": get_cost_tracking(),
    }


# ---------------------------------------------------------------------------
# Derived helpers (used by --budget flag and human-readable output)
# ---------------------------------------------------------------------------


def _weekly_pct(usage: dict) -> float:
    return _normalise_pct(usage.get("seven_day", {}).get("utilization", -1))


def _sonnet_pct(usage: dict) -> float:
    return _normalise_pct(usage.get("seven_day_sonnet", {}).get("utilization", -1))


def _normalise_pct(value: Any) -> float:
    try:
        percentage = float(value)
    except (TypeError, ValueError):
        return -1.0
    if 0.0 <= percentage <= 1.0:
        return percentage * 100.0
    return percentage


def get_budget(mode: str = "interactive") -> str:
    """Return budget tier: green / yellow / red.

    Interactive (default): green <50%, yellow 50-70%, red >70%.
    Overnight: green <95%, yellow 95-98%, red >=98%.
    """
    usage = get_usage()
    if "error" in usage:
        return "unknown"
    max_util = max(_weekly_pct(usage), _sonnet_pct(usage))

    if mode == "overnight":
        if max_util < 95:
            return "green"
        elif max_util < 98:
            return "yellow"
        else:
            return "red"
    else:
        if max_util < 50:
            return "green"
        elif max_util < 70:
            return "yellow"
        else:
            return "red"


# ---------------------------------------------------------------------------
# Weekly trend tracking
# ---------------------------------------------------------------------------


def _snapshot_window(reference_time: datetime | None = None) -> tuple[date, date]:
    snapshot_time = reference_time or datetime.now()
    window_end = snapshot_time.date()
    window_start = window_end - timedelta(days=7)
    return window_start, window_end


def _coerce_row_timestamp(row: dict[str, Any]) -> datetime | None:
    parsed_timestamp = row.get("_parsed_timestamp")
    if isinstance(parsed_timestamp, datetime):
        return parsed_timestamp

    timestamp = row.get("timestamp")
    if not isinstance(timestamp, str):
        return None
    try:
        return datetime.fromisoformat(timestamp)
    except ValueError:
        return None


def _derive_session_stats(reference_time: datetime | None = None) -> tuple[int, int]:
    """Derive session_count and goose_dispatches from sortase log for the snapshot window."""
    rows = _read_cost_rows(SORTASE_LOG)
    if not rows:
        return 0, 0

    window_start, window_end = _snapshot_window(reference_time)

    session_dates: set[str] = set()
    goose_dispatches = 0
    for row in rows:
        timestamp = _coerce_row_timestamp(row)
        if timestamp is None:
            continue
        if not (window_start <= timestamp.date() < window_end):
            continue
        ts = timestamp
        session_dates.add(ts.strftime("%Y-%m-%d"))
        if str(row.get("tool", "")).strip() == "goose":
            goose_dispatches += 1

    return len(session_dates), goose_dispatches


def record_snapshot(usage: dict[str, Any] | None = None, reference_time: datetime | None = None) -> None:
    """Append current week's usage stats to USAGE_HISTORY JSONL."""
    usage = usage or get_usage()
    if "error" in usage:
        return

    weekly = _weekly_pct(usage)
    sonnet = _sonnet_pct(usage)
    session_count, goose_dispatches = _derive_session_stats(reference_time)

    window_start, _window_end = _snapshot_window(reference_time)

    row = {
        "date": window_start.isoformat(),
        "weekly_pct": round(weekly, 1),
        "sonnet_pct": round(sonnet, 1),
        "session_count": session_count,
        "goose_dispatches": goose_dispatches,
    }

    USAGE_HISTORY.parent.mkdir(parents=True, exist_ok=True)
    with open(USAGE_HISTORY, "a") as fh:
        fh.write(json.dumps(row) + "\n")


def cmd_trend() -> None:
    """Read USAGE_HISTORY and render week-over-week trend table."""
    if not USAGE_HISTORY.exists():
        print("No usage history found. Run `respirometry` first to seed data.")
        return

    lines = USAGE_HISTORY.read_text().strip().splitlines()
    if not lines:
        print("No usage history found. Run `respirometry` first to seed data.")
        return

    rows: list[dict[str, Any]] = []
    for line in lines:
        try:
            rows.append(json.loads(line))
        except json.JSONDecodeError:
            continue

    if not rows:
        print("No usage history found. Run `respirometry` first to seed data.")
        return

    # Deduplicate by date, keep last entry per week
    seen: dict[str, dict[str, Any]] = {}
    for row in rows:
        seen[row["date"]] = row
    unique_rows = sorted(seen.values(), key=lambda r: r["date"], reverse=True)

    # Format table
    header = "Week      | All Models | Sonnet | Sessions | Goose"
    separator = "-" * len(header)
    print(header)
    print(separator)

    for row in unique_rows:
        try:
            window_start = datetime.strptime(row["date"], "%Y-%m-%d")
            window_end = window_start + timedelta(days=6)
            if window_start.month != window_end.month:
                week_label = (
                    f"{window_start.strftime('%b %d')}-{window_end.strftime('%b %d')}"
                )
            else:
                week_label = f"{window_start.strftime('%b %d')}-{window_end.strftime('%d')}"
        except (ValueError, KeyError):
            week_label = str(row.get("date", "?"))

        weekly_pct = row.get("weekly_pct", 0)
        sonnet_pct = row.get("sonnet_pct", 0)
        sessions = row.get("session_count", 0)
        goose = row.get("goose_dispatches", 0)

        print(
            f"{week_label:<10}| {weekly_pct:>8.0f}% | {sonnet_pct:>4.0f}% | "
            f"{sessions:>8} | {goose:>6}"
        )


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Show Claude Code plan usage and coding cost split."
    )
    parser.add_argument(
        "command",
        nargs="?",
        default="status",
        choices=["status", "log", "trend"],
        help="`log` is retained as a no-op compatibility command.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Print the canonical JSON payload with additive cost-tracking data.",
    )
    parser.add_argument(
        "--budget",
        action="store_true",
        help="Print budget tier only: green, yellow, red, or unknown.",
    )
    parser.add_argument(
        "--overnight",
        action="store_true",
        help="Use overnight thresholds with --budget.",
    )
    return parser


def main() -> None:
    args = _build_parser().parse_args()

    # `respirometry log` was previously a no-op stub; kept for compat.
    if args.command == "log":
        return

    if args.command == "trend":
        cmd_trend()
        return

    if args.budget:
        mode = "overnight" if args.overnight else "interactive"
        print(get_budget(mode))
        return

    usage = get_usage()
    if "error" in usage:
        print(usage["error"], file=sys.stderr)
        sys.exit(1)

    record_snapshot(usage=usage)

    if args.json:
        print(json.dumps(usage))
    else:
        weekly = _weekly_pct(usage)
        sonnet = _sonnet_pct(usage)
        age = usage.get("stale_age_seconds")
        source = usage.get("source", "?")
        if not usage.get("stale"):
            freshness = "live"
        elif age is not None:
            freshness = f"cached: {format_age(age)}"
        else:
            freshness = "cached: age unknown"
        print(f"Claude Code Usage  [{source} / {freshness}]")
        print()
        if weekly >= 0:
            print(f"  Weekly           {weekly:.0f}%")
        if sonnet >= 0:
            print(f"  Weekly (Sonnet)  {sonnet:.0f}%")
        print()
        max_util = max(weekly, sonnet)
        if max_util < 50:
            status = "SAFE"
        elif max_util < 70:
            status = "CAUTION"
        elif max_util < 85:
            status = "WARNING"
        else:
            status = "DANGER"
        print(f"Status: {status}")

        cost_tracking = usage.get("cost_tracking", {})
        if cost_tracking.get("available"):
            current = cost_tracking["current_7d"]
            trend = cost_tracking["trend"]
            flat_rate_tools = current.get("flat_rate_tools", {})
            metered_tools = current.get("metered_tools", {})
            flat_rate_tool_mix = (
                ", ".join(f"{tool}:{count}" for tool, count in flat_rate_tools.items()) or "none"
            )
            metered_tool_mix = (
                ", ".join(f"{tool}:{count}" for tool, count in metered_tools.items()) or "none"
            )
            print()
            print(f"Coding Cost  [{cost_tracking['source']} / {cost_tracking['lookback_days']}d]")
            print()
            print(
                "  ZhiPu plan       "
                f"{current['flat_rate_runs']} runs / {current['duration_hours']:.2f}h / "
                f"{current['tasks']} tasks"
            )
            print(f"  Metered          {current['metered_runs']} runs / ${current['metered_cost_usd']:.4f}")
            print(
                "  Split            "
                f"{current['flat_rate_pct']:.0f}% flat-rate / {current['metered_pct']:.0f}% metered"
            )
            print(
                "  Trend vs prior   "
                f"{trend['runs_delta']:+d} runs / "
                f"{trend['duration_hours_delta']:+.2f}h / "
                f"${trend['metered_cost_usd_delta']:+.4f}"
            )
            print(f"  Flat-rate mix    {flat_rate_tool_mix}")
            print(f"  Metered mix      {metered_tool_mix}")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""gemmule-scale — resize the gemmule Fly.io machine.

Usage:
    gemmule-scale up       # 8 CPUs, 32 GB RAM
    gemmule-scale down     # 2 CPUs, 8 GB RAM
    gemmule-scale status   # print current machine config

Uses the Fly.io Machines API. Requires FLY_API_TOKEN in the environment.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
from urllib.request import Request, urlopen

API_BASE = "https://api.machines.dev"
APP_NAME = "gemmule"

PROFILES = {
    "up": {
        "guest": {"cpus": 8, "cpu_kind": "shared", "memory_mb": 32 * 1024},
    },
    "down": {
        "guest": {"cpus": 2, "cpu_kind": "shared", "memory_mb": 8 * 1024},
    },
}


def _token() -> str:
    tok = os.environ.get("FLY_API_TOKEN", "")
    if not tok:
        print("error: FLY_API_TOKEN not set", file=sys.stderr)
        sys.exit(1)
    return tok


def _api(method: str, path: str, body: dict | None = None) -> dict | list:
    """Make a Fly.io Machines API call using the token from env."""
    token = _token()
    url = f"{API_BASE}{path}"
    data = json.dumps(body).encode() if body else None
    req = Request(url, data=data, method=method)
    req.add_header("Authorization", f"Bearer {token}")
    req.add_header("Content-Type", "application/json")
    with urlopen(req) as resp:
        raw = resp.read()
        return json.loads(raw) if raw else {}


def _fmt_guest(guest: dict) -> str:
    """Format a guest config dict for display."""
    cpus = guest.get("cpus", "?")
    kind = guest.get("cpu_kind", "?")
    mem = guest.get("memory_mb", "?")
    return f"{cpus} CPU ({kind}), {mem} MB"


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="gemmule-scale", description="Resize gemmule Fly.io machine")
    p.add_argument("command", choices=["up", "down", "status"])
    return p


def cmd_status() -> None:
    machines: list[dict] = _api("GET", f"/v1/apps/{APP_NAME}/machines")  # type: ignore[assignment]
    if not machines:
        print(f"no machines found for app '{APP_NAME}'")
        return
    m = machines[0]
    guest = m.get("config", {}).get("guest", {})
    print(
        f"machine {m['id']}  state={m.get('state', 'unknown')}  "
        f"region={m.get('region', '?')}  {_fmt_guest(guest)}"
    )


def cmd_resize(direction: str) -> None:
    target_guest = PROFILES[direction]["guest"]
    target_cpus = target_guest["cpus"]
    target_mem = target_guest["memory_mb"]

    machines: list[dict] = _api("GET", f"/v1/apps/{APP_NAME}/machines")  # type: ignore[assignment]
    if not machines:
        print(f"no machines found for app '{APP_NAME}'")
        sys.exit(1)

    m = machines[0]
    mid = m["id"]
    config = m.get("config", {})
    old_guest = config.get("guest", {})

    old_desc = _fmt_guest(old_guest)
    new_desc = _fmt_guest(target_guest)

    if old_guest.get("cpus") == target_cpus and old_guest.get("memory_mb") == target_mem:
        print(f"already at {new_desc}, nothing to do")
        return

    # Stop → patch → start
    print(f"stopping {mid} ...")
    _api("POST", f"/v1/apps/{APP_NAME}/machines/{mid}/stop")

    # Build patch body: preserve existing config, swap guest
    patch_body = dict(config)
    patch_body["guest"] = target_guest

    print(f"updating config: {old_desc} → {new_desc} ...")
    _api("PATCH", f"/v1/apps/{APP_NAME}/machines/{mid}", patch_body)

    print(f"starting {mid} ...")
    _api("POST", f"/v1/apps/{APP_NAME}/machines/{mid}/start")

    print(f"done: {old_desc} → {new_desc}")


def main(argv: list[str] | None = None) -> None:
    args = argv or sys.argv[1:]
    ns = build_parser().parse_args(args)
    if ns.command == "status":
        cmd_status()
    else:
        cmd_resize(ns.command)


if __name__ == "__main__":
    main()

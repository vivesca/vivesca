#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""gemmule-scale — resize the gemmule Fly.io machine (up/down/status)."""

from __future__ import annotations

import argparse
import json
import os
import sys
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

API_BASE = "https://api.machines.dev.ctl.v1.fly.io"
APP_NAME = "gemmule"

PROFILES = {
    "up": {"guest": {"cpus": 8, "cpu_kind": "shared", "memory_mb": 32768}},
    "down": {"guest": {"cpus": 2, "cpu_kind": "shared", "memory_mb": 8192}},
}


def _token() -> str:
    tok = os.environ.get("FLY_API_TOKEN", "")
    if not tok:
        print("error: FLY_API_TOKEN not set", file=sys.stderr)
        sys.exit(1)
    return tok


def _headers() -> dict[str, str]:
    return {"Authorization": f"Bearer {_token()}", "Content-Type": "application/json"}


def _api(method: str, path: str, body: dict | None = None) -> dict | list:
    url = f"{API_BASE}{path}"
    data = json.dumps(body).encode() if body else None
    req = Request(url, data=data, headers=_headers(), method=method)
    try:
        with urlopen(req) as resp:
            raw = resp.read()
            if not raw:
                return {}
            return json.loads(raw)
    except HTTPError as e:
        detail = e.read().decode(errors="replace")
        print(f"error: {e.code} {e.reason}: {detail}", file=sys.stderr)
        sys.exit(1)
    except URLError as e:
        print(f"error: cannot reach Fly API: {e.reason}", file=sys.stderr)
        sys.exit(1)


def _list_machines() -> list[dict]:
    return _api("GET", f"/v1/apps/{APP_NAME}/machines")  # type: ignore[return-value]


def _fmt_guest(guest: dict) -> str:
    cpus = guest.get("cpus", "?")
    mem = guest.get("memory_mb", "?")
    kind = guest.get("cpu_kind", "?")
    return f"{cpus} CPU ({kind}), {mem} MB"


def cmd_status() -> None:
    machines = _list_machines()
    if not machines:
        print(f"no machines found for app {APP_NAME!r}")
        return
    for m in machines:
        mid = m.get("id", "?")
        state = m.get("state", "?")
        guest = m.get("config", {}).get("guest", {})
        region = m.get("region", "?")
        print(f"{mid}  state={state}  region={region}  {_fmt_guest(guest)}")


def cmd_resize(direction: str) -> None:
    new_guest = PROFILES[direction]["guest"]
    machines = _list_machines()
    if not machines:
        print(f"no machines found for app {APP_NAME!r}")
        sys.exit(1)
    for m in machines:
        mid = m["id"]
        old_config = m.get("config", {})
        old_guest = old_config.get("guest", {})
        old_summary = _fmt_guest(old_guest)

        # Stop the machine
        print(f"{mid}: stopping ...")
        _api("POST", f"/v1/apps/{APP_NAME}/machines/{mid}/stop")

        # Patch config with new guest
        patched_config = {**old_config, "guest": new_guest}
        print(f"{mid}: patching config ...")
        _api("PATCH", f"/v1/apps/{APP_NAME}/machines/{mid}", body=patched_config)

        # Start the machine
        print(f"{mid}: starting ...")
        _api("POST", f"/v1/apps/{APP_NAME}/machines/{mid}/start")

        new_summary = _fmt_guest(new_guest)
        print(f"{mid}: {old_summary} -> {new_summary}")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="gemmule-scale", description="Resize the gemmule Fly.io machine")
    p.add_argument("command", choices=["up", "down", "status"],
                   help="up=8CPU/32GB, down=2CPU/8GB, status=show current config")
    return p


def main(argv: list[str] | None = None) -> None:
    args = build_parser().parse_args(argv)
    if args.command == "status":
        cmd_status()
    else:
        cmd_resize(args.command)


if __name__ == "__main__":
    main()

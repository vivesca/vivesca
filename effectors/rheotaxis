#!/usr/bin/env python3
"""rheotaxis — multi-backend search CLI.

Usage:
    rheotaxis "JINS glasses store Hong Kong Island"
    rheotaxis -b perplexity,serper "nearest gym Quarry Bay"
    rheotaxis -q "JINS Wan Chai" -q "JINS Hong Kong Island" -q "JINS store locator HK"
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

# Add germline to path for organelle imports
sys.path.insert(0, str(Path.home() / "germline"))

from metabolon.organelles import rheotaxis_engine


def main():
    parser = argparse.ArgumentParser(description="Multi-backend web search")
    parser.add_argument("query", nargs="?", help="Search query")
    parser.add_argument(
        "-q", "--queries", action="append", default=[],
        help="Multiple query framings (repeat -q for each)",
    )
    parser.add_argument(
        "-b", "--backends", default=None,
        help="Comma-separated backends: perplexity,exa,tavily,serper (default: all)",
    )
    parser.add_argument(
        "-t", "--timeout", type=int, default=20,
        help="Timeout per backend in seconds (default: 20)",
    )
    parser.add_argument(
        "--json", action="store_true",
        help="Output raw JSON instead of formatted text",
    )
    args = parser.parse_args()

    queries = args.queries or []
    if args.query:
        queries.insert(0, args.query)
    if not queries:
        parser.error("Provide a query or use -q for multiple framings")

    backends = args.backends.split(",") if args.backends else None

    if len(queries) == 1:
        results = rheotaxis_engine.parallel_search(
            queries[0], backends=backends, timeout=args.timeout,
        )
        if args.json:
            import json
            print(json.dumps([
                {"backend": r.backend, "query": r.query, "answer": r.answer,
                 "results": r.results, "error": r.error}
                for r in results
            ], indent=2))
        else:
            print(rheotaxis_engine.format_results(results))
    else:
        all_results = rheotaxis_engine.multi_query_search(
            queries, backends=backends, timeout=args.timeout,
        )
        if args.json:
            import json
            out = {}
            for q, results in all_results.items():
                out[q] = [
                    {"backend": r.backend, "answer": r.answer,
                     "results": r.results, "error": r.error}
                    for r in results
                ]
            print(json.dumps(out, indent=2))
        else:
            for q, results in all_results.items():
                print(f"{'='*60}")
                print(f"QUERY: {q}")
                print(f"{'='*60}")
                print(rheotaxis_engine.format_results(results))


if __name__ == "__main__":
    main()

def _resolve_exclude(
    exclude: str | None,
    backends: str | None,
    query: str | None,
) -> set[str]:
    """Compute exclude set from --exclude, -b, or auto-route."""
    if exclude and backends:
        emit_err(
            "rheotaxis search",
            "--exclude and -b are mutually exclusive",
            "MUTUAL_EXCLUSION",
            fix="Use --exclude OR -b, not both",
        )
        raise SystemExit(EXIT_ERROR)
    if exclude:
        return {name.strip() for name in exclude.split(",") if name.strip()}
    if backends:
        selected = {name.strip() for name in backends.split(",") if name.strip()}
        return set(ALL_BACKENDS) - selected
    if query:
        qtype = classify_query(query)
        routed = route_backends(qtype)
        return set(ALL_BACKENDS) - set(routed)
    return set()


def _use_json(json_flag: bool, text_flag: bool) -> bool:
    """Determine output mode: JSON when piped, when --json, unless --text."""
    if text_flag:
        return False
    if json_flag:
        return True
    return _is_agent()


@app.command
@app.default
def search(
    query: str | None = None,
    *,
    queries: Annotated[tuple[str, ...], cyclopts.Parameter(name=["-q", "--queries"])] = (),
    text: bool = False,
    json: Annotated[bool, cyclopts.Parameter(name="--json")] = False,
    exclude: str | None = None,
    backends: Annotated[str | None, cyclopts.Parameter(name=["-b"])] = None,
    raw: bool = False,
) -> None:
    """Search all backends in parallel. Quality filter always-on (--raw to bypass)."""
    if query is None:
        if _is_agent():
            emit_ok("rheotaxis", _tree.to_dict())
        else:
            from rich.console import Console

            console = Console()
            console.print("[bold]rheotaxis[/bold] — multi-backend web search\n")
            console.print('  [cyan]rheotaxis search[/cyan] "query"     Search all backends')
            console.print('  [cyan]rheotaxis research[/cyan] "query"   Deep Perplexity research')
            console.print("  [cyan]rheotaxis backends[/cyan]            List backends + health")
            console.print('  [cyan]rheotaxis route[/cyan] "query"      Show classification only')
            console.print(
                "\nFlags: --text (markdown), --json (force JSON), --raw (skip quality filter)"
            )
        return
    all_queries = [query, *queries]
    use_json = _use_json(json, text)
    exclude_set = _resolve_exclude(exclude, backends, query)

    if len(all_queries) == 1:
        results = asyncio.run(_run_all_filtered(query, exclude=exclude_set or None, raw=raw))

        if text:
            results = sorted(
                results,
                key=lambda result: BACKEND_WEIGHTS.get(result.tool, 0),
                reverse=True,
            )
            try:
                print(_report(query, results))
            except RuntimeError as exc:
                print(f"Error: {exc}", file=sys.stderr)
                raise SystemExit(EXIT_ERROR) from exc
        elif use_json:
            ok_count = sum(1 for result in results if not result.error)
            total = len(results)
            if ok_count == 0:
                emit_err(
                    "rheotaxis search",
                    f"all {total} backends failed",
                    "ALL_BACKENDS_FAILED",
                    fix="Check API keys: eval $(importin). Run: rheotaxis backends",
                )
                raise SystemExit(EXIT_ERROR)
            emit_ok(
                "rheotaxis search",
                {
                    "query": query,
                    "backends": [_result_to_dict(result) for result in results],
                    "backend_count": total,
                    "ok_count": ok_count,
                    "total_cost": round(sum(result.cost for result in results), 4),
                },
                next_actions=[action("rheotaxis backends", "Check backend health")],
            )
        else:
            _print_rich(query, results)
    else:
        _search_multi(all_queries, exclude_set, text, use_json, raw)


def _search_multi(
    queries: list[str],
    exclude_set: set[str],
    text: bool,
    use_json: bool,
    raw: bool,
) -> None:
    """Handle multi-query search."""

    async def _run_multi() -> list[list[ToolResult]]:
        tasks = [
            _run_all_filtered(query, exclude=exclude_set or None, raw=raw) for query in queries
        ]
        return await asyncio.gather(*tasks)

    per_query = asyncio.run(_run_multi())

    if text:
        any_ok = False
        for query, results in zip(queries, per_query, strict=True):
            results = sorted(
                results,
                key=lambda result: BACKEND_WEIGHTS.get(result.tool, 0),
                reverse=True,
            )
            print(f"\n## QUERY: {query}\n")
            try:
                print(_report(query, results))
                any_ok = True
            except RuntimeError:
                print(f"  All backends failed for: {query}\n")
        if not any_ok:
            raise SystemExit(EXIT_ERROR)
    elif use_json:
        combined_backends = []
        total_ok = 0
        total_count = 0
        total_cost = 0.0
        for query, results in zip(queries, per_query, strict=True):
            ok_count = sum(1 for result in results if not result.error)
            total_ok += ok_count
            total_count += len(results)
            total_cost += sum(result.cost for result in results)
            for result in results:
                entry = _result_to_dict(result)
                entry["query"] = query
                combined_backends.append(entry)
        if total_ok == 0:
            emit_err(
                "rheotaxis search",
                f"all {total_count} backends failed across {len(queries)} queries",
                "ALL_BACKENDS_FAILED",
                fix="Check API keys: eval $(importin). Run: rheotaxis backends",
            )
            raise SystemExit(EXIT_ERROR)
        emit_ok(
            "rheotaxis search",
            {
                "queries": queries,
                "backends": combined_backends,
                "backend_count": total_count,
                "ok_count": total_ok,
                "total_cost": round(total_cost, 4),
            },
            next_actions=[action("rheotaxis backends", "Check backend health")],
        )
    else:
        for query, results in zip(queries, per_query, strict=True):
            _print_rich(query, results)


def _print_rich(query: str, results: list[ToolResult]) -> None:
    """Pretty-print results in TTY mode using rich."""
    from rich.console import Console
    from rich.panel import Panel

    console = Console()
    ok_results = [result for result in results if not result.error]
    errored = [result for result in results if result.error]

    console.print(f"\n[bold]Query:[/bold] {query}")
    console.print(f"[dim]{len(ok_results)}/{len(results)} backends OK[/dim]\n")

    for result in sorted(ok_results, key=lambda r: BACKEND_WEIGHTS.get(r.tool, 0), reverse=True):
        console.print(
            Panel(
                result.result[:2000] if result.result else "(empty)",
                title=f"[bold cyan]{result.tool}[/bold cyan] ({result.latency_s:.1f}s)",
                border_style="dim",
            )
        )

    if errored:
        err_summary = ", ".join(
            f"{result.tool}: {(result.error or '')[:60]}" for result in errored
        )
        console.print(f"\n[dim red]Failed: {err_summary}[/dim red]")


@app.command
def research(
    query: str,
    *,
    text: bool = False,
    json: Annotated[bool, cyclopts.Parameter(name="--json")] = False,
) -> None:
    """Deep research via Perplexity sonar-deep-research."""
    try:
        answer = perplexity_deep(query)
    except Exception as exc:
        emit_err(
            "rheotaxis research",
            str(exc),
            "RESEARCH_FAILED",
            fix="Check PERPLEXITY_API_KEY and network connectivity",
        )
        raise SystemExit(EXIT_ERROR) from exc

    if text:
        print(answer)
    elif _use_json(json, False):
        emit_ok(
            "rheotaxis research",
            {"query": query, "answer": answer, "citations": [], "cost_usd": 0.40},
            next_actions=[action("rheotaxis backends", "Check backend health")],
        )
    else:
        from rich.console import Console
        from rich.markdown import Markdown

        console = Console()
        console.print(Markdown(answer))


@app.command(name="backends")
def list_backends() -> None:
    """List all backends with health status."""
    health_file = Path.home() / ".cache" / "vivesca" / "rheotaxis-health"
    try:
        health_status = health_file.read_text().strip()
    except FileNotFoundError:
        health_status = "unknown"

    backend_list = [
        {"name": name, "env_var": meta["env"], "cost_usd": meta["cost"]}
        for name, meta in BACKEND_META.items()
    ]

    if _is_agent():
        emit_ok(
            "rheotaxis backends",
            {"backends": backend_list, "health": health_status},
            next_actions=[action('rheotaxis search "query"', "Run a search")],
        )
    else:
        import os

        from rich.console import Console
        from rich.table import Table

        console = Console()
        table = Table(title="rheotaxis backends")
        table.add_column("Backend", style="cyan")
        table.add_column("Env Var")
        table.add_column("Cost/call")
        table.add_column("Key Set?")
        for entry in backend_list:
            has_key = "yes" if os.environ.get(entry["env_var"]) else "no"
            style = "green" if has_key == "yes" else "red"
            table.add_row(
                entry["name"],
                entry["env_var"],
                f"${entry['cost_usd']:.3f}",
                f"[{style}]{has_key}[/{style}]",
            )
        console.print(table)
        console.print(f"\nHealth: {health_status}")


@app.command
def route(query: str) -> None:
    """Show query classification + routing without searching."""
    qtype = classify_query(query)
    routed = route_backends(qtype)
    result = {"query": query, "type": qtype, "backends": routed}

    if _is_agent():
        emit_ok("rheotaxis route", result)
    else:
        from rich.console import Console

        console = Console()
        console.print(f"[bold]Query:[/bold] {query}")
        console.print(f"[bold]Type:[/bold] {qtype}")
        console.print(f"[bold]Backends:[/bold] {', '.join(routed)}")



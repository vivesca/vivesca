#!/usr/bin/env python3
"""rheotaxis — multi-backend web search CLI.

Always fans out to all 7 backends in parallel. Convergence = confidence,
divergence = signal. No backend selection knobs — the engine is the policy.
Slow backends are bounded per-call by BACKEND_TIMEOUT_S so one laggard
cannot stall the rest.

Subcommands:
    rheotaxis "query"                     # search all 7 (JSON when piped, rich in TTY)
    rheotaxis search "query" --text       # markdown output
    rheotaxis search "query" --raw        # skip quality filter
    rheotaxis search "q1" -q "q2"        # multi-query
    rheotaxis research "query"            # deep research via Perplexity
    rheotaxis backends                    # list backends + health
"""

from __future__ import annotations

import asyncio
import os
import sys
from pathlib import Path
from typing import Annotated

import cyclopts
from porin import (
    EXIT_ERROR,
    CommandTree,
    action,
    emit_err,
    emit_ok,
)

# Add germline/src for metabolon imports
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from metabolon.enzymes._parallel_search import ToolResult, _log_run, _report
from metabolon.organelles.rheotaxis_engine import perplexity_deep

# --- Resolve secrets that may be op:// references ---

_zhipu_key = os.environ.get("ZHIPU_API_KEY", "")
if not _zhipu_key or _zhipu_key.startswith("op://"):
    import subprocess as _sp

    try:
        _resolved = _sp.run(
            ["op", "read", "op://Agents/zhipu-api-key/credential"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if _resolved.returncode == 0 and _resolved.stdout.strip():
            os.environ["ZHIPU_API_KEY"] = _resolved.stdout.strip()
    except Exception:
        pass

ALL_BACKENDS = ["grok", "exa", "perplexity", "tavily", "serper", "zhipu", "jina"]
# Per-backend timeout. asyncio.gather waits for the slowest, so a single hung backend
# can stall the whole search. wait_for trips the laggard at this bound so the others ship.
BACKEND_TIMEOUT_S = 30.0

# --- Source weighting: higher = more trusted for factual queries ---

BACKEND_WEIGHTS = {
    "perplexity": 3,
    "exa": 2,
    "tavily": 1,
    "serper": 1,
    "grok": 1,
    "jina": 1,
    "zhipu": 1,
}

BACKEND_META = {
    "grok": {"env": "XAI_API_KEY", "cost": 0.05},
    "exa": {"env": "EXA_API_KEY", "cost": 0.01},
    "perplexity": {"env": "PERPLEXITY_API_KEY", "cost": 0.006},
    "tavily": {"env": "TAVILY_API_KEY", "cost": 0.0},
    "serper": {"env": "SERPER_API_KEY", "cost": 0.0},
    "zhipu": {"env": "ZHIPU_API_KEY", "cost": 0.0},
    "jina": {"env": "JINA_API_KEY", "cost": 0.0},
}

# --- TTY detection ---


def _is_agent() -> bool:
    """True when stdout is piped (agent consuming), not a TTY."""
    return not sys.stdout.isatty()



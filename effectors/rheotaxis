#!/usr/bin/env python3
"""rheotaxis — multi-backend web search CLI with porin output envelopes.

Usage:
    rheotaxis                              # show command tree
    rheotaxis "query"                      # search all 7 backends
    rheotaxis "query" --text               # markdown output
    rheotaxis "query" --research           # deep research via Perplexity
    rheotaxis "query" --exclude grok,zhipu # skip backends
    rheotaxis "query" -b exa,serper        # whitelist backends
    rheotaxis "q1" -q "q2" -q "q3"        # multi-query
    rheotaxis --backends                   # list backends + health
"""

from __future__ import annotations

import argparse
import asyncio
import sys
from pathlib import Path

# Add germline/src for metabolon imports
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

import json as _json

from porin import CommandTree, emit_ok, emit_err, action, EXIT_OK, EXIT_ERROR
from metabolon.enzymes._parallel_search import _run_all, _report, ToolResult
from metabolon.organelles.rheotaxis_engine import perplexity_deep

ALL_BACKENDS = ["grok", "exa", "perplexity", "tavily", "serper", "zhipu", "jina"]

# --- Source weighting: higher = more trusted for factual queries ---

BACKEND_WEIGHTS = {
    "perplexity": 3,
    "exa": 2,
    "tavily": 1,
    "serper": 1,
    "grok": 1,
    "jina": 1,
    "zhipu": 1,
}

# --- Signal density: detect low-value LLM padding ---


def signal_density(text: str) -> float:
    """Return 0.0–1.0 ratio of substantive content vs generic LLM padding.

    Uses a simple heuristic: count how many words are NOT in the known
    padding phrase list, then divide by total words.  Empty text → 0.0.
    """
    if not text:
        return 0.0
    words = text.lower().split()
    if not words:
        return 0.0
    padding_phrases = {
        "it", "looks", "like", "your", "query", "message", "seems",
        "i'll", "break", "this", "down", "for", "you", "feel",
        "free", "to", "clarify", "please", "provide", "more",
        "details", "i'm", "not", "sure", "what", "you're",
        "referring", "ask", "about", "happy", "help", "let",
        "me", "know", "if", "need", "be", "can", "could",
        "would", "don't", "hesitate", "any", "other", "questions",
        "i", "here", "assist", "just", "but", "or", "the",
        "a", "an", "is", "are", "was", "were", "am", "my",
        "we", "our", "they", "their", "them", "its", "his", "her",
        "and", "of", "in", "on", "at", "with", "from", "that",
        "which", "who", "whom", "how", "do", "does", "did",
        "will", "shall", "may", "might", "must", "should",
        "also", "very", "really", "much", "many", "some",
        "all", "each", "every", "both", "few", "most", "no",
        "into", "up", "out", "so", "than", "then", "there",
        "these", "those", "such", "only", "own", "same", "when",
        "where", "why", "again", "further", "once",
        "above", "below", "under", "over", "between",
        "through", "during", "before", "after",
        "however", "therefore", "thus", "hence", "since",
        "because", "although", "though", "even", "still",
    }
    substantive = sum(1 for w in words if w not in padding_phrases)
    return substantive / len(words)


def is_low_signal(text: str) -> bool:
    """True when signal density is below 0.2 (>80% generic padding)."""
    return signal_density(text) < 0.2


def order_backends(backends: list[str]) -> list[str]:
    """Sort backend names by BACKEND_WEIGHTS descending (highest first)."""
    return sorted(backends, key=lambda b: BACKEND_WEIGHTS.get(b, 0), reverse=True)


def _apply_quality_filter(results: list[ToolResult]) -> list[ToolResult]:
    """Remove results whose answer is >80% generic LLM padding."""
    filtered = []
    for r in results:
        if r.error:
            filtered.append(r)
            continue
        if r.result and is_low_signal(r.result):
            filtered.append(
                ToolResult(
                    tool=r.tool,
                    query=r.query,
                    result="",
                    cost=r.cost,
                    latency_s=r.latency_s,
                    error="filtered: low signal density",
                )
            )
        else:
            filtered.append(r)
    return filtered


# --- Query-type routing ---

import re as _re

_FACTUAL_PATTERNS = [
    _re.compile(r"\bhow\s+to\b", _re.IGNORECASE),
    _re.compile(r"\bwhat\s+is\b", _re.IGNORECASE),
    _re.compile(r"\bwhat\s+are\b", _re.IGNORECASE),
    _re.compile(r"\d+\.\d+(?:\.\d+)?"),           # version numbers like 3.12, 2.1.0
    _re.compile(r"\b(?:api|sdk|cli|http|grpc|rest)\b", _re.IGNORECASE),
    _re.compile(r"\bget\b.*\b(?:method|function|request)\b", _re.IGNORECASE),
]
_URL_PATTERNS = [
    _re.compile(r"https?://\S+", _re.IGNORECASE),
    _re.compile(r"\bwww\.\S+\.\w+", _re.IGNORECASE),
]

# Keyword sets for word-level classification (supplements regex patterns)
_FACTUAL_KEYWORDS = frozenset({
    "install", "setup", "configure", "configuration",
    "tutorial", "documentation", "reference", "guide", "example",
    "error", "debug", "fix", "syntax", "compile", "compiler",
    "build", "deploy", "deployment", "version", "release",
    "endpoint", "function", "method", "class", "module", "library",
    "package", "import", "parameter", "argument", "return", "type",
    "exception", "traceback", "stacktrace", "runtime", "memory",
    "algorithm", "protocol", "server", "client", "request", "response",
    "database", "query", "sql", "migration", "schema",
})

_OPINION_KEYWORDS = frozenset({
    "best", "recommend", "recommendation", "compare", "comparison",
    "vs", "versus", "should", "opinion", "review", "favorite",
    "top", "alternatives", "alternative", "pros", "cons",
    "advantage", "disadvantage", "prefer", "better", "worse",
})


def classify_query_keywords(query: str) -> str:
    """Classify a query using word-level keyword matching.

    Returns 'factual', 'opinion', or 'unknown' based on keyword hits.
    This supplements the regex-based classify_query for edge cases where
    regex patterns miss factual queries that contain technical keywords.
    """
    words = set(query.lower().split())
    if words & _FACTUAL_KEYWORDS:
        return "factual"
    if words & _OPINION_KEYWORDS:
        return "opinion"
    return "unknown"


def classify_query(query: str) -> str:
    """Classify a query as 'factual', 'url', or 'opinion'.

    Uses regex patterns first, then falls back to keyword matching.
    Factual/technical queries are routed to Perplexity + Exa for cited answers.
    URL extraction queries go to Exa only.
    Everything else (opinion/exploratory) hits all backends.
    """
    for pat in _URL_PATTERNS:
        if pat.search(query):
            return "url"
    for pat in _FACTUAL_PATTERNS:
        if pat.search(query):
            return "factual"
    # Keyword fallback: catch factual queries missed by regex
    if classify_query_keywords(query) == "factual":
        return "factual"
    return "opinion"


def route_backends(query_type: str) -> list[str]:
    """Return the list of backends to invoke for a given query type."""
    if query_type == "factual":
        return ["perplexity", "exa"]
    if query_type == "url":
        return ["exa"]
    return list(ALL_BACKENDS)


BACKEND_META = {
    "grok": {"env": "XAI_API_KEY", "cost": 0.05},
    "exa": {"env": "EXA_API_KEY", "cost": 0.01},
    "perplexity": {"env": "PERPLEXITY_API_KEY", "cost": 0.006},
    "tavily": {"env": "TAVILY_API_KEY", "cost": 0.0},
    "serper": {"env": "SERPER_API_KEY", "cost": 0.0},
    "zhipu": {"env": "ZHIPU_API_KEY", "cost": 0.0},
    "jina": {"env": "JINA_API_KEY", "cost": 0.0},
}


def _build_tree() -> CommandTree:
    tree = CommandTree("rheotaxis")
    tree.add_command(
        "search",
        "Search all backends in parallel",
        params=[
            {"name": "query", "type": "positional", "required": False},
            {"name": "--text", "type": "flag", "description": "Markdown output"},
            {
                "name": "--exclude",
                "type": "string",
                "description": "Comma-separated backends to skip",
            },
            {"name": "-b", "type": "string", "description": "Comma-separated backend whitelist"},
            {"name": "-q", "type": "multi", "description": "Additional queries"},
        ],
    )
    tree.add_command(
        "research",
        "Deep research via Perplexity sonar-deep-research",
        params=[
            {"name": "query", "type": "positional", "required": True},
            {"name": "--text", "type": "flag", "description": "Raw answer to stdout"},
        ],
    )
    tree.add_command(
        "backends",
        "List all backends with health status",
        params=[],
    )
    return tree


def _read_health() -> str:
    health_file = Path.home() / ".cache" / "vivesca" / "rheotaxis-health"
    try:
        return health_file.read_text().strip()
    except FileNotFoundError:
        return "unknown"


def _list_backends() -> None:
    health_status = _read_health()
    backends = []
    for name in ALL_BACKENDS:
        meta = BACKEND_META[name]
        backends.append(
            {
                "name": name,
                "env_var": meta["env"],
                "cost_usd": meta["cost"],
            }
        )
    emit_ok(
        "rheotaxis backends",
        {"backends": backends, "health": health_status},
        next_actions=[action("rheotaxis query", "Run a search")],
    )


def _format_results(q: str, results: list[ToolResult]) -> dict:
    ok_count = sum(1 for r in results if not r.error)
    total = len(results)
    backends = []
    for r in results:
        backends.append(
            {
                "name": r.tool,
                "latency_s": r.latency_s,
                "answer": r.result if not r.error else None,
                "results": r.result if not r.error else None,
                "error": r.error,
            }
        )
    return {
        "query": q,
        "backends": backends,
        "health": f"{ok_count}/{total}",
        "cost_usd": sum(r.cost for r in results),
    }


def main() -> None:
    parser = argparse.ArgumentParser(description="Multi-backend web search CLI")
    parser.add_argument("query", nargs="?", help="Search query")
    parser.add_argument(
        "-q",
        "--queries",
        action="append",
        default=[],
        help="Additional query framings (repeat -q for each)",
    )
    parser.add_argument(
        "--research",
        action="store_true",
        help="Deep research via Perplexity sonar-deep-research",
    )
    parser.add_argument(
        "--text",
        action="store_true",
        help="Human-readable markdown output instead of JSON",
    )
    parser.add_argument(
        "--exclude",
        default=None,
        help="Comma-separated backends to exclude",
    )
    parser.add_argument(
        "-b",
        default=None,
        help="Comma-separated backend whitelist",
    )
    parser.add_argument(
        "--backends",
        action="store_true",
        help="List all backends with health status",
    )
    parser.add_argument(
        "--quality",
        action="store_true",
        help="Filter out low-signal (padding-heavy) responses",
    )
    parser.add_argument(
        "--route",
        action="store_true",
        help="Show query classification + routing without searching",
    )
    args = parser.parse_args()

    # --backends mode: list and exit
    if args.backends:
        _list_backends()
        sys.exit(EXIT_OK)

    # Collect queries: positional + -q flags
    queries = list(args.queries)
    if args.query:
        queries.insert(0, args.query)

    # Bare invocation (no query) -> command tree
    if not queries:
        tree = _build_tree()
        emit_ok("rheotaxis", tree.to_dict())
        sys.exit(EXIT_OK)

    # --route mode: classify query and show routing, no search
    if args.route:
        classifications = []
        for q in queries:
            qtype = classify_query(q)
            backends = route_backends(qtype)
            classifications.append(
                {"query": q, "type": qtype, "backends": backends}
            )
        emit_ok(
            "rheotaxis route",
            {"classifications": classifications},
        )
        sys.exit(EXIT_OK)

    # Mutual exclusivity: --exclude and -b
    if args.exclude and args.b:
        emit_err(
            "rheotaxis search",
            "--exclude and -b are mutually exclusive",
            "MUTUAL_EXCLUSION",
            fix="Use --exclude OR -b, not both",
        )
        sys.exit(EXIT_ERROR)

    # Compute exclude set
    exclude: set[str] = set()
    if args.exclude:
        exclude = {b.strip() for b in args.exclude.split(",") if b.strip()}
    elif args.b:
        selected = {b.strip() for b in args.b.split(",") if b.strip()}
        exclude = set(ALL_BACKENDS) - selected
    else:
        # Auto-route: classify first query to select backends
        qtype = classify_query(queries[0])
        routed = route_backends(qtype)
        exclude = set(ALL_BACKENDS) - set(routed)

    # --- Research mode ---
    if args.research:
        for q in queries:
            try:
                answer = perplexity_deep(q)
            except Exception as exc:
                emit_err(
                    "rheotaxis research",
                    str(exc),
                    "RESEARCH_FAILED",
                    fix="Check PERPLEXITY_API_KEY and network connectivity",
                )
                sys.exit(EXIT_ERROR)
            if args.text:
                print(answer)
            else:
                emit_ok(
                    "rheotaxis research",
                    {
                        "query": q,
                        "answer": answer,
                        "citations": [],
                        "cost_usd": 0.40,
                    },
                    next_actions=[
                        action("rheotaxis --backends", "Check backend health"),
                    ],
                )
        sys.exit(EXIT_OK)

    # --- Default search mode ---
    exclude_arg = exclude or None

    if len(queries) == 1:
        results = asyncio.run(_run_all(queries[0], exclude=exclude_arg))

        # Apply quality filter if requested
        if args.quality:
            results = _apply_quality_filter(results)

        # For --text mode, order results by backend weight
        if args.text:
            results = sorted(results, key=lambda r: BACKEND_WEIGHTS.get(r.tool, 0), reverse=True)
            try:
                print(_report(queries[0], results))
            except RuntimeError as exc:
                print(f"Error: {exc}", file=sys.stderr)
                sys.exit(EXIT_ERROR)
        else:
            ok_count = sum(1 for r in results if not r.error)
            total = len(results)
            if ok_count == 0:
                emit_err(
                    "rheotaxis search",
                    f"all {total} backends failed",
                    "ALL_BACKENDS_FAILED",
                    fix="Check API keys: eval $(importin). Run: rheotaxis --backends",
                )
                sys.exit(EXIT_ERROR)
            emit_ok(
                "rheotaxis search",
                _json.loads(_report(queries[0], results, json_output=True)),
                next_actions=[
                    action("rheotaxis --backends", "Check backend health"),
                ],
            )
    else:
        # Multi-query: run _run_all for each via asyncio.gather
        async def _run_multi() -> list[list[ToolResult]]:
            tasks = [_run_all(q, exclude=exclude_arg) for q in queries]
            return await asyncio.gather(*tasks)

        per_query = asyncio.run(_run_multi())

        # Apply quality filter if requested
        if args.quality:
            per_query = [_apply_quality_filter(rq) for rq in per_query]

        if args.text:
            any_ok = False
            for q, results in zip(queries, per_query):
                results = sorted(results, key=lambda r: BACKEND_WEIGHTS.get(r.tool, 0), reverse=True)
                print(f"\n## QUERY: {q}\n")
                try:
                    print(_report(q, results))
                    any_ok = True
                except RuntimeError:
                    print(f"  All backends failed for: {q}\n")
            if not any_ok:
                sys.exit(EXIT_ERROR)
        else:
            combined_backends = []
            total_ok = 0
            total_count = 0
            total_cost = 0.0
            for q, results in zip(queries, per_query):
                ok_count = sum(1 for r in results if not r.error)
                total_ok += ok_count
                total_count += len(results)
                total_cost += sum(r.cost for r in results)
                for r in results:
                    combined_backends.append(
                        {
                            "name": r.tool,
                            "latency_s": r.latency_s,
                            "answer": r.result if not r.error else None,
                            "results": r.result if not r.error else None,
                            "error": r.error,
                            "query": q,
                        }
                    )
            if total_ok == 0:
                emit_err(
                    "rheotaxis search",
                    f"all {total_count} backends failed across {len(queries)} queries",
                    "ALL_BACKENDS_FAILED",
                    fix="Check API keys: eval $(importin). Run: rheotaxis --backends",
                )
                sys.exit(EXIT_ERROR)
            emit_ok(
                "rheotaxis search",
                {
                    "queries": queries,
                    "backends": combined_backends,
                    "health": f"{total_ok}/{total_count}",
                    "cost_usd": total_cost,
                },
                next_actions=[
                    action("rheotaxis --backends", "Check backend health"),
                ],
            )


if __name__ == "__main__":
    main()

def is_low_signal(text: str) -> bool:
    """True when signal density is below 0.2 (>80% generic padding)."""
    return signal_density(text) < 0.2


def order_backends(backends: list[str]) -> list[str]:
    """Sort backend names by BACKEND_WEIGHTS descending (highest first)."""
    return sorted(backends, key=lambda name: BACKEND_WEIGHTS.get(name, 0), reverse=True)


def _apply_quality_filter(results: list[ToolResult]) -> list[ToolResult]:
    """Remove results whose answer is >80% generic LLM padding."""
    filtered = []
    for result in results:
        if result.error:
            filtered.append(result)
            continue
        if result.result and is_low_signal(result.result):
            filtered.append(
                ToolResult(
                    tool=result.tool,
                    query=result.query,
                    result="",
                    cost=result.cost,
                    latency_s=result.latency_s,
                    error="filtered: low signal density",
                )
            )
        else:
            filtered.append(result)
    return filtered


# --- Streaming search engine ---


def _result_to_dict(result: ToolResult) -> dict:
    """Convert ToolResult to envelope-ready dict."""
    return {
        "name": result.tool,
        "latency_s": round(result.latency_s, 1),
        "cost": result.cost,
        "error": result.error,
        "content": result.result if result.result and not result.error else None,
    }


async def _run_all_filtered(
    query: str,
    *,
    raw: bool = False,
) -> list[ToolResult]:
    """Fan out to all 7 backends in parallel with quality filtering (always-on unless --raw).
    Each backend gets BACKEND_TIMEOUT_S; a slow one fails locally, the others still ship."""
    from metabolon.enzymes._parallel_search import (
        _run_exa,
        _run_grok,
        _run_jina,
        _run_perplexity,
        _run_serper,
        _run_tavily,
        _run_zhipu,
    )

    backend_map = {
        "grok": _run_grok,
        "exa": _run_exa,
        "perplexity": _run_perplexity,
        "tavily": _run_tavily,
        "serper": _run_serper,
        "zhipu": _run_zhipu,
        "jina": _run_jina,
    }

    results: list[ToolResult] = []

    async def _wrap(name: str, coro):
        try:
            result = await asyncio.wait_for(coro, timeout=BACKEND_TIMEOUT_S)
        except TimeoutError:
            result = ToolResult(
                tool=name,
                query=query,
                result="",
                error=f"timeout: backend exceeded {BACKEND_TIMEOUT_S:.0f}s",
            )
        except Exception as exc:
            result = ToolResult(tool=name, query=query, result="", error=str(exc))
        if not raw and not result.error and result.result and is_low_signal(result.result):
            result = ToolResult(
                tool=result.tool,
                query=result.query,
                result="",
                cost=result.cost,
                latency_s=result.latency_s,
                error="filtered: low signal density",
            )
        results.append(result)
        return result

    tasks = [_wrap(name, func(query)) for name, func in backend_map.items()]
    await asyncio.gather(*tasks)

    _log_run(query, results)
    return results


# --- Command tree for agent discovery ---

_tree = CommandTree("rheotaxis")
_tree.add_command(
    "search",
    "Search all 7 backends in parallel",
    params=[
        {"name": "query", "type": "positional", "required": True},
        {"name": "--text", "type": "flag", "description": "Markdown output"},
        {"name": "--json", "type": "flag", "description": "Force JSON in TTY"},
        {"name": "-q", "type": "multi", "description": "Additional queries"},
        {"name": "--raw", "type": "flag", "description": "Skip quality filter"},
    ],
)
_tree.add_command(
    "research",
    "Deep research via Perplexity sonar-deep-research",
    params=[
        {"name": "query", "type": "positional", "required": True},
        {"name": "--text", "type": "flag", "description": "Raw answer to stdout"},
    ],
)
_tree.add_command("backends", "List all backends with health status", params=[])

# --- cyclopts app ---

app = cyclopts.App(
    name="rheotaxis",
    help="Multi-backend web search CLI.",
)


def _use_json(json_flag: bool, text_flag: bool) -> bool:
    """Determine output mode: JSON when piped, when --json, unless --text."""
    if text_flag:
        return False
    if json_flag:
        return True
    return _is_agent()


@app.command
@app.default
def search(
    query: str | None = None,
    *,
    queries: Annotated[tuple[str, ...], cyclopts.Parameter(name=["-q", "--queries"])] = (),
    text: bool = False,
    json: Annotated[bool, cyclopts.Parameter(name="--json")] = False,
    raw: bool = False,
) -> None:
    """Search all 7 backends in parallel. Quality filter always-on (--raw to bypass)."""
    if query is None:
        if _is_agent():
            emit_ok("rheotaxis", _tree.to_dict())
        else:
            from rich.console import Console

            console = Console()
            console.print("[bold]rheotaxis[/bold] — multi-backend web search\n")
            console.print('  [cyan]rheotaxis search[/cyan] "query"     Search all 7 backends')
            console.print('  [cyan]rheotaxis research[/cyan] "query"   Deep Perplexity research')
            console.print("  [cyan]rheotaxis backends[/cyan]            List backends + health")
            console.print(
                "\nFlags: --text (markdown), --json (force JSON), --raw (skip quality filter)"
            )
        return
    all_queries = [query, *queries]
    use_json = _use_json(json, text)

    if len(all_queries) == 1:
        results = asyncio.run(_run_all_filtered(query, raw=raw))

        if text:
            results = sorted(
                results,
                key=lambda result: BACKEND_WEIGHTS.get(result.tool, 0),
                reverse=True,
            )
            try:
                print(_report(query, results))
            except RuntimeError as exc:
                print(f"Error: {exc} Run: rheotaxis --help", file=sys.stderr)
                raise SystemExit(EXIT_ERROR) from exc
        elif use_json:
            ok_count = sum(1 for result in results if not result.error)
            total = len(results)
            if ok_count == 0:
                emit_err(
                    "rheotaxis search",
                    f"all {total} backends failed",
                    "ALL_BACKENDS_FAILED",
                    fix="Check API keys: eval $(importin). Run: rheotaxis backends",
                )
                raise SystemExit(EXIT_ERROR)
            emit_ok(
                "rheotaxis search",
                {
                    "query": query,
                    "backends": [_result_to_dict(result) for result in results],
                    "backend_count": total,
                    "ok_count": ok_count,
                    "total_cost": round(sum(result.cost for result in results), 4),
                },
                next_actions=[action("rheotaxis backends", "Check backend health")],
            )
        else:
            _print_rich(query, results)
    else:
        _search_multi(all_queries, text, use_json, raw)


def _search_multi(
    queries: list[str],
    text: bool,
    use_json: bool,
    raw: bool,
) -> None:
    """Handle multi-query search."""

    async def _run_multi() -> list[list[ToolResult]]:
        tasks = [_run_all_filtered(query, raw=raw) for query in queries]
        return await asyncio.gather(*tasks)

    per_query = asyncio.run(_run_multi())

    if text:
        any_ok = False
        for query, results in zip(queries, per_query, strict=True):
            results = sorted(
                results,
                key=lambda result: BACKEND_WEIGHTS.get(result.tool, 0),
                reverse=True,
            )
            print(f"\n## QUERY: {query}\n")
            try:
                print(_report(query, results))
                any_ok = True
            except RuntimeError:
                print(f"  All backends failed for: {query}\n")
        if not any_ok:
            raise SystemExit(EXIT_ERROR)
    elif use_json:
        combined_backends = []
        total_ok = 0
        total_count = 0
        total_cost = 0.0
        for query, results in zip(queries, per_query, strict=True):
            ok_count = sum(1 for result in results if not result.error)
            total_ok += ok_count
            total_count += len(results)
            total_cost += sum(result.cost for result in results)
            for result in results:
                entry = _result_to_dict(result)
                entry["query"] = query
                combined_backends.append(entry)
        if total_ok == 0:
            emit_err(
                "rheotaxis search",
                f"all {total_count} backends failed across {len(queries)} queries",
                "ALL_BACKENDS_FAILED",
                fix="Check API keys: eval $(importin). Run: rheotaxis backends",
            )
            raise SystemExit(EXIT_ERROR)
        emit_ok(
            "rheotaxis search",
            {
                "queries": queries,
                "backends": combined_backends,
                "backend_count": total_count,
                "ok_count": total_ok,
                "total_cost": round(total_cost, 4),
            },
            next_actions=[action("rheotaxis backends", "Check backend health")],
        )
    else:
        for query, results in zip(queries, per_query, strict=True):
            _print_rich(query, results)


def _print_rich(query: str, results: list[ToolResult]) -> None:
    """Pretty-print results in TTY mode using rich."""
    from rich.console import Console
    from rich.panel import Panel

    console = Console()
    ok_results = [result for result in results if not result.error]
    errored = [result for result in results if result.error]

    console.print(f"\n[bold]Query:[/bold] {query}")
    console.print(f"[dim]{len(ok_results)}/{len(results)} backends OK[/dim]\n")

    for result in sorted(ok_results, key=lambda r: BACKEND_WEIGHTS.get(r.tool, 0), reverse=True):
        console.print(
            Panel(
                result.result[:2000] if result.result else "(empty)",
                title=f"[bold cyan]{result.tool}[/bold cyan] ({result.latency_s:.1f}s)",
                border_style="dim",
            )
        )

    if errored:
        err_summary = ", ".join(
            f"{result.tool}: {(result.error or '')[:60]}" for result in errored
        )
        console.print(f"\n[dim red]Failed: {err_summary}[/dim red]")


@app.command
def research(
    query: str,
    *,
    text: bool = False,
    json: Annotated[bool, cyclopts.Parameter(name="--json")] = False,
) -> None:
    """Deep research via Perplexity sonar-deep-research."""
    try:
        answer = perplexity_deep(query)
    except Exception as exc:
        emit_err(
            "rheotaxis research",
            str(exc),
            "RESEARCH_FAILED",
            fix="Check PERPLEXITY_API_KEY and network connectivity",
        )
        raise SystemExit(EXIT_ERROR) from exc

    if text:
        print(answer)
    elif _use_json(json, False):
        emit_ok(
            "rheotaxis research",
            {"query": query, "answer": answer, "citations": [], "cost_usd": 0.40},
            next_actions=[action("rheotaxis backends", "Check backend health")],
        )
    else:
        from rich.console import Console
        from rich.markdown import Markdown

        console = Console()
        console.print(Markdown(answer))


@app.command(name="backends")
def list_backends() -> None:
    """List all backends with health status."""
    health_file = Path.home() / ".cache" / "vivesca" / "rheotaxis-health"
    try:
        health_status = health_file.read_text().strip()
    except FileNotFoundError:
        health_status = "unknown"

    backend_list = [
        {"name": name, "env_var": meta["env"], "cost_usd": meta["cost"]}
        for name, meta in BACKEND_META.items()
    ]

    if _is_agent():
        emit_ok(
            "rheotaxis backends",
            {"backends": backend_list, "health": health_status},
            next_actions=[action('rheotaxis search "query"', "Run a search")],
        )
    else:
        import os

        from rich.console import Console
        from rich.table import Table

        console = Console()
        table = Table(title="rheotaxis backends")
        table.add_column("Backend", style="cyan")
        table.add_column("Env Var")
        table.add_column("Cost/call")
        table.add_column("Key Set?")
        for entry in backend_list:
            has_key = "yes" if os.environ.get(entry["env_var"]) else "no"
            style = "green" if has_key == "yes" else "red"
            table.add_row(
                entry["name"],
                entry["env_var"],
                f"${entry['cost_usd']:.3f}",
                f"[{style}]{has_key}[/{style}]",
            )
        console.print(table)
        console.print(f"\nHealth: {health_status}")


if __name__ == "__main__":
    app()

def classify_query_keywords(query: str) -> str:
    """Classify using word-level keyword matching. Returns factual/opinion/unknown."""
    words = set(query.lower().split())
    if words & _FACTUAL_KEYWORDS:
        return "factual"
    if words & _OPINION_KEYWORDS:
        return "opinion"
    return "unknown"


def classify_query(query: str) -> str:
    """Classify a query as factual/url/opinion for backend routing."""
    for pat in _URL_PATTERNS:
        if pat.search(query):
            return "url"
    for pat in _FACTUAL_PATTERNS:
        if pat.search(query):
            return "factual"
    if classify_query_keywords(query) == "factual":
        return "factual"
    return "opinion"


def route_backends(query_type: str) -> list[str]:
    """Return the list of backends to invoke for a given query type."""
    if query_type == "factual":
        return ["perplexity", "exa"]
    if query_type == "url":
        return ["exa"]
    return list(ALL_BACKENDS)


# --- Streaming search engine ---


def _result_to_dict(result: ToolResult) -> dict:
    """Convert ToolResult to envelope-ready dict."""
    return {
        "name": result.tool,
        "latency_s": round(result.latency_s, 1),
        "cost": result.cost,
        "error": result.error,
        "content": result.result if result.result and not result.error else None,
    }


async def _run_all_filtered(
    query: str,
    exclude: set[str] | None = None,
    *,
    raw: bool = False,
) -> list[ToolResult]:
    """Run all backends with quality filtering (always-on unless --raw)."""
    from metabolon.enzymes._parallel_search import (
        _run_exa,
        _run_grok,
        _run_jina,
        _run_perplexity,
        _run_serper,
        _run_tavily,
        _run_zhipu,
    )

    backend_map = {
        "grok": _run_grok,
        "exa": _run_exa,
        "perplexity": _run_perplexity,
        "tavily": _run_tavily,
        "serper": _run_serper,
        "zhipu": _run_zhipu,
        "jina": _run_jina,
    }
    skip = exclude or set()
    active = {name: func for name, func in backend_map.items() if name not in skip}

    results: list[ToolResult] = []

    async def _wrap(name: str, coro):
        try:
            result = await coro
        except Exception as exc:
            result = ToolResult(tool=name, query=query, result="", error=str(exc))
        if not raw and not result.error and result.result and is_low_signal(result.result):
            result = ToolResult(
                tool=result.tool,
                query=result.query,
                result="",
                cost=result.cost,
                latency_s=result.latency_s,
                error="filtered: low signal density",
            )
        results.append(result)
        return result

    tasks = [_wrap(name, func(query)) for name, func in active.items()]
    await asyncio.gather(*tasks)

    _log_run(query, results)
    return results



#!/usr/bin/env python3
"""golem-reviewer — monitors golem output, reviews quality, requeues failures.

Runs alongside golem-daemon. Every 5 minutes:
1. Checks for new completed tasks
2. Validates output (files created, tests pass, content quality)
3. Fixes common issues (hardcoded paths, syntax errors)
4. Requeues failed tasks with fixes
5. Commits output periodically
6. Writes progress reports
"""

from __future__ import annotations

import ast
import re
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path, PurePosixPath

GERMLINE = Path.home() / "germline"
EPIGENOME = Path.home() / "epigenome"
QUEUE_FILE = GERMLINE / "loci" / "golem-queue.md"
DAEMON_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
REVIEW_LOG = Path.home() / ".local" / "share" / "vivesca" / "golem-reviewer.log"
POLL_INTERVAL = 300  # 5 minutes
MAC_HOME_PREFIX = f"{PurePosixPath('/', 'Users', 'terry')}/"

# Track state between cycles
last_review_time = None
commit_counter = 0
cycle_number = 0


def log(msg: str):
    REVIEW_LOG.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    with open(REVIEW_LOG, "a") as f:
        f.write(line + "\n")
    print(line)


def run(cmd: str, cwd: str | None = None) -> tuple[int, str]:
    try:
        r = subprocess.run(
            cmd, shell=True, capture_output=True, text=True, timeout=120, cwd=cwd or str(GERMLINE)
        )
        return r.returncode, (r.stdout + r.stderr).strip()
    except subprocess.TimeoutExpired:
        return 124, "timeout"
    except Exception as e:
        return 1, str(e)


def check_daemon_status() -> dict:
    """Check golem-daemon health."""
    _code, out = run("python3 effectors/golem-daemon status")
    # Parse: "Daemon running (PID X), N pending tasks (...)"
    m = re.search(r"(\d+) pending", out)
    pending = int(m.group(1)) if m else 0
    # Check for "running" but NOT "not running"
    running = "running" in out.lower() and "not running" not in out.lower()
    return {"running": running, "pending": pending, "raw": out}


def check_new_output() -> dict:
    """Check what was produced since last review."""
    since = "30 minutes ago" if last_review_time else "2 hours ago"
    _code, commits = run(f"git log --oneline --since='{since}' 2>/dev/null")
    commit_count = len(commits.strip().splitlines()) if commits.strip() else 0

    # Count new files
    _code, new_files = run("git diff --name-only HEAD~10 2>/dev/null")
    new_tests = [f for f in new_files.splitlines() if f.startswith("assays/test_")]
    new_effectors = [f for f in new_files.splitlines() if f.startswith("effectors/")]
    new_consulting = []
    consulting_dir = EPIGENOME / "chromatin" / "euchromatin" / "consulting"
    if consulting_dir.exists():
        for subdir in ["cards", "deep-dives", "case-studies", "prep", "regulatory"]:
            d = consulting_dir / subdir
            if d.exists():
                new_consulting.extend(list(d.glob("*.md")))

    return {
        "commits": commit_count,
        "new_tests": len(new_tests),
        "new_effectors": len(new_effectors),
        "consulting_pieces": len(new_consulting),
    }


def fix_collection_errors():
    """Find and fix pytest collection errors."""
    code, out = run("uv run pytest --co -q 2>&1 | grep ERROR")
    if code != 0 or not out.strip():
        return 0

    errors = out.strip().splitlines()
    fixed = 0
    for err in errors:
        # Extract file path
        m = re.search(r"ERROR (assays/\S+\.py)", err)
        if not m:
            continue
        test_file = GERMLINE / m.group(1)
        if not test_file.exists():
            continue

        try:
            content = test_file.read_text()
            changed = False

            # Fix 1: hardcoded macOS home path
            if MAC_HOME_PREFIX in content:
                content = content.replace(MAC_HOME_PREFIX, str(Path.home()) + "/")
                changed = True

            # Fix 2: verify syntax
            try:
                ast.parse(content)
            except SyntaxError:
                # Can't auto-fix syntax errors beyond path replacement
                log(f"  SYNTAX ERROR in {test_file.name} — needs manual fix")
                continue

            if changed:
                test_file.write_text(content)
                fixed += 1
                log(f"  Fixed {test_file.name} (hardcoded paths)")
        except Exception as e:
            log(f"  Error fixing {test_file.name}: {e}")

    return fixed


def run_test_snapshot() -> dict:
    """Quick pytest snapshot."""
    _code, out = run("uv run pytest -q --tb=no --continue-on-collection-errors 2>&1 | tail -3")
    # Parse: "X passed, Y failed, Z skipped..."
    m = re.search(r"(\d+) passed", out)
    passed = int(m.group(1)) if m else 0
    m = re.search(r"(\d+) failed", out)
    failed = int(m.group(1)) if m else 0
    m = re.search(r"(\d+) error", out)
    errors = int(m.group(1)) if m else 0
    return {"passed": passed, "failed": failed, "errors": errors, "raw": out}


def check_daemon_failures() -> list[str]:
    """Check recent daemon failures."""
    _code, out = run(f"tail -100 {DAEMON_LOG} 2>/dev/null | grep FAILED")
    return out.strip().splitlines() if out.strip() else []


def auto_commit():
    """Commit any uncommitted golem output."""
    global commit_counter
    # Stage known output directories
    run("git add assays/ effectors/ metabolon/ 2>/dev/null")
    code, _status = run("git diff --cached --quiet 2>/dev/null")
    if code != 0:  # There are staged changes
        run('git commit -m "golem-reviewer: auto-commit cycle output"')
        commit_counter += 1
        log(f"  Auto-committed (total: {commit_counter})")
        run("git push 2>/dev/null")

    # Also commit epigenome content
    code, _ = run(
        "git add -A && git diff --cached --quiet || git commit -m 'golem-reviewer: consulting content' && git push",
        cwd=str(EPIGENOME),
    )


def write_progress_report(status: dict, output: dict, tests: dict, failures: list):
    """Write progress report."""
    report_dir = GERMLINE / "loci" / "copia"
    report_dir.mkdir(parents=True, exist_ok=True)

    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    report = f"""# Golem Reviewer — Cycle {cycle_number} ({ts})

## Daemon Status
- Queue: {status["pending"]} pending
- Running: {"yes" if status["running"] else "NO — INVESTIGATE"}

## Output Since Last Review
- New test files: {output["new_tests"]}
- New effectors: {output["new_effectors"]}
- Consulting pieces: {output["consulting_pieces"]}

## Test Health
- Passed: {tests["passed"]}
- Failed: {tests["failed"]}
- Collection errors: {tests["errors"]}

## Recent Failures
{len(failures)} failures in last 100 log lines.

## Auto-commits
{commit_counter} total this session.
"""
    report_path = report_dir / f"reviewer-cycle-{cycle_number}.md"
    report_path.write_text(report)
    log(f"  Report: {report_path.name}")


def review_cycle():
    """One review cycle."""
    global cycle_number, last_review_time
    cycle_number += 1
    log(f"=== Review cycle {cycle_number} ===")

    # 1. Daemon health
    status = check_daemon_status()
    log(f"  Daemon: {'running' if status['running'] else 'STOPPED'}, {status['pending']} pending")

    if not status["running"]:
        log("  ALERT: Daemon not running! Attempting restart...")
        run("python3 effectors/golem-daemon start")
        time.sleep(5)
        status = check_daemon_status()
        log(f"  After restart: {'running' if status['running'] else 'STILL STOPPED'}")

    # 2. Check output
    output = check_new_output()
    log(
        f"  Output: {output['new_tests']} tests, {output['new_effectors']} effectors, {output['consulting_pieces']} consulting"
    )

    # 3. Fix collection errors
    fixed = fix_collection_errors()
    if fixed:
        log(f"  Fixed {fixed} collection errors")

    # 4. Test snapshot (every 3 cycles to avoid slowness)
    tests = {"passed": 0, "failed": 0, "errors": 0, "raw": "skipped"}
    if cycle_number % 3 == 1:
        log("  Running pytest snapshot...")
        tests = run_test_snapshot()
        log(
            f"  Tests: {tests['passed']} passed, {tests['failed']} failed, {tests['errors']} errors"
        )

    # 5. Check failures
    failures = check_daemon_failures()
    if failures:
        log(f"  {len(failures)} recent daemon failures")

    # 6. Auto-commit
    auto_commit()

    # 7. Write report
    write_progress_report(status, output, tests, failures)

    last_review_time = datetime.now()
    log(f"  Cycle {cycle_number} complete. Next in {POLL_INTERVAL}s.")


def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        print("Usage: golem-reviewer [--once] [-h|--help]")
        print()
        print("Monitor golem output, review quality, requeue failures.")
        print()
        print("Options:")
        print("  --once    Run a single review cycle and exit")
        print("  -h, --help  Show this help message")
        return 0

    log("Golem reviewer started")

    if "--once" in sys.argv:
        review_cycle()
        return 0

    try:
        while True:
            review_cycle()
            time.sleep(POLL_INTERVAL)
    except KeyboardInterrupt:
        log("Reviewer stopped (interrupt)")
    except Exception as e:
        log(f"Reviewer crashed: {e}")
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())

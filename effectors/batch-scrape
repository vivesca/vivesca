#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["aiohttp", "beautifulsoup4", "tqdm", "lxml"]
# ///
"""Scrape all Andrew Ng 'The Batch' newsletter editions from deeplearning.ai into JSONL."""

import argparse
import asyncio
import json
import os
import re
import xml.etree.ElementTree as ET
from datetime import UTC, datetime

import aiohttp
from bs4 import BeautifulSoup
from tqdm import tqdm

SITEMAP_INDEX_URL = "https://www.deeplearning.ai/sitemap.xml"
BASE = "https://www.deeplearning.ai/the-batch/"

# Paths to skip (normalised without trailing slash)
SKIP_PATHS = {"/the-batch", "/the-batch/about"}


def load_existing_urls(path: str) -> set[str]:
    urls: set[str] = set()
    if not os.path.exists(path):
        return urls
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                record = json.loads(line)
                if "url" in record:
                    urls.add(record["url"])
            except json.JSONDecodeError:
                continue
    return urls


def is_batch_edition(url: str) -> bool:
    """True if URL is an actual edition/article page (not index, about, or tag)."""
    if not url.startswith(BASE):
        return False
    path = url.replace("https://www.deeplearning.ai", "").rstrip("/")
    if path in SKIP_PATHS:
        return False
    return "/the-batch/tag/" not in url


async def fetch_sitemap_urls(session: aiohttp.ClientSession) -> list[str]:
    """Discover edition URLs from the sitemap."""
    async with session.get(SITEMAP_INDEX_URL) as resp:
        index_text = await resp.text()

    root = ET.fromstring(index_text)
    ns = {"s": "http://www.sitemaps.org/schemas/sitemap/0.9"}
    sub_sitemaps = [loc.text for loc in root.findall(".//s:loc", ns) if loc.text]

    edition_urls: list[str] = []
    for sm_url in sub_sitemaps:
        async with session.get(sm_url) as resp:
            text = await resp.text()
        sub_root = ET.fromstring(text)
        locs = [loc.text for loc in sub_root.findall(".//s:loc", ns) if loc.text]
        edition_urls.extend(url for url in locs if is_batch_edition(url))

    # Deduplicate while preserving order
    seen: set[str] = set()
    unique: list[str] = []
    for url in edition_urls:
        if url not in seen:
            seen.add(url)
            unique.append(url)
    return unique


def extract_date(html: str) -> str:
    """Extract ISO date (YYYY-MM-DD) from meta tags or JSON-LD."""
    # Prefer article:published_time meta
    m = re.search(r'<meta\s+property="article:published_time"\s+content="([^"]+)"', html)
    if not m:
        m = re.search(r'<meta\s+content="([^"]+)"\s+property="article:published_time"', html)
    if m:
        return m.group(1)[:10]  # YYYY-MM-DD

    # Fallback: JSON-LD datePublished
    m = re.search(r'"datePublished"\s*:\s*"([^"]+)"', html)
    if m:
        return m.group(1)[:10]

    return ""


def extract_content(html: str) -> tuple[str, str]:
    """Extract title and body text from an edition page."""
    soup = BeautifulSoup(html, "lxml")

    # Title: first h1 that isn't just "News" or similar generic label
    title = ""
    for h1 in soup.find_all("h1"):
        text = h1.get_text(strip=True)
        # Skip generic headings used in issue pages
        if text.lower() != "news" and len(text) > 3:
            title = text
            break
    if not title:
        title_tag = soup.find("title")
        title = title_tag.get_text(strip=True) if title_tag else ""

    # Body: try article tag first, then common content containers
    body_tag = (
        soup.select_one("article")
        or soup.select_one("[class*='post-content']")
        or soup.select_one("[class*='post_full']")
        or soup.select_one("main")
    )
    if body_tag:
        # Remove nav, footer, aside, script, style elements
        for tag in body_tag.find_all(["nav", "footer", "aside", "script", "style", "header"]):
            tag.decompose()
        body = body_tag.get_text(separator="\n", strip=True)
    else:
        body = ""

    return title, body


async def fetch_edition(
    session: aiohttp.ClientSession,
    url: str,
    semaphore: asyncio.Semaphore,
) -> dict | None:
    async with semaphore:
        try:
            async with session.get(url, timeout=aiohttp.ClientTimeout(total=30)) as resp:
                if resp.status != 200:
                    return None
                html = await resp.text()
        except (aiohttp.ClientError, TimeoutError):
            return None

    title, body = extract_content(html)
    date = extract_date(html)
    fetched_at = datetime.now(UTC).isoformat()

    return {
        "body": body,
        "date": date,
        "fetched_at": fetched_at,
        "title": title,
        "url": url,
    }


async def main() -> None:
    parser = argparse.ArgumentParser(
        description="Scrape Andrew Ng's 'The Batch' newsletter from deeplearning.ai"
    )
    parser.add_argument("--output", default="batch.jsonl", help="JSONL output path")
    parser.add_argument("--concurrency", type=int, default=3, help="Max concurrent requests")
    parser.add_argument("--limit", type=int, default=0, help="Limit editions to fetch (0=all)")
    args = parser.parse_args()

    already_fetched = load_existing_urls(args.output)
    write_lock = asyncio.Lock()

    async with aiohttp.ClientSession(
        headers={"User-Agent": "batch-scrape/1.0 (newsletter archiver)"}
    ) as session:
        print("Fetching sitemap...")
        all_urls = await fetch_sitemap_urls(session)
        to_fetch = [url for url in all_urls if url not in already_fetched]

        if args.limit > 0:
            to_fetch = to_fetch[: args.limit]

        if not to_fetch:
            print(f"Nothing to do — {len(already_fetched)} editions already in file.")
            return

        print(
            f"Found {len(all_urls)} editions, {len(already_fetched)} already fetched, "
            f"{len(to_fetch)} to scrape."
        )
        semaphore = asyncio.Semaphore(args.concurrency)
        batch_size = 50
        fetched_count = 0

        with tqdm(total=len(to_fetch), desc="Scraping") as progress_bar:
            for batch_start in range(0, len(to_fetch), batch_size):
                batch = to_fetch[batch_start : batch_start + batch_size]
                tasks = [fetch_edition(session, url, semaphore) for url in batch]
                results = await asyncio.gather(*tasks)

                records = [r for r in results if r is not None]

                if records:
                    async with write_lock:
                        with open(args.output, "a") as f:
                            f.writelines(
                                json.dumps(record, sort_keys=True) + "\n" for record in records
                            )
                    fetched_count += len(records)

                progress_bar.update(len(batch))

    print(f"Done. {fetched_count} editions saved to {args.output}.")


if __name__ == "__main__":
    asyncio.run(main())

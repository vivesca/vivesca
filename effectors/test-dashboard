#!/usr/bin/env python3
"""test-dashboard — Test coverage and execution dashboard.

Reads ribosome.jsonl log + runs pytest collection. Outputs:
  - Total tests
  - Pass rate
  - Tests per provider
  - Recent trend (last 5 entries)
  - Untested module count

Usage:
    test-dashboard
"""

import contextlib
import json
import re
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

# Paths
GERMLINE_DIR = Path.home() / "germline"
RIBOSOME_LOG = Path.home() / ".local" / "share" / "vivesca" / "ribosome.jsonl"


def read_ribosome_log() -> list[dict]:
    """Read ribosome.jsonl and return list of entries."""
    if not RIBOSOME_LOG.exists():
        return []
    entries = []
    try:
        with open(RIBOSOME_LOG, errors="replace") as f:
            for line in f:
                line = line.strip()
                if line:
                    with contextlib.suppress(json.JSONDecodeError):
                        entries.append(json.loads(line))
    except OSError:
        pass
    return entries


def run_pytest_collection() -> tuple[int, dict[str, int]]:
    """Run pytest --co -q and return (total_tests, tests_per_file)."""
    try:
        result = subprocess.run(
            ["uv", "run", "pytest", "--co", "-q"],
            capture_output=True,
            text=True,
            cwd=GERMLINE_DIR,
            timeout=60,
        )
        output = result.stdout + result.stderr
    except subprocess.TimeoutExpired, FileNotFoundError:
        return 0, {}

    tests_per_file: dict[str, int] = defaultdict(int)
    total = 0

    for line in output.splitlines():
        # Match: assays/test_foo.py::TestClass::test_method
        m = re.match(r"^(assays/test_.*\.py)::", line)
        if m:
            test_file = m.group(1)
            tests_per_file[test_file] += 1
            total += 1

    return total, dict(tests_per_file)


def get_metabolon_modules() -> set[str]:
    """Get all Python modules in metabolon/ (excluding __init__.py and __pycache__)."""
    modules = set()
    metabolon_dir = GERMLINE_DIR / "metabolon"

    if not metabolon_dir.exists():
        return modules

    # Root-level modules
    for f in metabolon_dir.glob("*.py"):
        if f.name not in ("__init__.py",):
            modules.add(f.stem)

    # Subdirectory modules
    for subdir in metabolon_dir.iterdir():
        if subdir.is_dir() and not subdir.name.startswith("__"):
            for f in subdir.glob("*.py"):
                if f.name not in ("__init__.py",):
                    # Store as subdir/module format
                    modules.add(f"{subdir.name}/{f.stem}")

    return modules


def get_tested_modules() -> set[str]:
    """Extract module names from test file names in assays/test_*.py."""
    tested = set()
    assays_dir = GERMLINE_DIR / "assays"

    if not assays_dir.exists():
        return tested

    for f in assays_dir.glob("test_*.py"):
        # test_foo.py -> foo
        name = f.stem[5:]  # Remove "test_" prefix
        if name:
            tested.add(name)

    return tested


def calculate_pass_rate(entries: list[dict]) -> float:
    """Calculate pass rate from ribosome.jsonl entries."""
    if not entries:
        return 0.0

    passed = sum(1 for e in entries if e.get("exit") == 0)
    total = len(entries)
    return passed / total if total > 0 else 0.0


def get_tests_per_provider(entries: list[dict]) -> dict[str, int]:
    """Get count of ribosome invocations per provider from log."""
    provider_counts: dict[str, int] = defaultdict(int)

    for entry in entries:
        provider = entry.get("provider", "unknown")
        provider_counts[provider] += 1

    return dict(sorted(provider_counts.items(), key=lambda x: -x[1]))


def get_recent_trend(entries: list[dict], n: int = 5) -> list[dict]:
    """Get last n entries with summary info."""
    recent = entries[-n:] if len(entries) >= n else entries
    trend = []
    for e in recent:
        trend.append(
            {
                "ts": e.get("ts", ""),
                "provider": e.get("provider", "unknown"),
                "exit": e.get("exit"),
                "duration": e.get("duration"),
                "prompt": e.get("prompt", "")[:50] + "..."
                if len(e.get("prompt", "")) > 50
                else e.get("prompt", ""),
            }
        )
    return trend


def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        return 0
    # Read ribosome log
    entries = read_ribosome_log()

    # Run pytest collection
    total_tests, _tests_per_file = run_pytest_collection()

    # Get module coverage
    metabolon_modules = get_metabolon_modules()
    tested_modules = get_tested_modules()

    # Calculate untested - map test names to module names
    untested = set()
    for module in metabolon_modules:
        # Check if module name matches any tested module
        module_name = module.split("/")[-1]  # Get last part for subdir modules
        if module_name not in tested_modules and module not in tested_modules:
            untested.add(module)

    # Calculate stats
    pass_rate = calculate_pass_rate(entries)
    tests_per_provider = get_tests_per_provider(entries)
    recent_trend = get_recent_trend(entries, 5)

    # Output
    print("=== Test Dashboard ===\n")

    print(f"Total tests: {total_tests}")
    print(
        f"Pass rate: {pass_rate:.1%} ({sum(1 for e in entries if e.get('exit') == 0)}/{len(entries)} ribosome runs)"
    )

    print("\nRibosome runs by provider:")
    if tests_per_provider:
        for provider, count in tests_per_provider.items():
            print(f"  {provider}: {count}")
    else:
        print("  (no data)")

    print("\nRecent trend (last 5):")
    if recent_trend:
        for entry in recent_trend:
            status = "✓" if entry["exit"] == 0 else "✗"
            print(f"  {status} [{entry['provider']}] {entry['duration']}s - {entry['prompt']}")
    else:
        print("  (no entries)")

    print(f"\nUntested modules: {len(untested)}")
    if untested and len(untested) <= 20:
        for m in sorted(untested)[:20]:
            print(f"  - {m}")
    elif untested:
        for m in sorted(untested)[:10]:
            print(f"  - {m}")
        print(f"  ... and {len(untested) - 10} more")

    return 0


if __name__ == "__main__":
    exit(main())

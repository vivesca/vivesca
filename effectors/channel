#!/usr/bin/env python3
"""channel — gated transport to the symbiont via Max subscription.

Strips API credentials so claude uses Max OAuth auth instead of API billing.
Gates on credential availability: fails fast with a clear error if OAuth
auth is not configured, rather than silently dying inside claude --print.

Usage:
    channel sonnet -p "prompt"
    channel haiku -p "prompt"
    channel sonnet -p "prompt" --max-tokens 4096
    channel sonnet --organism -p "prompt"   # full organism: MCP, skills, tools
    echo "prompt" | channel sonnet
"""

import os
import subprocess
import sys
import time

CLAUDE = "/Users/terry/.local/bin/claude"
MODELS = {
    "sonnet": "sonnet",
    "haiku": "haiku",
    "opus": "opus",
}

_TISSUE_TASK = "poiesis_dispatch"


def _tissue_default() -> str | None:
    """Consult tissue_routing for the default channel model. Returns None on any failure."""
    try:
        import sys as _sys
        _germline = str(__import__("pathlib").Path.home() / "germline")
        if _germline not in _sys.path:
            _sys.path.insert(0, _germline)
        from metabolon.organelles.tissue_routing import route
        return route(_TISSUE_TASK)
    except Exception:
        return None


def _gate() -> bool:
    """Verify Max OAuth is live before opening the channel."""
    try:
        result = subprocess.run(
            [CLAUDE, "--version"],
            capture_output=True,
            text=True,
            timeout=5,
            env={k: v for k, v in os.environ.items() if k not in ("CLAUDECODE", "ANTHROPIC_API_KEY")},
        )
        return result.returncode == 0
    except Exception:
        return False


def _record(model: str, success: bool, duration_ms: int, task_type: str = "general") -> None:
    """Record outcome to mitophagy. Silently skips on any error."""
    try:
        import sys as _sys
        _sys.path.insert(0, str(__import__("pathlib").Path.home() / "germline"))
        from metabolon.organelles.mitophagy import record_outcome
        record_outcome(model=model, task_type=task_type, success=success, duration_ms=duration_ms)
    except Exception:
        pass


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__.strip())
        sys.exit(0)

    # Parse --organism flag before model detection
    argv = sys.argv[1:]
    organism = "--organism" in argv
    if organism:
        argv = [a for a in argv if a != "--organism"]

    if not argv:
        print(__doc__.strip())
        sys.exit(0)

    raw_model = argv[0]
    rest = argv[1:]

    if raw_model not in MODELS:
        # No explicit model — consult tissue routing for the default.
        routed = _tissue_default()
        if routed and routed in MODELS:
            print(f"[channel] tissue routing: {_TISSUE_TASK} -> {routed}", file=sys.stderr)
            model = routed
        else:
            print(f"Unknown model: {raw_model}. Choose from: {', '.join(MODELS)}", file=sys.stderr)
            sys.exit(1)
    else:
        model = raw_model

    env = {k: v for k, v in os.environ.items() if k not in ("CLAUDECODE", "ANTHROPIC_API_KEY")}

    if not _gate():
        print("channel: Max OAuth not available — channel closed", file=sys.stderr)
        sys.exit(2)

    args = [CLAUDE, "--print", "--model", MODELS[model]]
    if organism:
        args += ["--permission-mode", "bypassPermissions"]
    args += rest

    task_type = "organism" if organism else "general"
    t0 = time.monotonic()
    result = subprocess.run(args, env=env)
    duration_ms = int((time.monotonic() - t0) * 1000)
    _record(model, result.returncode == 0, duration_ms, task_type)
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()

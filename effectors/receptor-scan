#!/usr/bin/env python3
"""receptor-scan — waterfall knowledge search.

QMD (authoritative vault) first, Oghma (conversation memory) fallback.
Usage: receptor-scan <query>

Rewritten in Python to avoid bash-guard intercepting internal grep/echo.
"""

import os
import subprocess
import sys


def run(cmd: list[str], timeout: int = 15) -> str:
    """Run a command, return stdout. Empty string on failure."""
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip()
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("receptor-scan — waterfall knowledge search\n")
        print("Usage: receptor-scan <query>")
        print("\nSearches QMD (authoritative vault) first, Oghma (conversation memory) fallback.")
        sys.exit(0 if len(sys.argv) >= 2 and sys.argv[1] in ("-h", "--help") else 1)

    query = " ".join(sys.argv[1:])

    # Ensure tools are on PATH
    extra = [os.path.expanduser("~/.bun/bin"), os.path.expanduser("~/.local/bin")]
    os.environ["PATH"] = ":".join(extra) + ":" + os.environ.get("PATH", "")

    # Tier 1: QMD (vault + docs/solutions — authoritative)
    qmd_output = run(["qmd", "search", query, "--limit", "5"])
    qmd_count = sum(1 for line in qmd_output.splitlines() if line.startswith("qmd://"))

    print(f"=== Vault (authoritative) — {qmd_count} results ===")
    if qmd_count > 0:
        print(qmd_output)
    else:
        print("(no results)")

    # Tier 2: Oghma fallback only if vault returned < 3
    # Categories now restricted to learning + gotcha at extraction time (source fix)
    if qmd_count < 3:
        print()
        print("=== Oghma (conversation memory) ===")
        oghma_output = run(["oghma", "search", query, "--mode", "hybrid", "--limit", "5"])
        print(oghma_output if oghma_output else "(oghma unavailable)")


if __name__ == "__main__":
    main()

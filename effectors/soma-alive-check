#!/usr/bin/env bash
# soma-alive-check — Mac-side DR gate.
#
# Exit codes:
#   0 = soma is alive (Mac DR job should skip and exit)
#   1 = soma is dead (Mac DR job should run)
#
# Used as a gate at the start of Mac LaunchAgent wrapper scripts:
#   if soma-alive-check; then exit 0; fi    # soma is up → skip, we're DR
#   exec actual-command "$@"                 # soma is down → run
#
# Checks (in order of cost):
#   1. Tailscale ping to soma (fast, ~50ms)
#   2. fly machine status (slower, ~500ms, but authoritative)
#
# We deliberately do NOT check vivesca MCP or other app-level health — a
# responsive VM that's running supervisor is "alive enough" for DR purposes.
# App-level health is the primary's responsibility (soma-watchdog alerts).

set -u

# 1. Tailscale reachability — fast path
if command -v tailscale >/dev/null 2>&1; then
  if tailscale ping -c 1 --timeout 3s soma >/dev/null 2>&1; then
    exit 0  # alive
  fi
fi

# 2. Fly machine status — authoritative fallback
# Only used if Tailscale check fails (might be a Tailscale issue, not soma)
if command -v fly >/dev/null 2>&1; then
  status=$(fly status -a soma --json 2>/dev/null | grep -o '"state":"[^"]*"' | head -1 | sed 's/.*:"\([^"]*\)".*/\1/')
  if [ "$status" = "started" ]; then
    # Started in Fly's view AND we got here means Tailscale is broken.
    # Trust Fly: if machine is "started" and has passing health checks (added today),
    # it's alive. DR should NOT take over just because Tailscale is flaky.
    checks=$(fly status -a soma 2>/dev/null | grep -o '[0-9]* passing')
    if [[ "$checks" == *"1 passing"* ]] || [[ "$checks" == *"2 passing"* ]]; then
      exit 0  # alive per Fly
    fi
  fi
fi

# Both checks failed → soma is genuinely unreachable
exit 1

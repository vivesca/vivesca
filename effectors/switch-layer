#!/usr/bin/env python3
"""switch-layer <layer> — reincarnate the organism's vocabulary.

switch-layer cell          Live in a new layer
switch-layer default       Restore original names
switch-layer --current     Show active layer
switch-layer --list        List layers
switch-layer --dry-run <l> Preview changes
"""

import os
import re
import sys
from pathlib import Path

import yaml

GENOME = Path.home() / "skills"
VARIANTS = GENOME / "layers"
PHENOTYPE = Path.home() / ".claude" / "skills"
CURRENT_LAYER = VARIANTS / ".current"

CYTOPLASM = [
    Path.home() / "skills",
    Path.home() / "bin",
    Path.home() / "vivesca",
    Path.home() / "scripts",
]
EXPRESSIBLE = {".py", ".md", ".yaml", ".yml", ".toml", ".sh", ".zsh"}

FOREIGN_TISSUE = {
    ".git",
    "node_modules",
    "__pycache__",
    "layers",
    ".venv",
    "venv",
    ".archive",
    "compound-engineering",
    "superpowers",
}

MEMBRANE_EMBEDDED = {
    "plan",
    "publish",
    "forge",
    "analyze",
    "announce",
    "commute",
    "weekly",
    "overnight",
    "tweet",
    "monthly",
    "quarterly",
    "period",
    "loop",
    "rector",
}


def read_variant(name):
    path = VARIANTS / f"{name}.yaml"
    if not path.exists():
        print(f"Layer not found: {name}")
        print(f"Available: {', '.join(list_variants())}")
        sys.exit(1)
    with open(path) as f:
        raw = yaml.safe_load(f) or {}
    return {k: v for k, v in raw.items() if isinstance(v, str)}


def active_layer():
    if CURRENT_LAYER.exists():
        return CURRENT_LAYER.read_text().strip()
    return "default"


def list_variants():
    return sorted(p.stem for p in VARIANTS.glob("*.yaml"))


def reverse_mapping():
    current = active_layer()
    if current == "default":
        return {}
    mapping = read_variant(current)
    return {v: k for k, v in mapping.items()}


def express_phenotype(mapping, dry_run=False):
    changes = []
    organelles = [d for d in GENOME.iterdir() if d.is_dir() and d.name not in FOREIGN_TISSUE]

    if not dry_run:
        for link in PHENOTYPE.iterdir():
            if link.is_symlink():
                target = os.path.realpath(link)
                if target.startswith(str(GENOME)):
                    link.unlink()

    for organelle in organelles:
        genotype = organelle.name
        expressed = mapping.get(genotype, genotype)

        if expressed != genotype:
            changes.append(("skill", genotype, expressed))

        if not dry_run:
            symlink = PHENOTYPE / expressed
            if not symlink.exists():
                symlink.symlink_to(organelle)

            marker = organelle / "SKILL.md"
            if marker.exists():
                content = marker.read_text()
                content = re.sub(
                    r"(?m)^(name:\s*).+$",
                    rf"\g<1>{expressed}",
                    content,
                    count=1,
                )
                marker.write_text(content)

    return changes


def express_effectors(mapping, dry_run=False):
    changes = []
    bin_dir = Path.home() / "bin"

    for genotype, expressed in mapping.items():
        source = bin_dir / genotype
        alias = bin_dir / expressed

        if source.exists() and not source.is_symlink():
            if not dry_run:
                if alias.exists() or alias.is_symlink():
                    alias.unlink()
                alias.symlink_to(source)
            changes.append(("cli-alias", genotype, expressed))

    return changes


def transcribe(old_to_new, dry_run=False):
    changes = []
    soluble = {k: v for k, v in old_to_new.items() if k not in MEMBRANE_EMBEDDED}
    sorted_names = sorted(soluble.keys(), key=len, reverse=True)
    if not sorted_names:
        return changes

    pattern = re.compile(r"\b(" + "|".join(re.escape(n) for n in sorted_names) + r")\b")

    for region in CYTOPLASM:
        if not region.exists():
            continue
        for path in region.rglob("*"):
            if any(skip in path.parts for skip in FOREIGN_TISSUE):
                continue
            if path.suffix not in EXPRESSIBLE:
                continue
            if not path.is_file():
                continue

            try:
                content = path.read_text()
            except (UnicodeDecodeError, PermissionError):
                continue

            new_content = pattern.sub(lambda m: soluble[m.group(0)], content)

            if new_content != content:
                count = sum(
                    1 for m in pattern.finditer(content) if soluble.get(m.group(0)) != m.group(0)
                )
                changes.append(("code", str(path), f"{count} replacements"))
                if not dry_run:
                    path.write_text(new_content)

    return changes


def differentiate(layer_name, dry_run=False):
    current = active_layer()

    if current != "default" and current != layer_name:
        print(f"Apoptosing '{current}'...")
        reverse = reverse_mapping()
        if reverse:
            express_phenotype(reverse)
            transcribe(reverse)
        prev = read_variant(current)
        bin_dir = Path.home() / "bin"
        for expressed in prev.values():
            alias = bin_dir / expressed
            if alias.is_symlink():
                alias.unlink()
        CURRENT_LAYER.write_text("default")

    if layer_name == "default":
        reverse = reverse_mapping() if current != "default" else {}
        identity = {
            d.name: d.name for d in GENOME.iterdir() if d.is_dir() and d.name not in FOREIGN_TISSUE
        }
        express_phenotype(identity, dry_run)
        if not dry_run:
            CURRENT_LAYER.write_text("default")
        print("Restored to default names.")
        return

    mapping = read_variant(layer_name)

    print(f"Differentiating into: {layer_name}")
    if dry_run:
        print("(dry run)\n")

    all_changes = []
    all_changes.extend(express_phenotype(mapping, dry_run))
    all_changes.extend(express_effectors(mapping, dry_run))
    all_changes.extend(transcribe(mapping, dry_run))

    if not dry_run:
        CURRENT_LAYER.write_text(layer_name)

    if all_changes:
        for kind, old, new in all_changes:
            print(f"  [{kind}] {old} → {new}")
        print(f"\n{'Would change' if dry_run else 'Changed'}: {len(all_changes)} items")
    else:
        print("  No changes.")


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    if args[0] == "--current":
        print(active_layer())
    elif args[0] == "--list":
        current = active_layer()
        for layer in list_variants():
            marker = " (active)" if layer == current else ""
            print(f"  {layer}{marker}")
    elif args[0] == "--dry-run" and len(args) > 1:
        differentiate(args[1], dry_run=True)
    else:
        differentiate(args[0])


if __name__ == "__main__":
    main()

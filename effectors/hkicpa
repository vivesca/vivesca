# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""
hkicpa — auto-login to HKICPA LMS and open course page.

Usage:
  hkicpa              open enrolled courses
  hkicpa <course-url> open specific course
"""

import os
import subprocess
import sys
import time

HOME_URL = "https://lms.hkicpa.org.hk/web/user/html/index.html"
LOGIN_URL = "https://lms.hkicpa.org.hk"


def run(cmd: str) -> str:
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)
    return result.stdout.strip()


def ab(*args: str) -> None:
    subprocess.run(["agent-browser", *args], timeout=60)


def get_password() -> str:
    import shutil
    user = os.environ.get("USER", "terry")
    if shutil.which("secret-tool"):
        pw = run(f"secret-tool lookup service hkicpa account {user} 2>/dev/null")
        if pw:
            return pw
        print("No HKICPA password in keyring.", file=sys.stderr)
        print(f"  secret-tool store --label='HKICPA' service hkicpa account {user}", file=sys.stderr)
        sys.exit(1)
    elif shutil.which("security"):
        pw = run(f"security find-generic-password -s hkicpa -a {user} -w 2>/dev/null")
        if pw:
            return pw
        print("No HKICPA password in keychain.", file=sys.stderr)
        print(f"  security add-generic-password -s hkicpa -a {user} -w <password>", file=sys.stderr)
        sys.exit(1)
    else:
        print("No supported secret store found (need secret-tool or security).", file=sys.stderr)
        sys.exit(1)


def main() -> None:
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        return
    target = sys.argv[1] if len(sys.argv) > 1 else HOME_URL
    pw = get_password()

    run("agent-browser close")
    ab("--headed", "open", LOGIN_URL)
    time.sleep(2)

    ab("fill", "Password", pw)
    ab("press", "Enter")
    time.sleep(3)

    url = run("agent-browser get url")
    if "session/out" in url or "login" in url.lower():
        print("Login failed", file=sys.stderr)
        sys.exit(1)

    ab("open", target)
    print(f"Ready: {target}")


if __name__ == "__main__":
    main()

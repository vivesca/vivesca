#!/usr/bin/env bash
# ribosome — headless CC + cheap LLM backends. Faithful instruction executor.
#
# Usage:
#   ribosome "prompt"                                    # build (default)
#   ribosome explore "How does MCP registration work?"   # codebase exploration
#   ribosome build "Write tests for metabolon/foo.py"    # explicit build
#   ribosome test metabolon/foo.py                       # write tests for module
#   ribosome batch metabolon/foo.py metabolon/bar.py     # sequential test gen
#   ribosome summary [--recent N] [--json]               # provider stats
set -euo pipefail

# Ensure user-local tools (ruff, uv, etc.) are on PATH — worktrees inherit
# a minimal environment that often lacks ~/.local/bin.
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# ERR trap: produce diagnostic output when a command fails (set -e kills the script).
# Without this, crashes produce exit=2 with empty output, making debugging impossible.
_ribosome_crash_handler() {
  local _exit_code=$?
  echo "[ribosome crash] command failed with exit=$_exit_code at line $1 (provider=${PROVIDER:-?})" >&2
  exit "$_exit_code"
}
trap '_ribosome_crash_handler $LINENO' ERR

# No turn counter, no wall-limit. CC finishes naturally.
# Stall detection catches loops. Temporal activity timeout (2hr) is the outer bound.
BARE=true
FULL_REQUESTED=false
FORCE=false
QUIET=false
JSON_OUTPUT=false
SUMMARY=false
SUPERVISED=false
RECENT=0
PROVIDER=""
HARNESS=""
BACKEND=""
PROVIDER_COMPAT="${RIBOSOME_PROVIDER:-}"
FALLBACK=false
FALLBACK_PROVIDER=""
MANIFEST_MODE=false
RIBOSOME_TASK_ID=""

RIBOSOME_LOG="${RIBOSOME_LOG:-$HOME/.local/share/vivesca/ribosome.jsonl}"
mkdir -p "$(dirname "$RIBOSOME_LOG")"

COACHING_FILE="$HOME/epigenome/marks/feedback_ribosome_coaching.md"

# Summary subcommand - show provider stats from JSONL log
_run_summary() {
  python3 - "$@" << 'PYTHON_SCRIPT'
import json
import sys
import os
from collections import defaultdict

recent = 0
log_file = None
json_output = False

# Parse args
args = sys.argv[1:]
i = 0
while i < len(args):
    if args[i] == '--recent' and i + 1 < len(args):
        recent = int(args[i + 1])
        i += 2
    elif args[i].startswith('--log='):
        log_file = args[i][6:]
        i += 1
    elif args[i] == '--json':
        json_output = True
        i += 1
    else:
        i += 1

if not log_file:
    log_file = os.environ.get('RIBOSOME_LOG', os.path.expanduser('~/.local/share/vivesca/ribosome.jsonl'))

stats = defaultdict(lambda: {'runs': 0, 'pass': 0, 'fail': 0, 'total_duration': 0, 'tests_created': 0})

try:
    with open(log_file, 'r', errors='replace') as f:
        lines = f.readlines()

    if recent > 0:
        lines = lines[-recent:]

    for line in lines:
        line = line.strip()
        if not line:
            continue
        try:
            data = json.loads(line)
            provider = data.get('provider', 'unknown')
            stats[provider]['runs'] += 1
            exit_code = data.get('exit', -1)
            if exit_code == 0:
                stats[provider]['pass'] += 1
            else:
                stats[provider]['fail'] += 1
            stats[provider]['total_duration'] += data.get('duration', 0)
            stats[provider]['tests_created'] += data.get('tests_passed', 0) + data.get('tests_failed', 0)
        except json.JSONDecodeError:
            continue

    # Print output
    if json_output:
        result = {}
        for provider in sorted(stats.keys()):
            s = stats[provider]
            result[provider] = {
                'runs': s['runs'],
                'pass': s['pass'],
                'fail': s['fail'],
                'avg_duration': s['total_duration'] // s['runs'] if s['runs'] > 0 else 0,
                'tests_created': s['tests_created'],
            }
        print(json.dumps(result))
    else:
        print(f"{'Provider':<12} | {'Runs':>4} | {'Pass':>4} | {'Fail':>4} | {'Avg Duration':>12} | {'Tests Created':>13}")
        print('-' * 63)
        for provider in sorted(stats.keys()):
            s = stats[provider]
            avg_dur = s['total_duration'] // s['runs'] if s['runs'] > 0 else 0
            print(f"{provider:<12} | {s['runs']:>4} | {s['pass']:>4} | {s['fail']:>4} | {avg_dur:>10}s | {s['tests_created']:>13}")
except FileNotFoundError:
    print(f"No log file found: {log_file}", file=sys.stderr)
    sys.exit(1)
PYTHON_SCRIPT
}

# Handle subcommands first
# Consolidated subcommands: delegate to ribosome-tools Python script
_RIBOSOME_TOOLS="$(dirname "$0")/ribosome-tools"
case "${1:-}" in
  summary)
    shift
    summary_args=()
    while [[ "${1:-}" == --* ]]; do
      case "$1" in
        --recent) summary_args+=("--recent" "$2"); shift 2 ;;
        --json) summary_args+=("--json"); JSON_OUTPUT=true; shift ;;
        --log=*) summary_args+=("$1"); shift ;;
        --quiet) QUIET=true; shift ;;
        -h|--help) head -11 "$0" | tail -10 | sed 's/^# */  /'; exit 0 ;;
        *) echo "Unknown flag: $1" >&2; exit 1 ;;
      esac
    done
    if $QUIET; then
      _run_summary "${summary_args[@]+"${summary_args[@]}"}" >/dev/null
    else
      _run_summary "${summary_args[@]+"${summary_args[@]}"}"
    fi
    exit 0
    ;;
  dash|health|status|review)
    _subcmd="$1"; shift
    exec python3 "$_RIBOSOME_TOOLS" "$_subcmd" "$@"
    ;;
esac

# Strip optional task ID prefix: [t-xxxxxx] placed by ribosome-daemon before flags
# e.g. "ribosome [t-a4a00f] --provider volcano ..." → task_id=t-a4a00f, then parse flags
if [[ "${1:-}" =~ ^\[t-[0-9a-fA-F]+\]$ ]]; then
  RIBOSOME_TASK_ID="${1:1:-1}"  # strip brackets
  export RIBOSOME_TASK_ID
  shift
fi

# Subcommand routing — detect mode from first positional arg
_SUBCOMMAND=build  # default
case "${1:-}" in
  explore) _SUBCOMMAND=explore; shift ;;
  build)   _SUBCOMMAND=build; shift ;;
  test)    _SUBCOMMAND=test; shift ;;
  batch)   _SUBCOMMAND=batch; shift ;;
  summary) ;;  # already handled upstream, don't touch
esac

# Parse regular flags
while [[ "${1:-}" == -* ]]; do
  case "$1" in
    --batch) echo "[deprecated] --batch flag is deprecated, use: ribosome batch <mod1> <mod2>" >&2; _SUBCOMMAND=batch; shift ;;
    --test) echo "[deprecated] --test flag is deprecated, use: ribosome test <module>" >&2; _SUBCOMMAND=test; shift ;;
    --full) BARE=false; FULL_REQUESTED=true; shift ;;
    --bare) BARE=true; shift ;;
    --supervised) SUPERVISED=true; BARE=false; shift ;;
    --quiet) QUIET=true; shift ;;
    --json) JSON_OUTPUT=true; shift ;;
    --harness) HARNESS="$2"; shift 2 ;;
    --backend) BACKEND="$2"; shift 2 ;;
    --provider) PROVIDER_COMPAT="$2"; shift 2 ;;
    --fallback) FALLBACK=true; shift ;;
    --explore) echo "[deprecated] --explore flag is deprecated, use: ribosome explore \"query\"" >&2; _SUBCOMMAND=explore; shift ;;
    --force) FORCE=true; shift ;;
    --mode)
      shift
      [[ "${1:-}" == "manifest" ]] && MANIFEST_MODE=true
      shift
      ;;
    -h|--help) head -10 "$0" | tail -9 | sed 's/^# */  /'; exit 0 ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

# Per-subcommand defaults
case $_SUBCOMMAND in
  explore) BARE=true ;;
  test|batch) ;;
  build) ;;
esac

# Guard: --full uses Opus (expensive). Require --force for non-interactive use.
if $FULL_REQUESTED && ! $FORCE; then
  echo "[ribosome] --full uses Opus (non-bare CC). This is expensive for batch work." >&2
  echo "[ribosome] Pass --force to confirm, or omit --full for bare mode." >&2
  exit 1
fi

# Backend config: API key, base URL, model tiers
_configure_backend() {
  local backend="$1"
  case "$backend" in
    zhipu)
      _KEY="${ZHIPU_API_KEY:?ZHIPU_API_KEY not set}"
      _URL="https://open.bigmodel.cn/api/anthropic"
      _OPUS="glm-5.1"; _SONNET="glm-5.1"; _HAIKU="glm-4.5-air" ;;
    volcano)
      _KEY="${VOLCANO_API_KEY:?VOLCANO_API_KEY not set}"
      _URL="https://ark.cn-beijing.volces.com/api/coding"
      _OPUS="ark-code-latest"; _SONNET="ark-code-latest"; _HAIKU="ark-code-latest" ;;
    infini)
      _KEY="${INFINI_API_KEY:?INFINI_API_KEY not set}"
      _URL="https://cloud.infini-ai.com/maas/coding"
      _OPUS="glm-5.1"; _SONNET="glm-5.1"; _HAIKU="glm-5.1" ;;
    gemini)
      _KEY="${GOOGLE_API_KEY:?GOOGLE_API_KEY not set}"
      _URL=""; _OPUS=""; _SONNET=""; _HAIKU="" ;;
    codex)
      _KEY="${OPENAI_API_KEY:?OPENAI_API_KEY not set}"
      _URL=""; _OPUS=""; _SONNET=""; _HAIKU="" ;;
    *)
      echo "Unknown backend: $backend" >&2; exit 1 ;;
  esac
}

# Map legacy provider name to harness
_provider_to_harness() {
  case "$1" in
    zhipu|infini|volcano) echo "claude" ;;
    goose) echo "goose" ;;
    droid) echo "droid" ;;
    gemini) echo "gemini" ;;
    codex) echo "codex" ;;
    opencode) echo "opencode" ;;
  esac
}

# Map --provider / RIBOSOME_PROVIDER to harness+backend (backward compat)
if [[ -n "$PROVIDER_COMPAT" ]]; then
  case "$PROVIDER_COMPAT" in
    zhipu|infini|volcano)
      HARNESS="${HARNESS:-claude}"
      BACKEND="${BACKEND:-$PROVIDER_COMPAT}" ;;
    goose|droid|opencode)
      HARNESS="${HARNESS:-$PROVIDER_COMPAT}"
      BACKEND="${BACKEND:-zhipu}" ;;
    gemini|codex)
      HARNESS="${HARNESS:-$PROVIDER_COMPAT}" ;;
    *) echo "Unknown provider: $PROVIDER_COMPAT" >&2; exit 1 ;;
  esac
fi

# Defaults
HARNESS="${HARNESS:-claude}"
BACKEND="${BACKEND:-zhipu}"

# Validate harness
case "$HARNESS" in
  claude|goose|droid|gemini|codex|opencode) ;;
  *) echo "Unknown harness: $HARNESS" >&2; exit 1 ;;
esac

# Validate backend for harnesses that use it
case "$HARNESS" in
  claude|goose|droid|opencode)
    case "$BACKEND" in
      zhipu|infini|volcano) ;;
      *) echo "Unknown backend: $BACKEND" >&2; exit 1 ;;
    esac ;;
esac

# Derive PROVIDER for logging/backward compat
if [[ -n "$PROVIDER_COMPAT" ]]; then
  PROVIDER="$PROVIDER_COMPAT"
elif [[ "$HARNESS" != "claude" ]]; then
  PROVIDER="$HARNESS"
else
  PROVIDER="$BACKEND"
fi

# Auto-route: complex tasks (--full) get strongest free provider;
# simple/batch tasks get most unlimited. User --provider overrides both.
if [[ "$BACKEND" == "zhipu" && -z "${RIBOSOME_PROVIDER:-}" && "$FULL_REQUESTED" == "true" && "$HARNESS" == "claude" ]]; then
  BACKEND="infini"
  PROVIDER="infini"
fi

# Only configure backend when LLM may be needed (manifest mode is zero-LLM)
if ! $MANIFEST_MODE; then
  _configure_backend "$BACKEND"
fi

# Explore: cheap model tier (separate rate-limit pool from GLM-5.1)
if [[ $_SUBCOMMAND == explore && $BACKEND == zhipu && "$HARNESS" == "claude" ]]; then
  _OPUS="GLM-4.5-air"; _SONNET="GLM-4.5-air"
fi

# Fallback priority: strongest model first, free before paid at same tier.
# Iterates list, preflights API providers, returns first healthy one.
# Gemini/codex skip preflight (no API endpoint to probe).
# SWE-bench Verified (Apr 2026): Gemini 3.1 Pro 80.6%, M2.5 80.2%,
#   GPT-5.4 ~80%, GLM-5 77.8%, Doubao Seed 2.0 ~Kilo#4.
# Tier 1 (~80%): infini (free) > codex (paid) > gemini (paid)
# Tier 2 (~78%): volcano (free) > zhipu (free)
_FALLBACK_PRIORITY=(infini codex gemini volcano zhipu)

_find_fallback() {
  local failed="$1"
  local candidate
  for candidate in "${_FALLBACK_PRIORITY[@]}"; do
    [[ "$candidate" == "$failed" ]] && continue
    # Save/restore global state around preflight probe
    local _save_key="${_KEY:-}" _save_url="${_URL:-}" _save_opus="${_OPUS:-}" _save_sonnet="${_SONNET:-}" _save_haiku="${_HAIKU:-}"
    _configure_backend "$candidate" 2>/dev/null || continue
    local _harness
    _harness=$(_provider_to_harness "$candidate")
    if [[ "$_harness" != "claude" ]]; then
      # Non-CC harness — no API preflight, assume available
      _KEY="$_save_key"; _URL="$_save_url"; _OPUS="$_save_opus"; _SONNET="$_save_sonnet"; _HAIKU="$_save_haiku"
      echo "$candidate"; return 0
    fi
    if _preflight_check >/dev/null 2>&1; then
      _KEY="$_save_key"; _URL="$_save_url"; _OPUS="$_save_opus"; _SONNET="$_save_sonnet"; _HAIKU="$_save_haiku"
      echo "$candidate"; return 0
    fi
    $QUIET || echo "[fallback] $candidate unhealthy, skipping" >&2
    _KEY="$_save_key"; _URL="$_save_url"; _OPUS="$_save_opus"; _SONNET="$_save_sonnet"; _HAIKU="$_save_haiku"
  done
  echo ""; return 1
}

# Pre-flight health check: curl the provider's /v1/messages endpoint with a
# minimal request. Returns 0 if healthy, 1 if rate-limited (prints reset time
# on stdout), 2 if auth/connection error.
_preflight_check() {
  local _response _http_code _body
  _body=$(curl -s -w '\n%{http_code}' \
    "${_URL}/v1/messages" \
    -H "x-api-key: ${_KEY}" \
    -H "Content-Type: application/json" \
    -H "anthropic-version: 2023-06-01" \
    -d '{"model":"'"$_HAIKU"'","max_tokens":1,"messages":[{"role":"user","content":"ping"}]}' \
    --connect-timeout 10 --max-time 30 2>/dev/null) || return 2
  _http_code=$(echo "$_body" | tail -1)
  _response=$(echo "$_body" | sed '$d')
  # Check response body for rate-limit indicators even on non-429 status
  # Infini returns code 20013 for quota exhaustion (sometimes with non-429 HTTP status)
  if echo "$_response" | grep -qE '"code":20013|request limit exceeded|AccountQuotaExceeded'; then
    local _reset
    _reset=$(echo "$_response" | grep -oE 'reset at [0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1 || true)
    # Infini embeds the window in the error message: "5-hour request limit exceeded"
    local _window
    _window=$(echo "$_response" | grep -oE '[0-9]+-hour request limit' | grep -oE '[0-9]+' | head -1 || true)
    if [[ -n "$_window" ]]; then
      echo "${_reset:-rate-limited, no reset time} window=${_window}h"
    else
      echo "${_reset:-rate-limited, no reset time}"
    fi
    return 1
  fi
  case "$_http_code" in
    200) return 0 ;;
    429)
      # Extract reset time from error JSON (e.g. "reset at 2026-04-01 11:05:30 +0800")
      local _reset
      _reset=$(echo "$_response" | grep -oE 'reset at [0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1 || true)
      echo "${_reset:-rate-limited, no reset time}"
      return 1 ;;
    *) return 2 ;;
  esac
}

# Single source of truth for claude harness env. Preflight and run both use this.
# LOCKED: if you add an env var here, both preflight and run get it automatically.
_claude_env() {
  # Usage: _claude_env [extra_var=val ...] command args...
  env -i HOME="$HOME" PATH="$PATH" USER="${USER:-}" \
    CLAUDECODE= \
    ANTHROPIC_AUTH_TOKEN="$_KEY" \
    ANTHROPIC_API_KEY="" \
    ANTHROPIC_BASE_URL="$_URL" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="$_OPUS" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="$_SONNET" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="$_HAIKU" \
    API_TIMEOUT_MS=3000000 \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
    "$@"
}

# Per-harness runners: each uses env -i to isolate from parent env.
# This prevents ANTHROPIC_* leakage from a parent CC session (mtor/Temporal bug).
_run_harness_claude() {
  local prompt="$1"
  local _claude_timeout="$2"
  _claude_env \
    CLAUDE_CODE_MAX_RETRIES="${RIBOSOME_CLAUDE_RETRIES:-2}" \
    CLAUDE_CODE_TMPDIR="/tmp/ribosome-${PROVIDER}-${RIBOSOME_TASK_ID:-$$}" \
    MCP_CONNECTION_NONBLOCKING=true \
    ${RIBOSOME_DEFER_ENABLED:+RIBOSOME_DEFER_ENABLED="$RIBOSOME_DEFER_ENABLED"} \
    timeout "$_claude_timeout" \
    claude "${args[@]}" -p "$prompt" < /dev/null 2>&1
}

_run_harness_goose() {
  local prompt="$1"
  local _timeout="$2"
  env -i HOME="$HOME" PATH="$PATH" USER="${USER:-}" \
    ANTHROPIC_API_KEY="$_KEY" \
    ANTHROPIC_HOST="$_URL" \
    GOOSE_MOIM_MESSAGE_FILE="$COACHING_FILE" \
    timeout "$_timeout" \
    goose run -q --no-session \
      --provider anthropic --model "$_OPUS" \
      -t "$prompt" 2>&1
}

_preflight_probe() {
  local harness="$1"
  local output
  case "$harness" in
    claude)
      output=$(_claude_env timeout 30 claude --bare --print -p "echo ok" 2>&1)
      ;;
    goose)
      output=$(env -i HOME="$HOME" PATH="$PATH" USER="${USER:-}" \
        ANTHROPIC_API_KEY="$_KEY" \
        ANTHROPIC_HOST="$_URL" \
        timeout 30 goose run -q -t "echo ok" 2>&1)
      ;;
    # For other harnesses, skip preflight probe
    *)
      return 0
      ;;
  esac
  if [[ -z "${output// /}" ]]; then
    echo "FATAL: $harness preflight probe returned empty output" >&2
    return 1
  fi
}

_run_harness_droid() {
  local prompt="$1"
  local _timeout="$2"
  local _droid_args=(exec --auto medium -m "custom:$_OPUS")
  [[ -f "$COACHING_FILE" ]] && _droid_args+=(--append-system-prompt-file "$COACHING_FILE")
  env -i HOME="$HOME" PATH="$PATH" USER="${USER:-}" \
    ZHIPU_API_KEY="$_KEY" \
    timeout "$_timeout" \
    droid "${_droid_args[@]}" "$prompt" 2>&1
}

_run_harness_gemini() {
  local prompt="$1"
  local _timeout="$2"
  env -i HOME="$HOME" PATH="$PATH" USER="${USER:-}" \
    GEMINI_API_KEY="$_KEY" \
    GOOGLE_API_KEY="$_KEY" \
    timeout "$_timeout" \
    gemini --sandbox=false --yolo -p "$prompt" < /dev/null 2>&1
}

_run_harness_codex() {
  local prompt="$1"
  local _timeout="$2"
  env -i HOME="$HOME" PATH="$PATH" USER="${USER:-}" \
    OPENAI_API_KEY="$_KEY" \
    timeout "$_timeout" \
    codex exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check "$prompt" 2>&1
}

_run_harness_opencode() {
  local prompt="$1"
  local _timeout="$2"
  # Ensure auth.json exists — opencode reads creds from file, not env
  local _auth_dir="$HOME/.local/share/opencode"
  mkdir -p "$_auth_dir"
  printf '{"zhipuai":{"apiKey":"%s"}}' "$_KEY" > "$_auth_dir/auth.json"
  env -i HOME="$HOME" PATH="$HOME/.opencode/bin:$PATH" USER="${USER:-}" \
    timeout "$_timeout" \
    opencode run -m "zhipu-coding/glm-5.1" "$prompt" 2>&1
}

_execute_manifest() {
  local manifest="$1"
  local last_run_exit=0
  local last_run_cmd=""
  local last_run_output=""

  # Phase 1: Create files deterministically (zero LLM tokens)
  local in_file=false
  local current_file=""
  local current_content=""
  local commit_msg=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^FILE:\ (.+) ]]; then
      # Flush previous file
      if [[ -n "$current_file" ]]; then
        mkdir -p "$(dirname "$current_file")"
        printf '%s' "$current_content" > "$current_file"
        $QUIET || echo "[manifest] created $current_file" >&2
      fi
      current_file="${BASH_REMATCH[1]}"
      current_content=""
      in_file=true
    elif [[ "$line" == "END_FILE" ]]; then
      if [[ -n "$current_file" ]]; then
        mkdir -p "$(dirname "$current_file")"
        printf '%s' "$current_content" > "$current_file"
        $QUIET || echo "[manifest] created $current_file" >&2
      fi
      current_file=""
      current_content=""
      in_file=false
    elif $in_file; then
      current_content+="${line}"$'\n'
    elif [[ "$line" =~ ^RUN:\ (.+) ]]; then
      last_run_cmd="${BASH_REMATCH[1]}"
      $QUIET || echo "[manifest] RUN: $last_run_cmd" >&2
      last_run_output=$(eval "$last_run_cmd" 2>&1) && last_run_exit=0 || last_run_exit=$?
      if [[ $last_run_exit -ne 0 ]]; then
        $QUIET || echo "[manifest] FAILED (exit=$last_run_exit)" >&2
        $QUIET || echo "$last_run_output" | tail -20 >&2
      fi
    elif [[ "$line" == "FIX_IF_FAILING" && $last_run_exit -ne 0 ]]; then
      $QUIET || echo "[manifest] tests failed, handing off to LLM for fixes" >&2
      local fix_prompt
      fix_prompt="Tests failed. Fix the code so tests pass. Do NOT rewrite files from scratch — read them and make surgical fixes only.

Test command: $last_run_cmd
Exit code: $last_run_exit

Test output (last 50 lines):
$(echo "$last_run_output" | tail -50)

Changed files:
$(git diff --name-only 2>/dev/null)"
      # Delegate to normal ribosome LLM dispatch
      MANIFEST_MODE=false
      _run_ribosome "$fix_prompt"
      return $?
    elif [[ "$line" =~ ^COMMIT:\ (.+) ]]; then
      commit_msg="${BASH_REMATCH[1]}"
    fi
  done <<< "$manifest"

  # Final commit if all succeeded
  if [[ $last_run_exit -eq 0 && -n "$commit_msg" ]]; then
    local changed_files
    changed_files=$(git diff --name-only HEAD 2>/dev/null; git ls-files --others --exclude-standard 2>/dev/null)
    if [[ -n "$changed_files" ]]; then
      echo "$changed_files" | xargs git add
      git commit -m "$commit_msg"
      $QUIET || echo "[manifest] committed: $commit_msg" >&2
    fi
  fi

  return $last_run_exit
}

_run_ribosome() {
  local prompt="$1"

  # Auto-detect manifest format
  if [[ "$prompt" =~ ^FILE:\  ]]; then
    if ! $MANIFEST_MODE; then
      MANIFEST_MODE=true
      _execute_manifest "$prompt"
      return $?
    fi
  fi

  # Prepend provider-specific coaching notes
  # goose/droid inject coaching via native mechanisms (MOIM / --append-system-prompt-file)
  local _coaching_source="$COACHING_FILE"
  case "$HARNESS" in
    codex)  _coaching_source="${COACHING_FILE%.*}_codex.md" ;;
    gemini) _coaching_source="${COACHING_FILE%.*}_gemini.md" ;;
    goose|droid) _coaching_source="" ;;
  esac
  if [[ -n "$_coaching_source" && -f "$_coaching_source" ]]; then
    # Hard gate: coaching file must be under 10KB or GLM exits with 0 output
    local _coaching_size_kb
    _coaching_size_kb=$(( $(wc -c < "$_coaching_source") / 1024 ))
    if (( _coaching_size_kb > 10 )); then
      echo "FATAL: coaching file ${_coaching_source} is ${_coaching_size_kb}KB (>10KB cap). GLM will exit immediately. Trim first." >&2
      return 1
    fi
    local _coaching_tmp
    _coaching_tmp="$(mktemp)"
    printf '%s\n' "<coaching-notes>" > "$_coaching_tmp"
    cat "$_coaching_source" >> "$_coaching_tmp"
    printf '\n%s\n\n' "</coaching-notes>" >> "$_coaching_tmp"
    printf '%s' "$prompt" >> "$_coaching_tmp"
    prompt="$(cat "$_coaching_tmp")"
    rm -f "$_coaching_tmp"
  fi

  # Explore mode: wrap user query in exploration system prompt
  if [[ $_SUBCOMMAND == explore ]]; then
    local _explore_sys
    _explore_sys="$(cat <<'EXPLORE_SYS'
<mode>explore</mode>
You are an exploration agent. Your job is to search a codebase or the web and return structured findings. You do NOT write or modify code.

## Rules
- Use Grep, Glob, Read, and Bash (read-only commands like ls, wc, file, curl, jq) to explore
- For web research: use curl to fetch URLs, pipe large responses through head/tail/grep to avoid OOM
- Search breadth-first: cast a wide net with Glob/Grep, then drill into the most relevant hits
- Follow references across files — if a function is imported, find where it's defined
- Stop when you have enough signal to answer the query — don't exhaustively read every file
- Budget: aim to finish in ≤15 tool calls. Use parallel tool calls when searches are independent

## Output format
Return findings as a structured report:

### Summary
1-3 sentence answer to the query.

### Files
- `path/to/file.ext:L10-L25` — what this section does / why it matters

### Patterns
Key patterns, conventions, or architectural decisions found.

### Open questions
Anything you couldn't determine from the code alone.
EXPLORE_SYS
)"
    prompt="${_explore_sys}"$'\n\n'"## Query"$'\n'"${prompt}"
  fi

  local args=(--print --dangerously-skip-permissions)
  $BARE && args+=(--bare)
  if $SUPERVISED; then
    args+=(--output-format json --settings "$HOME/germline/loci/ribosome-supervised-settings.json")
    export RIBOSOME_DEFER_ENABLED=1
  fi
  local start_ts=$(date +%s)
  local output
  local exit_code=0
  # ZhiPu coding plan uses ANTHROPIC_AUTH_TOKEN for CC harness.
  # Do NOT unset it — CC needs it for authentication via /api/anthropic.

  if ! _preflight_probe "$HARNESS"; then
    echo "[preflight] $PROVIDER failed, trying fallback..." >&2
    local _fb
    _fb="$(_find_fallback "$PROVIDER")"
    if [[ -n "$_fb" ]]; then
      echo "[preflight] falling back to $_fb" >&2
      PROVIDER="$_fb"
      _configure_backend "$PROVIDER"
      HARNESS="$(_provider_to_harness "$PROVIDER")"
      if ! _preflight_probe "$HARNESS"; then
        echo "FATAL: fallback provider $_fb also failed preflight" >&2
        exit 1
      fi
    else
      echo "FATAL: no fallback provider available" >&2
      exit 1
    fi
  fi

  # Per-attempt timeout: matches Temporal activity timeout (2hr).
  # No wall-limit — stall detection catches loops, Temporal is the outer bound.
  local _claude_timeout=7200
  local _wall_limit=$_claude_timeout  # legacy: retry checks still reference this
  local _wall_start=$(date +%s)

  # Retry loop with exponential backoff for rate limits (429)
  local _max_retries=3
  local _attempt=0
  local _backoff=30  # initial backoff in seconds
  local _claude_ran=false  # track whether claude was actually invoked

  while [[ $_attempt -lt $_max_retries ]]; do
    # Wall-limit check: skip attempt if remaining time < per-attempt timeout
    local _elapsed=$(( $(date +%s) - _wall_start ))
    local _remaining=$(( _wall_limit - _elapsed ))
    if [[ $_remaining -lt 300 ]]; then
      $QUIET || echo "[wall-limit] ${_remaining}s remaining < 300s minimum, skipping retry" >&2
      break
    fi

    # Pre-flight health check: detect rate-limit before wasting time on claude
    # Skip preflight for non-CC harnesses (gemini, codex have their own error handling)
    if [[ "$HARNESS" != "claude" ]]; then
      : # non-CC harness, skip preflight
    else
      local _preflight_result
      local _pf_rc=0
      _preflight_result=$(_preflight_check) || _pf_rc=$?
      if [[ $_pf_rc -eq 1 ]]; then
      # Rate-limited — extract reset time and compute smart backoff
      _attempt=$(( _attempt + 1 ))
      # Parse "reset at YYYY-MM-DD HH:MM:SS" into epoch seconds
      local _reset_str _reset_epoch _wait_secs
      _reset_str=$(echo "$_preflight_result" | sed 's/reset at //')
      _wait_secs=$_backoff
      if [[ -n "$_reset_str" ]]; then
        _reset_epoch=$(date -d "$_reset_str" +%s 2>/dev/null || echo 0)
        if [[ $_reset_epoch -gt 0 ]]; then
          _wait_secs=$(( _reset_epoch - $(date +%s) + 30 ))  # 30s buffer past reset
          [[ $_wait_secs -lt 30 ]] && _wait_secs=30
        fi
      fi
      # Parse Infini-style window hint: "window=5h" means 5-hour rate limit window
      local _window_h
      _window_h=$(echo "$_preflight_result" | grep -oE 'window=[0-9]+h' | grep -oE '[0-9]+' | head -1 || true)
      if [[ -n "$_window_h" ]] && [[ $_wait_secs -lt $(( _window_h * 3600 )) ]]; then
        # No explicit reset time, but we know the window — wait the full window duration
        _wait_secs=$(( _window_h * 3600 ))
      fi
      # If wait exceeds 30 min, fail fast — let the daemon's cooldown handle it
      if [[ $_wait_secs -gt 1800 ]]; then
        $QUIET || echo "[preflight] $PROVIDER quota exhausted (reset in $(( _wait_secs / 60 ))min), failing fast for daemon cooldown — $_preflight_result" >&2
        output="AccountQuotaExceeded: $_preflight_result"
        exit_code=1
        break  # exit retry loop, report rate-limit to daemon
      fi
      [[ $_wait_secs -gt 600 ]] && _wait_secs=600  # cap at 10 min
      if [[ $_attempt -lt $_max_retries ]]; then
        # Wall-limit check: skip retry if remaining time < per-attempt timeout
        local _elapsed=$(( $(date +%s) - _wall_start ))
        local _remaining=$(( _wall_limit - _elapsed ))
        if [[ $_remaining -lt 300 ]]; then
          $QUIET || echo "[wall-limit] ${_remaining}s remaining < 300s minimum, skipping retry" >&2
          break
        fi
        $QUIET || echo "[preflight] $PROVIDER rate-limited (attempt $_attempt/$_max_retries), waiting ${_wait_secs}s — $_preflight_result" >&2
        sleep "$_wait_secs"
        _backoff=$(( _backoff * 2 ))
      fi
      continue  # skip claude launch, retry the preflight
    elif [[ $_pf_rc -eq 2 ]]; then
      # Connection/auth error — may be transient (DNS blip, network hiccup).
      # Retry with backoff like rate-limits. If all retries fail, fall through
      # to claude launch as last resort (the endpoint may behave differently for CC).
      _attempt=$(( _attempt + 1 ))
      if [[ $_attempt -lt $_max_retries ]]; then
        # Wall-limit check: skip retry if remaining time < per-attempt timeout
        local _elapsed=$(( $(date +%s) - _wall_start ))
        local _remaining=$(( _wall_limit - _elapsed ))
        if [[ $_remaining -lt 300 ]]; then
          $QUIET || echo "[preflight] skipping health check, ${_remaining}s remaining < 300s minimum, skipping retry" >&2
          break
        fi
        $QUIET || echo "[preflight] $PROVIDER connection error (attempt $_attempt/$_max_retries), retrying in ${_backoff}s" >&2
        sleep "$_backoff"
        _backoff=$(( _backoff * 2 ))
        continue
      fi
      $QUIET || echo "[preflight] skipping health check, $PROVIDER connection error after $_max_retries attempts, trying claude directly" >&2
    fi
    fi  # end non-CC preflight

    # NOTE: With set -e, `output=$(cmd)` where cmd exits non-zero kills the
    # script before `exit_code=$?` is reached.  Use `&& exit_code=0 || exit_code=$?`
    # to capture the exit code without triggering set -e.
    output=$(_run_harness_"$HARNESS" "$prompt" "$_claude_timeout") && exit_code=0 || exit_code=$?
    _claude_ran=true
    # Timeout returns 124 — treat as rate-limit for retry purposes
    [[ $exit_code -eq 124 ]] && exit_code=1

    # Claude exits 0 even on 429 API errors — detect this and treat as rate-limit
    if [[ $exit_code -eq 0 ]] && echo "$output" | grep -qiE 'API Error.*429|429.*quota|code.*20013|usage.limit|hit your.*limit'; then
      exit_code=1
      $QUIET || echo "[ribosome] claude reported 429 despite exit=0, treating as rate-limit" >&2
    fi

    # Success — break immediately
    [[ $exit_code -eq 0 ]] && break

    # Detect rate-limiting. Gate every path on a POSITIVE signal — "empty
    # output + failure" used to be classified as rate-limit on the theory
    # that claude had swallowed a 429 internally, but that assumption also
    # matches deterministic CLI errors (Unknown flag, missing binary, killed
    # process, stdin deadlock) which are not retryable. The 2026-04-11
    # incident that looked like a 59k rate-limit runaway was actually a
    # literal `---` frontmatter token being interpreted as a CLI flag,
    # retried forever because the classifier assumed it was transient.
    #
    # 1. Explicit 429 strings in stdout OR stderr
    # 2. Exit=2 WITH a rate-limit signal in stderr (not every exit=2 is 429;
    #    it also covers auth failure, model-not-found, config errors)
    local _is_ratelimit=false
    local _rl_pattern='429|AccountQuotaExceeded|rate.limit|quota.*exceeded|20013|request.limit.exceeded|usage.limit|hit your.*limit|quota will reset|too many requests|throttled'
    if echo "$output" | grep -qiE "$_rl_pattern"; then
      _is_ratelimit=true
    elif [[ $exit_code -eq 2 ]] && echo "$output" | grep -qiE "$_rl_pattern"; then
      _is_ratelimit=true
    fi

    # Deterministic CLI failures — never retry. Surface them loudly so the
    # chaperone review gate rejects fast instead of masking the real error.
    if echo "$output" | grep -qE 'Unknown flag|command not found|No such file or directory|ModuleNotFoundError|SyntaxError'; then
      _is_ratelimit=false
      $QUIET || echo "[ribosome] deterministic CLI error detected, not retryable" >&2
    fi

    if $_is_ratelimit; then
      _attempt=$(( _attempt + 1 ))
      if [[ $_attempt -lt $_max_retries ]]; then
        # Wall-limit check: skip retry if remaining time < per-attempt timeout
        local _elapsed=$(( $(date +%s) - _wall_start ))
        local _remaining=$(( _wall_limit - _elapsed ))
        if [[ $_remaining -lt 300 ]]; then
          $QUIET || echo "[wall-limit] ${_remaining}s remaining < 300s minimum, skipping retry" >&2
          break
        fi
        # Try to extract reset time from error message
        local _reset_time
        _reset_time=$(echo "$output" | grep -oiE 'reset at [0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}|try again at [0-9]{1,2}:[0-9]{2} [AP]M' | head -1 || true)
        $QUIET || echo "[retry] $PROVIDER rate-limited (attempt $_attempt/$_max_retries), backoff ${_backoff}s${_reset_time:+, $_reset_time}" >&2
        sleep "$_backoff"
        _backoff=$(( _backoff * 2 ))  # exponential: 30 → 60 → 120
      fi
    else
      # Non-rate-limit failure — don't retry
      break
    fi
  done

  # If all retries exhausted and claude was never launched, report as rate-limit failure
  if ! $_claude_ran && [[ $exit_code -eq 0 ]]; then
    exit_code=1
    # Distinguish wall-limit self-kill from real rate-limit exhaustion.
    # _attempt == 0 means we never even ran a preflight — almost always the wall-limit math,
    # not an actual provider rate limit.
    if [[ $_attempt -eq 0 ]]; then
      output="WallLimitSelfKill: $PROVIDER dispatch aborted before first attempt (wall=${_wall_limit}s, per-attempt=${_claude_timeout}s). Raise RIBOSOME_WALL_LIMIT."
    else
      output="AccountQuotaExceeded: $PROVIDER rate-limit retries exhausted after $_attempt attempts, claude was never launched"
    fi
  fi

  # Checkpoint: save uncommitted work when ribosome fails
  if [[ $exit_code -ne 0 ]]; then
    local _uncommitted
    _uncommitted=$(git diff --stat HEAD 2>/dev/null)
    if [[ -n "$_uncommitted" ]]; then
      local _stash_ref
      _stash_ref=$(git stash create 2>/dev/null || true)
      if [[ -n "$_stash_ref" ]]; then
        mkdir -p ~/germline/loci/checkpoints
        local _cp_file=~/germline/loci/checkpoints/${RIBOSOME_TASK_ID:-unknown}.json
        local short_prompt_cp="${prompt:0:100}"
        printf '{"workflow_id":"%s","timestamp":"%s","task":"%s","provider":"%s","exit_code":%d,"stash_ref":"%s","diff_stat":"%s"}\n' \
          "${RIBOSOME_TASK_ID:-unknown}" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
          "$(echo "${short_prompt_cp:-}" | tr '"' "'")" "$PROVIDER" "$exit_code" \
          "$_stash_ref" "$(echo "$_uncommitted" | tail -1 | tr '"' "'")" > "$_cp_file"
        echo "[checkpoint] saved uncommitted work: $_cp_file" >&2
      fi
    fi
  fi

  local duration=$(( $(date +%s) - start_ts ))
  local short_prompt="${prompt:0:100}"

  # Enriched logging: count files and run pytest on new test files
  local files_created=0
  local tests_passed=0
  local tests_failed=0
  local pytest_exit=0

  # Count new/modified files
  files_created=$(git diff --name-only --diff-filter=AM HEAD 2>/dev/null | wc -l | tr -d ' ')

  # Find new test files and run pytest
  local new_tests=$(git diff --name-only --diff-filter=A HEAD 2>/dev/null | grep '^assays/test_.*\.py$' || true)
  if [[ -n "$new_tests" ]]; then
    local pytest_output
    pytest_output=$(uv run pytest $new_tests -q --tb=no 2>&1 || true)
    pytest_exit=$?
    # Parse pass/fail from pytest output (e.g., "3 passed, 1 failed" or "5 passed")
    tests_passed=$(echo "$pytest_output" | grep -oE '[0-9]+ passed' | grep -oE '[0-9]+' || echo "0")
    tests_failed=$(echo "$pytest_output" | grep -oE '[0-9]+ failed' | grep -oE '[0-9]+' || echo "0")
    [[ -z "$tests_passed" ]] && tests_passed=0
    [[ -z "$tests_failed" ]] && tests_failed=0
  fi

  # Merge is deferred to translocase — only after chaperone review approves.

  # Log result with enriched fields
  local task_id="${RIBOSOME_TASK_ID:-}"
  local _mode="build"
  [[ $_SUBCOMMAND == explore ]] && _mode="explore"
  printf '{"ts":"%s","provider":"%s","mode":"%s","duration":%d,"exit":%d,"turns":%d,"prompt":"%s","tail":"%s","files_created":%d,"tests_passed":%d,"tests_failed":%d,"pytest_exit":%d,"task_id":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$PROVIDER" "$_mode" "$duration" "$exit_code" "$_wall_limit" \
    "$(echo "$short_prompt" | tr '"' "'" | tr '\n' ' ')" \
    "$(echo "${output: -200}" | tr '"' "'" | tr '\n' ' ')" \
    "$files_created" "$tests_passed" "$tests_failed" "$pytest_exit" "$task_id" >> "$RIBOSOME_LOG"

  # Structured JSONL record (supplements existing log)
  local _jsonl_file=~/germline/loci/ribosome-runs.jsonl
  printf '{"workflow_id":"%s","ts":"%s","task":"%s","provider":"%s","exit":%d,"duration":%d,"files_changed":%d,"tests_passed":%d,"tests_failed":%d,"pytest_exit":%d}\n' \
    "${RIBOSOME_TASK_ID:-unknown}" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "$(echo "${short_prompt:-}" | tr '"' "'" | tr '\n' ' ')" \
    "$PROVIDER" "$exit_code" "$duration" "$files_created" \
    "$tests_passed" "$tests_failed" "$pytest_exit" >> "$_jsonl_file"

  # Emit rate-limit marker on stderr if detected — ensures daemon's tail always
  # catches it even when claude output is long (pushing error msg out of last 200 chars)
  local _rl_window=""
  local _emit_rl_marker=false
  # Case 1: output contains explicit rate-limit text
  if [[ $exit_code -ne 0 ]] && echo "$output" | grep -qiE '429|AccountQuotaExceeded|rate.?limit|quota.?exceeded|20013|request.?limit.?exceeded|usage.?limit|hit your.*limit|quota will reset'; then
    _emit_rl_marker=true
    _rl_window=$(echo "$output" | grep -oE '[0-9]+-hour request limit' | grep -oE '[0-9]+' | head -1 || true)
  fi
  # Case 2: exit=2 (claude init error — API 429, auth failure, model not found)
  if [[ $exit_code -eq 2 ]]; then
    _emit_rl_marker=true
  fi
  # Case 3: empty/whitespace output with non-zero exit (claude swallowed 429 silently)
  if [[ $exit_code -ne 0 ]] && [[ -z "${output// /}" ]] && [[ $duration -le 10 ]]; then
    _emit_rl_marker=true
  fi
  if $_emit_rl_marker; then
    # If window unknown, fill in per-provider defaults so daemon can parse it
    if [[ -z "$_rl_window" ]]; then
      case "$PROVIDER" in
        infini) _rl_window=5 ;;    # Infini: 1000 req / 5 hours
        volcano) _rl_window=5 ;;   # Volcano: 5-hour quota window
        codex) _rl_window=1 ;;     # Codex: ~hourly resets
      esac
    fi
    echo "RIBOSOME_RATE_LIMIT: provider=$PROVIDER exit=$exit_code window=${_rl_window:-?}h duration=${duration}s" >&2
  fi

    if $JSON_OUTPUT; then
    local _json_tmp
    _json_tmp="$(mktemp)"
    printf '%s' "$output" > "$_json_tmp"
    python3 -c "
import json, sys
with open(sys.argv[1], 'r', errors='replace') as f:
    output_text = f.read()
result = {
    'output': output_text,
    'exit_code': int(sys.argv[2]),
    'duration': int(sys.argv[3]),
    'provider': sys.argv[4],
    'files_created': int(sys.argv[5]),
    'tests_passed': int(sys.argv[6]),
    'tests_failed': int(sys.argv[7]),
}
print(json.dumps(result))
" "$_json_tmp" "$exit_code" "$duration" "$PROVIDER" "$files_created" "$tests_passed" "$tests_failed"
    rm -f "$_json_tmp"
  elif ! $QUIET; then
    echo "$output"
  fi

  # Auto-capture: if prompt mentions "Write to ~/...md", save output there
  local _target
  _target=$(echo "$1" | grep -oE 'Write to ~/[^ "]+' | head -1 | sed 's/^Write to //' || true)
  if [[ -n "$_target" && ${#output} -gt 200 ]]; then
    _target="${_target/#~/$HOME}"
    mkdir -p "$(dirname "$_target")"
    printf '%s\n' "$output" > "$_target"
  fi

  # Auto-commit if CC forgot
  if [[ $exit_code -eq 0 ]]; then
    local uncommitted
    uncommitted=$(git diff --name-only HEAD 2>/dev/null; git ls-files --others --exclude-standard 2>/dev/null)
    if [[ -n "$uncommitted" ]]; then
      (echo "$uncommitted" | xargs git add && git commit -m "ribosome: auto-commit (CC forgot to commit)") 2>/dev/null || true
    fi
  fi

  # Clean up per-run TMPDIR to prevent stale file accumulation
  rm -rf "/tmp/ribosome-${PROVIDER}-${RIBOSOME_TASK_ID:-$$}" 2>/dev/null || true

  return $exit_code
}

# _run_with_fallback: run _run_ribosome, retry on fallback provider if primary fails
_run_with_fallback() {
  local prompt="$1"
  local final_exit=0
  _run_ribosome "$prompt" || final_exit=$?

  if $FALLBACK && [[ $final_exit -ne 0 ]]; then
    FALLBACK_PROVIDER="$(_find_fallback "$PROVIDER")"
    if [[ -n "$FALLBACK_PROVIDER" ]]; then
      $QUIET || echo "[fallback] primary provider '$PROVIDER' failed (exit=$final_exit), retrying on '$FALLBACK_PROVIDER'..." >&2
      PROVIDER="$FALLBACK_PROVIDER"
      HARNESS=$(_provider_to_harness "$FALLBACK_PROVIDER")
      if [[ "$HARNESS" == "claude" ]]; then
        BACKEND="$FALLBACK_PROVIDER"
      fi
      _configure_backend "$BACKEND"
      _run_ribosome "$prompt" || final_exit=$?
    fi
  fi
  return $final_exit
}

# Manifest mode: deterministic file creation, no LLM/backend needed.
# Must be after function definitions but before backend config and dispatch.
if $MANIFEST_MODE; then
  case $_SUBCOMMAND in
    batch|test|explore) ;;
    *) _execute_manifest "${*:-}" ;;
  esac
  exit $?
fi

case $_SUBCOMMAND in
  batch)
    for mod in "$@"; do
      ($QUIET || $JSON_OUTPUT) || echo ">>> ribosome: $mod"
      _run_with_fallback "Read $mod. Write comprehensive tests to assays/test_$(basename "${mod%.py}").py. NOTE: Effectors are scripts, not importable modules. Load via exec(open(path).read(), {\"__name__\": \"test_module\"}) or test via subprocess.run. NEVER use import <effector_name>. Mock external calls and file I/O. Run: uv run pytest assays/test_$(basename "${mod%.py}").py -v --tb=short. Fix any failures. Then git add the test file and git commit -m 'ribosome: tests for $(basename "${mod%.py}")'." || true
      ($QUIET || $JSON_OUTPUT) || echo
    done
    ;;
  test)
    mod="$1"
    _run_with_fallback "Read $mod. Write comprehensive tests to assays/test_$(basename "${mod%.py}").py. NOTE: Effectors are scripts, not importable modules. Load via exec(open(path).read(), {\"__name__\": \"test_module\"}) or test via subprocess.run. NEVER use import <effector_name>. Mock external calls and file I/O. Run: uv run pytest assays/test_$(basename "${mod%.py}").py -v --tb=short. Fix any failures. Then git add the test file and git commit -m 'ribosome: tests for $(basename "${mod%.py}")'."
    ;;
  *)
    if $MANIFEST_MODE; then
      _execute_manifest "$*"
      exit $?
    else
      _run_with_fallback "$*"
    fi
    ;;
esac

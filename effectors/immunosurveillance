#!/usr/bin/env python3
"""immunosurveillance — dependency change detection CLI.

Usage:
    immunosurveillance check    # Check all deps, print diff report, update cache
    immunosurveillance status   # Show current cached versions (no network)
    immunosurveillance diff     # Check all deps, print diff only (don't update cache)

Exit codes:
    0 — no changes (or status/diff ran cleanly)
    1 — changes detected (for scripting: if immunosurveillance check; then ...; fi)
    2 — usage error
"""

import os
import sys

# Ensure the lib directory is on the path regardless of working directory
_LIB_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "lib")
if _LIB_DIR not in sys.path:
    sys.path.insert(0, _LIB_DIR)

import custodes as _custodes


def _cmd_check():
    result = _custodes.check_all(update_cache=True)
    print(result["report"])
    if result["error"]:
        print(f"\n⚠️  Warning: {result['error']}", file=sys.stderr)
    return 1 if result["changes_found"] else 0


def _cmd_status():
    result = _custodes.get_status()
    print(result["report"])
    if result["error"]:
        print(f"\n⚠️  Warning: {result['error']}", file=sys.stderr)
    return 0


def _cmd_diff():
    result = _custodes.get_diff()
    print(result["report"])
    if result["error"]:
        print(f"\n⚠️  Warning: {result['error']}", file=sys.stderr)
    return 1 if result["changes_found"] else 0


def main():
    args = sys.argv[1:]
    if not args:
        print(__doc__.strip())
        sys.exit(2)

    cmd = args[0].lower()
    if cmd in ("--help", "-h", "help"):
        print(__doc__.strip())
        sys.exit(0)
    if cmd == "check":
        sys.exit(_cmd_check())
    elif cmd == "status":
        sys.exit(_cmd_status())
    elif cmd == "diff":
        sys.exit(_cmd_diff())
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print("Valid commands: check, status, diff", file=sys.stderr)
        print("Use --help for usage information.", file=sys.stderr)
        sys.exit(2)


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""regulatory-scrape — fetch a regulatory document and save as frontmattered markdown.

Usage:
  regulatory-scrape <url> --issuer fca --date 2024-04-22 --title "AI Update" --type guidance
  regulatory-scrape <url> --issuer pra --date 2023-05-17 --title "SS1/23" --type supervisory-statement --slug ss1-23-model-risk
  regulatory-scrape --batch catalog.tsv   # TSV: url\tissuer\tdate\ttitle\ttype\tslug(optional)
"""

import argparse
import csv
import os
import re
import subprocess
import sys

REG_DIR = os.path.expanduser("~/epigenome/chromatin/euchromatin/regulatory")


def slugify(text: str) -> str:
    s = text.lower()
    s = re.sub(r'[^a-z0-9]+', '-', s)
    return s.strip('-')[:60]


def scrape_one(url: str, issuer: str, date: str, title: str, doc_type: str, slug: str | None = None, status: str = "final") -> str:
    slug = slug or slugify(title)
    filename = f"{issuer}-{date[:7].replace('-', '-')}-{slug}.md"
    filepath = os.path.join(REG_DIR, filename)

    if os.path.exists(filepath) and os.path.getsize(filepath) > 500:
        print(f"SKIP (exists): {filename}", file=sys.stderr)
        return filepath

    r = subprocess.run(["pinocytosis", url], capture_output=True, text=True, timeout=60)
    if r.returncode != 0 or not r.stdout.strip():
        print(f"FAIL: {url} — {r.stderr.strip()}", file=sys.stderr)
        return ""

    frontmatter = f'''---
title: "{title}"
issuer: {issuer}
date: {date}
source: {url}
type: {doc_type}
status: {status}
---

'''
    with open(filepath, 'w') as f:
        f.write(frontmatter + r.stdout.strip() + '\n')

    print(f"OK: {filename} ({len(r.stdout)} chars)", file=sys.stderr)
    return filepath


def batch(tsv_path: str):
    with open(tsv_path) as f:
        reader = csv.reader(f, delimiter='\t')
        for row in reader:
            if not row or row[0].startswith('#'):
                continue
            url, issuer, date, title, doc_type = row[:5]
            slug = row[5] if len(row) > 5 else None
            scrape_one(url, issuer, date, title, doc_type, slug)


def main():
    p = argparse.ArgumentParser(description="Fetch regulatory doc → frontmattered markdown")
    p.add_argument("url", nargs="?", help="URL to scrape")
    p.add_argument("--issuer", help="Regulator code (fca, pra, ico, dsit, cma, etc.)")
    p.add_argument("--date", help="Publication date (YYYY-MM-DD)")
    p.add_argument("--title", help="Document title")
    p.add_argument("--type", dest="doc_type", default="guidance", help="Document type")
    p.add_argument("--slug", help="Filename slug (auto-generated if omitted)")
    p.add_argument("--status", default="final", help="Document status")
    p.add_argument("--batch", dest="batch_file", help="TSV file for batch processing")
    args = p.parse_args()

    if args.batch_file:
        batch(args.batch_file)
    elif args.url:
        if not all([args.issuer, args.date, args.title]):
            p.error("--issuer, --date, --title required")
        path = scrape_one(args.url, args.issuer, args.date, args.title, args.doc_type, args.slug, args.status)
        if path:
            print(path)
        else:
            sys.exit(1)
    else:
        p.print_help()


if __name__ == "__main__":
    main()

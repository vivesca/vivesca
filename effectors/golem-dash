from collections import defaultdict
from datetime import datetime, timedelta
from pathlib import Path

# Paths
VIVESCA_DIR = Path.home() / ".local" / "share" / "vivesca"
JSONL_PATH = VIVESCA_DIR / "golem.jsonl"
LOG_PATH = VIVESCA_DIR / "golem-daemon.log"
QUEUE_PATH = Path.home() / "germline" / "loci" / "golem-queue.md"

# ANSI colors
GREEN = "\033[32m"
RED = "\033[31m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"


def fmt_bytes(n: int) -> str:
    """Format bytes as human-readable string."""
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if abs(n) < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} PB"


def fmt_duration(seconds: int) -> str:
    """Format seconds as human-readable duration."""
    if seconds < 60:
        return f"{seconds}s"
    elif seconds < 3600:
        return f"{seconds // 60}m {seconds % 60}s"
    elif seconds < 86400:
        h, rem = divmod(seconds, 3600)
        m, s = divmod(rem, 60)
        return f"{h}h {m}m"
    else:
        d, rem = divmod(seconds, 86400)
        h, rem2 = divmod(rem, 3600)
        return f"{d}d {h}h"


def progress_bar(done: int, total: int, width: int = 30, use_color: bool = True) -> str:
    """Render a visual progress bar showing done/total.

    Returns a string like '████████░░░░░░ 12/30 (40%)'.
    """
    if total == 0:
        pct = 0
    else:
        pct = done / total

    filled = int(width * pct)
    empty = width - filled
    bar = "█" * filled + "░" * empty

    g = GREEN if use_color else ""
    c = CYAN if use_color else ""
    rst = RESET if use_color else ""

    return f"{g}{bar}{rst} {c}{done}/{total}{rst} ({pct * 100:.0f}%)"


def eta_wall_clock(eta_seconds: int) -> str:
    """Convert ETA seconds to a wall-clock completion time string.

    Returns '—' for zero ETA, or 'HH:MM' (today) / 'tomorrow HH:MM'.
    """
    if eta_seconds <= 0:
        return "—"

    target = datetime.now() + timedelta(seconds=eta_seconds)
    now = datetime.now()

    if target.date() == now.date():
        return f"today {target.strftime('%H:%M')}"
    elif target.date() == (now + timedelta(days=1)).date():
        return f"tomorrow {target.strftime('%H:%M')}"
    else:
        return target.strftime("%b %d %H:%M")


def _parse_ts(ts_str: str) -> datetime | None:
    """Parse a timestamp string from JSONL into a datetime object.

    Handles formats: '2026-04-01 00:43:38', '2026-04-01T00:43:54Z',
    '2026-04-01T00:43:54+08:00', ISO format.
    """
    if not ts_str:
        return None

    # Try ISO format first (Python 3.11+)
    try:
        return datetime.fromisoformat(ts_str.replace("Z", "+00:00")).replace(tzinfo=None)
    except (ValueError, AttributeError):
        pass

    # Fallback: common formats
    for fmt in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%dT%H:%M:%S", "%Y-%m-%d"):
        try:
            return datetime.strptime(ts_str, fmt)
        except ValueError:
            continue

    return None


def throughput_rate(records: list[dict], window_minutes: int = 60) -> float:
    """Calculate tasks completed per hour within the given time window.

    Only counts records with a valid timestamp and exit=0.
    Returns tasks/hour (float).
    """
    if not records:
        return 0.0

    cutoff = datetime.now() - timedelta(minutes=window_minutes)
    count = 0

    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None:
            continue
        if ts >= cutoff:
            count += 1

    # Scale to per-hour rate
    rate = count / window_minutes * 60
    return rate


def completion_burst(records: list[dict]) -> tuple[int, int]:
    """Count completions in the last 15 minutes and last 60 minutes.

    Returns (last_15min_count, last_60min_count).
    """
    now = datetime.now()
    cutoff_15 = now - timedelta(minutes=15)
    cutoff_60 = now - timedelta(minutes=60)

    m15 = m60 = 0
    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None:
            continue
        if ts >= cutoff_60:
            m60 += 1
            if ts >= cutoff_15:
                m15 += 1

    return m15, m60


SPARKLINE_CHARS = "▁▂▃▄▅▆▇█"


def throughput_sparkline(records: list[dict], hours: int = 6, bucket_minutes: int = 15) -> str:
    """Generate ASCII sparkline of completions per time bucket.

    Each bucket is `bucket_minutes` wide, covering the last `hours` hours.
    Returns a string like '▁▃▅█▇▂▁ (max 5/bucket)'.
    """
    now = datetime.now()
    num_buckets = hours * 60 // bucket_minutes
    cutoff = now - timedelta(hours=hours)
    counts = [0] * num_buckets

    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None or ts < cutoff:
            continue
        minutes_ago = (now - ts).total_seconds() / 60
        idx = int(minutes_ago / bucket_minutes)
        if 0 <= idx < num_buckets:
            counts[num_buckets - 1 - idx] += 1

    max_count = max(counts) if counts else 0
    if max_count == 0:
        return "▁" * num_buckets + " (0 max)"

    spark = ""
    for c in counts:
        level = int(c / max_count * (len(SPARKLINE_CHARS) - 1))
        spark += SPARKLINE_CHARS[level]

    return f"{spark} (max {max_count}/bucket)"


# ── Running tasks (from ps) ─────────────────────────────────────────

PROVIDER_RE = re.compile(r"--provider\s+(\S+)")


def get_running_golems() -> list[dict]:
    """Get list of currently running golem processes via ps."""
    try:
        result = subprocess.run(
            ["ps", "-eo", "pid,etime,args"],
            capture_output=True, text=True, timeout=5
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return []

    running = []
    for line in result.stdout.splitlines():
        if "effectors/golem" not in line and "/bin/sh -c golem " not in line:
            continue
        if "golem-dash" in line or "grep" in line.split()[0] if line.split() else "":
            continue

        parts = line.split(None, 2)
        if len(parts) < 3:
            continue

        pid_str, etime, args = parts
        try:
            pid = int(pid_str)
        except ValueError:
            continue

        # Extract provider
        m = PROVIDER_RE.search(args)
        provider = m.group(1) if m else "unknown"

        # Parse elapsed time
        secs = etime_to_seconds(etime)

        # Extract task snippet
        task = extract_task_snippet(args)

        running.append({
            "pid": pid,
            "provider": provider,
            "etime": etime,
            "duration_secs": secs,
            "task": task,
        })

    return running


def etime_to_seconds(etime: str) -> int:
    """Convert ps etime string to total seconds."""
    day = 0
    if "-" in etime:
        day_part, etime = etime.split("-", 1)
        day = int(day_part)

    parts = etime.split(":")
    if len(parts) == 2:
        minutes, seconds = int(parts[0]), int(parts[1])
        return day * 86400 + minutes * 60 + seconds
    elif len(parts) == 3:
        hours, minutes, seconds = int(parts[0]), int(parts[1]), int(parts[2])
        return day * 86400 + hours * 3600 + minutes * 60 + seconds
    return 0


def extract_task_snippet(args: str) -> str:
    """Extract task description from golem command line."""
    # Strip shell prefix
    rest = args
    if rest.startswith("/bin/sh -c golem "):
        rest = rest[len("/bin/sh -c golem "):]
    elif "effectors/golem" in rest:
        # Find the golem script and skip past it
        m = re.search(r"effectors/golem\s+", rest)
        if m:
            rest = rest[m.end():]

    # Strip flags
    rest = PROVIDER_RE.sub("", rest)
    rest = re.sub(r"--max-turns\s+\d+", "", rest)
    rest = re.sub(r"--full\s*", "", rest)

    # Clean up
    task = rest.strip().strip('"').strip("'")
    return task[:60] + "…" if len(task) > 60 else task


def load_jsonl(path: Path) -> list[dict]:
    """Parse golem.jsonl, return list of record dicts."""
    if not path.exists():
        return []
    records = []
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            records.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return records


def provider_stats(records: list[dict], use_color: bool = True) -> str:
    """Build provider stats table from JSONL records."""
    stats: dict[str, dict] = defaultdict(lambda: {"pass": 0, "fail": 0, "durations": []})
    for r in records:
        provider = r.get("provider", "unknown")
        if r.get("exit", 1) == 0:
            stats[provider]["pass"] += 1
        else:
            stats[provider]["fail"] += 1
        dur = r.get("duration")
        if dur is not None:
            stats[provider]["durations"].append(dur)

    if not stats:
        return "No task records found."

    header = f"  {'Provider':<10} {'Pass':>6} {'Fail':>6} {'Rate':>7} {'AvgDur':>8}"
    sep = "  " + "-" * 42
    lines = [header, sep]

    g = GREEN if use_color else ""
    r_col = RED if use_color else ""
    rst = RESET if use_color else ""
    y = YELLOW if use_color else ""

    for provider in sorted(stats):
        s = stats[provider]
        total = s["pass"] + s["fail"]
        rate = (s["pass"] / total * 100) if total else 0
        avg_dur = (sum(s["durations"]) / len(s["durations"])) if s["durations"] else 0
        avg_str = f"{avg_dur:.0f}s" if avg_dur else "-"
        rate_str = f"{rate:.0f}%"

        pass_str = f"{g}{s['pass']}{rst}" if use_color else str(s["pass"])
        fail_str = f"{r_col}{s['fail']}{rst}" if use_color else str(s["fail"])
        rate_color = g if rate >= 80 else (y if rate >= 50 else r_col)
        rate_str_color = f"{rate_color}{rate_str}{rst}" if use_color else rate_str

        lines.append(f"  {provider:<10} {pass_str:>6} {fail_str:>6} {rate_str_color:>7} {avg_str:>8}")

    return "\n".join(lines)


def enrich_running_progress(running: list[dict], records: list[dict]) -> list[dict]:
    """Enrich running tasks with estimated progress from provider history.

    Adds keys to each task dict: estimated_pct, estimated_remaining, is_stale.
    """
    provider_medians: dict[str, float] = {}
    by_provider: dict[str, list] = defaultdict(list)
    for r in records:
        dur = r.get("duration")
        if dur is not None:
            by_provider[r.get("provider", "unknown")].append(dur)
    for prov, durs in by_provider.items():
        s = sorted(durs)
        provider_medians[prov] = s[len(s) // 2]
    overall_median = 120.0
    if provider_medians:
        overall_median = sum(provider_medians.values()) / len(provider_medians)

    for task in running:
        expected = provider_medians.get(task["provider"], overall_median)
        elapsed = task["duration_secs"]
        pct = min(elapsed / expected * 100, 100) if expected > 0 else 0
        task["estimated_pct"] = round(pct)
        task["estimated_remaining"] = max(0, int(expected - elapsed))
        task["is_stale"] = elapsed > expected * 2

    return running


def per_provider_pending(queue_path: Path) -> dict[str, int]:
    """Parse queue file and return dict of provider -> pending count.

    Only counts unchecked items (- [ ] and - [!!]).
    """
    if not queue_path.exists():
        return {}

    counts: dict[str, int] = defaultdict(int)
    for line in queue_path.read_text().splitlines():
        # Only count pending (not done/failed)
        if not (line.strip().startswith("- [ ] ") or line.strip().startswith("- [!!] ")):
            continue
        cmd_match = re.search(r'`([^`]+)`', line)
        if not cmd_match:
            continue
        cmd = cmd_match.group(1)
        provider_match = re.search(r'--provider\s+(\w+)', cmd)
        provider = provider_match.group(1) if provider_match else "unknown"
        counts[provider] += 1

    return dict(counts)


def ewma_throughput(records: list[dict], alpha: float = 0.3) -> float:
    """Calculate exponentially weighted moving average throughput.

    Weights recent completions more heavily than older ones.
    Returns tasks/hour.
    """
    if not records:
        return 0.0

    now = datetime.now()
    # Collect (age_hours, weight) for each record with valid timestamp
    ages: list[float] = []
    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None:
            continue
        age_hours = max((now - ts).total_seconds() / 3600, 0.001)
        ages.append(age_hours)

    if not ages:
        return 0.0

    # EWMA: weight each record by alpha * (1-alpha)^(age_rank)
    # Sort by age (newest first)
    ages.sort()
    weighted_sum = 0.0
    weight_total = 0.0
    for i, age_h in enumerate(ages):
        w = alpha * ((1 - alpha) ** i)
        # Convert to rate: 1 task in age_h hours = 1/age_h tasks/hr
        rate = 1.0 / age_h if age_h > 0 else 0.0
        weighted_sum += w * rate
        weight_total += w

    if weight_total == 0:
        return 0.0

    return weighted_sum / weight_total


def eta_confidence(records: list[dict]) -> str:
    """Return confidence level for ETA based on sample size.

    Returns 'high' (30+), 'medium' (10+), 'low' (1+), or 'none' (0).
    Only counts records with a duration field.
    """
    count = sum(1 for r in records if r.get("duration") is not None)
    if count >= 30:
        return "high"
    elif count >= 10:
        return "medium"
    elif count >= 1:
        return "low"
    return "none"


def eta_confidence_intervals(
    records: list[dict], pending: int, running_count: int,
    running_tasks: list[dict] | None = None,
) -> dict:
    """Calculate best/expected/worst case ETAs from duration percentiles.

    Uses p25 (optimistic), p50 (expected), p75 (pessimistic) of the duration
    distribution to produce a range of ETAs.

    Returns dict with keys: best, expected, worst (all in seconds).
    """
    durations = sorted(r.get("duration") for r in records if r.get("duration") is not None)
    if not durations:
        p25, p50, p75 = 90, 120, 180  # defaults
    else:
        n = len(durations)
        p25 = durations[max(0, int(n * 0.25) - 1)]
        p50 = durations[n // 2]
        p75 = durations[min(n - 1, int(n * 0.75))]
        if p25 == 0:
            p25 = 1  # floor at 1s

    workers = max(running_count, 1)

    # Account for running task progress
    running_remaining = 0
    if running_tasks:
        running_remaining = max(
            t.get("estimated_remaining", p50) for t in running_tasks
        )

    def _eta(dur: int) -> int:
        if pending == 0 and running_count == 0:
            return 0
        if pending == 0:
            return running_remaining
        batch = int(pending * dur / workers)
        if pending <= running_count:
            return running_remaining
        return max(running_remaining, batch)

    return {
        "best": _eta(p25),
        "expected": _eta(p50),
        "worst": _eta(p75),
    }


def time_since_last_completion(records: list[dict]) -> int | None:
    """Return seconds since the most recent task completion, or None if no records.

    Used for stall detection: if no task has completed in a long time while
    tasks are pending, the queue may be stuck.
    """
    latest: datetime | None = None
    now = datetime.now()
    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None:
            continue
        if latest is None or ts > latest:
            latest = ts
    if latest is None:
        return None
    return int((now - latest).total_seconds())


def per_provider_throughput(records: list[dict], window_minutes: int = 60) -> dict[str, float]:
    """Calculate per-provider throughput in tasks/hour within the time window.

    Returns dict of provider -> tasks/hour.
    """
    if not records:
        return {}

    cutoff = datetime.now() - timedelta(minutes=window_minutes)
    counts: dict[str, int] = defaultdict(int)

    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None or ts < cutoff:
            continue
        provider = r.get("provider", "unknown")
        counts[provider] += 1

    return {prov: count / window_minutes * 60 for prov, count in counts.items()}


def per_provider_eta(
    records: list[dict], prov_pending: dict[str, int],
    running: list[dict] | None = None,
) -> dict[str, dict]:
    """Calculate per-provider ETA to drain their pending tasks.

    Uses per-provider median duration and throughput. Falls back to
    overall median for providers with no history.

    Returns dict of provider -> {pending, eta_seconds, eta_str, rate}.
    """
    # Compute per-provider median duration
    by_prov: dict[str, list] = defaultdict(list)
    for r in records:
        dur = r.get("duration")
        if dur is not None:
            by_prov[r.get("provider", "unknown")].append(dur)

    all_durations = [d for durs in by_prov.values() for d in durs]
    overall_median = sorted(all_durations)[len(all_durations) // 2] if all_durations else 120

    # Count running per provider
    running_by_prov: dict[str, int] = defaultdict(int)
    if running:
        for t in running:
            running_by_prov[t.get("provider", "unknown")] += 1

    # Per-provider throughput
    prov_rates = per_provider_throughput(records)

    result: dict[str, dict] = {}
    for prov, pend_count in prov_pending.items():
        medians = by_prov.get(prov, [])
        med = sorted(medians)[len(medians) // 2] if medians else overall_median
        workers = max(running_by_prov.get(prov, 0), 1)
        rate = prov_rates.get(prov, 0)

        if pend_count == 0 and running_by_prov.get(prov, 0) == 0:
            eta_s = 0
        elif pend_count == 0:
            # Just waiting for running
            if running:
                prov_running = [t for t in running if t.get("provider") == prov]
                eta_s = max((t.get("estimated_remaining", med) for t in prov_running), default=0)
            else:
                eta_s = 0
        else:
            eta_s = int(pend_count * med / workers)

        result[prov] = {
            "pending": pend_count,
            "eta_seconds": eta_s,
            "eta_str": fmt_duration(eta_s) if eta_s > 0 else "—",
            "rate": round(rate, 1),
        }

    return result


def throughput_trend(records: list[dict]) -> str:
    """Detect whether throughput is accelerating, steady, or decelerating.

    Compares completions in the most recent 15-minute window against the
    prior 15-minute window. Returns 'accelerating', 'steady', or 'decelerating'.
    """
    now = datetime.now()
    recent_cutoff = now - timedelta(minutes=15)
    prior_cutoff = now - timedelta(minutes=30)

    recent = 0
    prior = 0
    for r in records:
        ts_str = r.get("ts")
        if not ts_str:
            continue
        ts = _parse_ts(ts_str)
        if ts is None:
            continue
        if ts >= recent_cutoff:
            recent += 1
        elif ts >= prior_cutoff:
            prior += 1

    if prior == 0 and recent == 0:
        return "steady"
    if prior == 0:
        return "accelerating" if recent > 0 else "steady"

    ratio = recent / prior
    if ratio >= 1.3:
        return "accelerating"
    elif ratio <= 0.7:
        return "decelerating"
    return "steady"


def provider_concurrency_display(
    records: list[dict], running: list[dict], use_color: bool = True
) -> str:
    """Show per-provider concurrency: active running / historical avg parallelism.

    Format: 'zhipu: 2/8  infini: 1/8  volcano: 0/16'
    """
    # Known provider concurrency limits
    PROVIDER_MAX = {"zhipu": 8, "infini": 8, "volcano": 16, "gemini": 4}

    # Count running per provider
    running_by_prov: dict[str, int] = defaultdict(int)
    for t in running:
        running_by_prov[t.get("provider", "unknown")] += 1

    # Collect all providers seen in records
    all_providers: set[str] = set()
    for r in records:
        p = r.get("provider", "unknown")
        if p and p != "unknown":
            all_providers.add(p)
    for p in running_by_prov:
        all_providers.add(p)

    if not all_providers:
        return "  No provider data."

    c = CYAN if use_color else ""
    g = GREEN if use_color else ""
    dim = DIM if use_color else ""
    rst = RESET if use_color else ""

    parts = []
    for prov in sorted(all_providers):
        active = running_by_prov.get(prov, 0)
        max_c = PROVIDER_MAX.get(prov, "?")
        if active > 0:
            parts.append(f"{prov}: {g}{active}{rst}/{max_c}")
        else:
            parts.append(f"{prov}: {dim}{active}{rst}/{max_c}")

    return "  ".join(parts)


def get_hatchet_status() -> list[dict] | None:
    """Query Hatchet API for running tasks. Returns None if unavailable.

    Gracefully handles: SDK not installed, API not configured, network errors.
    """
    try:
        from hatchet_sdk import Hatchet
        h = Hatchet()
        runs = h.runs.list(limit=20)
        result = []
        for run in runs:
            result.append({
                "workflow_run_id": getattr(run, "workflow_run_id", ""),
                "status": getattr(run, "status", "unknown"),
                "started_at": str(getattr(run, "started_at", "")),
            })
        return result
    except Exception:
        return None


def print_compact() -> None:
    """Print one-line compact status for tmux status bar.

    Format: '■ 2/5 done | 3 pending | ETA 5m | 2 zhipu, 1 infini running'
    """
    records = load_jsonl(JSONL_PATH)
    status_text, last_done, pending, done, failed = queue_status(QUEUE_PATH, use_color=False)
    running = get_running_golems()
    running = enrich_running_progress(running, records)
    eta = calculate_eta(records, pending, len(running), running)
    total = pending + done + failed

    parts = []
    if total > 0:
        parts.append(f"■ {done}/{total}")
    else:
        parts.append("■ empty")

    if pending > 0:
        parts.append(f"{pending} pending")

    if eta["eta_seconds"] > 0:
        parts.append(f"ETA {eta['eta_str']}")

    if running:
        prov_counts: dict[str, int] = defaultdict(int)
        for t in running:
            prov_counts[t.get("provider", "?")] += 1
        prov_str = " ".join(f"{k}:{v}" for k, v in sorted(prov_counts.items()))
        parts.append(f"{len(running)} running [{prov_str}]")

    thr = ewma_throughput(records)
    if thr > 0:
        parts.append(f"{thr:.1f}/hr")

    print(" | ".join(parts))


def calculate_eta(
    records: list[dict],
    pending: int,
    running_count: int,
    running_tasks: list[dict] | None = None,
) -> dict:
    """Calculate ETA to drain the queue.

    Accounts for running task progress: partially-done tasks reduce the
    effective work remaining.

    Returns dict with keys:
        avg_duration, pending, running, workers, eta_seconds, eta_str,
        drain_milestones, running_remaining_secs
    """
    # Get all durations
    durations = [r.get("duration") for r in records if r.get("duration") is not None]
    if not durations:
        avg_duration = 120  # Default 2 minutes if no data
    else:
        # Use median to avoid outlier skew
        sorted_dur = sorted(durations)
        mid = len(sorted_dur) // 2
        avg_duration = sorted_dur[mid]

    # Effective workers: running + 1 (at least one)
    workers = max(running_count, 1)

    # Running task remaining seconds
    running_remaining = 0
    if running_tasks:
        for t in running_tasks:
            running_remaining += t.get("estimated_remaining", avg_duration)

    # Max remaining across running tasks (bottleneck for current batch)
    max_running_remaining = 0
    if running_tasks:
        max_running_remaining = max(
            t.get("estimated_remaining", avg_duration) for t in running_tasks
        )

    # ETA calculation
    if pending == 0 and running_count == 0:
        eta_seconds = 0
    elif pending == 0:
        # Just waiting for running tasks to finish
        eta_seconds = max_running_remaining
    else:
        batch_time = int(pending * avg_duration / workers)
        if pending <= running_count:
            eta_seconds = max_running_remaining
        else:
            eta_seconds = max(max_running_remaining, batch_time)

    # Drain milestones: 25%, 50%, 75%, 100%
    milestones = []
    total_tasks = pending + running_count
    if total_tasks > 0 and eta_seconds > 0:
        for pct in (25, 50, 75, 100):
            t = int(eta_seconds * pct / 100)
            milestones.append((pct, t))

    return {
        "avg_duration": avg_duration,
        "pending": pending,
        "running": running_count,
        "workers": workers,
        "eta_seconds": eta_seconds,
        "eta_str": fmt_duration(eta_seconds) if eta_seconds > 0 else "—",
        "drain_milestones": milestones,
        "running_remaining_secs": running_remaining,
    }


def running_tasks_table(running: list[dict], use_color: bool = True) -> str:
    """Format currently running tasks with per-task progress bars."""
    if not running:
        return "  No golem processes running."

    c = CYAN if use_color else ""
    y = YELLOW if use_color else ""
    g = GREEN if use_color else ""
    r_col = RED if use_color else ""
    dim = DIM if use_color else ""
    rst = RESET if use_color else ""

    lines = []
    for t in sorted(running, key=lambda x: x.get("estimated_pct", 0)):
        dur = fmt_duration(t["duration_secs"])
        pct = t.get("estimated_pct", 0)
        remaining = t.get("estimated_remaining", 0)
        stale = t.get("is_stale", False)

        # Mini progress bar (10 chars wide)
        filled = int(10 * pct / 100)
        bar_chars = "█" * filled + "░" * (10 - filled)

        if stale:
            pct_str = f"{r_col}{bar_chars} STALE{rst}"
        else:
            pct_str = f"{dim}{bar_chars}{rst} {g}{pct:.0f}%{rst}"

        rem_str = f" ~{fmt_duration(remaining)}" if remaining > 0 and not stale else ""
        lines.append(
            f"  {c}[{t['pid']}] {t['provider']:<8}{rst} {y}{dur:>6}{rst}  "
            f"{pct_str}{rem_str}  {t['task']}"
        )

    # Summary with stale count
    providers = defaultdict(int)
    stale_count = sum(1 for t in running if t.get("is_stale"))
    for t in running:
        providers[t["provider"]] += 1
    summary = "  ".join(f"{k}:{v}" for k, v in sorted(providers.items()))
    stale_str = f"  {r_col}\u26a0 {stale_count} stale{rst}" if stale_count else ""
    lines.append(f"  {len(running)} running  [{summary}]{stale_str}")

    return "\n".join(lines)


def eta_section(eta: dict, throughput: float, use_color: bool = True) -> str:
    """Format ETA section with throughput, wall-clock estimate, and drain milestones."""
    b = BOLD if use_color else ""
    c = CYAN if use_color else ""
    dim = DIM if use_color else ""
    rst = RESET if use_color else ""

    if eta["pending"] == 0 and eta["running"] == 0:
        return f"  {b}Queue empty{rst}"

    if eta["pending"] == 0 and eta["running"] > 0:
        rem = fmt_duration(eta["running_remaining_secs"]) if eta["running_remaining_secs"] > 0 else "soon"
        return f"  {b}Finishing {eta['running']} running tasks{rst} (~{rem})"

    wall = eta_wall_clock(eta["eta_seconds"])
    thr_str = f"{throughput:.1f}/hr" if throughput > 0 else "—/hr"

    lines = [
        f"  Pending: {eta['pending']}  |  Running: {eta['running']}  |  "
        f"Workers: {eta['workers']}  |  Avg: {eta['avg_duration']}s",
        f"  ETA: {c}{b}{eta['eta_str']}{rst}  ({wall})  |  "
        f"Throughput: {dim}{thr_str}{rst}",
    ]

    # Drain milestones
    milestones = eta.get("drain_milestones", [])
    if milestones:
        parts = []
        for pct, secs in milestones:
            clock = eta_wall_clock(secs)
            parts.append(f"{pct}%@{clock}")
        lines.append(f"  {dim}Milestones: {' \u2192 '.join(parts)}{rst}")

    return "\n".join(lines)


def queue_status(queue_path: Path, use_color: bool = True) -> tuple[str, list[tuple[str, str]], int, int, int]:
    """Parse queue file, return status summary.

    Returns: (status_text, last_done, pending_count, done_count, failed_count)
    """
    pending = done = failed = 0
    last_done: list[tuple[str, str]] = []

    if not queue_path.exists():
        return "Queue file not found.", [], 0, 0, 0

    for line in queue_path.read_text().splitlines():
        m = re.match(r'^- \[ \] `([^`]+)`', line)
        if m:
            pending += 1
            continue
        m = re.match(r'^- \[x\] `([^`]+)`', line)
        if m:
            done += 1
            result_part = line.split("\u2192")[-1].strip() if "\u2192" in line else "ok"
            last_done.append((m.group(1)[:60], result_part))
            continue
        m = re.match(r'^- \[!\] `([^`]+)`', line)
        if m:
            failed += 1

    total = pending + done + failed

    g = GREEN if use_color else ""
    r_col = RED if use_color else ""
    c = CYAN if use_color else ""
    b = BOLD if use_color else ""
    rst = RESET if use_color else ""

    parts = [
        f"  Pending: {c}{pending}{rst}",
        f"Done: {g}{done}{rst}",
        f"Failed: {r_col}{failed}{rst}",
        f"Total: {b}{total}{rst}",
    ]

    return "  ".join(parts), last_done[-5:] if last_done else [], pending, done, failed


def last_completed_table(last_done: list[tuple[str, str]], use_color: bool = True) -> str:
    """Format last N completed tasks."""
    if not last_done:
        return "  No completed tasks."

    g = GREEN if use_color else ""
    dim = DIM if use_color else ""
    rst = RESET if use_color else ""

    lines = []
    for cmd, result in reversed(last_done):
        # Extract short prompt from command
        prompt_match = re.search(r'"([^"]+)"', cmd)
        prompt = prompt_match.group(1)[:50] if prompt_match else cmd[:50]
        lines.append(f"  {g}\u2713{rst} {dim}{prompt}{rst}  \u2192 {result}")

    return "\n".join(lines)


def disk_free(use_color: bool = True) -> str:
    """Report free disk space on home partition."""
    try:
        usage = shutil.disk_usage(Path.home())
        free_str = fmt_bytes(usage.free)
        total_str = fmt_bytes(usage.total)
        pct = (usage.free / usage.total * 100) if usage.total else 0

        y = YELLOW if use_color else ""
        r_col = RED if use_color else ""
        rst = RESET if use_color else ""

        color = r_col if pct < 10 else (y if pct < 20 else "")
        return f"  Free: {color}{free_str}{rst} / {total_str} ({pct:.0f}% free)"
    except Exception as e:
        return f"  Disk check failed: {e}"


def print_dashboard(use_color: bool = True, json_output: bool = False) -> int:
    """Print the full golem dashboard."""
    b = BOLD if use_color else ""
    rst = RESET if use_color else ""

    # Gather data
    records = load_jsonl(JSONL_PATH)
    status_text, last_done, pending, done, failed = queue_status(QUEUE_PATH, use_color)
    running = get_running_golems()
    running = enrich_running_progress(running, records)
    eta = calculate_eta(records, pending, len(running), running)
    thr = throughput_rate(records, window_minutes=60)
    ewma = ewma_throughput(records)
    conf = eta_confidence(records)
    m15, m60 = completion_burst(records)
    spark = throughput_sparkline(records)
    prov_pending = per_provider_pending(QUEUE_PATH)
    prov_concurrency = provider_concurrency_display(records, running, use_color)

    if json_output:
        data = {
            "timestamp": datetime.now().isoformat(),
            "running": running,
            "queue": {
                "pending": pending,
                "done": done,
                "failed": failed,
                "completed_count": len(last_done),
                "per_provider_pending": prov_pending,
            },
            "eta": {**eta, "confidence": conf},
            "throughput_per_hour": thr,
            "ewma_throughput": ewma,
            "throughput_sparkline": spark,
            "completion_burst": {"last_15min": m15, "last_60min": m60},
            "provider_concurrency": prov_concurrency,
            "disk_free": disk_free(False),
        }
        print(json.dumps(data, indent=2))
        return 0

    total = pending + done + failed

    # 1. Progress bar
    print(f"\n{b}Progress{rst}")
    print(f"  {progress_bar(done, total, width=30, use_color=use_color)}")
    burst_str = f"  Last 15min: {m15}  |  Last 60min: {m60}"
    print(burst_str)

    # 2. Throughput sparkline
    print(f"\n{b}Throughput Trend (6hr){rst}")
    print(f"  {spark}")

    # 3. Running tasks (real-time progress with per-task bars)
    print(f"\n{b}Running Tasks{rst}")
    print(running_tasks_table(running, use_color))

    # 4. ETA to drain with milestones + confidence
    print(f"\n{b}ETA to Drain{rst}")
    print(eta_section(eta, thr, use_color))
    # Show EWMA throughput and confidence indicator
    y = YELLOW if use_color else ""
    dim = DIM if use_color else ""
    ewma_str = f"{ewma:.1f}/hr" if ewma > 0 else "—/hr"
    conf_str = conf
    print(f"  EWMA: {dim}{ewma_str}{rst}  |  Confidence: {y}{conf_str}{rst}")

    # 5. Provider stats
    print(f"\n{b}Provider Stats{rst}")
    print(provider_stats(records, use_color))

    # 6. Queue status with per-provider breakdown
    print(f"\n{b}Queue Status{rst}")
    print(status_text)
    if prov_pending:
        c = CYAN if use_color else ""
        dim = DIM if use_color else ""
        rst = RESET if use_color else ""
        prov_parts = [f"{c}{k}{rst}:{v}" for k, v in sorted(prov_pending.items())]
        print(f"  {dim}Pending by provider: {' '.join(prov_parts)}{rst}")

    # 7. Provider concurrency
    print(f"\n{b}Provider Concurrency{rst}")
    print(prov_concurrency)

    # 8. Last 5 completed
    print(f"\n{b}Last Completed{rst}")
    print(last_completed_table(last_done, use_color))

    # 9. Disk free
    print(f"\n{b}Disk{rst}")
    print(disk_free(use_color))
    print()

    return 0


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__.strip())
        return 0
    use_color = "--no-color" not in args
    json_output = "--json" in args
    compact = "--compact" in args

    if compact:
        print_compact()
        return 0

    # Parse --watch N
    watch_seconds = 0
    if "--watch" in args:
        idx = args.index("--watch")
        if idx + 1 < len(args):
            try:
                watch_seconds = max(int(args[idx + 1]), 1)
            except (ValueError, IndexError):
                watch_seconds = 5  # Default to 5s
        else:
            watch_seconds = 5

    if watch_seconds > 0:
        try:
            while True:
                # Clear screen and print dashboard
                print("\033[2J\033[H", end="")
                print_dashboard(use_color, json_output)
                print(f"  Refreshing every {watch_seconds}s  (Ctrl+C to stop)")
                time.sleep(watch_seconds)
        except KeyboardInterrupt:
            print("\n  Stopped.")
            return 0

    return print_dashboard(use_color, json_output)


if __name__ == "__main__":
    sys.exit(main())

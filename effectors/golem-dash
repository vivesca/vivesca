"""golem-dash — Dashboard for golem task queue.

Reads golem.jsonl, golem-daemon.log, and golem-queue.md.
Prints: (1) Progress bar, (2) Throughput sparkline, (3) Real-time running
tasks with per-task progress, (4) ETA to drain with milestones + confidence,
(5) Provider stats, (6) Queue status with per-provider pending breakdown,
(7) Provider concurrency, (8) Last 5 completed, (9) Disk free. Colorized.

Usage:
    golem-dash              # Show dashboard
    golem-dash --no-color   # No ANSI colors
    golem-dash --json       # Machine-readable output
    golem-dash --compact    # One-line tmux status bar
    golem-dash --watch 5    # Auto-refresh every 5 seconds
"""
from __future__ import annotations

import json
import re
import shutil
import subprocess
import sys

"""golem-dash — Live dashboard for golem task queue.

Reads golem.jsonl in real-time (tail -f style). Shows live updating table:
per-provider active/completed/failed/rate-limited counts, rolling success rate,
per-task progress with elapsed time, drain progress bar, ETA to queue drain.
Uses rich for terminal UI.

Usage:
    golem-dash              # Show live dashboard (auto-refresh)
    golem-dash --once       # Single snapshot, no live refresh
    golem-dash --window 60  # Rolling window in minutes (default 60)
"""
from __future__ import annotations

import json
import sys
import time
import re
from collections import defaultdict
from datetime import datetime, timedelta, timezone
from pathlib import Path

from rich.bar import Bar
from rich.console import Group
from rich.live import Live
from rich.panel import Panel
from rich.table import Table
from rich.text import Text

# Paths
VIVESCA_DIR = Path.home() / ".local" / "share" / "vivesca"
JSONL_PATH = VIVESCA_DIR / "golem.jsonl"
QUEUE_PATH = Path.home() / "germline" / "loci" / "golem-queue.md"
RUNNING_JSON_PATH = VIVESCA_DIR / "golem-running.json"
COOLDOWNS_PATH = VIVESCA_DIR / "golem-cooldowns.json"

# Rate-limit detection
RATE_LIMIT_PATTERNS = re.compile(
    r'429|AccountQuotaExceeded|rate.?limit|quota.?exceeded|20013|'
    r'request.?limit.?exceeded|API Error.*429|too many requests|TooManyRequests|'
    r'usage.?limit|hit your.*limit|quota will reset',
    re.IGNORECASE,
)

# Thresholds
SHORT_DURATION_LIMIT = 10  # seconds — fast exits are likely rate-limits

# Global: track when we first saw each running task_id (for elapsed time)
_task_first_seen: dict[str, float] = {}


def parse_ts(ts_str: str) -> datetime:
    """Parse a timestamp string (flexible formats)."""
    for fmt in (
        "%Y-%m-%dT%H:%M:%SZ",
        "%Y-%m-%dT%H:%M:%S",
        "%Y-%m-%d %H:%M:%S",
    ):
        try:
            return datetime.strptime(ts_str, fmt).replace(tzinfo=timezone.utc)
        except ValueError:
            continue
    return datetime.min.replace(tzinfo=timezone.utc)


def is_rate_limited(record: dict) -> bool:
    """Detect rate-limit from exit code + duration + tail."""
    exit_code = record.get("exit", -1)
    duration = record.get("duration", 0)
    tail = record.get("tail", "")
    if exit_code == 0:
        return False
    if RATE_LIMIT_PATTERNS.search(tail):
        return True
    # Fast exit with no output is a rate-limit signal
    if exit_code == 1 and duration <= SHORT_DURATION_LIMIT and tail.strip() in ("", " "):
        return True
    return False


def load_jsonl(window_minutes: int = 60) -> list[dict]:
    """Load golem.jsonl records within the rolling window."""
    if not JSONL_PATH.exists():
        return []
    cutoff = datetime.now(timezone.utc) - timedelta(minutes=window_minutes)
    records = []
    try:
        with open(JSONL_PATH, errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                    ts = parse_ts(rec.get("ts", ""))
                    if ts >= cutoff:
                        records.append(rec)
                except (json.JSONDecodeError, ValueError):
                    continue
    except OSError:
        pass
    return records


def load_all_jsonl() -> list[dict]:
    """Load all golem.jsonl records."""
    if not JSONL_PATH.exists():
        return []
    records = []
    try:
        with open(JSONL_PATH, errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    records.append(json.loads(line))
                except (json.JSONDecodeError, ValueError):
                    continue
    except OSError:
        pass
    return records


def load_running() -> list[dict]:
    """Load currently running tasks."""
    if not RUNNING_JSON_PATH.exists():
        return []
    try:
        return json.loads(RUNNING_JSON_PATH.read_text())
    except (json.JSONDecodeError, OSError):
        return []


def load_cooldowns() -> dict[str, str]:
    """Load provider cooldowns: {provider: expires_at_str}."""
    if not COOLDOWNS_PATH.exists():
        return {}
    try:
        entries = json.loads(COOLDOWNS_PATH.read_text())
        if isinstance(entries, list):
            return {e.get("provider", ""): e.get("expires_at", "") for e in entries if isinstance(e, dict)}
        return {}
    except (json.JSONDecodeError, OSError):
        return {}


def count_pending_by_provider() -> dict[str, int]:
    """Count pending tasks in queue by provider."""
    counts: dict[str, int] = defaultdict(int)
    if not QUEUE_PATH.exists():
        return counts
    try:
        text = QUEUE_PATH.read_text()
    except OSError:
        return counts
    for line in text.splitlines():
        line = line.strip()
        if line.startswith("- [ ]"):
            # Extract --provider X
            m = re.search(r"--provider\s+(\w+)", line)
            if m:
                counts[m.group(1)] += 1
            else:
                counts["unassigned"] += 1
    return counts


def count_total_pending() -> int:
    """Count total pending tasks."""
    if not QUEUE_PATH.exists():
        return 0
    try:
        text = QUEUE_PATH.read_text()
    except OSError:
        return 0
    return sum(1 for line in text.splitlines() if line.strip().startswith("- [ ]"))


def count_total_completed() -> int:
    """Count total completed tasks in queue."""
    if not QUEUE_PATH.exists():
        return 0
    try:
        text = QUEUE_PATH.read_text()
    except OSError:
        return 0
    return sum(1 for line in text.splitlines() if line.strip().startswith("- [x]"))


def fmt_duration(seconds: float) -> str:
    """Format seconds as compact duration."""
    if seconds < 60:
        return f"{seconds:.0f}s"
    elif seconds < 3600:
        return f"{seconds / 60:.1f}m"
    else:
        h = seconds / 3600
        return f"{h:.1f}h"


def fmt_eta(seconds: float) -> str:
    """Format ETA in human-friendly form."""
    if seconds <= 0:
        return "—"
    if seconds < 60:
        return f"{seconds:.0f}s"
    elif seconds < 3600:
        return f"{seconds / 60:.0f}m"
    elif seconds < 86400:
        h = seconds / 3600
        return f"{h:.1f}h"
    else:
        return f"{seconds / 86400:.1f}d"


def compute_avg_duration_by_provider(records: list[dict]) -> dict[str, float]:
    """Compute average duration of successful tasks per provider."""
    totals: dict[str, list[float]] = {}
    for rec in records:
        if rec.get("exit") == 0 and rec.get("duration", 0) > 0:
            prov = rec.get("provider", "unknown")
            totals.setdefault(prov, []).append(rec["duration"])
    return {prov: sum(durs) / len(durs) for prov, durs in totals.items()}


def estimate_task_progress(elapsed: float, avg_duration: float) -> float:
    """Estimate task progress as a fraction [0.0, 1.0].

    Based on elapsed time vs average task duration for the provider.
    Returns 0.0 if avg_duration is 0 (no data).
    """
    if avg_duration <= 0:
        return 0.0
    return min(elapsed / avg_duration, 1.0)


def compute_completions_per_minute(records: list[dict], window_minutes: int = 30) -> float:
    """Compute completions per minute over the given window."""
    if not records:
        return 0.0
    now = datetime.now(timezone.utc)
    cutoff = now - timedelta(minutes=window_minutes)
    count = 0
    for rec in records:
        ts = parse_ts(rec.get("ts", ""))
        if ts >= cutoff and rec.get("exit") == 0:
            count += 1
    return count / window_minutes


def update_task_first_seen(running: list[dict]) -> None:
    """Track first-seen timestamps for running tasks to compute elapsed time."""
    global _task_first_seen
    now = time.time()
    current_ids = set()
    for task in running:
        tid = task.get("task_id", "")
        current_ids.add(tid)
        if tid and tid not in _task_first_seen:
            _task_first_seen[tid] = now
    # Prune tasks no longer running
    _task_first_seen = {k: v for k, v in _task_first_seen.items() if k in current_ids}


def compute_elapsed(task_id: str) -> float:
    """Return elapsed seconds since we first saw this task_id."""
    first = _task_first_seen.get(task_id)
    if first is None:
        return 0.0
    return time.time() - first


def compute_provider_stats(
    window_records: list[dict],
    running: list[dict],
) -> dict[str, dict]:
    """Compute per-provider statistics from window records and running tasks."""
    stats: dict[str, dict] = {}

    # Initialize from running tasks
    for task in running:
        prov = task.get("provider", "unknown")
        if prov not in stats:
            stats[prov] = {
                "active": 0, "completed": 0, "failed": 0,
                "rate_limited": 0, "killed": 0,
                "total_duration": 0.0, "success_count": 0, "total_count": 0,
            }
        stats[prov]["active"] += 1

    # Aggregate from jsonl records
    for rec in window_records:
        prov = rec.get("provider", "unknown")
        if prov not in stats:
            stats[prov] = {
                "active": 0, "completed": 0, "failed": 0,
                "rate_limited": 0, "killed": 0,
                "total_duration": 0.0, "success_count": 0, "total_count": 0,
            }
        exit_code = rec.get("exit", -1)
        duration = rec.get("duration", 0)
        stats[prov]["total_count"] += 1
        stats[prov]["total_duration"] += duration

        if exit_code == 0:
            stats[prov]["completed"] += 1
            stats[prov]["success_count"] += 1
        elif exit_code == 137:
            stats[prov]["killed"] += 1
        elif is_rate_limited(rec):
            stats[prov]["rate_limited"] += 1
        else:
            stats[prov]["failed"] += 1

    return stats


def compute_per_provider_eta(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> dict[str, float]:
    """Estimate time to drain per-provider queue."""
    now = datetime.now(timezone.utc)
    one_hour_ago = now - timedelta(hours=1)
    result: dict[str, float] = {}

    for prov in set(list(stats.keys()) + list(pending_by_provider.keys())):
        queue = pending_by_provider.get(prov, 0)
        if queue == 0:
            result[prov] = 0.0
            continue

        # Count completions for this provider in last hour
        recent = sum(
            1 for r in all_records
            if parse_ts(r.get("ts", "")) >= one_hour_ago
            and r.get("exit") == 0
            and r.get("provider") == prov
        )

        if recent > 0:
            result[prov] = (queue / recent) * 3600
        else:
            # Fallback: avg duration * queue / active workers
            s = stats.get(prov, {})
            total_count = s.get("total_count", 0)
            total_duration = s.get("total_duration", 0)
            active = s.get("active", 0)
            if total_count > 0 and active > 0:
                avg_dur = total_duration / total_count
                result[prov] = (queue / active) * avg_dur
            else:
                result[prov] = float("inf")

    return result


def compute_eta(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> float:
    """Estimate overall time to drain the queue based on recent throughput."""
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return 0.0

    # Count completions in the last hour across all providers
    now = datetime.now(timezone.utc)
    one_hour_ago = now - timedelta(hours=1)
    recent_completed = 0
    for rec in all_records:
        ts = parse_ts(rec.get("ts", ""))
        if ts >= one_hour_ago and rec.get("exit") == 0:
            recent_completed += 1

    if recent_completed == 0:
        # No completions in the last hour; use avg duration from all records
        durations = [r.get("duration", 0) for r in all_records if r.get("exit") == 0 and r.get("duration", 0) > 0]
        if durations:
            avg_duration = sum(durations) / len(durations)
            total_active = sum(s["active"] for s in stats.values())
            if total_active > 0:
                return (total_pending / total_active) * avg_duration
        return float("inf")

    throughput_per_hour = recent_completed
    return (total_pending / throughput_per_hour) * 3600


def compute_throughput_trend(all_records: list[dict], bucket_minutes: int = 10) -> list[int]:
    """Compute completions per time bucket for sparkline."""
    now = datetime.now(timezone.utc)
    buckets: list[int] = []
    for i in range(6):
        bucket_end = now - timedelta(minutes=bucket_minutes * i)
        bucket_start = bucket_end - timedelta(minutes=bucket_minutes)
        count = sum(
            1 for r in all_records
            if bucket_start <= parse_ts(r.get("ts", "")) < bucket_end
            and r.get("exit") == 0
        )
        buckets.append(count)
    buckets.reverse()
    return buckets


def sparkline(values: list[int]) -> str:
    """Render a Unicode sparkline from a list of ints."""
    chars = "▁▂▃▄▅▆▇█"
    if not values or max(values) == 0:
        return "▁" * len(values) if values else ""
    mx = max(values)
    return "".join(chars[min(int(v / mx * (len(chars) - 1)), len(chars) - 1)] for v in values)


def build_running_tasks_table(
    running: list[dict],
    avg_duration_by_provider: dict[str, float] | None = None,
) -> Table:
    """Build a table showing each running task with elapsed time and progress."""
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title="[bold]Running Tasks[/bold]",
    )
    table.add_column("TaskID", style="cyan", min_width=9)
    table.add_column("Provider", min_width=8)
    table.add_column("Progress", justify="right", min_width=14)
    table.add_column("Elapsed", justify="right", min_width=7)
    table.add_column("Through", style="dim", min_width=10)
    table.add_column("Prompt", style="dim", min_width=30, max_width=50, no_wrap=True)

    avg_map = avg_duration_by_provider or {}

    for task in running:
        tid = task.get("task_id", "?")
        prov = task.get("provider", "?")
        dispatch = task.get("dispatch_provider", "")
        elapsed = compute_elapsed(tid)
        cmd = task.get("cmd", "")

        # Extract prompt snippet from cmd
        prompt_match = re.search(r'"(.+)', cmd)
        prompt = prompt_match.group(0).rstrip('"')[:48] if prompt_match else cmd[:48]

        through_str = f"→ {dispatch}" if dispatch and dispatch != prov else ""

        elapsed_str = fmt_duration(elapsed)
        if elapsed > 600:
            elapsed_str = f"[red]{elapsed_str}[/red]"
        elif elapsed > 300:
            elapsed_str = f"[yellow]{elapsed_str}[/yellow]"

        # Progress bar based on avg duration for this provider
        avg_dur = avg_map.get(prov, 0)
        pct = estimate_task_progress(elapsed, avg_dur)
        bar_w = 8
        filled = int(pct * bar_w)
        bar_str = "█" * filled + "░" * (bar_w - filled)
        if pct >= 1.0:
            progress_str = f"[yellow]{bar_str} {pct:.0%}[/yellow]"
        elif pct >= 0.5:
            progress_str = f"[cyan]{bar_str} {pct:.0%}[/cyan]"
        else:
            progress_str = f"[dim]{bar_str} {pct:.0%}[/dim]"

        table.add_row(tid, prov, progress_str, elapsed_str, through_str, prompt)

    return table


def build_drain_progress(total_pending: int, total_completed: int, eta_seconds: float) -> Text:
    """Build drain progress bar with ETA."""
    total = total_pending + total_completed
    if total == 0:
        return Text("  No tasks in queue", style="dim")

    pct = total_completed / total
    bar_width = 30
    filled = int(pct * bar_width)
    bar_str = "█" * filled + "░" * (bar_width - filled)

    line = Text()
    line.append(f"  Drain: ", style="bold")
    line.append(f"[{bar_str}] ", style="cyan")
    line.append(f"{pct:.0%} ", style="bold cyan")
    line.append(f"({total_completed}/{total}) ", style="dim")
    line.append(f"ETA: {fmt_eta(eta_seconds)}", style="bold yellow")
    return line


def build_dashboard(
    window_minutes: int = 60,
    all_records_cache: list[dict] | None = None,
) -> Panel:
    """Build the full dashboard as a Rich renderable."""
    window_records = load_jsonl(window_minutes)
    running = load_running()
    cooldowns = load_cooldowns()
    pending_by_provider = count_pending_by_provider()
    total_pending = sum(pending_by_provider.values())
    total_completed_queue = count_total_completed()

    # Track first-seen for running tasks
    update_task_first_seen(running)

    # Use cached all-records for ETA if provided (avoids re-reading on every refresh)
    all_records = all_records_cache if all_records_cache is not None else load_all_jsonl()

    stats = compute_provider_stats(window_records, running)
    eta_seconds = compute_eta(stats, pending_by_provider, all_records)
    per_provider_eta = compute_per_provider_eta(stats, pending_by_provider, all_records)
    trend = compute_throughput_trend(all_records)
    spark = sparkline(trend)

    # === Header ===
    now_str = datetime.now().strftime("%H:%M:%S")
    header = Text()
    header.append("⬡ Golem Dashboard", style="bold cyan")
    header.append(f"  {now_str}", style="dim")
    header.append(f"  window={window_minutes}m", style="dim")
    header.append(f"  queue={total_pending} pending / {total_completed_queue} done", style="yellow")
    header.append(f"  throughput: {spark}", style="green")

    # === Provider table ===
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title=None,
    )
    table.add_column("Provider", style="bold", min_width=10)
    table.add_column("Active", justify="right", min_width=6)
    table.add_column("✓", justify="right", style="green", min_width=5)
    table.add_column("✗", justify="right", style="red", min_width=5)
    table.add_column("⏳", justify="right", style="yellow", min_width=5)
    table.add_column("☠", justify="right", style="dim red", min_width=5)
    table.add_column("Rate", justify="right", min_width=8)
    table.add_column("AvgDur", justify="right", min_width=7)
    table.add_column("Queue", justify="right", style="cyan", min_width=6)
    table.add_column("Drain ETA", justify="right", min_width=9)
    table.add_column("Status", min_width=10)

    provider_order = ["zhipu", "infini", "volcano", "codex", "gemini"]
    for prov in sorted(stats.keys(), key=lambda p: provider_order.index(p) if p in provider_order else 99):
        s = stats[prov]
        total = s["completed"] + s["failed"] + s["rate_limited"] + s["killed"]
        if total > 0:
            rate = s["success_count"] / total * 100
        else:
            rate = 0.0

        avg_dur = s["total_duration"] / s["total_count"] if s["total_count"] > 0 else 0
        queue = pending_by_provider.get(prov, 0)
        prov_eta = per_provider_eta.get(prov, 0.0)

        # Rate coloring
        if rate >= 80:
            rate_str = f"[green]{rate:.0f}%[/green]"
        elif rate >= 50:
            rate_str = f"[yellow]{rate:.0f}%[/yellow]"
        elif total > 0:
            rate_str = f"[red]{rate:.0f}%[/red]"
        else:
            rate_str = "[dim]—[/dim]"

        # Status
        if prov in cooldowns:
            status = "[red]COOLDOWN[/red]"
        elif s["active"] > 0:
            status = f"[green]running ({s['active']})[/green]"
        elif queue > 0:
            status = "[yellow]queued[/yellow]"
        else:
            status = "[dim]idle[/dim]"

        eta_str = fmt_eta(prov_eta) if queue > 0 else "[dim]—[/dim]"

        table.add_row(
            prov,
            str(s["active"]),
            str(s["completed"]),
            str(s["failed"]),
            str(s["rate_limited"]),
            str(s["killed"]),
            rate_str,
            fmt_duration(avg_dur),
            str(queue),
            eta_str,
            status,
        )

    # === Summary line ===
    total_active = sum(s["active"] for s in stats.values())
    total_completed_window = sum(s["completed"] for s in stats.values())
    total_failed_window = sum(s["failed"] for s in stats.values())
    total_rl_window = sum(s["rate_limited"] for s in stats.values())
    window_total = total_completed_window + total_failed_window + total_rl_window
    window_rate = (total_completed_window / window_total * 100) if window_total > 0 else 0.0

    summary = Text()
    summary.append(f"  Workers: {total_active}  ", style="bold")
    summary.append(f"Done(window): {total_completed_window}  ", style="green")
    summary.append(f"Failed: {total_failed_window}  ", style="red")
    summary.append(f"RateLimited: {total_rl_window}  ", style="yellow")
    summary.append(f"Success: {window_rate:.0f}%  ", style="bold green" if window_rate >= 80 else "bold yellow")
    summary.append(f"ETA: {fmt_eta(eta_seconds)}", style="bold cyan")

    # === Drain progress ===
    drain_progress = build_drain_progress(total_pending, total_completed_queue, eta_seconds)

    # === Running tasks table ===
    components = [header, table, summary, drain_progress]
    if running:
        avg_durs = compute_avg_duration_by_provider(all_records)
        components.append(build_running_tasks_table(running, avg_durs))

    # === Cooldown info ===
    cooldown_lines = []
    now_utc = datetime.now(timezone.utc)
    for prov, expires_str in cooldowns.items():
        if expires_str:
            exp = parse_ts(expires_str)
            remaining = (exp - now_utc).total_seconds()
            if remaining > 0:
                cooldown_lines.append(f"  {prov}: cooldown {fmt_duration(remaining)} remaining")

    cooldown_text = Text()
    if cooldown_lines:
        cooldown_text.append("Cooldowns:\n", style="bold yellow")
        for cl in cooldown_lines:
            cooldown_text.append(cl + "\n", style="yellow")
        components.append(cooldown_text)

    return Panel(
        Group(*components),
        title="[bold]Golem Task Monitor[/bold]",
        border_style="blue",
        padding=(1, 2),
    )


def tail_jsonl(file_path: Path, from_byte: int = 0):
    """Yield new lines from jsonl file as they appear (tail -f style)."""
    try:
        with open(file_path) as f:
            f.seek(from_byte)
            while True:
                line = f.readline()
                if line:
                    yield line.strip()
                else:
                    time.sleep(0.5)
    except (OSError, KeyboardInterrupt):
        return


def main():
    import argparse

    parser = argparse.ArgumentParser(description="Golem task queue dashboard")
    parser.add_argument("--once", action="store_true", help="Single snapshot, no live refresh")
    parser.add_argument("--window", type=int, default=60, help="Rolling window in minutes (default: 60)")
    args = parser.parse_args()

    if not JSONL_PATH.exists():
        print(f"No data file found at {JSONL_PATH}", file=sys.stderr)
        print("Start golem-daemon first.", file=sys.stderr)
        sys.exit(1)

    if args.once:
        panel = build_dashboard(window_minutes=args.window)
        from rich.console import Console
        Console().print(panel)
        return

    # Live mode: pre-load all records once for ETA caching, then tail for new entries
    all_records_cache = load_all_jsonl()
    initial_byte = JSONL_PATH.stat().st_size if JSONL_PATH.exists() else 0

    with Live(
        build_dashboard(window_minutes=args.window, all_records_cache=all_records_cache),
        refresh_per_second=0.5,
        screen=False,
    ) as live:
        # Refresh from tail -f
        current_byte = initial_byte
        while True:
            try:
                # Check if file was rotated (truncated)
                if JSONL_PATH.exists():
                    new_size = JSONL_PATH.stat().st_size
                    if new_size < current_byte:
                        # File was rotated
                        all_records_cache = load_all_jsonl()
                        current_byte = 0
                    elif new_size > current_byte:
                        # Read new records
                        with open(JSONL_PATH, errors="replace") as f:
                            f.seek(current_byte)
                            new_lines = f.readlines()
                        for line in new_lines:
                            line = line.strip()
                            if line:
                                try:
                                    all_records_cache.append(json.loads(line))
                                except (json.JSONDecodeError, ValueError):
                                    pass
                        current_byte = new_size
                        # Periodically trim cache to prevent unbounded growth (keep last 10k)
                        if len(all_records_cache) > 10000:
                            all_records_cache = all_records_cache[-5000:]

                live.update(build_dashboard(
                    window_minutes=args.window,
                    all_records_cache=all_records_cache,
                ))
                time.sleep(2)
            except KeyboardInterrupt:
                break


if __name__ == "__main__":
    main()

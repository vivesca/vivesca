#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""Unified dispatch CLI for cheap LLM tasks via ZhiPu.

Routes tasks to direct API, goose, or droid based on mode.
    scout <dir> "<prompt>"                 # explore (direct API → goose)
    scout --build <dir> "<prompt>"         # implement (goose + GLM-5.1)
    scout --mcp "<prompt>"                 # MCP task (droid --auto high)
    scout --safe <dir> "<prompt>"          # read-only audit (direct API → droid)
    scout --model GLM-5.1 <dir> "<prompt>" # override model
    scout --backend droid <dir> "<prompt>" # force backend (skip direct API)
    scout --skill etiology <dir> "debug"   # run organism skill via recipe
    scout --skill debridement --mcp <dir>  # skill via droid
    scout --output <file> ...              # route output to file/telegram/stdout
"""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path


def _direct_api(prompt: str, model: str = "glm-4.7") -> int:
    """Single-turn API call to api.z.ai. No agent loop."""
    import json as _json
    import urllib.request
    url = "https://api.z.ai/api/anthropic/v1/messages"
    key = os.environ.get("ZHIPU_API_KEY", "")
    if not key:
        print("scout: ZHIPU_API_KEY not set", file=sys.stderr)
        return 1
    body = _json.dumps({
        "model": model,
        "max_tokens": 8192,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()
    req = urllib.request.Request(url, body)
    req.add_header("x-api-key", key)
    req.add_header("anthropic-version", "2023-06-01")
    req.add_header("content-type", "application/json")
    try:
        resp = urllib.request.urlopen(req, timeout=120)
        data = _json.loads(resp.read())
        print(data["content"][0]["text"])
        return 0
    except Exception as e:
        print(f"scout: direct API failed: {e}", file=sys.stderr)
        return 1


def _read_dir_context(directory: str, glob_pattern: str = "*.py") -> str:
    """Read files matching pattern and format as context."""
    from pathlib import Path
    parts: list[str] = []
    for f in sorted(Path(directory).glob(glob_pattern)):
        if f.is_file() and f.stat().st_size < 50000:
            parts.append(f"### {f.name}\n```\n{f.read_text()}\n```")
    return "\n\n".join(parts)


COACHING_NOTES = Path.home() / "epigenome/marks/feedback_glm_coaching.md"


def _inject_coaching(prompt: str) -> str:
    """Prepend GLM coaching notes to prompt if available."""
    if COACHING_NOTES.exists():
        notes = COACHING_NOTES.read_text().strip()
        # Strip frontmatter
        if notes.startswith("---"):
            end = notes.find("---", 3)
            if end > 0:
                notes = notes[end + 3:].strip()
        return f"{notes}\n\n---\n\nTask:\n{prompt}"
    return prompt


def _build_goose_cmd(model: str, prompt: str, recipe: str | None = None) -> list[str]:
    cmd = ["goose", "run", "-q", "--no-session",
           "--provider", "glm-coding", "--model", model]
    if recipe:
        cmd += ["--recipe", recipe]
    cmd += ["-t", prompt]
    return cmd


def _build_droid_cmd(model: str, directory: str, prompt: str,
                     auto: str | None = None) -> list[str]:
    model_flag = model if model.startswith("custom:") else f"custom:{model}"
    cmd = ["droid", "exec", "-m", model_flag, "--cwd", directory, prompt]
    if auto:
        cmd.insert(2, "--auto")
        cmd.insert(3, auto)
    return cmd


def _exec(cmd: list[str], directory: str | None = None,
          capture: bool = False) -> tuple[int, str]:
    """Run cmd, optionally in directory. Returns (rc, stdout)."""
    env = {**os.environ, "GOOGLE_API_KEY": "", "GEMINI_API_KEY": ""}
    prev = os.getcwd()
    if directory:
        os.chdir(directory)
    try:
        if capture:
            r = subprocess.run(cmd, capture_output=True, text=True, env=env)
            return r.returncode, r.stdout or ""
        return subprocess.run(cmd, env=env).returncode, ""
    finally:
        if directory:
            os.chdir(prev)

def _resolve_mode(args: argparse.Namespace) -> tuple[str, str, str, str | None, str]:
    """Return (backend, model, directory, auto_level, mode)."""
    mode = "explore"
    auto: str | None = None
    if args.skill:
        mode = "skill"
        if args.mcp:
            backend = "droid"
            model = "GLM-4.7"
            auto = "high"
        else:
            backend = "goose"
            model = "GLM-5.1" if args.build else "GLM-4.7"
    elif args.build:
        mode = "build"
        backend, model = "goose", "GLM-5.1"
    elif args.mcp:
        mode = "mcp"
        backend, model = "droid", "GLM-4.7"
        auto = "high"
    elif args.safe:
        mode = "safe"
        backend, model = "droid", "GLM-4.7"
    else:
        backend, model = "goose", "GLM-4.7"

    if args.backend:
        backend = args.backend
    if args.model:
        model = args.model
    directory = args.dir or os.path.expanduser("~")
    return backend, model, directory, auto, mode


def _parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    """Parse args, handling MCP mode's dir-optional semantics."""
    parser = argparse.ArgumentParser(description="Unified dispatch CLI for LLM tasks.")
    parser.add_argument("dir", nargs="?", default=".", help="Working directory")
    parser.add_argument("prompt", nargs="*", default=[], help="Task prompt")
    parser.add_argument("--build", action="store_true", help="Implementation mode")
    parser.add_argument("--mcp", action="store_true", help="MCP task mode")
    parser.add_argument("--safe", action="store_true", help="Read-only audit mode")
    parser.add_argument("--model", help="Override model")
    parser.add_argument("--backend", choices=["goose", "droid"], help="Force backend")
    parser.add_argument("-f", "--file", help="Read prompt from file")
    parser.add_argument("--skill", help="Run an organism skill by name")
    parser.add_argument("--output", help="Route output: file path, 'telegram', or omit for stdout")
    parser.add_argument("--dry-run", action="store_true", help="Print command only")
    parser.add_argument("--verbose", action="store_true", help="Verbose output")

    args = parser.parse_args(argv)
    # Flatten prompt tokens into a single string
    args.prompt = " ".join(args.prompt) if isinstance(args.prompt, list) else args.prompt
    # In MCP mode with a single positional, treat it as the prompt (not dir).
    if args.mcp and args.prompt == "" and args.dir != ".":
        args.prompt = args.dir
        args.dir = "."

    return args


def _run_captured(cmd: list[str], **kwargs) -> tuple[int, str]:
    """Run subprocess capturing stdout. Returns (returncode, stdout_text)."""
    r = subprocess.run(cmd, capture_output=True, text=True, **kwargs)
    return r.returncode, (r.stdout or "")


def _route_output(text: str, dest: str) -> int:
    """Route captured output to file, telegram, or leave for caller."""
    from pathlib import Path
    # Defensive: ensure text is str (mocks may return bytes)
    if isinstance(text, bytes):
        text = text.decode()
    if dest == "-":
        print(text, end="")
        return 0
    if dest == "telegram":
        return subprocess.run(
            ["efferens", "telegram", text.rstrip()]).returncode
    # File path
    Path(dest).parent.mkdir(parents=True, exist_ok=True)
    Path(dest).write_text(text)
    return 0


def main(argv: list[str] | None = None) -> int:
    from pathlib import Path
    args = _parse_args(argv)
    # Resolve prompt from arg or file
    prompt = args.prompt
    if args.file:
        with open(args.file) as fh:
            prompt = fh.read().strip()

    backend, model, directory, auto, mode = _resolve_mode(args)

    # --skill: resolve recipe and adjust prompt/backend
    recipe_path: str | None = None
    if args.skill:
        rp = Path.home() / f"germline/membrane/receptors/{args.skill}/recipe.yaml"
        if not rp.exists():
            print(f"scout: skill '{args.skill}' not found (no recipe.yaml)",
                  file=sys.stderr)
            print(f"  hint: run 'skill-sync {args.skill}' to generate",
                  file=sys.stderr)
            return 1
        recipe_path = str(rp)
        # If no prompt provided, use a minimal default
        if not prompt:
            prompt = f"Execute the {args.skill} skill."
        # Droid path: prepend skill invocation prefix
        if backend == "droid":
            prompt = f"Use the /{args.skill} skill. " + prompt

    if not prompt:
        print("Error: provide a prompt via argument or -f <file>", file=sys.stderr)
        return 1

    # Inject coaching notes
    prompt = _inject_coaching(prompt)

    # Prepend safe-mode guard
    if args.safe:
        prompt = "READ ONLY. Do not create, modify, or delete any files. " + prompt

    # Build command based on backend
    if mode == "skill" and backend == "goose":
        cmd = ["goose", "run", "-q", "--no-session",
               "--provider", "glm-coding", "--model", model,
               "--recipe", recipe_path, "-t", prompt]
    elif backend == "goose":
        cmd = _build_goose_cmd(model, prompt)
    else:
        cmd = _build_droid_cmd(model, directory, prompt, auto)

    if args.dry_run:
        print(" ".join(cmd))
        return 0

    if args.verbose:
        print(f"scout: {backend} / {model} in {directory}", file=sys.stderr)

    # Determine if we need to capture output (--output set)
    capture = args.output is not None

    # Direct API fast path for explore/safe when no backend override
    use_direct = mode in ("explore", "safe") and not args.backend
    if use_direct and not capture:
        full_prompt = prompt
        ctx = _read_dir_context(directory)
        if ctx:
            full_prompt = ctx + "\n\n" + prompt
        api_model = model.lower()
        if args.verbose:
            print(f"scout: trying direct API ({api_model})", file=sys.stderr)
        rc = _direct_api(full_prompt, api_model)
        if rc == 0:
            return 0

    # Execute via goose or droid
    env = {**os.environ, "GOOGLE_API_KEY": "", "GEMINI_API_KEY": ""}
    if backend == "goose":
        if capture:
            prev = os.getcwd()
            os.chdir(directory)
            try:
                rc, stdout_text = _run_captured(cmd, env=env)
            finally:
                os.chdir(prev)
            if rc == 0:
                _route_output(stdout_text, args.output)
            elif not args.backend:
                print("scout: goose failed, retrying with droid...",
                      file=sys.stderr)
                droid_cmd = _build_droid_cmd(model, directory, prompt, auto)
                rc2, stdout_text = _run_captured(droid_cmd)
                if rc2 == 0:
                    _route_output(stdout_text, args.output)
                return rc2
            return rc
        else:
            prev = os.getcwd()
            os.chdir(directory)
            try:
                rc = subprocess.run(cmd, env=env).returncode
            finally:
                os.chdir(prev)
            if rc != 0 and not args.backend:
                print("scout: goose failed, retrying with droid...",
                      file=sys.stderr)
                droid_cmd = _build_droid_cmd(model, directory, prompt, auto)
                rc = subprocess.run(droid_cmd, env=env).returncode
            return rc
    else:
        if capture:
            rc, stdout_text = _run_captured(cmd)
            if rc == 0:
                _route_output(stdout_text, args.output)
            return rc
        else:
            return subprocess.run(cmd, env=env).returncode


if __name__ == "__main__":
    raise SystemExit(main())

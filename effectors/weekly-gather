#!/usr/bin/env -S uv run --script --python 3.13
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""
weekly-gather — deterministic session-close gathering for the /weekly skill.

Gathers context from Calendar, Praxis.md, Tonus.md, Quarterly notes,
Daily notes, Oura/sopor, Job alerts, and Garden posts.
"""

import argparse
import concurrent.futures
import json
import re
import subprocess
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path

# Lazy import for gather library — keeps --help working even when
# ~/code/vivesca/lib/gather.py is absent.
_gather = None

def _load_gather():
    global _gather
    if _gather is not None:
        return _gather
    lib_dir = str(Path.home() / "code/vivesca/lib")
    if lib_dir not in sys.path:
        sys.path.insert(0, lib_dir)
    try:
        import gather as _mod
        _gather = _mod
    except ImportError:
        _gather = False
    return _gather

HOME = Path.home()
NOTES = HOME / "notes"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def run_cmd(cmd: list[str], timeout: int = 15) -> tuple[int, str, str]:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.returncode, r.stdout, r.stderr
    except Exception as e:
        return -1, "", str(e)

# ---------------------------------------------------------------------------
# Gatherers
# ---------------------------------------------------------------------------

def gather_calendar():
    today = datetime.now()
    # Next Monday
    days_ahead = 7 - today.weekday()
    if days_ahead == 0:
        days_ahead = 7
    next_mon = today + timedelta(days=days_ahead)

    lib = _load_gather()
    if not lib:
        return {"raw": {}, "summary": "Calendar unavailable (gather lib missing)", "total": 0}

    res = lib.get_calendar(next_mon.strftime("%Y-%m-%d"), 7)
    
    events_by_day = {}
    total_events = 0
    
    if res.get("available") and res.get("events"):
        for ev in res["events"]:
            # Count fixed commitments
            date_str = ev.get("date")
            if date_str:
                events_by_day[date_str] = events_by_day.get(date_str, 0) + 1
                total_events += 1

    # Format like (3 Mon, 2 Tue, ...)
    day_counts = []
    for offset in range(7):
        d = next_mon + timedelta(days=offset)
        d_str = d.strftime("%Y-%m-%d")
        count = events_by_day.get(d_str, 0)
        if count > 0:
            day_counts.append(f"{count} {d.strftime('%a')}")
            
    summary = f"{total_events} events next week"
    if day_counts:
        summary += f" ({', '.join(day_counts)})"
        
    return {"raw": res, "summary": summary, "total": total_events}

def gather_todo():
    lib = _load_gather()
    if not lib:
        return {
            "due_this_week": 0, "overdue": 0, "stale": 0,
            "completed": 0, "someday": 0,
            "summary": "Todo unavailable (gather lib missing)",
        }

    todo_ctx = lib.read_todo()
    
    today = datetime.now().date()
    days_ahead = 7 - today.weekday()
    if days_ahead == 0:
        days_ahead = 7
    next_mon = today + timedelta(days=days_ahead)
    next_sun = next_mon + timedelta(days=6)
    two_weeks_ago = today - timedelta(days=14)
    
    due_this_week = 0
    overdue = 0
    stale = 0
    completed = 0
    someday = 0
    
    if todo_ctx.get("available"):
        for item in todo_ctx.get("items", []):
            if item.get("done"):
                completed += 1
                continue
                
            due_str = item.get("due")
            when_str = item.get("when")
            
            # Someday
            if when_str and when_str.lower() == "someday":
                someday += 1
                continue
                
            is_due_this_week = False
            
            if due_str:
                try:
                    d = datetime.strptime(due_str, "%Y-%m-%d").date()
                    if next_mon <= d <= next_sun:
                        due_this_week += 1
                        is_due_this_week = True
                    elif d < today:
                        overdue += 1
                except Exception:
                    pass

            if not is_due_this_week and when_str:
                try:
                    w = datetime.strptime(when_str, "%Y-%m-%d").date()
                    if next_mon <= w <= next_sun:
                        due_this_week += 1
                except Exception:
                    pass

            # Stale
            if when_str:
                try:
                    w = datetime.strptime(when_str, "%Y-%m-%d").date()
                    if w <= two_weeks_ago:
                        stale += 1
                except Exception:
                    pass

    summary = f"{due_this_week} due this week, {overdue} overdue, {stale} stale (2+ weeks)"
    if completed > 0 or someday > 0:
        extras = []
        if completed > 0:
            extras.append(f"{completed} completed")
        if someday > 0:
            extras.append(f"{someday} someday")
        summary += f", {', '.join(extras)}"
        
    return {
        "due_this_week": due_this_week,
        "overdue": overdue,
        "stale": stale,
        "completed": completed,
        "someday": someday,
        "summary": summary
    }

def gather_now():
    lib = _load_gather()
    if not lib:
        return {"open_items": 0, "summary": "Now unavailable (gather lib missing)"}

    now_ctx = lib.read_now()
    open_items = len(now_ctx.get("progress", []))
    return {
        "open_items": open_items,
        "summary": f"{open_items} open items"
    }

def gather_quarterly():
    today = datetime.now()
    quarter = (today.month - 1) // 3 + 1
    year = today.year
    q_note = NOTES / "Quarterly" / f"{year}-Q{quarter}.md"
    
    found = q_note.exists()
    content = q_note.read_text(encoding="utf-8") if found else None
    
    return {
        "found": found,
        "quarter": f"Q{quarter} {year}",
        "summary": f"Q{quarter} {year} note found" if found else f"Q{quarter} {year} note NOT found",
        "content": content
    }

def gather_daily():
    today = datetime.now().date()
    daily_data = []
    notes_found = 0
    commute_closes = 0
    
    for i in range(6, -1, -1):
        d_date = today - timedelta(days=i)
        d_str = d_date.strftime("%Y-%m-%d")
        path = NOTES / "Daily" / f"{d_str}.md"
        
        cc_section = None
        headers = []
        
        if path.exists():
            notes_found += 1
            try:
                content = path.read_text(encoding="utf-8")
                in_cc = False
                cc_lines = []
                for line in content.splitlines():
                    if line.startswith("## Commute Close"):
                        in_cc = True
                        cc_lines.append(line)
                    elif in_cc:
                        if line.startswith("## "):
                            in_cc = False
                        else:
                            cc_lines.append(line)
                    elif line.startswith("### "):
                        if re.match(r"^###\s+\d{1,2}:\d{2}", line):
                            headers.append(line.strip())
                            
                if cc_lines:
                    cc_section = "\n".join(cc_lines)
                    commute_closes += 1
            except Exception:
                pass

        daily_data.append({
            "date": d_str,
            "commute_close": cc_section,
            "session_headers": headers
        })
        
    summary = f"{notes_found}/7 daily notes, {commute_closes} Commute Close sections"
    return {
        "notes_found": notes_found,
        "commute_closes": commute_closes,
        "daily_data": daily_data,
        "summary": summary
    }

def gather_oura():
    # Attempt sopor trend --days 7 first, fallback to sopor week
    code, out, _err = run_cmd(["sopor", "trend", "--days", "7"])
    if code != 0:
        code, out, _err = run_cmd(["sopor", "week"])

    sleep_avg = "N/A"
    hrv_avg = "N/A"
    readiness_avg = "N/A"

    if out:
        # Try to parse `sopor week` format
        m_readiness = re.search(r"Readiness\s*│\s*(\d+)", out)
        if m_readiness:
            readiness_avg = m_readiness.group(1)

        m_sleep = re.search(r"Sleep Duration\s*│\s*([\d\.]+[hm])", out)
        if m_sleep:
            sleep_avg = m_sleep.group(1)

        m_hrv = re.search(r"Avg HRV\s*│\s*([\d\.]+ms)", out)
        if m_hrv:
            hrv_avg = m_hrv.group(1)

        # Also fallback for generic `sopor trend` output if it matched differently
        if sleep_avg == "N/A":
            m2_sleep = re.search(r"(?i)sleep[^0-9]*([\d\.]+[hm])", out)
            if m2_sleep:
                sleep_avg = m2_sleep.group(1)

    summary = f"Sleep avg {sleep_avg}, HRV avg {hrv_avg}, Readiness avg {readiness_avg}"
    return {
        "sleep_avg": sleep_avg,
        "hrv_avg": hrv_avg,
        "readiness_avg": readiness_avg,
        "raw": out,
        "summary": summary
    }

def gather_job_alerts():
    today = datetime.now().date()
    unchecked = 0
    
    for i in range(6, -1, -1):
        d_date = today - timedelta(days=i)
        d_str = d_date.strftime("%Y-%m-%d")
        path = NOTES / "Job Hunting" / f"Job Alerts {d_str}.md"
        
        if path.exists():
            try:
                content = path.read_text(encoding="utf-8")
                for line in content.splitlines():
                    if line.strip().startswith("- [ ]"):
                        unchecked += 1
            except Exception:
                pass

    return {
        "unchecked": unchecked,
        "summary": f"{unchecked} unchecked this week"
    }

def gather_garden():
    garden_dir = NOTES / "Writing" / "Blog" / "Published"
    seven_days_ago = time.time() - 7 * 86400

    posts = []
    if garden_dir.exists():
        try:
            for f in garden_dir.iterdir():
                if f.is_file() and f.suffix == ".md":
                    mtime = f.stat().st_mtime
                    if mtime >= seven_days_ago:
                        posts.append(f.stem)
        except Exception:
            pass
            
    summary = f"{len(posts)} posts published this week"
    return {
        "count": len(posts),
        "posts": posts,
        "summary": summary
    }

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def run_all():
    dispatch = {
        "calendar": gather_calendar,
        "todo": gather_todo,
        "now": gather_now,
        "quarterly": gather_quarterly,
        "daily": gather_daily,
        "oura": gather_oura,
        "job_alerts": gather_job_alerts,
        "garden": gather_garden,
    }
    
    results = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(dispatch)) as pool:
        futures = {pool.submit(fn): key for key, fn in dispatch.items()}
        for future in concurrent.futures.as_completed(futures):
            key = futures[future]
            try:
                results[key] = future.result()
            except Exception as e:
                results[key] = {"error": str(e), "summary": f"Error: {e}"}
                
    return results

def render_text(results):
    lines = [
        "─── Weekly Context ──────────────────────────────",
        f"  Calendar:    {results['calendar']['summary']}",
        f"  Praxis:     {results['todo']['summary']}",
        f"  Tonus:       {results['now']['summary']}",
        f"  Quarterly:   {results['quarterly']['summary']}",
        f"  Last week:   {results['daily']['summary']}",
        f"  Health:      {results['oura']['summary']}",
        f"  Job alerts:  {results['job_alerts']['summary']}",
        f"  Garden:      {results['garden']['summary']}",
        "──────────────────────────────────────────────────",
    ]
    return "\n".join(lines)

def main():
    parser = argparse.ArgumentParser(description="Gather context for /weekly skill.")
    parser.add_argument("--json", action="store_true", help="Output structured JSON.")
    args = parser.parse_args()
    
    results = run_all()
    
    if args.json:
        print(json.dumps(results, indent=2, ensure_ascii=False))
    else:
        print(render_text(results))

if __name__ == "__main__":
    main()

}

_UUID_RE = re.compile(r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$", re.IGNORECASE)

def _client(timeout=TIMEOUT) -> httpx.Client:
    api_key = os.getenv("LACUNA_API_KEY", "")
    headers = {"X-API-Key": api_key} if api_key else {}
    return httpx.Client(timeout=timeout, headers=headers)

def s(text) -> str:
    """Escape Rich markup in any API-sourced string."""
    return escape(str(text)) if text else ""

def resolve(name: str) -> str:
    name = name.strip()
    return ALIASES.get(name, name)

def validate_doc_id(name: str, label: str) -> str:
    """Resolve alias and validate the result looks like a UUID."""
    resolved = resolve(name)
    if not _UUID_RE.match(resolved):
        console.print(Panel(
            f"[bold red]Unknown {label}:[/bold red] [yellow]{s(name)}[/yellow]\n\n"
            f"Available aliases: {', '.join(sorted(ALIASES.keys()))}",
            border_style="red"
        ))
        raise typer.Exit(code=1)
    return resolved

def handle_request_error(e: Exception):
    if isinstance(e, httpx.TimeoutException):
        msg = "Request timed out. Gap analysis can take 30s+ on cold cache. Try: lacuna warmup"
    elif isinstance(e, httpx.HTTPStatusError):
        msg = f"Backend error: HTTP {e.response.status_code}"
    elif isinstance(e, httpx.RequestError):
        msg = "Connection failed. Check your network and try again."
    else:
        msg = "Unexpected error. Check that the Lacuna service is running."
    console.print(Panel(f"[bold red]{msg}[/bold red]", border_style="red"))
    raise typer.Exit(code=1)


@app.command()

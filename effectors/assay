#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["httpx"]
# ///
"""assay — life experiment tracker. Named after Greek πεῖρα (trial, experiment).

Deterministic CLI for N=1 self-experiments with Oura Ring as the primary sensor.
Creates vault notes, pulls baseline/check-in data, computes deltas at close.

Usage:
    assay new "caffeine cut" --hypothesis "..." --days 14
    assay check [name]
    assay close [name]
    assay list
"""

from __future__ import annotations

import argparse
import re
import sys
from datetime import date, timedelta
from pathlib import Path
from typing import Any

# Lazy imports — these require metabolon on sys.path which may not be
# available at --help time.  Import them only when a command needs them.
_fetch = None
_get_token = None
MEAL_PLAN = None


def _ensure_metabolon_imports() -> None:
    global _fetch, _get_token, MEAL_PLAN
    if _fetch is not None:
        return
    sys.path.insert(0, str(Path.home() / "germline" / "metabolon"))
    from organelles.chemoreceptor import _fetch as fetch_fn
    from organelles.chemoreceptor import _get_token as token_fn

    from metabolon.locus import meal_plan

    _fetch = fetch_fn
    _get_token = token_fn
    if MEAL_PLAN is None:
        MEAL_PLAN = meal_plan


VAULT = Path.home() / "epigenome" / "chromatin"
EXPERIMENT_DIR = VAULT / "experiments"


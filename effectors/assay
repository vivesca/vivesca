    "during",
    "each",
    "when",
    "than",
    "then",
    "also",
}

_DOMAIN_SYNONYMS: dict[str, list[str]] = {
    "caffeine": ["coffee", "cappuccino", "espresso", "latte", "matcha", "cola", "energy drink"],
    "alcohol": ["beer", "wine", "whiskey", "spirits", "cocktail", "drinking"],
    "sleep": ["bedtime", "wake", "nap", "insomnia", "sopor"],
    "exercise": ["workout", "training", "gym", "cardio", "lifting", "cycling"],
    "meditation": ["mindfulness", "breathwork", "yoga", "contemplation"],
    "fasting": ["intermittent", "omad", "eating window", "hunger"],
    "protein": ["whey", "casein", "leucine", "chicken", "beef", "eggs"],
    "carbs": ["glucose", "rice", "bread", "pasta", "sugar", "glycogen"],
    "fat": ["keto", "lipid", "omega", "butter", "oil"],
    "cold": ["ice bath", "cold shower", "cryotherapy", "plunge"],
    "heat": ["sauna", "steam", "hot bath", "infrared"],
    "stress": ["cortisol", "anxiety", "workload", "deadline", "tension"],
    "reading": ["books", "kindle", "articles", "screen"],
    "sunlight": ["light therapy", "morning light", "vitamin d", "outdoor"],
    "supplements": ["vitamins", "minerals", "nootropics", "capsules"],
    "magnesium": ["glycinate", "citrate", "threonate", "malate"],
    "creatine": ["monohydrate", "phosphocreatine", "pcr"],
}


def _extract_keywords(name: str, hypothesis: str) -> list[str]:
    """Extract meaningful keywords from experiment name and hypothesis, with synonym expansion."""
    combined = f"{name} {hypothesis}".lower()
    # Tokenise on non-alphanumeric boundaries
    tokens = re.findall(r"[a-z][a-z0-9]*", combined)
    base_keywords: list[str] = []
    for tok in tokens:
        if len(tok) >= 4 and tok not in _STOP_WORDS and tok not in base_keywords:
            base_keywords.append(tok)

    # Synonym expansion
    extras: list[str] = []
    for key, synonyms in _DOMAIN_SYNONYMS.items():
        if key in combined:
            for syn in synonyms:
                if syn not in base_keywords and syn not in extras:
                    extras.append(syn)

    return base_keywords + extras


# ---------------------------------------------------------------------------
# Oura helpers
# ---------------------------------------------------------------------------


def pull_oura(start: str, end: str) -> dict[str, dict[str, Any]]:
    """Pull sleep + readiness data for a date range. Returns {date: {sleep_score, readiness_score, ...}}."""
    _ensure_metabolon_imports()
    token = _get_token()
    sleep = _fetch("daily_sleep", start, end, token)
    readiness = _fetch("daily_readiness", start, end, token)

    by_date: dict[str, dict[str, Any]] = {}
    for s in sleep:
        d = s.get("day", "")
        by_date.setdefault(d, {})["sleep_score"] = s.get("score")
        by_date[d]["sleep_contributors"] = s.get("contributors", {})
    for r in readiness:
        d = r.get("day", "")
        by_date.setdefault(d, {})["readiness_score"] = r.get("score")
        by_date[d]["readiness_contributors"] = r.get("contributors", {})
    return dict(sorted(by_date.items()))


def summarise_period(data: dict[str, dict]) -> dict[str, Any]:
    """Compute averages from a period of Oura data."""
    sleep_scores = [v["sleep_score"] for v in data.values() if v.get("sleep_score")]
    readiness_scores = [v["readiness_score"] for v in data.values() if v.get("readiness_score")]

    hrv_vals = []
    for v in data.values():
        hrv = (v.get("readiness_contributors") or {}).get("hrv_balance")
        if hrv is not None:
            hrv_vals.append(hrv)

    return {
        "days": len(data),
        "sleep_avg": round(sum(sleep_scores) / len(sleep_scores), 1) if sleep_scores else None,
        "sleep_range": f"{min(sleep_scores)}-{max(sleep_scores)}" if sleep_scores else None,
        "readiness_avg": round(sum(readiness_scores) / len(readiness_scores), 1)
        if readiness_scores
        else None,
        "readiness_range": f"{min(readiness_scores)}-{max(readiness_scores)}"
        if readiness_scores
        else None,
        "hrv_balance_avg": round(sum(hrv_vals) / len(hrv_vals), 1) if hrv_vals else None,
        "hrv_balance_range": f"{min(hrv_vals)}-{max(hrv_vals)}" if hrv_vals else None,
    }


# ---------------------------------------------------------------------------
# Meal plan helpers
# ---------------------------------------------------------------------------


def pull_intake(start: str, keywords: list[str]) -> list[str]:
    """Return Order log entries from meal plan since start_date matching any keyword."""
    _ensure_metabolon_imports()
    if not MEAL_PLAN.exists():
        return []

    text = MEAL_PLAN.read_text()
    log_marker = "## Order log"
    if log_marker not in text:
        return []

    log_start = text.index(log_marker) + len(log_marker)
    next_section = text.find("\n## ", log_start)
    log_section = text[log_start:next_section] if next_section != -1 else text[log_start:]

    start_date = date.fromisoformat(start)
    kws = [k.lower() for k in keywords]
    matches: list[str] = []

    for line in log_section.splitlines():
        line = line.strip()
        if not line.startswith("- "):
            continue
        # Extract date from entries like: - YYYY-MM-DD (Day): ...
        m = re.match(r"- (\d{4}-\d{2}-\d{2})", line)
        if not m:
            continue
        try:
            entry_date = date.fromisoformat(m.group(1))
        except ValueError:
            continue
        if entry_date < start_date:
            continue
        line_lower = line.lower()
        if any(kw in line_lower for kw in kws):
            matches.append(line[2:])  # strip leading "- "

    return matches


# ---------------------------------------------------------------------------
# Vault note helpers
# ---------------------------------------------------------------------------


def slugify(name: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")


def find_experiment(name: str | None) -> Path | None:
    """Find an active experiment by name (fuzzy) or return the only active one."""
    active = list(EXPERIMENT_DIR.glob("assay-*.md"))
    if not active:
        return None
    if name:
        slug = slugify(name)
        for p in active:
            if slug in p.stem:
                return p
        return None
    # If only one active, return it
    results = [p for p in active if _is_active(p)]
    if len(results) == 1:
        return results[0]
    return None


def _is_active(path: Path) -> bool:
    text = path.read_text()
    return "status: active" in text


def list_experiments() -> list[Path]:
    return sorted(EXPERIMENT_DIR.glob("assay-*.md"))


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_new(args: argparse.Namespace) -> None:
    name = args.name
    slug = slugify(name)
    days = args.days
    start = date.today()
    end = start + timedelta(days=days)

    # Pull baseline: same duration before start
    baseline_start = start - timedelta(days=days)
    baseline_end = start - timedelta(days=1)

    print(f"Pulling {days}-day baseline from Oura ({baseline_start} to {baseline_end})...")
    baseline_data = pull_oura(str(baseline_start), str(baseline_end))
    baseline_summary = summarise_period(baseline_data)

    filename = f"assay-{start}-{slug}.md"
    path = EXPERIMENT_DIR / filename

    hypothesis = args.hypothesis or "TBD"

    watch_keywords = _extract_keywords(name, hypothesis)
    watch_keywords_yaml = "[" + ", ".join(watch_keywords) + "]"

    content = f"""---
type: experiment
status: active
start_date: {start}
end_date: {end}
name: "{name}"
hypothesis: "{hypothesis}"
baseline_days: {days}
watch_keywords: {watch_keywords_yaml}
---

# {name}

## Hypothesis
{hypothesis}

## Protocol
- **Duration:** {days} days ({start} to {end})
- **Intervention:** {args.intervention or "TBD"}
- **Metrics:** Oura sleep score, readiness score, HRV balance

## Baseline ({baseline_start} to {baseline_end})
- Sleep: avg {baseline_summary["sleep_avg"]}, range {baseline_summary["sleep_range"]}
- Readiness: avg {baseline_summary["readiness_avg"]}, range {baseline_summary["readiness_range"]}
- HRV balance: avg {baseline_summary["hrv_balance_avg"]}, range {baseline_summary["hrv_balance_range"]}
- Days with data: {baseline_summary["days"]}

## Check-ins
"""

    path.write_text(content)
    print(f"Created: {path}")
    print(
        f"Baseline: sleep {baseline_summary['sleep_avg']}, readiness {baseline_summary['readiness_avg']}, HRV balance {baseline_summary['hrv_balance_avg']}"
    )
    print(f"Experiment runs {start} to {end} ({days} days)")
    print(f"Watch keywords: {', '.join(watch_keywords)}")


def cmd_check(args: argparse.Namespace) -> None:
    path = find_experiment(args.name)
    if not path:
        print("No active experiment found.", file=sys.stderr)
        sys.exit(1)

    text = path.read_text()

    # Parse start date from frontmatter
    m = re.search(r"start_date:\s*(\d{4}-\d{2}-\d{2})", text)
    if not m:
        print("Cannot parse start_date", file=sys.stderr)
        sys.exit(1)
    start = m.group(1)
    today = str(date.today())
    day_num = (date.today() - date.fromisoformat(start)).days + 1

    print(f"Day {day_num} — pulling Oura data ({start} to {today})...")
    data = pull_oura(start, today)
    summary = summarise_period(data)

    # Parse baseline for comparison
    baseline_sleep = _extract_float(text, r"Sleep: avg ([\d.]+)")
    baseline_readiness = _extract_float(text, r"Readiness: avg ([\d.]+)")
    baseline_hrv = _extract_float(text, r"HRV balance: avg ([\d.]+)")

    # Parse watch_keywords from frontmatter
    kw_match = re.search(r"watch_keywords:\s*\[(.+?)\]", text)
    watch_keywords: list[str] = []
    if kw_match:
        watch_keywords = [k.strip() for k in kw_match.group(1).split(",")]

    # Pull matching intake entries from meal plan
    intake_entries = pull_intake(start, watch_keywords) if watch_keywords else []

    # Format check-in entry
    entry = f"\n### Day {day_num} — {today}\n"
    entry += f"- Sleep: avg {summary['sleep_avg']} (baseline {baseline_sleep})"
    if summary["sleep_avg"] and baseline_sleep:
        delta = round(summary["sleep_avg"] - baseline_sleep, 1)
        entry += f" [{'+' if delta > 0 else ''}{delta}]"
    entry += "\n"
    entry += f"- Readiness: avg {summary['readiness_avg']} (baseline {baseline_readiness})"
    if summary["readiness_avg"] and baseline_readiness:
        delta = round(summary["readiness_avg"] - baseline_readiness, 1)
        entry += f" [{'+' if delta > 0 else ''}{delta}]"
    entry += "\n"
    entry += f"- HRV balance: avg {summary['hrv_balance_avg']} (baseline {baseline_hrv})"
    if summary["hrv_balance_avg"] and baseline_hrv:
        delta = round(summary["hrv_balance_avg"] - baseline_hrv, 1)
        entry += f" [{'+' if delta > 0 else ''}{delta}]"
    entry += "\n"
    if intake_entries:
        entry += f"- Intake: {'; '.join(intake_entries)}\n"

    # Append to file
    with open(path, "a") as f:
        f.write(entry)

    print(entry)
    print(f"Appended to {path.name}")


def cmd_close(args: argparse.Namespace) -> None:
    path = find_experiment(args.name)
    if not path:
        print("No active experiment found.", file=sys.stderr)
        sys.exit(1)

    text = path.read_text()

    m_start = re.search(r"start_date:\s*(\d{4}-\d{2}-\d{2})", text)
    re.search(r"end_date:\s*(\d{4}-\d{2}-\d{2})", text)
    if not m_start:
        print("Cannot parse dates", file=sys.stderr)
        sys.exit(1)

    start = m_start.group(1)
    today = str(date.today())

    print(f"Pulling final data ({start} to {today})...")
    data = pull_oura(start, today)
    final = summarise_period(data)

    baseline_sleep = _extract_float(text, r"Sleep: avg ([\d.]+)")
    baseline_readiness = _extract_float(text, r"Readiness: avg ([\d.]+)")
    baseline_hrv = _extract_float(text, r"HRV balance: avg ([\d.]+)")

    # Collect cross-linked events from experiment file
    cross_linked: list[str] = []
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("> **Intake logged:**") or stripped.startswith(
            "> **Symptom logged:**"
        ):
            cross_linked.append(stripped)

    cross_linked_section = ""
    if cross_linked:
        cross_linked_section = "\n## Cross-linked Events\n"
        for event in cross_linked:
            cross_linked_section += f"{event}\n"

    verdict = "\n## Results\n"
    verdict += f"- Sleep: {baseline_sleep} -> {final['sleep_avg']}"
    if final["sleep_avg"] and baseline_sleep:
        delta = round(final["sleep_avg"] - baseline_sleep, 1)
        verdict += f" ({'+' if delta > 0 else ''}{delta})"
    verdict += "\n"
    verdict += f"- Readiness: {baseline_readiness} -> {final['readiness_avg']}"
    if final["readiness_avg"] and baseline_readiness:
        delta = round(final["readiness_avg"] - baseline_readiness, 1)
        verdict += f" ({'+' if delta > 0 else ''}{delta})"
    verdict += "\n"
    verdict += f"- HRV balance: {baseline_hrv} -> {final['hrv_balance_avg']}"
    if final["hrv_balance_avg"] and baseline_hrv:
        delta = round(final["hrv_balance_avg"] - baseline_hrv, 1)
        verdict += f" ({'+' if delta > 0 else ''}{delta})"
    verdict += "\n"
    verdict += f"- Days with data: {final['days']}\n"
    verdict += "\n## Verdict\n_TBD — interpret with symbiont_\n"

    # Append cross-linked events (if any), results, and flip status
    with open(path, "a") as f:
        if cross_linked_section:
            f.write(cross_linked_section)
        f.write(verdict)

    text = path.read_text()
    text = text.replace("status: active", "status: closed")
    path.write_text(text)

    print(verdict)
    print(f"Experiment closed: {path.name}")


def cmd_list(_args: argparse.Namespace) -> None:
    experiments = list_experiments()
    if not experiments:
        print("No experiments found.")
        return
    for p in experiments:
        status = "active" if _is_active(p) else "closed"
        m = re.search(r'name:\s*"(.+?)"', p.read_text())
        name = m.group(1) if m else p.stem
        print(f"  [{status}] {name} — {p.name}")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def _extract_float(text: str, pattern: str) -> float | None:
    m = re.search(pattern, text)
    if m:
        try:
            return float(m.group(1))
        except ValueError:
            pass
    return None


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def main() -> None:
    # Agent-facing: bare invocation returns JSON command tree
    if len(sys.argv) == 1:
        import json
        print(json.dumps({
            "ok": True,
            "command": "assay",
            "result": {
                "description": "Life experiment tracker with Oura Ring integration",
                "commands": {
                    "new": "Start a new N=1 experiment with baseline pull",
                    "check": "Pull latest Oura data and append check-in",
                    "close": "Close experiment with final comparison",
                    "list": "List all experiments with status",
                },
            },
            "next_actions": [
                {"command": "assay new 'caffeine cut' --hypothesis 'better sleep' --days 14", "description": "Start a new experiment"},
                {"command": "assay list", "description": "List all experiments"},
                {"command": "assay check", "description": "Check in on the active experiment"},
            ],
            "version": "0.1.0",
        }))
        sys.exit(0)

    parser = argparse.ArgumentParser(description="assay — life experiment tracker")
    sub = parser.add_subparsers(dest="command")

    p_new = sub.add_parser("new", help="Start a new experiment")
    p_new.add_argument("name", help="Experiment name")
    p_new.add_argument("--hypothesis", "-H", help="What you expect to happen")
    p_new.add_argument("--intervention", "-I", help="What you're changing")
    p_new.add_argument("--days", "-d", type=int, default=14, help="Duration in days (default: 14)")

    p_check = sub.add_parser("check", help="Pull latest data and append check-in")
    p_check.add_argument("name", nargs="?", help="Experiment name (optional if only one active)")

    p_close = sub.add_parser("close", help="Close experiment with final comparison")
    p_close.add_argument("name", nargs="?", help="Experiment name (optional if only one active)")

    sub.add_parser("list", help="List all experiments")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    {"new": cmd_new, "check": cmd_check, "close": cmd_close, "list": cmd_list}[args.command](args)


if __name__ == "__main__":
    main()

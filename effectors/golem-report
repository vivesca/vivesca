#!/usr/bin/env python3
"""golem-report — Generate task completion reports from golem.jsonl and golem-queue.md.

Usage:
    golem-report                  # Report for today
    golem-report --date 2026-04-01  # Report for specific date
    golem-report --help
"""
from __future__ import annotations

import json
import re
import sys
from datetime import datetime
from pathlib import Path
from collections import defaultdict

JSONL_FILE = Path.home() / ".local" / "share" / "vivesca" / "golem.jsonl"
QUEUE_FILE = Path.home() / "germline" / "loci" / "golem-queue.md"


def parse_jsonl(date_filter: str | None = None) -> list[dict]:
    """Parse golem.jsonl, optionally filtering by date (YYYY-MM-DD)."""
    records = []
    if not JSONL_FILE.exists():
        return records
    
    try:
        for line in JSONL_FILE.read_text(errors="replace").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
                # Filter by date if specified
                if date_filter:
                    ts = rec.get("ts", "")
                    # Handle both "2026-04-01T20:04:45Z" and "2026-04-01 12:34:56" formats
                    ts_date = ts[:10] if ts else ""
                    if ts_date != date_filter:
                        continue
                records.append(rec)
            except (json.JSONDecodeError, ValueError):
                pass
    except (PermissionError, OSError):
        pass
    
    return records


def parse_queue_retries() -> dict[str, int]:
    """Parse golem-queue.md for retry counts per task_id."""
    retries: dict[str, int] = {}
    if not QUEUE_FILE.exists():
        return retries
    
    try:
        for line in QUEUE_FILE.read_text().splitlines():
            # Match retry markers: [retry:N] or just (retry)
            m = re.search(r'\[t-([0-9a-fA-F]+)\]', line)
            if not m:
                continue
            task_id = f"t-{m.group(1)}"
            
            # Check for [retry:N] pattern
            retry_match = re.search(r'\[retry:(\d+)\]', line)
            if retry_match:
                retries[task_id] = max(retries.get(task_id, 0), int(retry_match.group(1)))
            elif '(retry)' in line:
                retries[task_id] = max(retries.get(task_id, 0), 1)
    except (PermissionError, OSError):
        pass
    
    return retries


def is_rate_limited(rec: dict) -> bool:
    """Determine if a task failure was due to rate-limiting."""
    if rec.get("exit") == 0:
        return False
    
    duration = rec.get("duration", 999)
    tail = rec.get("tail", "").lower()
    exit_code = rec.get("exit", 0)
    
    # Fast exit with empty output
    if duration <= 10 and exit_code in (1, 2):
        return True
    # Killed (OOM/cleanup)
    if exit_code == 137:
        return True
    # Empty output
    if not rec.get("tail", "").strip():
        return True
    # Rate-limit patterns in output
    patterns = ["429", "accountquota", "rate.limit", "quota.exceeded", "usage.limit"]
    for p in patterns:
        if p in tail:
            return True
    
    return False


def format_duration(seconds: int) -> str:
    """Format seconds as human-readable duration."""
    if seconds < 60:
        return f"{seconds}s"
    mins = seconds // 60
    secs = seconds % 60
    return f"{mins}m{secs}s"


def generate_report(date: str | None = None) -> str:
    """Generate markdown report for the specified date."""
    target_date = date or datetime.now().strftime("%Y-%m-%d")
    records = parse_jsonl(target_date)
    queue_retries = parse_queue_retries()
    
    if not records:
        return f"# Golem Report — {target_date}\n\nNo tasks found for this date.\n"
    
    # Calculate stats
    total = len(records)
    passed = sum(1 for r in records if r.get("exit") == 0)
    failed = total - passed
    success_rate = (passed / total * 100) if total > 0 else 0
    
    # Total duration
    total_duration = sum(r.get("duration", 0) for r in records)
    avg_duration = total_duration / total if total > 0 else 0
    
    # Rate-limit events
    rate_limited = sum(1 for r in records if is_rate_limited(r))
    
    # Per-provider stats
    provider_stats: dict[str, dict] = defaultdict(lambda: {
        "count": 0, "passed": 0, "failed": 0, "rate_limited": 0, "total_duration": 0
    })
    
    for r in records:
        p = r.get("provider", "unknown")
        provider_stats[p]["count"] += 1
        provider_stats[p]["total_duration"] += r.get("duration", 0)
        if r.get("exit") == 0:
            provider_stats[p]["passed"] += 1
        else:
            provider_stats[p]["failed"] += 1
            if is_rate_limited(r):
                provider_stats[p]["rate_limited"] += 1
    
    # Top 3 longest tasks
    sorted_by_duration = sorted(records, key=lambda r: r.get("duration", 0), reverse=True)[:3]
    
    # Top 3 most-retried tasks (from queue + jsonl cross-reference)
    task_retries: dict[str, int] = {}
    for r in records:
        tid = r.get("task_id", "")
        if tid and tid in queue_retries:
            task_retries[tid] = queue_retries[tid]
    top_retried = sorted(task_retries.items(), key=lambda x: x[1], reverse=True)[:3]
    
    # Build report
    lines = [
        f"# Golem Report — {target_date}",
        "",
        "## Summary",
        "",
        f"| Metric | Value |",
        f"|--------|-------|",
        f"| Tasks completed | {total} |",
        f"| Success rate | {success_rate:.1f}% ({passed}/{total}) |",
        f"| Avg duration | {format_duration(int(avg_duration))} |",
        f"| Rate-limit events | {rate_limited} |",
        "",
        "## By Provider",
        "",
        "| Provider | Tasks | Passed | Failed | Rate-limited | Avg duration |",
        "|----------|-------|--------|--------|--------------|--------------|",
    ]
    
    for provider in sorted(provider_stats.keys()):
        s = provider_stats[provider]
        avg_dur = s["total_duration"] / s["count"] if s["count"] > 0 else 0
        lines.append(
            f"| {provider} | {s['count']} | {s['passed']} | {s['failed']} | "
            f"{s['rate_limited']} | {format_duration(int(avg_dur))} |"
        )
    
    lines.extend([
        "",
        "## Top 3 Longest Tasks",
        "",
    ])
    
    if sorted_by_duration:
        lines.append("| Task ID | Provider | Duration | Exit |")
        lines.append("|---------|----------|----------|------|")
        for r in sorted_by_duration:
            tid = r.get("task_id", "n/a")
            dur = r.get("duration", 0)
            prov = r.get("provider", "?")
            exit_code = r.get("exit", "?")
            lines.append(f"| {tid} | {prov} | {format_duration(dur)} | {exit_code} |")
    else:
        lines.append("_No tasks found._")
    
    lines.extend([
        "",
        "## Top 3 Most-Retried Tasks",
        "",
    ])
    
    if top_retried:
        lines.append("| Task ID | Retries |")
        lines.append("|---------|--------|")
        for tid, count in top_retried:
            lines.append(f"| {tid} | {count} |")
    else:
        lines.append("_No retried tasks found._")
    
    lines.append("")
    
    return "\n".join(lines)


def main() -> int:
    args = sys.argv[1:]
    
    if "-h" in args or "--help" in args:
        print(__doc__)
        return 0
    
    date = None
    if "--date" in args:
        idx = args.index("--date")
        if idx + 1 < len(args):
            date = args[idx + 1]
            # Validate date format
            if not re.match(r'^\d{4}-\d{2}-\d{2}$', date):
                print(f"Error: Invalid date format '{date}'. Use YYYY-MM-DD.", file=sys.stderr)
                return 1
    
    report = generate_report(date)
    print(report)
    return 0


if __name__ == "__main__":
    sys.exit(main())

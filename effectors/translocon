class _ProgressTicker:
    """Print a dot to stderr every N seconds while a subprocess runs."""

    def __init__(self, interval: float = 10.0) -> None:
        self._interval = interval
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None

    def start(self) -> None:
        self._stop.clear()
        self._thread = threading.Thread(target=self._tick, daemon=True)
        self._thread.start()

    def stop(self) -> None:
        self._stop.set()
        if self._thread is not None:
            self._thread.join(timeout=self._interval + 1)
            self._thread = None

    def _tick(self) -> None:
        while not self._stop.wait(timeout=self._interval):
            print(".", end="", flush=True, file=sys.stderr)


def _load_routes() -> dict:
    """Load routing config. Falls back to hardcoded defaults if no file."""
    if ROUTES_PATH.exists():
        import yaml
        return yaml.safe_load(ROUTES_PATH.read_text())
    return dict(_DEFAULT_ROUTES)

def _is_healthy(backend: str) -> bool:
    """Check if backend is healthy (not in cooldown)."""
    if not HEALTH_PATH.exists():
        return True
    state = json.loads(HEALTH_PATH.read_text())
    entry = state.get(backend, {})
    cooldown = entry.get("cooldown_until")
    if cooldown and datetime.fromisoformat(cooldown) > datetime.now():
        return False
    return True

def _record_result(backend: str, success: bool) -> None:
    """Update health state after a backend call."""
    HEALTH_PATH.parent.mkdir(parents=True, exist_ok=True)
    state: dict = {}
    if HEALTH_PATH.exists():
        state = json.loads(HEALTH_PATH.read_text())
    entry = state.setdefault(backend, {"consecutive_failures": 0, "cooldown_until": None})
    if success:
        entry["consecutive_failures"] = 0
        entry["cooldown_until"] = None
    else:
        entry["consecutive_failures"] = entry.get("consecutive_failures", 0) + 1
        if entry["consecutive_failures"] >= MAX_FAILURES:
            entry["cooldown_until"] = (datetime.now() + timedelta(seconds=COOLDOWN)).isoformat()
    HEALTH_PATH.write_text(json.dumps(state, indent=2))

def _record_rate_limit(backend: str) -> None:
    """Record a rate limit hit — shorter cooldown than general failures."""
    HEALTH_PATH.parent.mkdir(parents=True, exist_ok=True)
    state: dict = {}
    if HEALTH_PATH.exists():
        state = json.loads(HEALTH_PATH.read_text())
    entry = state.setdefault(backend, {"consecutive_failures": 0, "cooldown_until": None})
    # Rate limits get a 60-second cooldown (much shorter than the 5-min general cooldown)
    entry["cooldown_until"] = (datetime.now() + timedelta(seconds=60)).isoformat()
    entry["last_rate_limit"] = datetime.now().isoformat()
    HEALTH_PATH.write_text(json.dumps(state, indent=2))

def _log_call(entry: dict) -> None:
    """Append a call record to the per-call log."""
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    entry.setdefault("timestamp", datetime.now().isoformat(timespec="seconds"))
    with open(LOG_PATH, "a") as f:
        f.write(json.dumps(entry) + "\n")

def _direct_api(prompt: str, model: str = "glm-4.7") -> int:
    import urllib.request
    key = os.environ.get("ZHIPU_API_KEY", "")
    if not key:
        print("translocon: ZHIPU_API_KEY not set", file=sys.stderr)
        return 1
    body = json.dumps({"model": model, "max_tokens": 8192,
                       "messages": [{"role": "user", "content": prompt}]}).encode()
    req = urllib.request.Request("https://open.bigmodel.cn/api/anthropic/v1/messages", body)
    req.add_header("x-api-key", key)
    req.add_header("anthropic-version", "2023-06-01")
    req.add_header("content-type", "application/json")
    try:
        data = json.loads(urllib.request.urlopen(req, timeout=120).read())
        print(data["content"][0]["text"])
        return 0
    except Exception as e:
        print(f"translocon: direct API failed: {e}", file=sys.stderr)
        return 1


_TOTAL_SIZE_CAP = 100_000  # 100 KB cumulative cap to protect token budgets

def _read_dir_context(directory: str, glob_pattern: str = "*.py") -> str:
    parts: list[str] = []
    cumulative = 0
    skipped = 0
    for f in sorted(Path(directory).glob(glob_pattern)):
        if not f.is_file() or f.stat().st_size >= 50000:
            continue
        content = f.read_text()
        cumulative += len(content)
        if cumulative > _TOTAL_SIZE_CAP:
            skipped += 1
            continue
        parts.append(f"### {f.name}\n```\n{content}\n```")
    if skipped:
        print(f"translocon: skipped {skipped} file(s) after reaching {_TOTAL_SIZE_CAP} byte cap", file=sys.stderr)
    return "\n\n".join(parts)


COACHING_NOTES = Path.home() / "epigenome/marks/feedback_glm_coaching.md"


def _inject_coaching(prompt: str) -> str:
    if COACHING_NOTES.exists():
        notes = COACHING_NOTES.read_text().strip()
        if notes.startswith("---"):
            end = notes.find("---", 3)
            if end > 0:
                notes = notes[end + 3:].strip()
        return f"{notes}\n\n---\n\nTask:\n{prompt}"
    return prompt


def _build_golem_cmd(model: str, directory: str, prompt: str,
                     auto: str | None = None) -> list[str]:
    """Build golem CLI command (replaces goose/droid)."""
    cmd = ["golem"]
    # Map model to provider if it matches a known one
    if "volcano" in model.lower():
        cmd += ["--provider", "volcano"]
    elif "infini" in model.lower():
        cmd += ["--provider", "infini"]
    
    if auto == "high":
        cmd.append("--force")
    
    # Golem takes prompt as last argument
    cmd.append(prompt)
    return cmd


def _resolve_mode(args: argparse.Namespace) -> tuple[list[str], str, str, str | None, str]:
    """Return (chain, model, directory, auto, mode) from flags + route config."""
    if args.build:
        mode = "build"
    elif args.mcp:
        mode = "mcp"
    elif args.safe:
        mode = "safe"
    elif args.skill:
        mode = "skill"
    else:
        mode = "explore"

    routes = _load_routes()
    route = routes.get(mode, routes.get("explore", _DEFAULT_ROUTES["explore"]))
    # Replace missing backends with golem in the chain
    chain: list[str] = ["golem"]
    model: str = route.get("model", "GLM-5.1")
    auto: str | None = route.get("auto")

    # User overrides
    if args.backend:
        chain = ["golem"]
    if args.model:
        model = args.model
    directory = args.dir or os.path.expanduser("~")
    return chain, model, directory, auto, mode


def _parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Unified dispatch CLI for LLM tasks (translocon).")
    parser.add_argument("dir", nargs="?", default=".", help="Working directory")
    parser.add_argument("prompt", nargs="*", default=[], help="Task prompt")
    parser.add_argument("--build", action="store_true", help="Implementation mode")
    parser.add_argument("--mcp", action="store_true", help="MCP task mode")
    parser.add_argument("--safe", action="store_true", help="Read-only audit mode")
    parser.add_argument("--model", help="Override model")
    parser.add_argument("--backend", choices=["goose", "droid"], help="Force backend")
    parser.add_argument("-f", "--file", help="Read prompt from file")
    parser.add_argument("--skill", help="Run an organism skill by name")
    parser.add_argument("--output", help="Route output: file path, 'telegram', or omit for stdout")
    parser.add_argument("--eval", action="store_true", help="Analyze sortase traces")
    parser.add_argument("--count", type=int, default=20, help="Traces to analyze (with --eval)")
    parser.add_argument("--failures-only", action="store_true", help="Show only failures (with --eval)")
    parser.add_argument("--stats", action="store_true", help="Print dispatch statistics")
    parser.add_argument("--metrics", action="store_true", help="Print per-backend duration metrics (avg/p50/p95)")
    parser.add_argument("--batch", metavar="GLOB", help="Dispatch all plan files matching glob sequentially")
    parser.add_argument("--retries", type=int, default=0, help="Retry failed plans N times (with --batch)")
    parser.add_argument("--dry-run", action="store_true", help="Print command only")
    parser.add_argument("--output-file", action="store_true", help="Tee full stdout+stderr to ~/logs/translocon-<task>-<ts>.log")
    parser.add_argument("--verbose", action="store_true", help="Verbose output")

    args = parser.parse_args(argv)
    args.prompt = " ".join(args.prompt) if isinstance(args.prompt, list) else args.prompt
    if args.mcp and args.prompt == "" and args.dir != ".":
        args.prompt = args.dir
        args.dir = "."
    return args


def _output_log_path(task_name: str) -> Path:
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    safe = "".join(c if c.isalnum() or c in "-_" else "_" for c in task_name)[:48]
    path = Path.home() / "logs" / f"translocon-{safe}-{stamp}.log"
    path.parent.mkdir(parents=True, exist_ok=True)
    return path


def _run_captured(cmd: list[str], **kwargs) -> tuple[int, str]:
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=300, **kwargs)
    return r.returncode, (r.stdout or "")


def _run_tee(cmd: list[str], log_path: Path, **kwargs) -> int:
    """Run command, streaming stdout+stderr to both terminal and log file."""
    with open(log_path, "w") as log_fh:
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, **kwargs)
        assert proc.stdout is not None
        while True:
            chunk = proc.stdout.read(4096)
            if not chunk:
                break
            os.write(sys.stdout.fileno(), chunk)
            log_fh.write(chunk.decode(errors="replace"))
        proc.wait()
        return proc.returncode


def _route_output(text: str, dest: str) -> int:
    if isinstance(text, bytes):
        text = text.decode()
    if dest == "-":
        print(text, end="")
        return 0
    if dest == "telegram":
        return subprocess.run(["efferens", "telegram", text.rstrip()], timeout=60).returncode
    Path(dest).parent.mkdir(parents=True, exist_ok=True)
    Path(dest).write_text(text)
    return 0


def _run_stats(days: int = 7) -> int:
    """Print dispatch statistics from sortase log for the last N days."""
    from collections import Counter

    log_path = Path.home() / ".local/share/sortase/log.jsonl"
    if not log_path.exists():
        print("translocon: no sortase log found", file=sys.stderr)
        return 1

    cutoff = datetime.now() - timedelta(days=days)
    traces: list[dict] = []
    with open(log_path) as fh:
        for line in fh:
            line = line.strip()
            if not line:
                continue
            entry = json.loads(line)
            ts = entry.get("timestamp", "")
            if ts:
                try:
                    entry_dt = datetime.fromisoformat(ts)
                    if entry_dt >= cutoff:
                        traces.append(entry)
                except (ValueError, TypeError):
                    traces.append(entry)  # include unparseable entries
            else:
                traces.append(entry)

    total = len(traces)
    if total == 0:
        print(f"Translocon Stats (last {days} days)")
        print("  No dispatches recorded.")
        return 0

    success_count = sum(1 for t in traces if t.get("success"))
    fail_count = total - success_count
    success_pct = success_count / total * 100
    fail_pct = fail_count / total * 100

    durations = [t.get("duration_s", 0) for t in traces if t.get("duration_s") is not None]
    avg_duration = sum(durations) / len(durations) if durations else 0

    failure_reasons = Counter(
        t.get("failure_reason") or "unknown"
        for t in traces
        if not t.get("success")
    )
    top_failure = failure_reasons.most_common(1)
    top_failure_str = f"{top_failure[0][0]} ({top_failure[0][1]})" if top_failure else "none"

    backend_counts = Counter(t.get("tool", "unknown") for t in traces)
    top_backend = backend_counts.most_common(1)
    top_backend_str = f"{top_backend[0][0]} ({top_backend[0][1]})" if top_backend else "none"

    print(f"Translocon Stats (last {days} days)")
    print(f"  Dispatches: {total}")
    print(f"  Success: {success_count} ({success_pct:.0f}%)")
    print(f"  Failures: {fail_count} ({fail_pct:.0f}%)")
    print(f"  Avg duration: {avg_duration:.0f}s")
    print(f"  Top failure: {top_failure_str}")
    print(f"  Top backend: {top_backend_str}")
    return 0


def _run_eval(count: int = 20, failures_only: bool = False) -> int:
    from collections import Counter
    log_path = Path.home() / ".local/share/sortase/log.jsonl"
    if not log_path.exists():
        print("translocon: no sortase log found", file=sys.stderr)
        return 1
    traces: list[dict] = []
    with open(log_path) as f:
        for line in f:
            line = line.strip()
            if line:
                traces.append(json.loads(line))
    traces = traces[-count:]
    total = len(traces)
    if total == 0:
        print("translocon: no traces found in log")
        return 0
    success = sum(1 for t in traces if t.get("success"))
    fail = total - success
    print(f"Sortase traces: {total} | Success: {success} ({success/total*100:.0f}%) | Fail: {fail}")
    print()
    tools = Counter(t.get("tool", "?") for t in traces)
    for tool, n in tools.most_common():
        ts = sum(1 for t in traces if t.get("tool") == tool and t.get("success"))
        print(f"  {tool}: {ts}/{n} ({ts/n*100:.0f}%)")
    print()
    reasons = Counter(t.get("failure_reason", "unknown") for t in traces if not t.get("success"))
    if reasons:
        print("Failure reasons:")
        for reason, n in reasons.most_common():
            print(f"  {reason}: {n}")
        print()
    if failures_only or fail > 0:
        failed = [t for t in traces if not t.get("success")]
        if failed:
            print("Failed traces:")
            for t in failed:
                print(f"  [{t.get('tool','?')}] {t.get('plan','?')} — "
                      f"{t.get('failure_reason','?')} ({t.get('duration_s',0):.0f}s)")
    return 0


def _extract_task_summary(prompt: str) -> str:
    """Extract the task description from a coaching-injected prompt.

    Coaching notes are prepended before '\\n\\n---\\n\\nTask:\\n'.
    If that separator exists, take the text after it.
    Otherwise use the full prompt (no coaching was injected).
    """
    marker = "\n\n---\n\nTask:\n"
    idx = prompt.find(marker)
    task = prompt[idx + len(marker):] if idx >= 0 else prompt
    # Take first meaningful line
    for line in task.strip().splitlines():
        stripped = line.strip()
        if stripped and not stripped.startswith("#"):
            return stripped[:72]
    return task.strip()[:72]


def _atomic_commit(directory: str, backend: str, prompt: str) -> None:
    """Auto-commit after successful build. Mitosis is the safety net; this is the primary."""
    diff = subprocess.run(["git", "diff", "--stat"], cwd=directory, capture_output=True, text=True, timeout=30)
    untracked = subprocess.run(["git", "ls-files", "--others", "--exclude-standard"],
                               cwd=directory, capture_output=True, text=True, timeout=30)
    if not diff.stdout.strip() and not untracked.stdout.strip():
        return  # nothing to commit
    # Stage only modified/new files — NOT unrelated plan files
    # Modified tracked files
    subprocess.run(["git", "add", "-u"], cwd=directory, capture_output=True, timeout=30)
    # New files created by goose (exclude loci/plans/ to avoid archiving race)
    for f in untracked.stdout.strip().splitlines():
        f = f.strip()
        if f and not f.startswith("loci/plans/"):
            subprocess.run(["git", "add", "--", f], cwd=directory, capture_output=True, timeout=30)
    summary = _extract_task_summary(prompt).replace("\n", " ")
    msg = f"translocon({backend}): {summary}"
    subprocess.run(["git", "commit", "-m", msg], cwd=directory, capture_output=True, timeout=60)


def _batch_dispatch(args: argparse.Namespace) -> int:
    """Dispatch all plan files matching the --batch glob sequentially, print summary."""
    from glob import glob as _glob

    pattern = args.batch
    expanded = os.path.expanduser(pattern)
    # Support brace expansion and ~ via shell, but also try direct glob
    paths = sorted(Path(p) for p in _glob(expanded) if Path(p).is_file())
    if not paths:
        print(f"translocon --batch: no files matched '{pattern}'", file=sys.stderr)
        return 1

    if args.verbose:
        print(f"translocon: batch mode — {len(paths)} plan(s)", file=sys.stderr)

    # Build a clean clone of args without --batch so each dispatch is normal
    dispatch_argv: list[str] = []
    if args.build:
        dispatch_argv.append("--build")
    if args.mcp:
        dispatch_argv.append("--mcp")
    if args.safe:
        dispatch_argv.append("--safe")
    if args.model:
        dispatch_argv += ["--model", args.model]
    if args.backend:
        dispatch_argv += ["--backend", args.backend]
    if args.verbose:
        dispatch_argv.append("--verbose")
    if args.output:
        dispatch_argv += ["--output", args.output]
    if args.output_file:
        dispatch_argv.append("--output-file")
    if args.retries:
        dispatch_argv += ["--retries", str(args.retries)]
    if args.dry_run:
        dispatch_argv.append("--dry-run")
    dispatch_argv.append(args.dir or ".")

    # Dry-run: list plans and what would dispatch, then exit
    if args.dry_run:
        for plan_path in paths:
            print(f"  would dispatch: {plan_path.name}", file=sys.stderr)
        print(f"Batch dry-run: {len(paths)} plan(s) matched '{pattern}'", file=sys.stderr)
        return 0

    success_count = 0
    fail_count = 0
    skip_count = 0
    results: list[tuple[str, bool, str]] = []

    for plan_path in paths:
        if not plan_path.exists():
            print(f"  {plan_path.name}: SKIP (file vanished)", file=sys.stderr)
            skip_count += 1
            continue
        dispatch_argv_with_file = dispatch_argv + ["--file", str(plan_path)]
        child_args = _parse_args(dispatch_argv_with_file)
        child_args.batch = None  # prevent recursion
        plan_name = plan_path.name
        print(f"translocon: dispatching {plan_name}...", file=sys.stderr)
        max_retries = args.retries
        for attempt in range(max_retries + 1):
            try:
                rc = main_impl(child_args)
            except Exception as exc:
                print(f"  {plan_name}: ERROR {exc}", file=sys.stderr)
                rc = 1
            if rc == 0:
                break
            if attempt < max_retries:
                import time
                backoff = 15 * (attempt + 1)
                print(f"  {plan_name}: retrying in {backoff}s (attempt {attempt + 2}/{max_retries + 1})", file=sys.stderr)
                time.sleep(backoff)
        ok = rc == 0
        if ok:
            success_count += 1
        else:
            fail_count += 1
        status = "OK" if ok else "FAIL"
        results.append((plan_name, ok, status))
        print(f"  {plan_name}: {status}", file=sys.stderr)

    dispatched = success_count + fail_count
    print(file=sys.stderr)
    print(f"Batch complete: {success_count} ok, {fail_count} fail, {skip_count} skipped, {len(paths)} total", file=sys.stderr)
    for plan_name, _, status in results:
        print(f"  {status}\t{plan_name}", file=sys.stderr)

    return 1 if fail_count > 0 else 0


def main_impl(args: argparse.Namespace) -> int:
    """Core dispatch logic — shared by main() and batch mode."""
    if args.stats:
        return _run_stats()
    if args.metrics:
        from metabolon.organelles.translocon_metrics import format_report
        print(format_report(days=30))
        return 0
    if args.eval:
        return _run_eval(args.count, args.failures_only)
    prompt = args.prompt
    if args.file:
        with open(args.file) as fh:
            prompt = fh.read().strip()

    chain, model, directory, auto, mode = _resolve_mode(args)
    backend = chain[0]  # primary backend for compat

    recipe_path: str | None = None
    if args.skill:
        rp = Path.home() / f"germline/membrane/receptors/{args.skill}/recipe.yaml"
        if not rp.exists():
            print(f"translocon: skill '{args.skill}' not found (no recipe.yaml)", file=sys.stderr)
            print(f"  hint: run 'skill-sync {args.skill}' to generate", file=sys.stderr)
            return 1
        recipe_path = str(rp)
        if not prompt:
            prompt = f"Execute the {args.skill} skill."
        if backend == "droid":
            prompt = f"Use the /{args.skill} skill. " + prompt

    if not prompt:
        print("Error: provide a prompt via argument or -f <file>", file=sys.stderr)
        return 1

    prompt = _inject_coaching(prompt)
    if args.safe:
        prompt = "READ ONLY. Do not create, modify, or delete any files. " + prompt

    if args.dry_run:
        header = f"# translocon dry-run: backend={backend} model={model} dir={directory}"
        if recipe_path:
            header += f" recipe={recipe_path}"
        if auto:
            header += f" auto={auto}"
        print(header, file=sys.stderr)
        print(prompt)
        return 0
    if args.verbose:
        print(f"translocon: {chain} / {model} in {directory}", file=sys.stderr)

    import time
    from metabolon.organelles.translocon_metrics import record as _record_metric
    t0 = time.monotonic()
    capture = args.output is not None
    output_length = 0

    def _entry(backend: str, success: bool, out_len: int = 0) -> dict:
        dur = round(time.monotonic() - t0, 2)
        _record_metric(
            backend=backend, model=model, prompt_length=len(prompt),
            output_length=out_len, duration_s=dur, success=success, mode=mode,
        )
        return {"mode": mode, "backend": backend, "model": model, "skill": args.skill,
                "duration_s": dur, "success": success,
                "directory": directory, "prompt_length": len(prompt)}

    # Direct API fast path for explore/safe
    if mode in ("explore", "safe") and not args.backend and not capture:
        ctx = _read_dir_context(directory)
        full_prompt = (ctx + "\n\n" + prompt) if ctx else prompt
        if args.verbose:
            print(f"translocon: trying direct API ({model.lower()})", file=sys.stderr)
        rc = _direct_api(full_prompt, model.lower())
        _log_call(_entry("direct", rc == 0))
        if rc == 0:
            return 0

    # Chain execution with health checks
    env = {**os.environ, "GOOGLE_API_KEY": "", "GEMINI_API_KEY": ""}
    healthy_chain = [b for b in chain if _is_healthy(b)] or [chain[0]]
    tee_log = None
    if args.output_file:
        tee_log = _output_log_path(_extract_task_summary(prompt))
        if args.verbose:
            print(f"translocon: logging to {tee_log}", file=sys.stderr)
    ticker = _ProgressTicker(interval=10.0)
    for b in healthy_chain:
        cmd = _build_golem_cmd(model, directory, prompt, auto)
        benv = env
        prev = os.getcwd()
        try:
            os.chdir(directory)
            ticker.start()
            try:
                out_len = 0
                if capture:
                    rc, stdout_text = _run_captured(cmd, env=benv)
                    out_len = len(stdout_text)
                    if tee_log:
                        tee_log.write_text(stdout_text)
                    if rc == 0:
                        _route_output(stdout_text, args.output)
                elif tee_log:
                    rc = _run_tee(cmd, tee_log, env=benv)
                else:
                    rc = subprocess.run(cmd, env=benv, timeout=300).returncode
            finally:
                ticker.stop()
                print("", file=sys.stderr)  # newline after progress dots
        finally:
            os.chdir(prev)
        if rc == 0:
            _record_result(b, True)
            _log_call(_entry(b, True, out_len))
            if mode == "build":
                _atomic_commit(directory, b, prompt)
            return 0
        if args.verbose:
            print(f"translocon: {b} failed, trying next...", file=sys.stderr)
        _record_result(b, False)
        # Check if failure was a rate limit (429)
        if rc == 1 and tee_log and tee_log.exists():
            tail = tee_log.read_text()[-500:]
            if "429" in tail or "Too Many Requests" in tail or "余额不足" in tail:
                _record_rate_limit(b)
                if args.verbose:
                    print(f"translocon: {b} hit rate limit, 60s cooldown set", file=sys.stderr)

    _log_call(_entry(healthy_chain[-1], False))
    return 1


def main(argv: list[str] | None = None) -> int:
    """Entry point — parse args, route to batch or single dispatch."""
    args = _parse_args(argv)
    if args.batch:
        return _batch_dispatch(args)
    return main_impl(args)


if __name__ == "__main__":
    raise SystemExit(main())

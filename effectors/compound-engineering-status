#!/usr/bin/env bash
# Check status of compound-engineering auto-update

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: compound-engineering-status"
    echo ""
    echo "Show the current status of compound-engineering auto-update."
    echo "Reports scheduler state, last update log, and management commands."
    exit 0
fi

echo "📊 Compound Engineering Auto-Update Status"
echo "==========================================="
echo ""

# Check LaunchAgent status (macOS only)
if command -v launchctl >/dev/null 2>&1; then
    if launchctl list | grep -q "com.terry.compound-engineering-update"; then
        echo "✅ LaunchAgent is loaded and active"
        echo "   Schedule: Every Sunday at 2:00 AM HKT"
    else
        echo "❌ LaunchAgent is not loaded"
    fi
else
    echo "ℹ️  launchctl not available (not macOS)"
    # Check for systemd/cron equivalent
    if crontab -l 2>/dev/null | grep -q "compound-engineering"; then
        echo "✅ Cron job is configured"
    else
        echo "❌ No cron job configured"
    fi
fi

echo ""

# Check when it last ran
if [ -f "$HOME/.compound-engineering-updates.log" ]; then
    echo "📝 Last update log:"
    tail -20 "$HOME/.compound-engineering-updates.log"
else
    echo "ℹ️  No update logs yet (will run on next Sunday at 2 AM)"
fi

echo ""
echo "🔧 Management Commands:"
echo "   update-compound-engineering          - Run update now"
echo "   compound-engineering-test            - Test the update script"
echo "   launchctl unload ~/Library/LaunchAgents/com.terry.compound-engineering-update.plist - Disable auto-update (macOS)"
echo "   launchctl load ~/Library/LaunchAgents/com.terry.compound-engineering-update.plist   - Enable auto-update (macOS)"
echo "   crontab -e                                                          - Edit cron (Linux)"

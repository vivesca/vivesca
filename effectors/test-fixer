#!/usr/bin/env python3
"""test-fixer — Parse pytest failures, group by file, diagnose likely causes.

Runs pytest -q --tb=line, parses FAILED/ERROR lines, groups results by file,
and outputs a markdown report with failure details and likely root causes.

Usage:
    test-fixer           # Run pytest, print markdown report
    test-fixer --json    # Output JSON instead
    test-fixer --dir /path/to/project   # Run against a different directory
"""
from __future__ import annotations

import json
import re
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

GERMLINE_ROOT = Path.home() / "germline"


def run_pytest(cwd: Path | None = None) -> str:
    """Run pytest -q --tb=line and return stdout."""
    result = subprocess.run(
        [sys.executable, "-m", "pytest", "-q", "--tb=line", "--no-header"],
        capture_output=True,
        text=True,
        cwd=cwd or GERMLINE_ROOT,
    )
    return result.stdout + result.stderr


def parse_pytest_output(output: str) -> list[dict]:
    """Parse pytest output, extracting FAILED and ERROR lines.

    Returns list of dicts with keys: file, test, error, error_type.
    Deduplicates lines that appear in both the body and the short summary.
    """
    seen: set[str] = set()
    results: list[dict] = []
    # Match FAILED and ERROR lines: FILE::TEST - ERROR_MSG
    pattern = re.compile(
        r"^(FAILED|ERROR)\s+(?P<file>\S+?)::(?P<test>\S+?)\s*-\s*(?P<error>.+)$",
        re.MULTILINE,
    )
    for m in pattern.finditer(output):
        key = f"{m.group('file')}::{m.group('test')}"
        if key in seen:
            continue
        seen.add(key)
        error_msg = m.group("error").strip()
        # Extract error type (exception class name)
        error_type_match = re.match(r"([\w.]+Error|[\w.]+Exception|assert)", error_msg)
        error_type = error_type_match.group(1) if error_type_match else "Unknown"
        results.append({
            "file": m.group("file"),
            "test": m.group("test"),
            "error": error_msg,
            "error_type": error_type,
        })
    return results


def group_by_file(results: list[dict]) -> dict[str, list[dict]]:
    """Group failure results by file path."""
    grouped: dict[str, list[dict]] = defaultdict(list)
    for r in results:
        grouped[r["file"]].append(r)
    return dict(grouped)


def diagnose_failure(error_type: str, error_msg: str) -> str:
    """Return a likely cause string for a given error type and message."""
    et = error_type.lower()
    msg = error_msg.lower()

    if "assert" in et or "assertionerror" in et:
        if "none" in msg or "null" in msg:
            return "Returned None unexpectedly — check upstream function return value"
        return "Assertion failed — test expectation doesn't match actual output (logic bug)"

    if "import" in et or "module" in et:
        return "Missing import or dependency — module not installed or path wrong"

    if "type" in et and "error" in et:
        return "Type mismatch — wrong argument type or None passed to operation"

    if "attribute" in et:
        if "nonetype" in msg:
            return "Attribute access on None — upstream returned None instead of expected object"
        return "Missing attribute — class/object doesn't have expected method or field"

    if "name" in et:
        return "Undefined name — typo or missing variable/function definition"

    if "key" in et:
        return "Missing dict key — accessed key that doesn't exist"

    if "index" in et:
        return "Index out of range — list/sequence shorter than expected"

    if "value" in et:
        return "Invalid value — function received unexpected value"

    if "syntax" in et:
        return "Syntax error — malformed Python in source or test file"

    if "connection" in et or "refused" in msg or "timeout" in msg:
        return "Infrastructure/network issue — external service or DB not reachable"

    if "filenotfound" in et or "file" in et and "not found" in msg:
        return "File not found — missing fixture file or wrong path"

    if "fixture" in msg:
        return "Fixture issue — missing or misconfigured pytest fixture"

    if "operational" in et:
        return "Database operational error — schema mismatch or connection problem"

    return f"Unclassified error ({error_type}) — inspect full traceback"


def generate_markdown(
    grouped: dict[str, list[dict]],
    all_results: list[dict],
) -> str:
    """Generate markdown report from grouped failure data."""
    if not all_results:
        return "# Test Failure Report\n\n✅ All tests passed — no failures found.\n"

    lines: list[str] = [
        "# Test Failure Report\n",
        f"**{len(all_results)} failure(s) across {len(grouped)} file(s)**\n",
    ]

    # Summary table
    lines.append("## Summary\n")
    lines.append("| File | Failures | Error Types |")
    lines.append("|------|----------|-------------|")
    for fpath, failures in sorted(grouped.items()):
        types = ", ".join(sorted({r["error_type"] for r in failures}))
        lines.append(f"| `{fpath}` | {len(failures)} | {types} |")
    lines.append("")

    # Per-file details
    lines.append("## Details\n")
    for fpath in sorted(grouped):
        failures = grouped[fpath]
        lines.append(f"### `{fpath}`\n")
        for f in failures:
            cause = diagnose_failure(f["error_type"], f["error"])
            lines.append(f"- **{f['test']}**")
            lines.append(f"  - Error: `{f['error']}`")
            lines.append(f"  - Likely cause: {cause}")
        lines.append("")

    return "\n".join(lines)


def main(argv: list[str] | None = None) -> None:
    """CLI entry point."""
    args = argv or sys.argv[1:]
    use_json = "--json" in args
    cwd: Path | None = None

    # Parse --dir flag
    for i, arg in enumerate(args):
        if arg == "--dir" and i + 1 < len(args):
            cwd = Path(args[i + 1])

    output = run_pytest(cwd)
    results = parse_pytest_output(output)
    grouped = group_by_file(results)

    if use_json:
        print(json.dumps({
            "failures": results,
            "total": len(results),
            "files_affected": len(grouped),
            "grouped": {k: v for k, v in grouped.items()},
        }, indent=2))
    else:
        print(generate_markdown(grouped, results))


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""test-fixer — run pytest, parse failures, group by file, report likely causes.

Usage:
    test-fixer              # run against ~/germline, markdown report to stdout
    test-fixer --json       # JSON report to stdout
    test-fixer --dir PATH   # run pytest in a different directory
"""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

# ---------------------------------------------------------------------------
# Failure classification
# ---------------------------------------------------------------------------

_PATTERNS: list[tuple[re.Pattern[str], str]] = [
    (re.compile(r"ImportError|ModuleNotFoundError"), "missing or circular import"),
    (re.compile(r"AttributeError"), "attribute access on wrong type or misspelled name"),
    (re.compile(r"TypeError"), "type mismatch — wrong argument count or type"),
    (re.compile(r"NameError"), "undefined name (typo or missing import)"),
    (re.compile(r"FileNotFoundError"), "missing fixture file or bad path"),
    (re.compile(r"KeyError"), "dict key missing — data shape changed"),
    (re.compile(r"ValueError"), "bad value — conversion or validation failure"),
    (re.compile(r"IndexError"), "list/tuple index out of range"),
    (re.compile(r"SyntaxError"), "syntax error in source file"),
    (re.compile(r"IndentationError"), "incorrect indentation"),
    (re.compile(r"AssertionError"), "assertion failed — logic or data mismatch"),
    (re.compile(r"pytest\.exit"), "pytest forced exit (likely fixture teardown issue)"),
    (re.compile(r"recursion depth|RecursionError"), "infinite recursion"),
    (re.compile(r"TimeoutError|timeout"), "test timed out"),
]


def classify_error(line: str) -> str:
    """Return a short likely-cause string for a traceback line."""
    for pattern, cause in _PATTERNS:
        if pattern.search(line):
            return cause
    return "unknown error type"


# ---------------------------------------------------------------------------
# Pytest output parsing
# ---------------------------------------------------------------------------

_RE_FAILED_LINE = re.compile(r"FAILED\s+(.+?)::(\S+)\s*-\s*(.+)")
_RE_FAILED_SHORT = re.compile(r"FAILED\s+(.+?)::(\S+)")
_RE_TB_LINE = re.compile(r"^(.+?):(\d+):\s*(.+)")
_RE_SUMMARY_HEADER = re.compile(r"^=+\s*short test summary")
_RE_FAILED_SUMMARY = re.compile(r"^FAILED\s+")


def parse_failures(stdout: str) -> dict[str, list[dict]]:
    """Parse pytest -q --tb=line output into failures grouped by file.

    Returns {filepath: [{"test": str, "line": str, "error": str, "cause": str}, ...]}
    """
    groups: dict[str, list[dict]] = defaultdict(list)
    lines = stdout.splitlines()

    for line in lines:
        m = _RE_FAILED_LINE.match(line)
        if not m:
            m = _RE_FAILED_SHORT.match(line)
        if m:
            filepath, test_name = m.group(1), m.group(2)
            error = m.group(3).strip() if m.lastindex and m.lastindex >= 3 else ""
            cause = classify_error(error)
            groups[filepath].append(
                {
                    "test": test_name,
                    "line": "",
                    "error": error,
                    "cause": cause,
                }
            )
            continue

        # Try traceback line format: file.py:42: ErrorType: message
        m2 = _RE_TB_LINE.match(line)
        if m2 and "FAILED" not in line:
            filepath, lineno, msg = m2.group(1), m2.group(2), m2.group(3)
            if groups.get(filepath):
                # Attach line number to the last failure for this file
                groups[filepath][-1]["line"] = lineno
                if not groups[filepath][-1]["error"]:
                    groups[filepath][-1]["error"] = msg
                    groups[filepath][-1]["cause"] = classify_error(msg)

    return dict(groups)


# ---------------------------------------------------------------------------
# Report formatting
# ---------------------------------------------------------------------------


def format_markdown(groups: dict[str, list[dict]], total_failed: int) -> str:
    """Format parsed failures as a markdown report."""
    if not groups:
        return "## Test Results\n\n**No failures found.** All tests passing.\n"

    lines = [
        "## Test Failure Report",
        "",
        f"**{total_failed} failure(s)** across **{len(groups)} file(s)**",
        "",
    ]

    for filepath in sorted(groups):
        failures = groups[filepath]
        lines.append(f"### `{filepath}` ({len(failures)} failure(s))")
        lines.append("")
        lines.append("| Test | Line | Error | Likely Cause |")
        lines.append("|------|------|-------|-------------|")
        for f in failures:
            test = f["test"]
            ln = f["line"] or "—"
            err = f["error"][:80] if f["error"] else "—"
            cause = f["cause"]
            lines.append(f"| `{test}` | {ln} | {err} | {cause} |")
        lines.append("")

    return "\n".join(lines)


def format_json(groups: dict[str, list[dict]], total_failed: int) -> str:
    """Format parsed failures as JSON."""
    return json.dumps(
        {
            "total_failed": total_failed,
            "files_affected": len(groups),
            "failures": {fp: entries for fp, entries in sorted(groups.items())},
        },
        indent=2,
    )


# ---------------------------------------------------------------------------
# Runner
# ---------------------------------------------------------------------------


def run_pytest(directory: Path) -> tuple[str, int]:
    """Run pytest -q --tb=line and return (stdout, returncode)."""
    result = subprocess.run(
        [sys.executable, "-m", "pytest", "-q", "--tb=line", "-x", "--no-header"],
        cwd=str(directory),
        capture_output=True,
        text=True,
        timeout=300,
    )
    return result.stdout, result.returncode


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def main(argv: list[str] | None = None) -> None:
    parser = argparse.ArgumentParser(
        description="Run pytest, parse failures, and report likely causes."
    )
    parser.add_argument(
        "--json",
        action="store_true",
        dest="json_output",
        help="Output JSON instead of markdown",
    )
    parser.add_argument(
        "--dir",
        type=Path,
        default=Path.home() / "germline",
        help="Project directory to run pytest in (default: ~/germline)",
    )
    args = parser.parse_args(argv)

    stdout, rc = run_pytest(args.dir)

    if rc == 0:
        groups: dict[str, list[dict]] = {}
        total_failed = 0
    else:
        groups = parse_failures(stdout)
        total_failed = sum(len(v) for v in groups.values())

    if args.json_output:
        print(format_json(groups, total_failed))
    else:
        print(format_markdown(groups, total_failed))

    sys.exit(rc if total_failed else 0)


if __name__ == "__main__":
    main()

#!/usr/bin/env bash
# gh-auth-renew — renew GitHub CLI auth via OAuth device flow
#
# Why this exists:
#   `gh auth login -w` opens a browser locally and prompts interactively.
#   This script does the same device flow but:
#     1. Drives an existing Chrome tab (which is already logged in to GitHub)
#     2. Auto-fills the user code
#     3. Force-clicks Authorize past the anti-clickjacking delay
#     4. Polls for the token, saves to 1Password, configures gh
#
#   Stops at GitHub's sudo-mode challenge (passkey/2FA) — that step requires
#   a human touch. After you tap Touch ID, this script resumes automatically.
#
# Prerequisites:
#   - Chrome running on Mac, logged in to github.com
#   - 1Password CLI authenticated, Agents vault accessible
#   - jq installed

set -euo pipefail

CLIENT_ID="178c6fc778ccc68e1d6a"  # gh CLI public OAuth app — stable for years
SCOPES="repo,workflow,gist,read:org"
OP_ITEM="github-token-ganglion"
OP_VAULT="Agents"

log() { echo "[gh-auth-renew] $*" >&2; }

# 1. Request device code
log "Requesting device code..."
resp=$(curl -sS -X POST https://github.com/login/device/code \
  -H "Accept: application/json" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "client_id=${CLIENT_ID}&scope=${SCOPES}")

device_code=$(echo "$resp" | jq -r .device_code)
user_code=$(echo "$resp" | jq -r .user_code)
interval=$(echo "$resp" | jq -r .interval)
expires=$(echo "$resp" | jq -r .expires_in)

if [ -z "$device_code" ] || [ "$device_code" = "null" ]; then
  log "ERROR: device code request failed: $resp"
  exit 1
fi

log "User code: $user_code (expires in ${expires}s)"

# 2. Open Chrome to the device page with code in URL
log "Opening Chrome to device authorization page..."
osascript <<OSA >/dev/null
tell application "Google Chrome"
  set newTab to make new tab at end of tabs of window 1 with properties {URL:"https://github.com/login/device?user_code=${user_code}"}
  set active tab index of window 1 to (count of tabs of window 1)
  activate
end tell
OSA

# 3. Wait briefly, then drive the flow
log "Driving select_account → authorize → confirm flow..."
sleep 1

# Click Continue on account selection page
osascript -e 'tell application "Google Chrome"
  tell active tab of window 1
    execute javascript "var b = Array.from(document.querySelectorAll('"'"'button, input[type=submit]'"'"')).find(b => (b.textContent.trim() || b.value) === '"'"'Continue'"'"'); if (b) b.click();"
  end tell
end tell' >/dev/null 2>&1 || true

sleep 1.5

# Fill the 9 code input fields
osascript -e 'tell application "Google Chrome"
  tell active tab of window 1
    execute javascript "var code = '"'"'""${user_code}""'"'"'; for (var i = 0; i < code.length; i++) { var input = document.getElementById('"'"'user-code-'"'"' + i); if (input) { var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, '"'"'value'"'"').set; setter.call(input, code[i]); input.dispatchEvent(new Event('"'"'input'"'"', {bubbles: true})); } }"
  end tell
end tell' >/dev/null 2>&1 || true

sleep 0.5

# Submit code
osascript -e 'tell application "Google Chrome"
  tell active tab of window 1
    execute javascript "var b = document.querySelector('"'"'input[name=commit]'"'"'); if (b) b.click();"
  end tell
end tell' >/dev/null 2>&1 || true

sleep 1.5

# Force-enable and click Authorize button
osascript -e 'tell application "Google Chrome"
  tell active tab of window 1
    execute javascript "var b = document.querySelector('"'"'form[action*=authorize] button.js-oauth-authorize-btn'"'"'); if (b) { b.disabled = false; b.removeAttribute('"'"'disabled'"'"'); b.click(); }"
  end tell
end tell' >/dev/null 2>&1 || true

log ""
log "=========================================================="
log "  Chrome is now showing GitHub's sudo-mode challenge."
log "  Click 'Use passkey' (Touch ID) or complete 2FA."
log "  Polling for token every ${interval}s..."
log "=========================================================="
log ""

# 4. Poll for token
while true; do
  sleep "$interval"
  resp=$(curl -sS -X POST https://github.com/login/oauth/access_token \
    -H "Accept: application/json" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -d "client_id=${CLIENT_ID}&device_code=${device_code}&grant_type=urn:ietf:params:oauth:grant-type:device_code")

  token=$(echo "$resp" | jq -r '.access_token // empty')
  err=$(echo "$resp" | jq -r '.error // empty')

  if [ -n "$token" ]; then
    log "Token received."
    break
  fi

  case "$err" in
    authorization_pending) log "  waiting for passkey/2FA..." ;;
    slow_down) interval=$((interval + 5)); log "  rate-limited, slowing to ${interval}s" ;;
    expired_token) log "ERROR: device code expired. Re-run."; exit 1 ;;
    access_denied) log "ERROR: authorization denied."; exit 1 ;;
    *) log "ERROR: $err — $(echo "$resp" | jq -r '.error_description // "unknown"')"; exit 1 ;;
  esac
done

# 5. Configure gh CLI
log "Configuring gh CLI..."
echo "$token" | gh auth login --with-token -h github.com

# 6. Update 1Password
log "Updating 1Password item '$OP_ITEM'..."
op item edit "$OP_ITEM" --vault "$OP_VAULT" "credential=$token" >/dev/null

# 7. Verify
log "Verifying..."
if gh auth status >/dev/null 2>&1; then
  log "SUCCESS: gh authenticated, 1Password updated."
  gh auth status
else
  log "ERROR: gh auth verification failed"
  exit 1
fi

#!/bin/bash
# GLM-5.1 Claude Code wrapper via ZhipuAI/BigModel Anthropic-compatible API
# Key in 1Password: op://Agents/Agent Environment/zhipu_api_key → $ZHIPU_API_KEY
# Injected via ~/.zshenv.tpl → ~/.zshenv

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<'HELP'
cg — Claude Code via GLM-5.1 (ZhipuAI Anthropic-compatible endpoint).

Usage:
    cg [claude-args...]        Start interactive session with GLM-5.1
    cg -p "prompt"             Non-interactive print mode
    cg --help                  Show this help

Routes all traffic through ZhipuAI's Anthropic-compatible API.
Requires ZHIPU_API_KEY in environment (1Password injection via ~/.zshenv).
HELP
    exit 0
fi

export ANTHROPIC_API_KEY="${ZHIPU_API_KEY:?ZHIPU_API_KEY not set — check 1Password injection in ~/.zshenv}"
export ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic"
unset ANTHROPIC_AUTH_TOKEN
exec claude --dangerously-skip-permissions --model glm-5.1 "$@"

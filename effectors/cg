#!/bin/bash
# GLM-5 Claude Code wrapper via ZhipuAI/BigModel Anthropic-compatible API
# Key in 1Password: op://Agents/Agent Environment/zhipu_api_key → $ZHIPU_API_KEY
# Injected via ~/.zshenv.tpl → ~/.zshenv
export HOME=~/glm-home
export ANTHROPIC_API_KEY="${ZHIPU_API_KEY:?ZHIPU_API_KEY not set — check 1Password injection in ~/.zshenv}"
export ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic"
export ANTHROPIC_MODEL="glm-5"
unset ANTHROPIC_AUTH_TOKEN
exec /Users/terry/.local/bin/claude --dangerously-skip-permissions "$@"

#!/usr/bin/env python3
"""taste-score — measure consumption rate of copia outputs.

Reads the archived manifest, checks file access times,
reports which outputs were consumed vs ignored.

Usage:
    taste-score                     # score most recent manifest
    taste-score ~/tmp/copia-session-2026-03-19-2009.md  # score specific run
"""

import os
import sys
import time
from pathlib import Path


def parse_manifest(path: Path) -> list[dict]:
    """Extract file paths and descriptions from manifest."""
    items = []
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line.startswith("- "):
            continue
        # Look for ~/path patterns
        parts = line.split("~/")
        if len(parts) < 2:
            continue
        # Extract path (up to space, —, or end)
        raw = "~/" + parts[1].split(" —")[0].split(" ✓")[0].split(" →")[0].strip()
        expanded = Path(raw.replace("~", str(Path.home())))
        desc = line.split("—")[-1].strip() if "—" in line else ""
        items.append({"path": expanded, "raw": raw, "desc": desc})
    return items


def score_items(items: list[dict], manifest_mtime: float) -> list[dict]:
    """Check if each file was accessed after the manifest was created."""
    scored = []
    for item in items:
        p = item["path"]
        if not p.exists():
            item["status"] = "missing"
            item["consumed"] = False
        else:
            atime = os.stat(p).st_atime
            mtime = os.stat(p).st_mtime
            # Consumed if accessed after manifest creation
            # (atime updates on read, mtime on write)
            last_touch = max(atime, mtime)
            item["consumed"] = last_touch > manifest_mtime
            item["status"] = "read" if item["consumed"] else "ignored"
            item["hours_since"] = round((time.time() - last_touch) / 3600, 1)
        scored.append(item)
    return scored


def main():
    # Find manifest
    if len(sys.argv) > 1:
        manifest = Path(sys.argv[1]).expanduser()
    else:
        # Find most recent archived manifest
        tmp = Path.home() / "tmp"
        candidates = sorted(
            tmp.glob("copia-session-*.md"), key=lambda p: p.stat().st_mtime, reverse=True
        )
        if not candidates:
            print("No archived manifests found in ~/tmp/")
            sys.exit(1)
        manifest = candidates[0]

    print(f"Manifest: {manifest.name}")
    manifest_mtime = manifest.stat().st_mtime
    manifest_age = round((time.time() - manifest_mtime) / 3600, 1)
    print(f"Age: {manifest_age}h ago\n")

    items = parse_manifest(manifest)
    if not items:
        print("No file paths found in manifest.")
        sys.exit(0)

    scored = score_items(items, manifest_mtime)

    consumed = [s for s in scored if s["consumed"]]
    ignored = [s for s in scored if not s["consumed"]]
    rate = len(consumed) / len(scored) * 100 if scored else 0

    print(f"{'CONSUMED':>10}  {'PATH'}")
    print(f"{'--------':>10}  {'----'}")
    for s in scored:
        mark = "  ✓" if s["consumed"] else "  ✗"
        age = f" ({s.get('hours_since', '?')}h)" if "hours_since" in s else ""
        print(f"{mark:>10}  {s['raw']}{age}")

    print(f"\n{'=' * 50}")
    print(f"Taste score: {len(consumed)}/{len(scored)} consumed ({rate:.0f}%)")
    print(f"Taste error: {len(ignored)}/{len(scored)} ignored ({100 - rate:.0f}%)")

    if ignored:
        print("\nIgnored items (taste errors):")
        for s in ignored:
            print(f"  - {s['raw']} — {s['desc']}")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""orphan-scan — find .py files in metabolon/ not imported anywhere.

Scans every .py file under metabolon/ (excluding __init__.py) and checks
whether its module path is referenced by any import statement anywhere in
the germline tree. Reports orphan modules that are never imported.

Usage:
    orphan-scan              # print orphans to stdout
    orphan-scan --json       # JSON output
    orphan-scan --dir DIR    # scan a different root (default: ~/germline)
"""
from __future__ import annotations

import ast
import json
import re
import sys
from pathlib import Path


ROOT = Path.home() / "germline"
METABOLON = ROOT / "metabolon"
EXCLUDE_NAMES = {"__init__.py", "__pycache__"}
# Files that are entry points (run via python -m or exec'd), not imported
ENTRY_POINT_BASENAMES = {"__main__.py"}


def module_path(py_file: Path, root: Path) -> str:
    """Convert a .py file path to its dotted module path."""
    rel = py_file.relative_to(root)
    parts = list(rel.with_suffix("").parts)
    if parts[-1] == "__init__":
        parts = parts[:-1]
    return ".".join(parts)


def collect_metabolon_modules(metabolon_dir: Path) -> dict[str, Path]:
    """Return {dotted_module_path: file_path} for all .py files in metabolon/."""
    modules: dict[str, Path] = {}
    for py_file in sorted(metabolon_dir.rglob("*.py")):
        if py_file.name in EXCLUDE_NAMES:
            continue
        # Skip test files inside metabolon itself
        if py_file.name.startswith("test_"):
            continue
        mod = module_path(py_file, metabolon_dir.parent)
        modules[mod] = py_file
    return modules


def extract_imports_from_file(py_file: Path) -> set[str]:
    """Parse a .py file and return the set of imported module names."""
    imports: set[str] = set()
    try:
        source = py_file.read_text(encoding="utf-8", errors="replace")
        tree = ast.parse(source, filename=str(py_file))
    except (SyntaxError, OSError):
        return imports

    for node in ast.walk(tree):
        if isinstance(node, ast.Import):
            for alias in node.names:
                imports.add(alias.name)
        elif isinstance(node, ast.ImportFrom):
            if node.module:
                imports.add(node.module)
                # Also add parent packages (e.g. from a.b.c import X => a, a.b, a.b.c)
                parts = node.module.split(".")
                for i in range(1, len(parts) + 1):
                    imports.add(".".join(parts[:i]))
    return imports


def find_orphans(root: Path, metabolon_dir: Path | None = None) -> list[dict]:
    """Find .py files in metabolon/ that are never imported.

    Returns list of dicts: [{"module": str, "path": str, "is_entry_point": bool}]
    """
    if metabolon_dir is None:
        metabolon_dir = root / "metabolon"

    modules = collect_metabolon_modules(metabolon_dir)
    if not modules:
        return []

    # Collect all imports from every .py file in the tree
    all_imports: set[str] = set()
    for py_file in root.rglob("*.py"):
        if py_file.name in EXCLUDE_NAMES:
            continue
        all_imports.update(extract_imports_from_file(py_file))

    # Also scan non-.py files (effectors, configs) for string-based imports
    for f in root.rglob("*"):
        if f.is_dir() or f.suffix in {".pyc", ".pyo"}:
            continue
        if f.suffix == ".py":
            continue  # already handled
        if f.name.startswith("."):
            continue
        try:
            text = f.read_text(encoding="utf-8", errors="replace")
        except (OSError, UnicodeDecodeError):
            continue
        # Look for metabolon.xxx import patterns in non-Python files
        for match in re.finditer(r"\bmetabolon(?:\.\w+)+", text):
            all_imports.add(match.group())

    orphans: list[dict] = []
    for mod, path in sorted(modules.items()):
        # Check if the module or any parent package import would reference it
        imported = mod in all_imports
        # Also check if a parent module is imported (which implies this sub-module exists)
        if not imported:
            parts = mod.split(".")
            for i in range(len(parts), 0, -1):
                parent = ".".join(parts[:i])
                if parent in all_imports:
                    imported = True
                    break

        if not imported:
            orphans.append({
                "module": mod,
                "path": str(path.relative_to(root)),
                "is_entry_point": path.name in ENTRY_POINT_BASENAMES,
            })

    return orphans


def format_report(orphans: list[dict], use_json: bool = False) -> str:
    """Format orphan list for output."""
    if use_json:
        return json.dumps(orphans, indent=2)

    if not orphans:
        return "No orphan modules found. All metabolon .py files are imported somewhere."

    lines = [f"Found {len(orphans)} orphan module(s) in metabolon/:\n"]
    entry_points = [o for o in orphans if o["is_entry_point"]]
    true_orphans = [o for o in orphans if not o["is_entry_point"]]

    if true_orphans:
        lines.append("  Orphans (never imported):")
        for o in true_orphans:
            lines.append(f"    {o['module']}")
            lines.append(f"      ({o['path']})")

    if entry_points:
        lines.append("\n  Entry points (not imported by design):")
        for o in entry_points:
            lines.append(f"    {o['module']}")
            lines.append(f"      ({o['path']})")

    lines.append(f"\n  Total: {len(true_orphans)} orphans, {len(entry_points)} entry points")
    return "\n".join(lines)


def main() -> int:
    use_json = "--json" in sys.argv
    dir_override = None
    for i, arg in enumerate(sys.argv[1:], 1):
        if arg == "--dir" and i < len(sys.argv) - 1:
            dir_override = Path(sys.argv[i + 1])

    root = dir_override if dir_override else ROOT
    metabolon_dir = root / "metabolon"

    if not metabolon_dir.is_dir():
        print(f"Error: {metabolon_dir} not found", file=sys.stderr)
        return 1

    orphans = find_orphans(root, metabolon_dir)
    print(format_report(orphans, use_json=use_json))
    return 0


if __name__ == "__main__":
    sys.exit(main())

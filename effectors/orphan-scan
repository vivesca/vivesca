#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""orphan-scan — Find .py files in metabolon/ not imported anywhere.

Scans every non-__init__.py module under metabolon/ and checks whether
any .py file in the repository imports it.  Modules with zero references
are reported as orphans.

Usage:
    orphan-scan              # List orphans to stdout
    orphan-scan --json       # Machine-readable JSON output
    orphan-scan --path DIR   # Scan a different root (default: ~/germline)
"""
from __future__ import annotations

import ast
import json
import sys
from pathlib import Path

DEFAULT_ROOT = Path.home() / "germline"

_ENTRY_POINT_FILES = {"__main__.py"}


# ── Public API (exported for tests) ────────────────────────────────────────


def collect_modules(metabolon_dir: Path) -> list[Path]:
    """Return sorted list of .py files under metabolon_dir excluding __init__.py."""
    return sorted(
        p for p in metabolon_dir.rglob("*.py")
        if p.name != "__init__.py"
    )


def file_to_module(path: Path, root: Path) -> str:
    """Convert a file path to a dotted module string.

    e.g. metabolon/organelles/crispr.py -> metabolon.organelles.crispr
    """
    rel = path.relative_to(root)
    parts = list(rel.with_suffix("").parts)
    return ".".join(parts)


def build_import_index(root: Path) -> set[str]:
    """Scan all .py files under *root* and return the set of module tokens
    that appear in import statements.

    For ``from metabolon.organelles import crispr`` stores both
    ``metabolon.organelles`` and ``crispr``.
    """
    referenced: set[str] = set()

    for py_file in root.rglob("*.py"):
        try:
            source = py_file.read_text(errors="ignore")
        except OSError:
            continue
        try:
            tree = ast.parse(source, filename=str(py_file))
        except SyntaxError:
            continue

        for node in ast.walk(tree):
            if isinstance(node, ast.Import):
                for alias in node.names:
                    referenced.add(alias.name)
            elif isinstance(node, ast.ImportFrom):
                if node.module:
                    referenced.add(node.module)
                    # Store parent packages too
                    parts = node.module.split(".")
                    for i in range(1, len(parts)):
                        referenced.add(".".join(parts[:i]))
                # Store the names being imported so that
                # `from metabolon.organelles import nucleus` references "nucleus"
                for alias in node.names:
                    referenced.add(alias.name)
                    if node.module:
                        referenced.add(f"{node.module}.{alias.name}")

    return referenced


def find_orphans(root: Path) -> list[dict]:
    """Return list of orphan module dicts with keys path, module."""
    metabolon_dir = root / "metabolon"
    if not metabolon_dir.is_dir():
        return []

    modules = collect_modules(metabolon_dir)
    referenced = build_import_index(root)
    orphans: list[dict] = []

    for mod_path in modules:
        # Skip __main__.py — entry point, not an import target
        if mod_path.name in _ENTRY_POINT_FILES:
            continue

        dotted = file_to_module(mod_path, root)
        leaf = mod_path.stem

        if dotted not in referenced and leaf not in referenced:
            orphans.append({
                "path": str(mod_path.relative_to(root)),
                "module": dotted,
            })

    return orphans


def format_human(orphans: list[dict], root: Path) -> str:
    """Format orphans as a human-readable report."""
    if not orphans:
        return "No orphan modules found in metabolon/."

    mod_count = _count_total_modules(root)
    pct = len(orphans) / mod_count * 100 if mod_count else 0

    lines = [f"Orphan modules in metabolon/ ({len(orphans)} found):\n"]
    for o in orphans:
        lines.append(f"  {o['path']}")
    lines.append(f"\n  {len(orphans)} of {mod_count} modules ({pct:.1f}%) are orphans.")
    return "\n".join(lines)


def format_json(orphans: list[dict], root: Path) -> str:
    """Format orphans as JSON with summary stats."""
    mod_count = _count_total_modules(root)
    return json.dumps({
        "root": str(root),
        "total_modules": mod_count,
        "orphan_count": len(orphans),
        "orphan_pct": round(len(orphans) / mod_count * 100, 1) if mod_count else 0,
        "orphans": orphans,
    }, indent=2)


def _count_total_modules(root: Path) -> int:
    """Count non-__init__.py modules in metabolon/."""
    metabolon_dir = root / "metabolon"
    if not metabolon_dir.is_dir():
        return 0
    return sum(
        1 for p in metabolon_dir.rglob("*.py")
        if p.name != "__init__.py"
    )


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]
    use_json = "--json" in args
    root = DEFAULT_ROOT

    for i, a in enumerate(args):
        if a == "--path" and i + 1 < len(args):
            root = Path(args[i + 1])

    orphans = find_orphans(root)

    if use_json:
        print(format_json(orphans, root))
    else:
        print(format_human(orphans, root))

    return 0


if __name__ == "__main__":
    sys.exit(main())

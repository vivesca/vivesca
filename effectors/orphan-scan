#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""orphan-scan — Find .py files in metabolon/ not imported anywhere.

Scans every non-__init__.py module under metabolon/ and checks whether
any .py file in the repository imports it.  Modules with zero references
are reported as orphans.  __main__.py files are reported as entry points.

Usage:
    orphan-scan              # List orphans to stdout
    orphan-scan --json       # Machine-readable JSON output
    orphan-scan --path DIR   # Scan a different root (default: ~/germline)
"""
from __future__ import annotations

import ast
import json
import re
import sys
from pathlib import Path

DEFAULT_ROOT = Path.home() / "germline"

_ENTRY_POINT_STEMS = {"__main__"}

_TEST_FILE_RE = re.compile(r"^test_.*\.py$|^conftest\.py$")


# ── Public API (exported for tests) ────────────────────────────────────────


def module_path(py_file: Path, root: Path) -> str:
    """Convert a .py file to its dotted module path relative to root.

    metabolon/organelles/chromatin.py -> metabolon.organelles.chromatin
    metabolon/__init__.py             -> metabolon
    """
    rel = py_file.relative_to(root).with_suffix("")
    return ".".join(rel.parts)


def collect_metabolon_modules(metabolon_dir: Path) -> set[str]:
    """Return dotted module names for every .py file under metabolon_dir.

    Excludes __init__.py, test_*.py, and conftest.py.
    """
    modules: set[str] = set()
    root = metabolon_dir.parent
    for p in metabolon_dir.rglob("*.py"):
        if p.name == "__init__.py":
            continue
        if _TEST_FILE_RE.match(p.name):
            continue
        modules.add(module_path(p, root))
    return modules


def extract_imports_from_file(py_file: Path) -> set[str]:
    """Return the set of module tokens referenced by import statements.

    Handles ``import foo.bar`` and ``from foo.bar import baz``.
    For ``from foo.bar import baz``, stores both ``foo.bar`` and ``foo``.
    Returns empty set on syntax errors.
    """
    try:
        source = py_file.read_text(errors="ignore")
    except OSError:
        return set()

    try:
        tree = ast.parse(source, filename=str(py_file))
    except SyntaxError:
        return set()

    imports: set[str] = set()
    for node in ast.walk(tree):
        if isinstance(node, ast.Import):
            for alias in node.names:
                imports.add(alias.name)
        elif isinstance(node, ast.ImportFrom):
            if node.module:
                imports.add(node.module)
                # Store parent packages so that
                # `from metabolon.organelles import crispr` marks
                # metabolon.organelles as referenced.
                parts = node.module.split(".")
                for i in range(1, len(parts)):
                    imports.add(".".join(parts[:i]))
            # Capture each imported name so that
            # `from metabolon.organelles import nucleus` marks nucleus
            # as referenced (leaf match in find_orphans).
            for alias in node.names:
                name = alias.name
                imports.add(name)
                if node.module:
                    imports.add(f"{node.module}.{name}")

    return imports


def find_orphans(root: Path) -> list[dict]:
    """Return orphan and entry-point module dicts.

    Each dict has keys: module, path, is_entry_point.
    """
    metabolon_dir = root / "metabolon"
    if not metabolon_dir.is_dir():
        return []

    all_modules = collect_metabolon_modules(metabolon_dir)

    # Build index of every module token imported anywhere in the project
    referenced: set[str] = set()
    for py_file in root.rglob("*.py"):
        referenced.update(extract_imports_from_file(py_file))

    results: list[dict] = []
    for mod in sorted(all_modules):
        leaf = mod.rsplit(".", 1)[-1]
        is_imported = mod in referenced or leaf in referenced
        if not is_imported:
            # Convert dotted module back to relative path
            rel_path = mod.replace(".", "/") + ".py"
            is_ep = leaf in _ENTRY_POINT_STEMS
            results.append({
                "module": mod,
                "path": rel_path,
                "is_entry_point": is_ep,
            })

    return results


def format_report(orphans: list[dict], *, use_json: bool = False) -> str:
    """Format orphans for output.  Returns human-readable or JSON string."""
    if use_json:
        return json.dumps(orphans, indent=2)

    if not orphans:
        return "No orphan modules found in metabolon/."

    entry_points = [o for o in orphans if o["is_entry_point"]]
    pure_orphans = [o for o in orphans if not o["is_entry_point"]]

    lines: list[str] = []
    if pure_orphans:
        lines.append("Orphans (never imported):")
        for o in pure_orphans:
            lines.append(f"  {o['path']}")

    if entry_points:
        lines.append("Entry points (not imported by design):")
        for o in entry_points:
            lines.append(f"  {o['path']}")

    summary = f"\n  {len(pure_orphans)} orphans, {len(entry_points)} entry points"
    lines.append(summary)
    return "\n".join(lines)


# ── CLI ─────────────────────────────────────────────────────────────────────


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]
    use_json = "--json" in args
    root = DEFAULT_ROOT

    for i, a in enumerate(args):
        if a == "--path" and i + 1 < len(args):
            root = Path(args[i + 1])

    orphans = find_orphans(root)
    print(format_report(orphans, use_json=use_json))
    return 0


if __name__ == "__main__":
    sys.exit(main())

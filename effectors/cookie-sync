#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["playwright"]
# ///
from __future__ import annotations

"""
cookie-sync — Export Chrome cookies to JSON and import into Playwright.

Export reads Chrome's Cookies SQLite DB, decrypts v10/v11 encrypted values
using the macOS Keychain, and writes a portable JSON file.

Usage:
    cookie-sync export [--profile Default] [--domain example.com]
    cookie-sync import <cookies.json>

Output format (JSON array):
[
  {
    "domain": ".example.com",
    "name": "session_id",
    "value": "decrypted_value",
    "path": "/",
    "expires": 1735689600.0,
    "httponly": true,
    "secure": true,
    "samesite": "Lax"
  }
]
"""

import argparse
import base64
import hashlib
import json
import os
import platform
import shutil
import sqlite3
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any

IS_MACOS = platform.system() == "Darwin"

# ── Constants ──────────────────────────────────────────────────────────────────

if IS_MACOS:
    CHROME_BASE = Path.home() / "Library" / "Application Support" / "Google" / "Chrome"
else:
    CHROME_BASE = Path.home() / ".config" / "google-chrome"
DEFAULT_OUTPUT = (
    Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local" / "share"))
    / "vivesca"
    / "cookies.json"
)

PBKDF2_SALT = b"saltysalt"
PBKDF2_ITERATIONS = 1003 if IS_MACOS else 1
KEY_LENGTH = 16  # AES-128

V10_PREFIX = b"v10"
V11_PREFIX = b"v11"


# ── macOS Keychain helpers ────────────────────────────────────────────────────


def get_chrome_key() -> bytes:
    """Retrieve Chrome Safe Storage key.

    macOS: Uses Keychain via ``security find-generic-password``.
    Linux: Chrome uses "peanuts" as the default password for PBKDF2.
    """
    if IS_MACOS:
        result = subprocess.run(
            ["security", "find-generic-password", "-w", "-s", "Chrome Safe Storage"],
            capture_output=True,
            text=True,
            timeout=300,
        )
        if result.returncode != 0:
            raise RuntimeError(f"Failed to get Chrome Safe Storage key: {result.stderr.strip()}")
        password = result.stdout.strip().encode("utf-8")
    else:
        # Linux: Chrome uses the literal string "peanuts" as the password
        password = b"peanuts"
    return derive_key(password)


def derive_key(password: bytes) -> bytes:
    """Derive AES-128 key via PBKDF2-HMAC-SHA1 (Chrome's KDF on macOS)."""
    return hashlib.pbkdf2_hmac("sha1", password, PBKDF2_SALT, PBKDF2_ITERATIONS, dklen=KEY_LENGTH)


# ── Decryption ────────────────────────────────────────────────────────────────


def decrypt_v10(encrypted: bytes, key: bytes) -> str:
    """Decrypt v10 cookie (AES-128-CBC, IV = 16 space bytes, PKCS7)."""
    from cryptography.hazmat.primitives import padding as sym_padding
    from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes

    iv = b" " * 16
    ciphertext = encrypted[3:]  # strip "v10"
    cipher = Cipher(algorithms.AES(key), modes.CBC(iv))
    decryptor = cipher.decryptor()
    padded = decryptor.update(ciphertext) + decryptor.finalize()
    unpadder = sym_padding.PKCS7(128).unpadder()
    plaintext = unpadder.update(padded) + unpadder.finalize()
    return plaintext.decode("utf-8", errors="replace")


def decrypt_v11(encrypted: bytes, key: bytes) -> str:
    """Decrypt v11 cookie (AES-128-GCM).

    Layout: b"v11" + 12-byte nonce + ciphertext + 16-byte auth tag.
    """
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM

    nonce = encrypted[3:15]
    ciphertext_and_tag = encrypted[15:]
    aesgcm = AESGCM(key)
    plaintext = aesgcm.decrypt(nonce, ciphertext_and_tag, None)
    return plaintext.decode("utf-8", errors="replace")


def decrypt_cookie_value(raw: bytes | None, key: bytes) -> str:
    """Decrypt a Chrome cookie value, handling v10, v11, and plaintext."""
    if raw is None:
        return ""
    if raw.startswith(V10_PREFIX):
        return decrypt_v10(raw, key)
    if raw.startswith(V11_PREFIX):
        return decrypt_v11(raw, key)
    return raw.decode("utf-8", errors="replace")


# ── SameSite mapping ──────────────────────────────────────────────────────────

SAMESITE_MAP = {-1: "None", 0: "Unspecified", 1: "Lax", 2: "Strict", 3: "None"}


def _samesite_str(val: int) -> str:
    """Convert Chrome SameSite int to string label."""
    return SAMESITE_MAP.get(val, "Unspecified")


# ── SQLite helpers ────────────────────────────────────────────────────────────


def read_cookies(db_path: Path, domain_filter: str | None = None) -> list[dict[str, Any]]:
    """Read cookies from Chrome's SQLite database.

    Chrome locks the DB, so we copy to a temp file first.
    Returns dicts with ``encrypted_value`` as raw bytes (base64-encoded in
    ``value`` field) and a ``_encrypted`` flag.
    """
    tmp_fd, tmp_path = tempfile.mkstemp(suffix=".db")
    os.close(tmp_fd)
    try:
        shutil.copy2(db_path, tmp_path)
        conn = sqlite3.connect(tmp_path)
        cur = conn.cursor()
        query = (
            "SELECT host_key, name, path, encrypted_value, expires_utc, "
            "is_secure, is_httponly, samesite FROM cookies"
        )
        params: tuple = ()
        if domain_filter:
            query += " WHERE host_key LIKE ?"
            params = (f"%{domain_filter}%",)
        cur.execute(query, params)
        cookies: list[dict[str, Any]] = []
        for row in cur.fetchall():
            host_key, name, path, enc_val, expires_utc, is_secure, is_httponly, samesite = row
            cookies.append(
                {
                    "domain": host_key,
                    "name": name,
                    "path": path,
                    "value": base64.b64encode(enc_val).decode("ascii") if enc_val else "",
                    "expires": expires_utc,
                    "secure": bool(is_secure),
                    "httpOnly": bool(is_httponly),
                    "sameSite": _samesite_str(samesite),
                    "_encrypted": bool(enc_val),
                }
            )
        conn.close()
    finally:
        os.unlink(tmp_path)
    return cookies


def decrypt_exported_cookies(cookies: list[dict[str, Any]], key: bytes) -> list[dict[str, Any]]:
    """Replace base64-encoded encrypted_value with decrypted plaintext."""
    for c in cookies:
        if not c.get("_encrypted") or not c.get("value"):
            c.pop("_encrypted", None)
            continue
        raw = base64.b64decode(c["value"])
        if raw[:3] in (V10_PREFIX, V11_PREFIX):
            c["value"] = decrypt_cookie_value(raw, key)
        else:
            c["value"] = raw.decode("utf-8", errors="replace")
        c.pop("_encrypted", None)
    return cookies


# ── Import into Playwright ────────────────────────────────────────────────────


def import_cookies(cookies_path: Path, browser_type: str = "chromium") -> None:
    """Load cookies from JSON and add them to a Playwright browser context."""
    import asyncio

    from playwright.async_api import async_playwright  # type: ignore[import-untyped]

    cookies = json.loads(cookies_path.read_text(encoding="utf-8"))
    if not cookies:
        print("No cookies to import.")
        return

    async def _run() -> None:
        async with async_playwright() as p:
            launcher = {
                "chromium": p.chromium,
                "firefox": p.firefox,
                "webkit": p.webkit,
            }.get(browser_type, p.chromium)
            browser = await launcher.launch(headless=True)
            context = await browser.new_context()
            await context.add_cookies(cookies)
            print(f"Added {len(cookies)} cookies to {browser_type} context.")
            await browser.close()

    asyncio.run(_run())


# ── CLI ───────────────────────────────────────────────────────────────────────


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="cookie-sync",
        description="Chrome cookie export/import for Playwright",
    )
    sub = parser.add_subparsers(dest="command")

    exp = sub.add_parser("export", help="Export cookies from Chrome to JSON")
    exp.add_argument("--profile", default="Default", help="Chrome profile name (default: Default)")
    exp.add_argument("--domain", default=None, help="Filter cookies by domain substring")
    exp.add_argument("--output", "-o", default=None, help="Output JSON path")
    exp.add_argument(
        "--no-decrypt", action="store_true", help="Skip decryption (export raw values)"
    )

    imp = sub.add_parser("import", help="Import cookies JSON into Playwright context")
    imp.add_argument("cookies_json", type=Path, help="Path to cookies JSON file")
    imp.add_argument("--browser", default="chromium", choices=["chromium", "firefox", "webkit"])

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.command == "export":
        db_path = CHROME_BASE / args.profile / "Cookies"
        if not db_path.exists():
            print(f"Chrome cookies DB not found: {db_path}", file=sys.stderr)
            return 1

        output_path = Path(args.output) if args.output else DEFAULT_OUTPUT
        output_path.parent.mkdir(parents=True, exist_ok=True)

        cookies = read_cookies(db_path, domain_filter=args.domain)

        if not args.no_decrypt:
            try:
                key = get_chrome_key()
                cookies = decrypt_exported_cookies(cookies, key)
            except Exception as exc:
                print(
                    f"Decryption failed (use --no-decrypt to skip): {exc}",
                    file=sys.stderr,
                )
                return 1
        else:
            for c in cookies:
                c.pop("_encrypted", None)

        output_path.write_text(json.dumps(cookies, indent=2, ensure_ascii=False), encoding="utf-8")
        print(f"Exported {len(cookies)} cookies to {output_path}")
        return 0

    elif args.command == "import":
        if not args.cookies_json.exists():
            print(f"File not found: {args.cookies_json}", file=sys.stderr)
            return 1
        import_cookies(args.cookies_json, browser_type=args.browser)
        return 0

    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

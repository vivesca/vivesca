#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["playwright"]
# ///
"""
Export cookies from Mac Chrome's Cookies SQLite DB to JSON, and import into Playwright.

Usage:
    cookie-sync export [--profile Default] [--domain example.com]
    cookie-sync import <cookies.json>

Export reads Chrome's Cookies DB, decrypts v10/v11 encrypted values via the
macOS Keychain ("Chrome Safe Storage" generic password), and writes a JSON
file to ~/.local/share/vivesca/cookies.json.

Import reads a cookies JSON file and adds every cookie to a Playwright
BrowserContext.
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import sqlite3
import subprocess
import sys
from pathlib import Path
from typing import Any

# ── Constants ──────────────────────────────────────────────────────────────────

DEFAULT_OUTPUT = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local" / "share")) / "vivesca" / "cookies.json"
CHROME_BASE = Path.home() / "Library" / "Application Support" / "Google" / "Chrome"
PBKDF2_SALT = b"saltysalt"
PBKDF2_ITERATIONS = 1003
KEY_LENGTH = 16  # AES-128
IV = b" " * 16  # 16 bytes of 0x20


# ── Chrome decryption helpers ──────────────────────────────────────────────────


def get_chrome_key() -> bytes:
    """Retrieve the Chrome Safe Storage key from the macOS Keychain."""
    result = subprocess.run(
        ["security", "find-generic-password", "-w", "-s", "Chrome Safe Storage"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        raise RuntimeError(f"Failed to get Chrome Safe Storage key: {result.stderr.strip()}")
    return result.stdout.strip().encode("utf-8")


def derive_encryption_key(password: bytes) -> bytes:
    """Derive the AES-128 key via PBKDF2-HMAC-SHA1 (Chrome's KDF)."""
    import hashlib

    return hashlib.pbkdf2_hmac("sha1", password, PBKDF2_SALT, PBKDF2_ITERATIONS, dklen=KEY_LENGTH)


def decrypt_cookie_value(encrypted: bytes, key: bytes) -> str:
    """Decrypt a Chrome v10/v11 cookie value using AES-128-CBC."""
    from Crypto.Cipher import AES  # noqa: F811 — optional dep

    if encrypted[:3] == b"v10" or encrypted[:3] == b"v11":
        ciphertext = encrypted[3:]
    else:
        # Unencrypted or unknown scheme — return as-is
        return encrypted.decode("utf-8", errors="replace")

    cipher = AES.new(key, AES.MODE_CBC, IV)
    plaintext = cipher.decrypt(ciphertext)
    # Remove PKCS7 padding
    pad_len = plaintext[-1]
    if pad_len < 1 or pad_len > 16:
        return plaintext.decode("utf-8", errors="replace")
    return plaintext[:-pad_len].decode("utf-8", errors="replace")


# ── Chrome cookie DB ──────────────────────────────────────────────────────────


def read_cookies(db_path: Path, domain_filter: str | None = None) -> list[dict[str, Any]]:
    """Read cookies from Chrome's SQLite database.

    Returns a list of cookie dicts with serialisable values.
    """
    cookies: list[dict[str, Any]] = []
    # Chrome locks its DB; copy to a temp file to avoid lock errors.
    import shutil
    import tempfile

    tmp_fd, tmp_path = tempfile.mkstemp(suffix=".db")
    os.close(tmp_fd)
    try:
        shutil.copy2(db_path, tmp_path)
        conn = sqlite3.connect(tmp_path)
        cursor = conn.cursor()
        query = (
            "SELECT host_key, name, path, encrypted_value, expires_utc, "
            "is_secure, is_httponly, samesite "
            "FROM cookies"
        )
        params: tuple = ()
        if domain_filter:
            query += " WHERE host_key LIKE ?"
            params = (f"%{domain_filter}%",)
        cursor.execute(query, params)
        for row in cursor.fetchall():
            host_key, name, path, enc_val, expires_utc, is_secure, is_httponly, samesite = row
            cookies.append({
                "domain": host_key,
                "name": name,
                "path": path,
                "value": base64.b64encode(enc_val).decode("ascii") if enc_val else "",
                "expires": expires_utc,
                "secure": bool(is_secure),
                "httpOnly": bool(is_httponly),
                "sameSite": _samesite_str(samesite),
                "_encrypted": True,
            })
        conn.close()
    finally:
        os.unlink(tmp_path)
    return cookies


def _samesite_str(val: int) -> str:
    """Convert Chrome's SameSite integer to a string label."""
    return {-1: "None", 0: "Unspecified", 1: "Lax", 2: "Strict", 3: "None"}.get(val, "Unspecified")


def decrypt_exported_cookies(cookies: list[dict[str, Any]], key: bytes) -> list[dict[str, Any]]:
    """Replace base64-encoded encrypted_value with decrypted plaintext."""
    from Crypto.Cipher import AES  # noqa: F811

    for c in cookies:
        if not c.get("_encrypted") or not c.get("value"):
            continue
        raw = base64.b64decode(c["value"])
        if raw[:3] in (b"v10", b"v11"):
            cipher = AES.new(key, AES.MODE_CBC, IV)
            plaintext = cipher.decrypt(raw[3:])
            pad_len = plaintext[-1]
            if 1 <= pad_len <= 16:
                plaintext = plaintext[:-pad_len]
            c["value"] = plaintext.decode("utf-8", errors="replace")
        else:
            c["value"] = raw.decode("utf-8", errors="replace")
        del c["_encrypted"]
    return cookies


# ── Import into Playwright ─────────────────────────────────────────────────────


def import_cookies(cookies_path: Path, browser_type: str = "chromium") -> None:
    """Load cookies from JSON and add them to a Playwright browser context."""
    import asyncio

    from playwright.async_api import async_playwright  # type: ignore[import-untyped]

    cookies = json.loads(cookies_path.read_text(encoding="utf-8"))
    if not cookies:
        print("No cookies to import.")
        return

    async def _run() -> None:
        async with async_playwright() as p:
            launcher = {"chromium": p.chromium, "firefox": p.firefox, "webkit": p.webkit}.get(
                browser_type, p.chromium
            )
            browser = await launcher.launch(headless=True)
            context = await browser.new_context()
            await context.add_cookies(cookies)
            print(f"Added {len(cookies)} cookies to {browser_type} context.")
            await browser.close()

    asyncio.run(_run())


# ── CLI ────────────────────────────────────────────────────────────────────────


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Chrome cookie export/import for Playwright")
    sub = parser.add_subparsers(dest="command")

    exp = sub.add_parser("export", help="Export cookies from Chrome to JSON")
    exp.add_argument("--profile", default="Default", help="Chrome profile name (default: Default)")
    exp.add_argument("--domain", default=None, help="Filter cookies by domain substring")
    exp.add_argument("--output", "-o", default=None, help="Output JSON path")
    exp.add_argument("--no-decrypt", action="store_true", help="Skip decryption (export raw values)")

    imp = sub.add_parser("import", help="Import cookies JSON into Playwright context")
    imp.add_argument("cookies_json", type=Path, help="Path to cookies JSON file")
    imp.add_argument("--browser", default="chromium", choices=["chromium", "firefox", "webkit"])

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.command == "export":
        db_path = CHROME_BASE / args.profile / "Cookies"
        if not db_path.exists():
            print(f"Chrome cookies DB not found: {db_path}", file=sys.stderr)
            return 1
        output_path = Path(args.output) if args.output else DEFAULT_OUTPUT
        output_path.parent.mkdir(parents=True, exist_ok=True)

        cookies = read_cookies(db_path, domain_filter=args.domain)

        if not args.no_decrypt:
            try:
                raw_key = get_chrome_key()
                aes_key = derive_encryption_key(raw_key)
                cookies = decrypt_exported_cookies(cookies, aes_key)
            except Exception as exc:
                print(f"Decryption failed (use --no-decrypt to skip): {exc}", file=sys.stderr)
                return 1
        else:
            # Strip _encrypted flag even without decryption
            for c in cookies:
                c.pop("_encrypted", None)

        output_path.write_text(json.dumps(cookies, indent=2, ensure_ascii=False), encoding="utf-8")
        print(f"Exported {len(cookies)} cookies to {output_path}")
        return 0

    elif args.command == "import":
        if not args.cookies_json.exists():
            print(f"File not found: {args.cookies_json}", file=sys.stderr)
            return 1
        import_cookies(args.cookies_json, browser_type=args.browser)
        return 0

    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

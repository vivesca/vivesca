#!/usr/bin/env -S uv run --script --python 3.13
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""
proteostasis -- dependency auto-updater with rollback.

Maintains the organism's external dependency pool:
detect outdated → upgrade → smoke test → rollback on failure.

Usage:
    proteostasis                # auto-update (respects 20h frequency gate)
    proteostasis --force        # bypass frequency gate
    proteostasis --dry-run      # check + print, do not upgrade or update state
"""

import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone, timedelta
from pathlib import Path


def _ver_tuple(v: str) -> tuple[int, ...]:
    """Parse '3.1.2' into (3, 1, 2) for comparison."""
    return tuple(int(x) for x in v.split(".") if x.isdigit())


STATE_PATH = Path.home() / ".config" / "dep-check" / "state.json"
HKT = timezone(timedelta(hours=8))
FREQUENCY_HOURS = 20
DRY_RUN = "--dry-run" in sys.argv
FORCE = "--force" in sys.argv

# Keywords that flag a CC release as potentially breaking
CC_BREAKING_KEYWORDS = [
    "breaking", "removed", "deprecated", "no longer",
    "hook", "plugin", "permissions", "api change", "renamed",
]

# Git-pinned packages: skip normal auto-upgrade, only upgrade when
# PyPI has >= min_version. (pip_name, min_version)
PY_GIT_PINNED = {
    "fastmcp": "3.1.2",
}

# Smoke test: imports that must succeed after any Python upgrade.
# Each entry is a dotted import path.
PY_SMOKE_IMPORTS = [
    "fastmcp.tools",
    "anthropic",
    "metabolon.enzymes",
    "metabolon.morphology",
]


# ── PATH helper ──────────────────────────────────────────────────────────────

def _path() -> str:
    """Build a PATH that resolves gh, npm, pip regardless of invocation context."""
    extra = [
        "/opt/homebrew/bin",
        str(Path.home() / "bin"),
        str(Path.home() / "officina" / "bin"),
        str(Path.home() / ".cargo" / "bin"),
        str(Path.home() / ".local" / "bin"),
        str(Path.home() / ".bun" / "bin"),
    ]
    return ":".join(extra) + ":" + os.environ.get("PATH", "")


# ── State ────────────────────────────────────────────────────────────────────

def _migrate_known_version(v) -> dict:
    """Upgrade a bare string value from the old schema to the new nested dict."""
    if isinstance(v, dict):
        return v
    return {"installed": v, "latest_seen": v, "todo_created_for": None}


def load_state() -> dict:
    try:
        raw = json.loads(STATE_PATH.read_text())
        kv = raw.get("known_versions", {})
        raw["known_versions"] = {k: _migrate_known_version(val) for k, val in kv.items()}
        return raw
    except Exception:
        return {"known_versions": {}, "last_run": None, "last_notified": None}


def save_state(state: dict) -> None:
    if DRY_RUN:
        return
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2))


def should_run(state: dict) -> bool:
    if FORCE:
        return True
    last = state.get("last_run")
    if not last:
        return True
    try:
        dt = datetime.fromisoformat(last)
        return (datetime.now(HKT) - dt).total_seconds() > FREQUENCY_HOURS * 3600
    except Exception:
        return True


# ── Subprocess helper ────────────────────────────────────────────────────────

def run(cmd: list, timeout: int = 15) -> tuple[bool, str]:
    """Run a command with enriched PATH. Returns (success, output). Never raises."""
    try:
        r = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            env={**os.environ, "PATH": _path()},
        )
        out = (r.stdout or "").strip()
        err = (r.stderr or "").strip()
        combined = out if out else err
        return r.returncode == 0, combined
    except subprocess.TimeoutExpired:
        return False, f"[timed out after {timeout}s]"
    except FileNotFoundError:
        return False, f"[command not found: {cmd[0]}]"
    except Exception as e:
        return False, str(e)


# ── Smoke test ───────────────────────────────────────────────────────────────

def smoke_test() -> tuple[bool, str]:
    """Quick import smoke test using the mise-managed Python."""
    imports = "; ".join(f"__import__('{m}')" for m in PY_SMOKE_IMPORTS)
    try:
        r = subprocess.run(
            [_mise_python(), "-c", imports],
            capture_output=True, text=True, timeout=15,
        )
        return r.returncode == 0, (r.stdout or r.stderr or "").strip()
    except Exception as e:
        return False, str(e)


# ── Claude Code (alert only — it auto-updates itself) ───────────────────────

def get_installed_cc_version() -> str | None:
    link = Path.home() / ".local" / "bin" / "claude"
    try:
        target = link.resolve()
        return target.name
    except Exception:
        return None


def get_latest_cc_release() -> tuple[str | None, str]:
    ok, out = run(
        ["gh", "release", "view", "--repo", "anthropics/claude-code",
         "--json", "tagName,body"],
        timeout=20,
    )
    if not ok:
        return None, out
    try:
        d = json.loads(out)
        tag = d["tagName"].lstrip("v")
        body = d.get("body", "")
        return tag, body
    except Exception as e:
        return None, str(e)


def check_claude_code(state: dict) -> list[str]:
    """CC auto-updates itself. We only alert on breaking changes."""
    alerts = []
    installed = get_installed_cc_version()
    if not installed:
        return []

    latest, body = get_latest_cc_release()
    if latest is None:
        return []

    kv = state["known_versions"].get("claude-code")
    if not isinstance(kv, dict):
        kv = {"installed": installed, "latest_seen": installed, "todo_created_for": None}

    if latest != installed and is_breaking(body):
        url = f"https://github.com/anthropics/claude-code/releases/tag/v{latest}"
        alerts.append(f"CC BREAKING: {installed} → {latest} — {url}")

    kv["installed"] = installed
    kv["latest_seen"] = latest
    state["known_versions"]["claude-code"] = kv
    return alerts


def is_breaking(body: str) -> bool:
    lower = body.lower()
    return any(kw in lower for kw in CC_BREAKING_KEYWORDS)


# ── Python auto-update ───────────────────────────────────────────────────────

def _pip_outdated() -> dict[str, dict]:
    """Get all outdated pip packages. Returns {name: {version, latest_version}}."""
    ok, out = run(
        [_mise_python(), "-m", "pip", "list", "--outdated", "--format=json"],
        timeout=30,
    )
    if not ok or not out:
        return {}
    try:
        return {p["name"].lower(): p for p in json.loads(out)}
    except Exception:
        return {}


def _pip_snapshot() -> dict[str, str]:
    """Snapshot all installed pip versions. Returns {name: version}."""
    ok, out = run([_mise_python(), "-m", "pip", "list", "--format=json"], timeout=15)
    if not ok or not out:
        return {}
    try:
        return {p["name"].lower(): p["version"] for p in json.loads(out)}
    except Exception:
        return {}


def _mise_python() -> str:
    """Resolve the mise-managed python3."""
    p = Path.home() / ".local/share/mise/shims/python3"
    return str(p) if p.exists() else "python3"


def auto_update_python(state: dict) -> list[str]:
    """Upgrade all outdated pip packages. Smoke test + rollback."""
    alerts = []
    outdated = _pip_outdated()
    if not outdated:
        return []

    # Exclude git-pinned packages from bulk upgrade
    to_upgrade = {k: v for k, v in outdated.items() if k not in PY_GIT_PINNED}

    if DRY_RUN:
        for name, info in sorted(to_upgrade.items()):
            alerts.append(f"pip would upgrade: {name} {info['version']} → {info['latest_version']}")
        for name, min_ver in PY_GIT_PINNED.items():
            alerts.append(f"pip git-pinned: {name} (waiting for >={min_ver} on PyPI)")
        return alerts

    if to_upgrade:
        # Snapshot before upgrade
        snapshot = _pip_snapshot()
        pkg_names = list(to_upgrade.keys())

        ok, out = run(
            [_mise_python(), "-m", "pip", "install", "--upgrade", "--break-system-packages"]
            + pkg_names,
            timeout=300,
        )
        if not ok:
            alerts.append(f"pip upgrade failed: {out[:100]}")
        else:
            # Detect what changed
            new_versions = _pip_snapshot()
            upgraded = {
                k: (snapshot.get(k, "?"), new_versions.get(k, "?"))
                for k in pkg_names
                if snapshot.get(k) != new_versions.get(k)
            }

            if upgraded:
                passed, detail = smoke_test()
                if passed:
                    for pkg, (old, new) in sorted(upgraded.items()):
                        alerts.append(f"pip upgraded: {pkg} {old} → {new}")
                else:
                    # Rollback all changed packages
                    for pkg, (old, _) in upgraded.items():
                        if old != "?":
                            run(
                                [_mise_python(), "-m", "pip", "install",
                                 "--break-system-packages", f"{pkg}=={old}"],
                                timeout=60,
                            )
                    alerts.append(
                        f"pip ROLLBACK: smoke test failed after upgrading "
                        f"{len(upgraded)} packages. Reverted. Detail: {detail[:200]}"
                    )

    # Git-pinned: check if target version is on PyPI
    for pip_name, min_ver in PY_GIT_PINNED.items():
        ok, out = run([_mise_python(), "-m", "pip", "index", "versions", pip_name], timeout=15)
        if not ok:
            continue
        first_line = out.split("\n")[0] if out else ""
        m = re.search(r"\(([^)]+)\)", first_line)
        if not m:
            continue
        pypi_latest = m.group(1)
        if _ver_tuple(pypi_latest) >= _ver_tuple(min_ver):
            run(
                [_mise_python(), "-m", "pip", "install",
                 "--break-system-packages", f"{pip_name}>={min_ver}"],
                timeout=60,
            )
            alerts.append(f"pip unpinned: {pip_name} → {pypi_latest} (git pin resolved)")

    return alerts


# ── npm auto-update ──────────────────────────────────────────────────────────

def auto_update_npm(state: dict) -> list[str]:
    """Upgrade all outdated npm globals. Rollback individual failures."""
    alerts = []

    ok, out = run(["npm", "outdated", "-g", "--json"], timeout=30)
    if not out:
        return []
    try:
        data = json.loads(out)
    except Exception:
        return []

    for pkg, info in sorted(data.items()):
        current = info.get("current") or info.get("wanted")
        latest = info.get("latest")
        if not latest or current == latest:
            continue

        if DRY_RUN:
            alerts.append(f"npm would upgrade: {pkg} {current or '?'} → {latest}")
            continue

        ok, out = run(["npm", "install", "-g", f"{pkg}@latest"], timeout=120)
        if ok:
            alerts.append(f"npm upgraded: {pkg} {current or '?'} → {latest}")
        elif current:
            run(["npm", "install", "-g", f"{pkg}@{current}"], timeout=60)
            alerts.append(f"npm ROLLBACK: {pkg} failed, reverted to {current}")

    return alerts


# ── Main ─────────────────────────────────────────────────────────────────────

def main() -> None:
    state = load_state()

    if not should_run(state):
        return

    alerts: list[str] = []
    alerts += check_claude_code(state)
    alerts += auto_update_python(state)
    alerts += auto_update_npm(state)

    now_str = datetime.now(HKT).isoformat()
    state["last_run"] = now_str
    if alerts:
        state["last_notified"] = now_str

    save_state(state)

    if alerts:
        print("\n".join(alerts))


if __name__ == "__main__":
    try:
        main()
    except Exception:
        sys.exit(0)

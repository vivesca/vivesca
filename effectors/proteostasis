#!/usr/bin/env -S uv run --script --python 3.13
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""
proteostasis -- dependency auto-updater with diagnosis.

Maintains the organism's external dependency pool:
detect outdated → upgrade → smoke test → diagnose → fix → emit signal if stuck.

Usage:
    proteostasis                # auto-update (respects 20h frequency gate)
    proteostasis --force        # bypass frequency gate
    proteostasis --dry-run      # check + print, do not upgrade or update state
"""

import json
import os
import re
import subprocess
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path


def _ver_tuple(v: str) -> tuple[int, ...]:
    return tuple(int(x) for x in v.split(".") if x.isdigit())


STATE_PATH = Path.home() / ".config" / "proteostasis" / "state.json"
SIGNAL_PATH = Path.home() / "epigenome" / "chromatin" / "immunity" / "proteostasis-blocked.json"
HKT = timezone(timedelta(hours=8))
FREQUENCY_HOURS = 20
DRY_RUN = "--dry-run" in sys.argv
FORCE = "--force" in sys.argv

CC_BREAKING_KEYWORDS = [
    "breaking",
    "removed",
    "deprecated",
    "no longer",
    "hook",
    "plugin",
    "permissions",
    "api change",
    "renamed",
]

# Git-pinned: skip normal upgrade, auto-install when PyPI has >= min_version.
PY_GIT_PINNED = {
    "fastmcp": "3.1.2",
}

# Smoke test imports that must succeed after any upgrade.
PY_SMOKE_IMPORTS = [
    "fastmcp.tools",
    "anthropic",
    "metabolon.enzymes",
    "metabolon.morphology",
]


# ── Helpers ──────────────────────────────────────────────────────────────────


def _path() -> str:
    extra = [
        "/opt/homebrew/bin",
        "/usr/local/bin",
        str(Path.home() / ".cargo" / "bin"),
        str(Path.home() / ".local" / "bin"),
        str(Path.home() / ".bun" / "bin"),
        str(Path.home() / "germline" / "effectors"),
    ]
    return ":".join(extra) + ":" + os.environ.get("PATH", "")


def _uv() -> str:
    for p in [
        "/opt/homebrew/bin/uv",
        str(Path.home() / ".cargo/bin/uv"),
        str(Path.home() / ".local/bin/uv"),
    ]:
        if Path(p).exists():
            return p
    return "uv"


def _mise_python() -> str:
    p = Path.home() / ".local/share/mise/shims/python3"
    return str(p) if p.exists() else "python3"


def run(cmd: list, timeout: int = 15) -> tuple[bool, str]:
    try:
        r = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            env={**os.environ, "PATH": _path()},
        )
        out = (r.stdout or "").strip()
        err = (r.stderr or "").strip()
        return r.returncode == 0, out if out else err
    except subprocess.TimeoutExpired:
        return False, f"[timed out after {timeout}s]"
    except FileNotFoundError:
        return False, f"[not found: {cmd[0]}]"
    except Exception as e:
        return False, str(e)


# ── State ────────────────────────────────────────────────────────────────────


def load_state() -> dict:
    try:
        raw = json.loads(STATE_PATH.read_text())
        if "blocked" not in raw:
            raw["blocked"] = {}
        return raw
    except Exception:
        return {"last_run": None, "blocked": {}}


def save_state(state: dict) -> None:
    if DRY_RUN:
        return
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2))


def should_run(state: dict) -> bool:
    if FORCE or DRY_RUN:
        return True
    last = state.get("last_run")
    if not last:
        return True
    try:
        return (
            datetime.now(HKT) - datetime.fromisoformat(last)
        ).total_seconds() > FREQUENCY_HOURS * 3600
    except Exception:
        return True


# ── Signal emission ──────────────────────────────────────────────────────────


def emit_signal(blocked: dict) -> None:
    """Write blocked packages to a known location for circulation pickup."""
    if DRY_RUN:
        return
    SIGNAL_PATH.parent.mkdir(parents=True, exist_ok=True)
    if blocked:
        SIGNAL_PATH.write_text(
            json.dumps(
                {
                    "updated": datetime.now(HKT).isoformat(),
                    "blocked": blocked,
                },
                indent=2,
            )
        )
    elif SIGNAL_PATH.exists():
        SIGNAL_PATH.unlink()  # all clear — remove signal


# ── Smoke test & diagnosis ───────────────────────────────────────────────────


def smoke_test() -> tuple[bool, str]:
    imports = "; ".join(f"__import__('{m}')" for m in PY_SMOKE_IMPORTS)
    try:
        r = subprocess.run(
            [_mise_python(), "-c", imports],
            capture_output=True,
            text=True,
            timeout=15,
        )
        return r.returncode == 0, (r.stdout or r.stderr or "").strip()
    except Exception as e:
        return False, str(e)


def diagnose() -> dict:
    """Run uv pip check. Returns {pkg: {required_by, constraint, installed}}."""
    ok, out = run([_uv(), "pip", "check", "--python", _mise_python()], timeout=15)
    if ok:
        return {}
    conflicts = {}
    for line in out.splitlines():
        m = re.match(
            r"(.+?) [\d.]+ has requirement (.+?)(?:>=|<=|==|!=|~=|>|<)(.+?),"
            r" but you have (.+?) ([\d.]+)",
            line,
        )
        if m:
            source, _, _, dep_name, installed_ver = m.groups()
            conflicts[dep_name.strip()] = {
                "required_by": source.strip(),
                "constraint": line.strip(),
                "installed": installed_ver.strip(),
            }
    return conflicts


def attempt_fix(conflicts: dict) -> tuple[bool, str]:
    """Upgrade conflicting packages to resolve version mismatches."""
    if not conflicts:
        return False, "no conflicts detected"
    ok, out = run(
        [
            _uv(),
            "pip",
            "install",
            "--upgrade",
            "--python",
            _mise_python(),
            *list(conflicts.keys()),
        ],
        timeout=120,
    )
    if not ok:
        return False, f"fix failed: {out[:200]}"
    passed, detail = smoke_test()
    return passed, detail if not passed else "fixed"


# ── Claude Code ──────────────────────────────────────────────────────────────


def check_claude_code(state: dict) -> list[str]:
    installed = None
    link = Path.home() / ".local" / "bin" / "claude"
    try:
        installed = link.resolve().name
    except Exception:
        return []

    ok, out = run(
        ["gh", "release", "view", "--repo", "anthropics/claude-code", "--json", "tagName,body"],
        timeout=20,
    )
    if not ok:
        return []
    try:
        d = json.loads(out)
        latest = d["tagName"].lstrip("v")
        body = d.get("body", "")
    except Exception:
        return []

    if latest != installed and any(kw in body.lower() for kw in CC_BREAKING_KEYWORDS):
        url = f"https://github.com/anthropics/claude-code/releases/tag/v{latest}"
        return [f"CC BREAKING: {installed} → {latest} — {url}"]
    return []


# ── Python auto-update ───────────────────────────────────────────────────────


def _uv_outdated() -> dict[str, dict]:
    """All outdated pip packages via uv."""
    ok, out = run(
        [_uv(), "pip", "list", "--outdated", "--format=json", "--python", _mise_python()],
        timeout=30,
    )
    if not ok or not out:
        return {}
    try:
        return {p["name"].lower(): p for p in json.loads(out)}
    except Exception:
        return {}


def _uv_snapshot() -> dict[str, str]:
    ok, out = run(
        [_uv(), "pip", "list", "--format=json", "--python", _mise_python()],
        timeout=15,
    )
    if not ok or not out:
        return {}
    try:
        return {p["name"].lower(): p["version"] for p in json.loads(out)}
    except Exception:
        return {}


def _uv_install(*args, timeout=60) -> tuple[bool, str]:
    return run([_uv(), "pip", "install", "--python", _mise_python(), *list(args)], timeout=timeout)


def _bisect_upgrades(upgraded, blocked, alerts):
    for pkg, (old, new) in sorted(upgraded.items()):
        _uv_install(f"{pkg}=={new}")
        ok, detail = smoke_test()
        if ok:
            alerts.append(f"pip upgraded: {pkg} {old} → {new}")
        else:
            conflicts = diagnose()
            _uv_install(f"{pkg}=={old}")
            blocked[pkg] = {
                "version": new,
                "since": datetime.now(HKT).isoformat(),
                "error": detail[:300],
                "conflicts": {k: v["constraint"] for k, v in conflicts.items()},
            }
            alerts.append(
                f"pip blocked: {pkg} {new} — "
                + (
                    ", ".join(c["constraint"] for c in conflicts.values())
                    if conflicts
                    else detail[:100]
                )
            )


def auto_update_python(state: dict) -> list[str]:
    alerts = []
    outdated = _uv_outdated()
    if not outdated:
        return []

    blocked = state.get("blocked", {})
    to_upgrade = {}
    for k, v in outdated.items():
        if k in PY_GIT_PINNED:
            continue
        blk = blocked.get(k)
        if blk and blk["version"] == v["latest_version"]:
            continue  # same broken version — skip
        if blk and blk["version"] != v["latest_version"]:
            del blocked[k]  # newer version available — unblock and try
        to_upgrade[k] = v

    if DRY_RUN:
        for name, info in sorted(to_upgrade.items()):
            alerts.append(
                f"pip would upgrade: {name} {info['version']} → {info['latest_version']}"
            )
        for name, blk in sorted(blocked.items()):
            alerts.append(f"pip blocked: {name} {blk['version']} (since {blk['since']})")
        for name, min_ver in PY_GIT_PINNED.items():
            alerts.append(f"pip git-pinned: {name} (waiting for >={min_ver})")
        return alerts

    if to_upgrade:
        snapshot = _uv_snapshot()
        pkg_names = list(to_upgrade.keys())

        ok, out = _uv_install("--upgrade", *pkg_names, timeout=120)
        if not ok:
            alerts.append(f"pip upgrade failed: {out[:100]}")
        else:
            new_versions = _uv_snapshot()
            upgraded = {
                k: (snapshot.get(k, "?"), new_versions.get(k, "?"))
                for k in pkg_names
                if snapshot.get(k) != new_versions.get(k)
            }

            if upgraded:
                passed, _ = smoke_test()
                if passed:
                    for pkg, (old, new) in sorted(upgraded.items()):
                        alerts.append(f"pip upgraded: {pkg} {old} → {new}")
                else:
                    # Diagnose before reverting
                    conflicts = diagnose()
                    if conflicts:
                        fixed, _ = attempt_fix(conflicts)
                        if fixed:
                            for pkg, (old, new) in sorted(upgraded.items()):
                                alerts.append(f"pip upgraded: {pkg} {old} → {new}")
                            alerts.append(f"pip healed: {', '.join(conflicts)}")
                        else:
                            for pkg, (old, _) in upgraded.items():
                                if old != "?":
                                    _uv_install(f"{pkg}=={old}")
                            _bisect_upgrades(upgraded, blocked, alerts)
                    else:
                        for pkg, (old, _) in upgraded.items():
                            if old != "?":
                                _uv_install(f"{pkg}=={old}")
                        _bisect_upgrades(upgraded, blocked, alerts)

    state["blocked"] = blocked
    emit_signal(blocked)

    # Git-pinned: check if target version is on PyPI
    for pip_name, min_ver in PY_GIT_PINNED.items():
        ok, out = run(
            [_uv(), "pip", "index", "versions", pip_name, "--python", _mise_python()],
            timeout=15,
        )
        if not ok:
            # Fallback: try pip index
            ok, out = run([_mise_python(), "-m", "pip", "index", "versions", pip_name], timeout=15)
        if not ok:
            continue
        first_line = out.split("\n")[0] if out else ""
        m = re.search(r"\(([^)]+)\)", first_line)
        if not m:
            continue
        if _ver_tuple(m.group(1)) >= _ver_tuple(min_ver):
            _uv_install(f"{pip_name}>={min_ver}")
            alerts.append(f"pip unpinned: {pip_name} → {m.group(1)} (git pin resolved)")

    return alerts


# ── npm auto-update ──────────────────────────────────────────────────────────


def auto_update_npm(state: dict) -> list[str]:
    alerts = []
    ok, out = run(["npm", "outdated", "-g", "--json"], timeout=30)
    if not out:
        return []
    try:
        data = json.loads(out)
    except Exception:
        return []

    for pkg, info in sorted(data.items()):
        current = info.get("current") or info.get("wanted")
        latest = info.get("latest")
        if not latest or current == latest:
            continue
        if DRY_RUN:
            alerts.append(f"npm would upgrade: {pkg} {current or '?'} → {latest}")
            continue

        ok, out = run(["npm", "install", "-g", f"{pkg}@latest"], timeout=120)
        if ok:
            alerts.append(f"npm upgraded: {pkg} {current or '?'} → {latest}")
        elif current:
            run(["npm", "install", "-g", f"{pkg}@{current}"], timeout=60)
            alerts.append(f"npm failed: {pkg} (reverted to {current})")

    return alerts


# ── Main ─────────────────────────────────────────────────────────────────────


def main() -> None:
    state = load_state()
    if not should_run(state):
        return

    alerts: list[str] = []
    alerts += check_claude_code(state)
    alerts += auto_update_python(state)
    alerts += auto_update_npm(state)

    state["last_run"] = datetime.now(HKT).isoformat()
    save_state(state)

    if alerts:
        print("\n".join(alerts))


if __name__ == "__main__":
    if "--help" in sys.argv:
        print(__doc__)
        sys.exit(0)
    try:
        main()
    except Exception:
        sys.exit(0)

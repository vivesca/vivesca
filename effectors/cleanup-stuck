#!/usr/bin/env bash
# Cleanup stuck processes that cause fork exhaustion

case "${1:-}" in
  -h|--help)
    echo "cleanup-stuck — kill stuck/orphan processes (pyenv, claude, playwright)."
    echo
    echo "Usage: cleanup-stuck"
    exit 0
    ;;
esac

echo "Killing stuck pyenv processes..."
pkill -9 -f "pyenv" 2>/dev/null

echo "Killing orphan Claude agents..."
pkill -9 -f "node.*claude" 2>/dev/null
pkill -9 -f "python.*agent" 2>/dev/null

echo "Killing stuck playwright..."
pkill -9 -f "playwright" 2>/dev/null
pkill -9 -f "chromium" 2>/dev/null

echo "Process count: $(ps aux | wc -l | tr -d ' ')"
echo "Done. Open a new terminal tab for fresh environment."

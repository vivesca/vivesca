#!/usr/bin/env python3
"""golem-daemon — Task queue processor for golem commands.

Reads ~/germline/loci/golem-queue.md for pending tasks, runs up to 4
concurrent golem subprocesses. Marks completed tasks and starts next.

Usage:
    golem-daemon start   # Start daemon (nohup, backgrounds itself)
    golem-daemon stop    # Stop daemon via pidfile
    golem-daemon status  # Check if running
    golem-daemon clean   # Remove completed/failed entries from queue
"""
from __future__ import annotations

import ast
import os
import re
import sys
import time
import signal
import subprocess
import shutil
from pathlib import Path
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed
import json
import fcntl

# Paths
QUEUE_FILE = Path.home() / "germline" / "loci" / "golem-queue.md"
PIDFILE = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.pid"
LOGFILE = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
POLL_INTERVAL = 30
GOLEM_TIMEOUT = 1800  # 30 min max per golem run
DISK_SPACE_MIN_BYTES = 1 * 1024 * 1024 * 1024  # 1GB minimum free space
JSONLFILE = Path.home() / ".local" / "share" / "vivesca" / "golem.jsonl"
ROTATE_MAX_BYTES = 5 * 1024 * 1024  # 5MB rotation threshold


def check_disk_space() -> tuple[bool, int]:
    """Check if there's enough disk space.

    Returns:
        (ok: bool, free_bytes: int)
        ok is True if free space >= 1GB, False otherwise.
    """
    try:
        usage = shutil.disk_usage(Path.home())
        return (usage.free >= DISK_SPACE_MIN_BYTES, usage.free)
    except Exception:
        # On error, assume OK to avoid blocking unnecessarily
        return (True, -1)


class QueueLock:
    _lock_path = Path.home() / '.local' / 'share' / 'vivesca' / 'golem-queue.lock'

    def __enter__(self):
        self._lock_path.parent.mkdir(parents=True, exist_ok=True)
        self._fd = open(self._lock_path, 'w')
        fcntl.flock(self._fd, fcntl.LOCK_EX)
        return self

    def __exit__(self, *args):
        fcntl.flock(self._fd, fcntl.LOCK_UN)
        self._fd.close()


# Per-provider concurrency limits
PROVIDER_LIMITS = {
    "zhipu": 8,
    "infini": 8,
    "volcano": 16,
}
DEFAULT_LIMIT = 4  # Fallback for unknown providers

# Counter for successful mark_done calls (reset on auto-commit)
_mark_done_count = 0

def rotate_logs():
    """Rotate log/jsonl files if they exceed 5MB.

    Renames file to file.1 (overwriting old .1) if > ROTATE_MAX_BYTES.
    """
    for path in (LOGFILE, JSONLFILE):
        try:
            if path.exists() and path.stat().st_size > ROTATE_MAX_BYTES:
                rotated = Path(str(path) + ".1")
                path.replace(rotated)
        except OSError:
            pass  # Don't block daemon start on rotation failure


def log(msg: str):
    """Append timestamped message to log file."""
    try:
        LOGFILE.parent.mkdir(parents=True, exist_ok=True)
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with open(LOGFILE, "a") as f:
            f.write(f"[{ts}] {msg}\n")
    except OSError:
        pass  # Don't crash daemon on log failure


def auto_commit() -> str:
    """Auto-commit staged changes from assays/, effectors/, metabolon/.

    Returns:
        Commit hash if committed, or 'nothing to commit' if no changes.
    """
    germline_dir = Path.home() / "germline"
    try:
        # Stage the directories
        subprocess.run(
            f"git -C {germline_dir} add assays/ effectors/ metabolon/",
            shell=True,
            capture_output=True,
            text=True,
            timeout=60,
        )
        # Check if there's anything staged
        check = subprocess.run(
            f"git -C {germline_dir} diff --cached --quiet",
            shell=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if check.returncode == 0:
            return "nothing to commit"
        # Commit
        result = subprocess.run(
            f"git -C {germline_dir} commit -m 'golem: daemon auto-commit'",
            shell=True,
            capture_output=True,
            text=True,
            timeout=60,
        )
        if result.returncode == 0:
            # Extract commit hash from output
            for line in result.stdout.splitlines():
                if line.startswith("["):
                    # Format: [main abc1234] ...
                    parts = line.split()
                    if len(parts) >= 2:
                        return parts[1].rstrip("]")
            return "committed"
        return f"commit failed: {result.stderr[:60]}"
    except Exception as e:
        return f"auto_commit error: {e}"


def read_pid() -> int | None:
    """Read PID from pidfile, return None if not running."""
    if not PIDFILE.exists():
        return None
    try:
        pid = int(PIDFILE.read_text().strip())
        os.kill(pid, 0)  # Check if process exists
        return pid
    except (ValueError, ProcessLookupError, PermissionError):
        PIDFILE.unlink(missing_ok=True)
        return None

def write_pid():
    """Write current PID to pidfile."""
    PIDFILE.parent.mkdir(parents=True, exist_ok=True)
    PIDFILE.write_text(str(os.getpid()))

def remove_pid():
    """Remove pidfile."""
    PIDFILE.unlink(missing_ok=True)

def parse_queue() -> list[tuple[int, str]]:
    """Parse queue file, return list of (line_number, command) for pending tasks."""
    if not QUEUE_FILE.exists():
        return []

    try:
        lines = QUEUE_FILE.read_text().splitlines()
    except (PermissionError, OSError, UnicodeDecodeError):
        return []

    pending = []

    for i, line in enumerate(lines):
        # Match: - [ ] `golem ...`
        m = re.match(r'^- \[ \] `([^`]+)`', line)
        if m:
            cmd = m.group(1).strip()
            if cmd.startswith("golem "):
                pending.append((i, cmd))

    return pending


def parse_provider(cmd: str) -> str:
    """Extract --provider value from command, or 'default' if not found."""
    m = re.search(r'--provider\s+(\w+)', cmd)
    return m.group(1) if m else "default"


def get_provider_limit(provider: str) -> int:
    """Get concurrency limit for a provider."""
    return PROVIDER_LIMITS.get(provider, DEFAULT_LIMIT)

def mark_done(line_num: int, result: str = ""):
    """Mark task as done in queue file, move to Done section."""
    with QueueLock():
        if not QUEUE_FILE.exists():
            return
        if line_num < 0:
            return
        try:
            lines = QUEUE_FILE.read_text().splitlines()
        except (PermissionError, OSError, UnicodeDecodeError):
            return
        if line_num >= len(lines):
            return
        original = lines[line_num]
        # Verify the line is still a pending task
        if not original.strip().startswith("- [ ] "):
            return
        done_line = original.replace("- [ ] ", "- [x] ", 1)
        lines[line_num] = done_line
        for i, line in enumerate(lines):
            if line.strip() == "## Done":
                result_line = f"{done_line} \u2192 {result[:80]}" if result else done_line
                lines.insert(i + 2, result_line)
                break
        try:
            QUEUE_FILE.write_text("\n".join(lines) + "\n")
        except (PermissionError, OSError):
            return


def mark_failed(line_num: int, result: str = "", exit_code: int = 1) -> dict:
    """Mark task as failed. Retry once unless exit_code=2 (command error)."""
    with QueueLock():
        if not QUEUE_FILE.exists():
            return {"retried": False}
        if line_num < 0:
            return {"retried": False}
        try:
            lines = QUEUE_FILE.read_text().splitlines()
        except (PermissionError, OSError, UnicodeDecodeError):
            return {"retried": False}
        if line_num >= len(lines):
            return {"retried": False}
        original = lines[line_num]
        # Verify the line is still a pending task
        if not original.strip().startswith("- [ ] "):
            return {"retried": False}
        cmd_match = re.search(r'`([^`]+)`', original)

        # Determine new line content
        retried = False
        # Exit 2 = command not found / usage error — never retry
        if exit_code == 2 or not cmd_match:
            lines[line_num] = original.replace("- [ ] ", "- [!] ", 1)
        elif '(retry)' not in cmd_match.group(1):
            old_cmd = cmd_match.group(1)
            new_cmd = old_cmd + ' (retry)'
            lines[line_num] = original.replace(f'`{old_cmd}`', f'`{new_cmd}`', 1)
            retried = True
        else:
            lines[line_num] = original.replace("- [ ] ", "- [!] ", 1)

        try:
            QUEUE_FILE.write_text("\n".join(lines) + "\n")
        except (PermissionError, OSError):
            return {"retried": False}

        if retried:
            log(f"Re-queued (retry): {cmd_match.group(1)[:60]}...")
        return {"retried": retried}


def _golem_env() -> dict:
    """Build environment for golem subprocesses.

    Sources ~/.env.fly for API keys and adds effectors to PATH.
    """
    env = os.environ.copy()
    env_file = Path.home() / ".env.fly"
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            line = line.strip()
            if line.startswith("export "):
                line = line[7:]
            if "=" in line and not line.startswith("#"):
                k, v = line.split("=", 1)
                env[k.strip()] = v.strip().strip('"').strip("'")
    effectors = str(Path.home() / "germline" / "effectors")
    venv_bin = str(Path.home() / "germline" / ".venv" / "bin")
    local_bin = str(Path.home() / ".local" / "bin")
    env["PATH"] = f"{effectors}:{venv_bin}:{local_bin}:{env.get('PATH', '/usr/bin:/bin')}"
    return env

def run_golem(cmd: str) -> tuple[str, int, str]:
    """Run a golem command, return (cmd, exit_code, output_tail)."""
    log(f"Starting: {cmd[:80]}...")
    start = time.time()

    try:
        result = subprocess.run(
            cmd,
            shell=True,
            capture_output=True,
            text=True,
            timeout=GOLEM_TIMEOUT,
            cwd=str(Path.home() / "germline"),
            env=_golem_env(),
        )
        duration = int(time.time() - start)
        tail = (result.stdout + result.stderr)[-200:].replace("\n", " ")
        log(f"Finished ({duration}s, exit={result.returncode}): {cmd[:50]}...")
        return (cmd, result.returncode, tail)
    except subprocess.TimeoutExpired:
        duration = int(time.time() - start)
        log(f"TIMEOUT ({duration}s): {cmd[:50]}...")
        return (cmd, 124, f"timeout after {GOLEM_TIMEOUT}s")
    except Exception as e:
        log(f"ERROR: {cmd[:50]}... - {e}")
        return (cmd, 1, str(e))




def validate_golem_output() -> tuple[bool, list[str]]:
    """Validate new/modified .py files before pytest gate.

    Checks:
        1. ast.parse() each .py — fail on SyntaxError
        2. grep for TODO/FIXME/stub — fail if found
        3. test_*.py must be flat in assays/ — reject assays/subdir/test_foo.py
        4. No __pycache__/.pyc

    Returns:
        (passed: bool, errors: list[str])
    """
    errors: list[str] = []
    germline_dir = Path.home() / "germline"

    try:
        # Get new/modified .py files
        git_result = subprocess.run(
            f"git -C {germline_dir} diff --name-only --diff-filter=AM HEAD 2>/dev/null",
            shell=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if git_result.returncode != 0:
            return (True, [])  # git diff failed (e.g., no commits), pass silently

        py_files = [f for f in git_result.stdout.strip().splitlines() if f.endswith(".py")]

        for rel_path in py_files:
            file_path = germline_dir / rel_path

            # Check 1: ast.parse() — fail on SyntaxError
            try:
                source = file_path.read_text()
                ast.parse(source)
            except SyntaxError as e:
                errors.append(f"SyntaxError in {rel_path}: {e}")
                continue  # skip further checks if syntax is broken
            except FileNotFoundError:
                errors.append(f"File not found: {rel_path}")
                continue

            # Check 2: grep for TODO/FIXME/stub
            for line_num, line in enumerate(source.splitlines(), 1):
                line_upper = line.upper()
                if "TODO" in line_upper or "FIXME" in line_upper:
                    # Skip if it's in a string literal that looks like a test expectation
                    if '"TODO' not in line and "'TODO" not in line and '"FIXME' not in line and "'FIXME" not in line:
                        errors.append(f"TODO/FIXME in {rel_path}:{line_num}: {line.strip()[:60]}")
                if "stub" in line.lower():
                    # Allow "stub" only in comments explaining what stub is
                    if not line.strip().startswith("#"):
                        errors.append(f"stub in {rel_path}:{line_num}: {line.strip()[:60]}")

            # Check 3: test_*.py must be flat in assays/
            if rel_path.startswith("assays/") and "/test_" in rel_path:
                # assays/test_foo.py is OK, assays/subdir/test_foo.py is not
                parts = rel_path.split("/")
                if len(parts) > 2:  # more than assays/test_*.py
                    errors.append(f"test file not flat in assays/: {rel_path}")

        # Check 4: No __pycache__/.pyc in new/modified files
        pycache_result = subprocess.run(
            f"git -C {germline_dir} diff --name-only --diff-filter=AM HEAD 2>/dev/null | grep -E '(__pycache__|\\.pyc)' || true",
            shell=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if pycache_result.stdout.strip():
            for f in pycache_result.stdout.strip().splitlines():
                errors.append(f"__pycache__/.pyc not allowed: {f}")

        return (len(errors) == 0, errors)

    except Exception as e:
        errors.append(f"validate_golem_output exception: {e}")
        return (False, errors)


def check_new_test_files_and_run_pytest() -> tuple[bool, str]:
    """Check for new assays/test_*.py files, run pytest, return (passed, summary)."""
    germline_dir = str(Path.home() / "germline")
    try:
        # Get list of newly added files from git
        git_result = subprocess.run(
            "git -C {} diff --name-only --diff-filter=A HEAD~1 2>/dev/null".format(germline_dir),
            shell=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if git_result.returncode != 0:
            # If diff fails (e.g., first commit), just pass
            return (True, "git diff failed, skipping test check")

        new_files = git_result.stdout.strip().splitlines()
        # Filter for assays/test_*.py pattern
        new_test_files = [f for f in new_files if f.startswith("assays/") and f.endswith(".py") and "/test_" in ("/" + f)]

        if not new_test_files:
            return (True, "no new test files found")

        # Run pytest on new test files
        pytest_cmd = "uv run pytest {} -q --tb=line".format(" ".join(new_test_files))
        pytest_result = subprocess.run(
            pytest_cmd,
            shell=True,
            capture_output=True,
            text=True,
            cwd=germline_dir,
            timeout=300,
        )

        summary = pytest_result.stdout.strip().splitlines()[-3:] if pytest_result.stdout else []
        summary_str = " | ".join(summary).replace("\n", " ")
        log(f"pytest on new tests: exit={pytest_result.returncode}, {summary_str}")

        if pytest_result.returncode == 0:
            return (True, f"pytest passed: {summary_str}")
        else:
            return (False, f"pytest failed: {summary_str}")

    except Exception as e:
        log(f"ERROR in check_new_test_files_and_run_pytest: {e}")
        # On error, proceed but log
        return (True, f"test check exception: {e}")

def daemon_loop():
    """Main daemon loop: poll queue, run tasks, mark done."""
    rotate_logs()
    log("Daemon started")
    write_pid()

    # Max workers = max provider limit (volcano=16)
    max_workers = max(PROVIDER_LIMITS.values())
    running = {}  # future -> (line_num, cmd, provider)
    provider_running: dict[str, int] = {}  # provider -> count of running tasks
    poll_cycle = 0
    disk_space_paused = False

    try:
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            while True:
                poll_cycle += 1

                # Check disk space every 10 poll cycles
                if poll_cycle % 10 == 0:
                    ok, free_bytes = check_disk_space()
                    if not ok:
                        free_gb = free_bytes / (1024 * 1024 * 1024)
                        if not disk_space_paused:
                            log(f"WARNING: Low disk space ({free_gb:.2f}GB free), pausing task dispatch")
                            disk_space_paused = True
                    elif disk_space_paused:
                        free_gb = free_bytes / (1024 * 1024 * 1024)
                        log(f"Disk space recovered ({free_gb:.2f}GB free), resuming task dispatch")
                        disk_space_paused = False

                # Check for completed tasks
                done_futures = [f for f in running if f.done()]
                for future in done_futures:
                    line_num, cmd, provider = running.pop(future)
                    provider_running[provider] = max(0, provider_running.get(provider, 0) - 1)
                    try:
                        _, exit_code, tail = future.result()
                        if exit_code == 0:
                            # Golem succeeded — run advisory checks (don't block on them)
                            passed, errors = validate_golem_output()
                            if not passed:
                                log(f"VALIDATION WARN: {cmd[:50]}... → {'; '.join(errors[:3])}")
                            test_passed, test_result = check_new_test_files_and_run_pytest()
                            if not test_passed:
                                log(f"PYTEST WARN: {cmd[:50]}... → {test_result}")
                            mark_done(line_num, f"exit={exit_code}")
                            # Auto-commit every 5 successful completions
                            global _mark_done_count
                            _mark_done_count += 1
                            if _mark_done_count >= 5:
                                commit_hash = auto_commit()
                                log(f"auto-commit ({_mark_done_count} tasks): {commit_hash}")
                                _mark_done_count = 0
                        else:
                            mark_failed(line_num, f"exit={exit_code} {tail[:60]}", exit_code=exit_code)
                            log(f"FAILED (exit={exit_code}): {cmd[:60]}...")
                    except Exception as e:
                        log(f"Future error: {e}")
                        mark_failed(line_num, str(e))

                # Fill available slots per provider (skip if disk space is low)
                if disk_space_paused:
                    pending = parse_queue()
                    log(f"Disk space low, skipping dispatch ({len(pending)} pending)")
                else:
                    pending = parse_queue()

                    for line_num, cmd in pending:
                        provider = parse_provider(cmd)
                        current = provider_running.get(provider, 0)
                        limit = get_provider_limit(provider)

                        if current < limit:
                            # Check if already running (avoid duplicate dispatch)
                            already_running = any(
                                c == cmd for (_, c, _) in running.values()
                            )
                            if already_running:
                                continue

                            future = executor.submit(run_golem, cmd)
                            running[future] = (line_num, cmd, provider)
                            provider_running[provider] = current + 1
                            log(f"Queued [{provider}]: {cmd[:60]}...")

                # Status check
                if running:
                    running_by_provider = ", ".join(
                        f"{p}:{n}" for p, n in sorted(provider_running.items()) if n > 0
                    )
                    log(f"Running: {len(running)} tasks ({running_by_provider}), {len(pending)} pending")
                else:
                    log(f"Idle: {len(pending)} pending")

                time.sleep(POLL_INTERVAL)

    except KeyboardInterrupt:
        log("Interrupted")
    except Exception as e:
        log(f"Fatal error: {e}")
    finally:
        remove_pid()
        log("Daemon stopped")

def cmd_start(foreground: bool = False):
    """Start daemon. Use --foreground/-f for supervisor compatibility."""
    pid = read_pid()
    if pid:
        print(f"Daemon already running (PID {pid})")
        return 1

    if foreground:
        daemon_loop()
        return 0

    # Double-fork to fully detach
    if os.fork() > 0:
        print("Daemon started")
        return 0

    os.setsid()

    if os.fork() > 0:
        os._exit(0)

    # Redirect stdio
    sys.stdin.close()
    sys.stdout = open(os.devnull, "w")
    sys.stderr = open(os.devnull, "w")

    daemon_loop()
    return 0

def cmd_stop():
    """Stop daemon via pidfile."""
    pid = read_pid()
    if not pid:
        print("Daemon not running")
        return 1
    
    try:
        os.kill(pid, signal.SIGTERM)
        print(f"Sent SIGTERM to PID {pid}")
        # Wait for process to exit
        for _ in range(10):
            time.sleep(0.5)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                print("Daemon stopped")
                return 0
        # Force kill if still running
        os.kill(pid, signal.SIGKILL)
        print("Force killed")
        return 0
    except ProcessLookupError:
        print("Daemon already stopped")
        return 0

def cmd_status():
    """Check daemon status."""
    pid = read_pid()
    if pid:
        # Count pending tasks by provider
        pending = parse_queue()
        by_provider: dict[str, int] = {}
        for _, cmd in pending:
            p = parse_provider(cmd)
            by_provider[p] = by_provider.get(p, 0) + 1

        provider_info = ", ".join(
            f"{p}:{n}/{PROVIDER_LIMITS.get(p, DEFAULT_LIMIT)}"
            for p, n in sorted(by_provider.items())
        ) if by_provider else "none"

        print(f"Daemon running (PID {pid}), {len(pending)} pending tasks ({provider_info})")
        return 0
    else:
        print("Daemon not running")
        return 1

def cmd_clean() -> int:
    """Remove completed ([x]) and failed ([!]) entries from the queue.

    Preserves headers, blank lines, and pending ([ ]) tasks.
    Rewrites the queue file and prints the count of removed entries.
    """
    if not QUEUE_FILE.exists():
        print("Queue file not found")
        return 1

    with QueueLock():
        try:
            lines = QUEUE_FILE.read_text().splitlines()
        except (PermissionError, OSError, UnicodeDecodeError):
            print("Queue file unreadable")
            return 1
        kept = []
        removed = 0
        for line in lines:
            if re.match(r'^- \[[!x]\]', line):
                removed += 1
            else:
                kept.append(line)
        try:
            QUEUE_FILE.write_text("\n".join(kept) + "\n")
        except (PermissionError, OSError):
            print("Queue file not writable")
            return 1

    print(f"Removed {removed} entries from queue")
    return 0


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return 1

    cmd = sys.argv[1]

    if cmd in ("-h", "--help"):
        print(__doc__)
        return 0

    if cmd == "start":
        fg = "--foreground" in sys.argv or "-f" in sys.argv
        return cmd_start(foreground=fg)
    elif cmd == "stop":
        return cmd_stop()
    elif cmd == "status":
        return cmd_status()
    elif cmd == "clean":
        return cmd_clean()
    else:
        print(f"Unknown command: {cmd}")
        print("Commands: start, stop, status, clean")
        return 1

if __name__ == "__main__":
    sys.exit(main())

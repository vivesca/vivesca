def disk_hygiene() -> int:
    """Prune old Claude session files and caches. Returns bytes freed (approx)."""
    freed = 0

    # 1. Prune old golem session JSONL files (keep newest SESSION_KEEP)
    if SESSION_DIR.is_dir():
        sessions = sorted(SESSION_DIR.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
        for old in sessions[SESSION_KEEP:]:
            try:
                freed += old.stat().st_size
                old.unlink()
            except OSError:
                pass

    # 2. Prune uv cache (non-blocking)
    uv_cache = Path.home() / ".cache" / "uv"
    if uv_cache.is_dir():
        try:
            subprocess.run(["uv", "cache", "prune", "--force"], capture_output=True, timeout=60)
        except Exception:
            pass

    # 3. Prune go-build cache
    go_cache = Path.home() / ".cache" / "go-build"
    if go_cache.is_dir():
        try:
            shutil.rmtree(go_cache, ignore_errors=True)
            freed += 400 * 1024 * 1024  # rough estimate
        except Exception:
            pass

    # 4. Prune infections.jsonl if > 20MB
    infections = Path.home() / ".local" / "share" / "vivesca" / "infections.jsonl"
    if infections.exists():
        try:
            sz = infections.stat().st_size
            if sz > 20 * 1024 * 1024:
                # Keep last 5000 lines
                lines = infections.read_text().splitlines()
                infections.write_text("\n".join(lines[-5000:]) + "\n")
                freed += sz - infections.stat().st_size
        except Exception:
            pass

    return freed


def fly_stop_self() -> bool:
    """Stop this Fly machine via the Machines API. Returns True on success."""
    token = os.environ.get("FLY_API_TOKEN", "")
    if not token:
        return False
    try:
        from urllib.request import Request, urlopen
        # List machines to find our ID
        url = f"{FLY_API_BASE}/v1/apps/{FLY_APP_NAME}/machines"
        req = Request(url, method="GET")
        req.add_header("Authorization", f"Bearer {token}")
        req.add_header("Content-Type", "application/json")
        with urlopen(req, timeout=10) as resp:
            machines = json.loads(resp.read())
        if not machines:
            return False
        mid = machines[0]["id"]
        # Stop the machine
        stop_url = f"{FLY_API_BASE}/v1/apps/{FLY_APP_NAME}/machines/{mid}/stop"
        req = Request(stop_url, method="POST")
        req.add_header("Authorization", f"Bearer {token}")
        req.add_header("Content-Type", "application/json")
        urlopen(req, timeout=10)
        return True
    except Exception:
        return False


def check_disk_space() -> tuple[bool, int]:
    """Check if there's enough disk space.

    Returns:
        (ok: bool, free_bytes: int)
        ok is True if free space >= 1GB, False otherwise.
    """
    try:
        usage = shutil.disk_usage(Path.home())
        return (usage.free >= DISK_SPACE_MIN_BYTES, usage.free)
    except Exception:
        # On error, assume OK to avoid blocking unnecessarily
        return (True, -1)


class QueueLock:
    _lock_path = Path.home() / '.local' / 'share' / 'vivesca' / 'golem-queue.lock'

    def __enter__(self):
        self._lock_path.parent.mkdir(parents=True, exist_ok=True)
        self._fd = open(self._lock_path, 'w')
        fcntl.flock(self._fd, fcntl.LOCK_EX)
        return self

    def __exit__(self, *args):
        fcntl.flock(self._fd, fcntl.LOCK_UN)
        self._fd.close()



#!/usr/bin/env python3
"""golem-daemon — Task queue processor for golem commands.

Reads ~/germline/loci/golem-queue.md for pending tasks, runs up to 4
concurrent golem subprocesses. Marks completed tasks and starts next.

Usage:
    golem-daemon start   # Start daemon (nohup, backgrounds itself)
    golem-daemon stop    # Stop daemon via pidfile
    golem-daemon status  # Check if running
"""
import os
import re
import sys
import time
import signal
import subprocess
from pathlib import Path
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed
import json

# Paths
QUEUE_FILE = Path.home() / "germline" / "loci" / "golem-queue.md"
PIDFILE = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.pid"
LOGFILE = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
MAX_CONCURRENT = 4
POLL_INTERVAL = 30

def log(msg: str):
    """Append timestamped message to log file."""
    LOGFILE.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(LOGFILE, "a") as f:
        f.write(f"[{ts}] {msg}\n")

def read_pid() -> int | None:
    """Read PID from pidfile, return None if not running."""
    if not PIDFILE.exists():
        return None
    try:
        pid = int(PIDFILE.read_text().strip())
        os.kill(pid, 0)  # Check if process exists
        return pid
    except (ValueError, ProcessLookupError, PermissionError):
        PIDFILE.unlink(missing_ok=True)
        return None

def write_pid():
    """Write current PID to pidfile."""
    PIDFILE.parent.mkdir(parents=True, exist_ok=True)
    PIDFILE.write_text(str(os.getpid()))

def remove_pid():
    """Remove pidfile."""
    PIDFILE.unlink(missing_ok=True)

def parse_queue() -> list[tuple[int, str]]:
    """Parse queue file, return list of (line_number, command) for pending tasks."""
    if not QUEUE_FILE.exists():
        return []
    
    lines = QUEUE_FILE.read_text().splitlines()
    pending = []
    
    for i, line in enumerate(lines):
        # Match: - [ ] `golem ...`
        m = re.match(r'^- \[ \] `([^`]+)`', line)
        if m:
            cmd = m.group(1).strip()
            if cmd.startswith("golem "):
                pending.append((i, cmd))
    
    return pending

def mark_done(line_num: int, result: str = ""):
    """Mark task as done in queue file, move to Done section."""
    lines = QUEUE_FILE.read_text().splitlines()
    
    # Change - [ ] to - [x]
    original = lines[line_num]
    done_line = original.replace("- [ ] ", "- [x] ", 1)
    lines[line_num] = done_line
    
    # Find Done section and append
    done_idx = None
    for i, line in enumerate(lines):
        if line.strip() == "## Done":
            done_idx = i
            break
    
    if done_idx is not None:
        # Insert after "(move completed tasks here with result)"
        insert_idx = done_idx + 2
        result_line = f"{done_line} → {result[:80]}" if result else done_line
        lines.insert(insert_idx, result_line)
        # Remove the original done line (now shifted by 1)
        # Actually, keep both - the [x] in place and copy in Done
    
    QUEUE_FILE.write_text("\n".join(lines) + "\n")

def run_golem(cmd: str) -> tuple[str, int, str]:
    """Run a golem command, return (cmd, exit_code, output_tail)."""
    log(f"Starting: {cmd[:80]}...")
    start = time.time()
    
    try:
        result = subprocess.run(
            cmd,
            shell=True,
            capture_output=True,
            text=True,
            cwd=str(Path.home() / "germline")
        )
        duration = int(time.time() - start)
        tail = (result.stdout + result.stderr)[-200:].replace("\n", " ")
        log(f"Finished ({duration}s, exit={result.returncode}): {cmd[:50]}...")
        return (cmd, result.returncode, tail)
    except Exception as e:
        log(f"ERROR: {cmd[:50]}... - {e}")
        return (cmd, 1, str(e))

def daemon_loop():
    """Main daemon loop: poll queue, run tasks, mark done."""
    log("Daemon started")
    write_pid()
    
    running = {}  # future -> (line_num, cmd)
    
    try:
        with ThreadPoolExecutor(max_workers=MAX_CONCURRENT) as executor:
            while True:
                # Check for completed tasks
                done_futures = [f for f in running if f.done()]
                for future in done_futures:
                    line_num, cmd = running.pop(future)
                    try:
                        _, exit_code, tail = future.result()
                        mark_done(line_num, f"exit={exit_code}")
                    except Exception as e:
                        log(f"Future error: {e}")
                        mark_done(line_num, str(e))
                
                # Fill available slots
                pending = parse_queue()
                available = MAX_CONCURRENT - len(running)
                
                for line_num, cmd in pending[:available]:
                    future = executor.submit(run_golem, cmd)
                    running[future] = (line_num, cmd)
                    log(f"Queued: {cmd[:60]}...")
                
                # Status check
                if running:
                    log(f"Running: {len(running)} tasks, {len(pending)} pending")
                else:
                    log(f"Idle: {len(pending)} pending")
                
                time.sleep(POLL_INTERVAL)
                
    except KeyboardInterrupt:
        log("Interrupted")
    except Exception as e:
        log(f"Fatal error: {e}")
    finally:
        remove_pid()
        log("Daemon stopped")

def cmd_start():
    """Start daemon in background."""
    pid = read_pid()
    if pid:
        print(f"Daemon already running (PID {pid})")
        return 1
    
    # Double-fork to fully detach
    if os.fork() > 0:
        print("Daemon started")
        return 0
    
    os.setsid()
    
    if os.fork() > 0:
        os._exit(0)
    
    # Redirect stdio
    sys.stdin.close()
    sys.stdout = open(os.devnull, "w")
    sys.stderr = open(os.devnull, "w")
    
    daemon_loop()
    return 0

def cmd_stop():
    """Stop daemon via pidfile."""
    pid = read_pid()
    if not pid:
        print("Daemon not running")
        return 1
    
    try:
        os.kill(pid, signal.SIGTERM)
        print(f"Sent SIGTERM to PID {pid}")
        # Wait for process to exit
        for _ in range(10):
            time.sleep(0.5)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                print("Daemon stopped")
                return 0
        # Force kill if still running
        os.kill(pid, signal.SIGKILL)
        print("Force killed")
        return 0
    except ProcessLookupError:
        print("Daemon already stopped")
        return 0

def cmd_status():
    """Check daemon status."""
    pid = read_pid()
    if pid:
        # Count pending tasks
        pending = parse_queue()
        print(f"Daemon running (PID {pid}), {len(pending)} pending tasks")
        return 0
    else:
        print("Daemon not running")
        return 1

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return 1
    
    cmd = sys.argv[1]
    
    if cmd == "start":
        return cmd_start()
    elif cmd == "stop":
        return cmd_stop()
    elif cmd == "status":
        return cmd_status()
    else:
        print(f"Unknown command: {cmd}")
        print("Commands: start, stop, status")
        return 1

if __name__ == "__main__":
    sys.exit(main())

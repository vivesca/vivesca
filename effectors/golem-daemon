def _update_running_file(running: dict):
    """Write current running tasks to state file for cmd_status."""
    tasks = []
    for _, (_, cmd, provider, task_id) in running.items():
        tasks.append({"task_id": task_id, "provider": provider, "cmd": cmd[:80]})
    try:
        RUNNING_FILE.parent.mkdir(parents=True, exist_ok=True)
        RUNNING_FILE.write_text(json.dumps(tasks))
    except OSError:
        pass


def daemon_loop():
    """Main daemon loop: poll queue, run tasks, mark done."""
    rotate_logs()
    log("Daemon started")
    write_pid()

    # Max workers = max provider limit (volcano=16)
    max_workers = max(PROVIDER_LIMITS.values())
    running = {}  # future -> (line_num, cmd, provider, task_id)
    provider_running: dict[str, int] = {}  # provider -> count of running tasks
    poll_cycle = 0
    disk_space_paused = False
    idle_since: float | None = None  # timestamp when we became idle

    try:
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            while True:
                poll_cycle += 1

                # Check disk space every 10 poll cycles + run hygiene
                if poll_cycle % 10 == 0:
                    ok, free_bytes = check_disk_space()
                    if not ok:
                        free_gb = free_bytes / (1024 * 1024 * 1024)
                        if not disk_space_paused:
                            log(f"WARNING: Low disk space ({free_gb:.2f}GB free), running disk hygiene")
                            freed = disk_hygiene()
                            if freed > 0:
                                log(f"Disk hygiene freed ~{freed // (1024*1024)}MB")
                            # Re-check after hygiene
                            ok, free_bytes = check_disk_space()
                            if not ok:
                                log(f"Still low after hygiene ({free_bytes // (1024*1024)}MB free), pausing dispatch")
                                disk_space_paused = True
                    elif disk_space_paused:
                        free_gb = free_bytes / (1024 * 1024 * 1024)
                        log(f"Disk space recovered ({free_gb:.2f}GB free), resuming task dispatch")
                        disk_space_paused = False
                    # Periodic hygiene even when not low (every 100 cycles = ~50 min)
                    if poll_cycle % 100 == 0:
                        freed = disk_hygiene()
                        if freed > 0:
                            log(f"Periodic hygiene freed ~{freed // (1024*1024)}MB")

                # Periodic health check (every HEALTH_CHECK_INTERVAL cycles)
                if poll_cycle % HEALTH_CHECK_INTERVAL == 0:
                    try:
                        r = subprocess.run(
                            ["python3", str(Path.home() / "germline" / "effectors" / "gemmule-health"), "--daemon"],
                            capture_output=True, text=True, timeout=120
                        )
                        if r.stdout.strip():
                            log(f"HEALTH: {r.stdout.strip()}")
                        if r.returncode == 2:  # critical
                            log("HEALTH CRITICAL — pausing dispatch for safety")
                            disk_space_paused = True
                    except Exception as e:
                        log(f"Health check error: {e}")

                # Check for completed tasks
                done_futures = [f for f in running if f.done()]
                for future in done_futures:
                    line_num, cmd, provider, task_id = running.pop(future)
                    provider_running[provider] = max(0, provider_running.get(provider, 0) - 1)
                    try:
                        _, exit_code, tail = future.result()
                        if exit_code == 0:
                            # Golem succeeded — run advisory checks (don't block on them)
                            passed, errors = validate_golem_output()
                            if not passed:
                                log(f"VALIDATION WARN [{task_id}]: {cmd[:50]}... → {'; '.join(errors[:3])}")
                            test_passed, test_result = check_new_test_files_and_run_pytest()
                            if not test_passed:
                                log(f"PYTEST WARN [{task_id}]: {cmd[:50]}... → {test_result}")
                            mark_done(line_num, f"exit={exit_code}", task_id=task_id)
                            # Auto-commit every 5 successful completions
                            global _mark_done_count
                            _mark_done_count += 1
                            if _mark_done_count >= 5:
                                commit_hash = auto_commit()
                                log(f"auto-commit ({_mark_done_count} tasks): {commit_hash}")
                                _mark_done_count = 0
                        else:
                            mark_failed(line_num, f"exit={exit_code} {tail[:60]}", exit_code=exit_code, task_id=task_id)
                            log(f"FAILED [{task_id}] (exit={exit_code}): {cmd[:60]}...")
                    except Exception as e:
                        log(f"Future error: {e}")
                        mark_failed(line_num, str(e), task_id=task_id)
                if done_futures:
                    _update_running_file(running)

                # Fill available slots per provider (skip if disk space is low)
                if disk_space_paused:
                    pending = parse_queue()
                    log(f"Disk space low, skipping dispatch ({len(pending)} pending)")
                else:
                    pending = parse_queue()

                # Auto-stop check: if no pending AND no running → idle timer
                # Must check BEFORE auto_requeue to avoid infinite refill loop
                if not pending and not running:
                    if idle_since is None:
                        idle_since = time.time()
                        log("Queue empty, no tasks running — idle timer started")
                    else:
                        idle_min = (time.time() - idle_since) / 60
                        log(f"Idle for {idle_min:.1f} min (stop at {IDLE_STOP_MINUTES})")
                        if idle_min >= IDLE_STOP_MINUTES:
                            log(f"Idle for {IDLE_STOP_MINUTES}+ min — committing and stopping machine")
                            auto_commit()
                            if fly_stop_self():
                                log("Fly machine stop requested — goodbye")
                                break
                            else:
                                log("FLY_API_TOKEN not set or stop failed — continuing with auto-requeue")
                                idle_since = None  # Reset, fall through to auto-requeue
                    # Skip auto-requeue and dispatch while idle timer is ticking
                    time.sleep(POLL_INTERVAL)
                    continue

                idle_since = None  # We have work — reset idle timer

                # Auto-requeue when queue runs low
                if len(pending) < 50:
                    added = auto_requeue()
                    if added > 0:
                        pending = parse_queue()

                # Disk guard — pause dispatch if disk is full
                if not disk_guard():
                    log("Disk guard: skipping dispatch this cycle")
                    time.sleep(POLL_INTERVAL)
                    continue

                for line_num, cmd, task_id in pending:
                    provider = parse_provider(cmd)
                    current = provider_running.get(provider, 0)
                    limit = get_provider_limit(provider)

                    if current < limit:
                        # Check if already running (avoid duplicate dispatch)
                        already_running = any(
                            c == cmd for (_, c, _, _) in running.values()
                        )
                        if already_running:
                            continue

                        future = executor.submit(run_golem, cmd)
                        running[future] = (line_num, cmd, provider, task_id)
                        provider_running[provider] = current + 1
                        log(f"Queued [{provider}] [{task_id}]: {cmd[:60]}...")
                if pending:
                    _update_running_file(running)

                # Status check
                if running:
                    running_by_provider = ", ".join(
                        f"{p}:{n}" for p, n in sorted(provider_running.items()) if n > 0
                    )
                    log(f"Running: {len(running)} tasks ({running_by_provider}), {len(pending)} pending")
                else:
                    log(f"Idle: {len(pending)} pending")

                time.sleep(POLL_INTERVAL)

    except KeyboardInterrupt:
        log("Interrupted")
    except Exception as e:
        log(f"Fatal error: {e}")
    finally:
        remove_pid()
        log("Daemon stopped")

def cmd_start(foreground: bool = False):
    """Start daemon. Use --foreground/-f for supervisor compatibility."""
    pid = read_pid()
    if pid:
        print(f"Daemon already running (PID {pid})")
        return 1

    if foreground:
        daemon_loop()
        return 0

    # Double-fork to fully detach
    if os.fork() > 0:
        print("Daemon started")
        return 0

    os.setsid()

    if os.fork() > 0:
        os._exit(0)

    # Redirect stdio
    sys.stdin.close()
    sys.stdout = open(os.devnull, "w")
    sys.stderr = open(os.devnull, "w")

    daemon_loop()
    return 0

def cmd_stop():
    """Stop daemon via pidfile."""
    pid = read_pid()
    if not pid:
        print("Daemon not running")
        return 1
    
    try:
        os.kill(pid, signal.SIGTERM)
        print(f"Sent SIGTERM to PID {pid}")
        # Wait for process to exit
        for _ in range(10):
            time.sleep(0.5)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                print("Daemon stopped")
                return 0
        # Force kill if still running
        os.kill(pid, signal.SIGKILL)
        print("Force killed")
        return 0
    except ProcessLookupError:
        print("Daemon already stopped")
        return 0

def cmd_status():
    """Check daemon status."""
    pid = read_pid()
    if pid:
        # Count pending tasks by provider
        pending = parse_queue()
        by_provider: dict[str, int] = {}
        for item in pending:
            cmd = item[1]
            p = parse_provider(cmd)
            by_provider[p] = by_provider.get(p, 0) + 1

        provider_info = ", ".join(
            f"{p}:{n}/{PROVIDER_LIMITS.get(p, DEFAULT_LIMIT)}"
            for p, n in sorted(by_provider.items())
        ) if by_provider else "none"

        print(f"Daemon running (PID {pid}), {len(pending)} pending tasks ({provider_info})")
        return 0
    else:
        print("Daemon not running")
        return 1

def cmd_clean() -> int:
    """Remove completed ([x]) and failed ([!]) entries from the queue.

    Preserves headers, blank lines, and pending ([ ]) tasks.
    Rewrites the queue file and prints the count of removed entries.
    """
    if not QUEUE_FILE.exists():
        print("Queue file not found")
        return 1

    with QueueLock():
        try:
            lines = QUEUE_FILE.read_text().splitlines()
        except (PermissionError, OSError, UnicodeDecodeError):
            print("Queue file unreadable")
            return 1
        kept = []
        removed = 0
        for line in lines:
            if re.match(r'^- \[[!x]\]', line):
                removed += 1
            else:
                kept.append(line)
        try:
            QUEUE_FILE.write_text("\n".join(kept) + "\n")
        except (PermissionError, OSError):
            print("Queue file not writable")
            return 1

    print(f"Removed {removed} entries from queue")
    return 0


def cmd_retry_all() -> int:
    """Re-queue all [!] failed tasks as [ ] pending for another attempt.

    Strips any trailing (retry) tag so each task gets a fresh retry cycle.
    Returns count of re-queued tasks.
    """
    if not QUEUE_FILE.exists():
        print("Queue file not found")
        return 1

    with QueueLock():
        try:
            lines = QUEUE_FILE.read_text().splitlines()
        except (PermissionError, OSError, UnicodeDecodeError):
            print("Queue file unreadable")
            return 1

        requeued = 0
        new_lines: list[str] = []
        for line in lines:
            m = re.match(r'^- \[!\] `([^`]+)`', line)
            if m:
                cmd = m.group(1).strip()
                # Strip trailing (retry) to give a fresh cycle
                cmd = re.sub(r'\s*\(retry\)\s*$', '', cmd)
                new_lines.append(f"- [ ] `{cmd}`")
                requeued += 1
            else:
                new_lines.append(line)

        try:
            QUEUE_FILE.write_text("\n".join(new_lines) + "\n")
        except (PermissionError, OSError):
            print("Queue file not writable")
            return 1

    print(f"Re-queued {requeued} failed tasks")
    return 0


def cmd_stats() -> int:
    """Show pass/fail/retry counts, avg duration by provider, tasks completed today."""
    records: list[dict] = []
    for path in (JSONLFILE, Path(str(JSONLFILE) + ".1")):
        if path.exists():
            try:
                for line in path.read_text(errors="replace").splitlines():
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        records.append(json.loads(line))
                    except (json.JSONDecodeError, ValueError):
                        pass
            except (PermissionError, OSError, UnicodeDecodeError):
                pass

    if not records:
        print("No task history found")
        return 0

    today = datetime.now().strftime("%Y-%m-%d")

    # Overall counts
    total = len(records)
    passed = sum(1 for r in records if r.get("exit") == 0)
    failed = total - passed

    # Retries exhausted (permanently failed in queue)
    retries = 0
    if QUEUE_FILE.exists():
        try:
            for line in QUEUE_FILE.read_text().splitlines():
                if re.match(r'^- \[!\]', line):
                    retries += 1
        except (PermissionError, OSError, UnicodeDecodeError):
            pass

    # Today's tasks
    today_records = [r for r in records if r.get("ts", "").startswith(today)]
    today_total = len(today_records)
    today_passed = sum(1 for r in today_records if r.get("exit") == 0)

    # Avg duration by provider
    provider_stats: dict[str, dict] = {}
    for r in records:
        p = r.get("provider", "unknown")
        d = r.get("duration", 0)
        if p not in provider_stats:
            provider_stats[p] = {"count": 0, "total_dur": 0, "passed": 0, "failed": 0}
        provider_stats[p]["count"] += 1
        provider_stats[p]["total_dur"] += d
        if r.get("exit") == 0:
            provider_stats[p]["passed"] += 1
        else:
            provider_stats[p]["failed"] += 1

    # Print stats
    print(f"Total tasks: {total} (passed: {passed}, failed: {failed})")
    print(f"Permanently failed (retries exhausted): {retries}")
    print(f"Tasks today ({today}): {today_total} (passed: {today_passed}, failed: {today_total - today_passed})")
    print()
    print("By provider:")
    for provider in sorted(provider_stats):
        s = provider_stats[provider]
        avg_dur = s["total_dur"] / s["count"] if s["count"] else 0
        avg_min = int(avg_dur // 60)
        avg_sec = int(avg_dur % 60)
        print(f"  {provider:10s}  {s['count']:4d} tasks  {s['passed']:4d} passed  {s['failed']:4d} failed  avg {avg_min}m{avg_sec:02d}s")

    return 0


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return 1

    cmd = sys.argv[1]

    if cmd in ("-h", "--help"):
        print(__doc__)
        return 0

    if cmd == "start":
        fg = "--foreground" in sys.argv or "-f" in sys.argv
        return cmd_start(foreground=fg)
    elif cmd == "stop":
        return cmd_stop()
    elif cmd == "status":
        return cmd_status()
    elif cmd == "stats":
        return cmd_stats()
    elif cmd == "clean":
        return cmd_clean()
    elif cmd == "retry-all":
        return cmd_retry_all()
    else:
        print(f"Unknown command: {cmd}")
        print("Commands: start, stop, status, stats, clean, retry-all")
        return 1

if __name__ == "__main__":
    sys.exit(main())

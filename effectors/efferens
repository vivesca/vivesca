#!/usr/bin/env python3
"""efferens CLI — shared notice board for skills and humans.

Usage:
    efferens                        # list all (same as efferens list)
    efferens list [--to X]          # list messages, optionally filtered
    efferens post "msg" [opts]      # post a message
    efferens clear <id>             # delete one message
    efferens clear --all            # delete all messages
    efferens archive <id>           # move one to .archive/
    efferens archive --all          # archive all messages
    efferens count                  # just the number
"""

import argparse
import os
import sys

sys.path.insert(0, os.path.expanduser("~/code/acta/src"))
import acta


def cmd_list(args):
    to = getattr(args, "to", None)
    msgs = acta.read(to=to)
    if not msgs:
        print("Board empty." if not to else f"No messages for '{to}'.")
        return
    label = f" (to: {to})" if to else ""
    print(f"{len(msgs)} message(s){label}:\n")
    for m in msgs:
        sev = m.get("severity", "info")
        sender = m.get("from", "?")
        recipient = m.get("to", "all")
        marker = {"action": "!", "warning": "~", "info": " "}.get(sev, " ")
        body_preview = m.get("body", "")[:100].replace("\n", " ")
        print(f"  [{marker}] {m['id']}")
        print(f"      {sender} → {recipient} | {body_preview}")
        print()


def cmd_post(args):
    path = acta.post(
        message=args.message,
        sender=args.sender,
        to=args.to,
        severity=args.severity,
        subject=args.subject,
    )
    print(f"Posted: {path.name}")


def cmd_clear(args):
    if args.all:
        n = acta.clear_all()
        print(f"Cleared {n} message(s).")
    elif args.id:
        if acta.clear(args.id):
            print(f"Cleared: {args.id}")
        else:
            print(f"Not found: {args.id}", file=sys.stderr)
            sys.exit(1)
    else:
        print("Specify <id> or --all", file=sys.stderr)
        sys.exit(1)


def cmd_archive(args):
    if args.all:
        n = acta.archive_all()
        print(f"Archived {n} message(s).")
    elif args.id:
        if acta.archive(args.id):
            print(f"Archived: {args.id}")
        else:
            print(f"Not found: {args.id}", file=sys.stderr)
            sys.exit(1)
    else:
        print("Specify <id> or --all", file=sys.stderr)
        sys.exit(1)


def cmd_count(_args):
    print(acta.count())


def main():
    parser = argparse.ArgumentParser(description="efferens — shared notice board")
    sub = parser.add_subparsers(dest="command")

    p_list = sub.add_parser("list", help="List messages")
    p_list.add_argument(
        "--to", default=None, help="Filter by recipient (e.g. terry, avantis-verify)"
    )

    p_post = sub.add_parser("post", help="Post a message")
    p_post.add_argument("message", help="Message body")
    p_post.add_argument("--from", dest="sender", default="cli", help="Sending skill/context")
    p_post.add_argument("--to", default="all", help="Recipient (terry, skill-name, all)")
    p_post.add_argument("--severity", "-v", default="info", choices=["action", "info", "warning"])
    p_post.add_argument(
        "--subject", "-t", default=None, help="Subject slug (auto-generated if omitted)"
    )

    p_clear = sub.add_parser("clear", help="Clear message(s)")
    p_clear.add_argument("id", nargs="?", help="Message ID")
    p_clear.add_argument("--all", action="store_true", help="Clear all")

    p_archive = sub.add_parser("archive", help="Archive message(s)")
    p_archive.add_argument("id", nargs="?", help="Message ID")
    p_archive.add_argument("--all", action="store_true", help="Archive all")

    sub.add_parser("count", help="Count unread messages")

    args = parser.parse_args()

    if args.command is None or args.command == "list":
        cmd_list(args)
    elif args.command == "post":
        cmd_post(args)
    elif args.command == "clear":
        cmd_clear(args)
    elif args.command == "archive":
        cmd_archive(args)
    elif args.command == "count":
        cmd_count(args)


if __name__ == "__main__":
    main()

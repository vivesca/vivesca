#!/bin/bash
# Shared environment for all supervisor programs.
# Sources API keys and sets consistent PATH.
# Usage in supervisor: command=/home/vivesca/germline/effectors/supervisor-env <actual-command> <args...>

export HOME="/home/vivesca"
export TZ="Asia/Hong_Kong"
export PATH="/home/vivesca/germline/.venv/bin:/home/vivesca/germline/effectors:/home/vivesca/bin:/home/vivesca/.local/bin:/home/vivesca/.cargo/bin:/usr/local/bin:/usr/bin:/bin"

# Source API keys from resolved env file (written by op read, chmod 600)
if [ -f "$HOME/germline/.env.vivesca" ]; then
    set -a
    source "$HOME/germline/.env.vivesca"
    set +a
fi

# Source Fly.io secrets if present
if [ -f "$HOME/.env.fly" ]; then
    set -a
    source "$HOME/.env.fly"
    set +a
fi

exec "$@"

#!/usr/bin/env python3
"""Poll for PAYG activation, then subscribe to additional OCI regions.

Once PAYG is active (region subscription succeeds), subscribes to
Osaka (KIX), Sydney (SYD), Seoul (ICN). Then updates oci-arm-retry
to try all regions.

Usage:
  oci-region-subscribe              # one-shot check
  oci-region-subscribe --loop       # poll every 5 min until success
"""
import subprocess, sys, time, json

TENANCY = "ocid1.tenancy.oc1..aaaaaaaapkyvu7vwtpn5x7fgvcoy45wo6m457s4c6frhcwqivfzig5mizgya"
REGIONS = ["KIX", "SYD", "ICN"]  # Osaka, Sydney, Seoul
ENV = {"SUPPRESS_LABEL_WARNING": "True"}

def oci(*args):
    r = subprocess.run(
        ["oci"] + list(args),
        capture_output=True, text=True,
        env={**__import__("os").environ, **ENV},
        timeout=300,
    )
    return r.returncode, r.stdout, r.stderr

def get_subscribed_regions():
    rc, out, _ = oci("iam", "region-subscription", "list", "--tenancy-id", TENANCY)
    if rc != 0:
        return []
    try:
        return [r["region-key"] for r in json.loads(out).get("data", [])]
    except Exception:
        return []

def subscribe_region(key):
    rc, out, err = oci("iam", "region-subscription", "create",
                       "--tenancy-id", TENANCY, "--region-key", key)
    if rc == 0:
        return True, "OK"
    if "TenantCapacityExceeded" in err:
        return False, "PAYG not active yet"
    return False, err.strip()[:100]

def notify(msg):
    try:
        subprocess.run(["deltos", msg], capture_output=True, timeout=10)
    except Exception:
        pass

def main():
    loop = "--loop" in sys.argv
    attempt = 0

    while True:
        attempt += 1
        ts = time.strftime("%Y-%m-%d %H:%M:%S")
        print(f"[{ts}] Attempt {attempt}")

        current = get_subscribed_regions()
        print(f"  Current regions: {current}")

        needed = [r for r in REGIONS if r not in current]
        if not needed:
            print("  All target regions already subscribed!")
            notify("OCI: All regions subscribed (KIX/SYD/ICN)")
            break

        # Try first needed region as canary
        ok, msg = subscribe_region(needed[0])
        if not ok:
            print(f"  {needed[0]}: {msg}")
            if not loop:
                print("  PAYG not active. Run with --loop to poll.")
                sys.exit(1)
            print(f"  Sleeping 5 min...")
            time.sleep(300)
            continue

        # Canary succeeded — PAYG is active! Subscribe all remaining
        print(f"  {needed[0]}: SUBSCRIBED!")
        for region in needed[1:]:
            ok2, msg2 = subscribe_region(region)
            print(f"  {region}: {'SUBSCRIBED' if ok2 else msg2}")
            time.sleep(2)

        final = get_subscribed_regions()
        print(f"\n  Final regions: {final}")
        notify(f"OCI PAYG active! Regions: {', '.join(final)}")
        break

    print("Done.")

if __name__ == "__main__":
    main()

#!/usr/bin/env -S uv run --script --python 3.13
# /// script
# dependencies = ["pyyaml"]
# ///
"""
peira-queue — Add a peira campaign to the overnight queue.

Usage:
    peira-queue                    # uses most recent campaign
    peira-queue "topic-substring"  # matches campaign by name
    peira-queue --list             # show campaigns available to queue
    peira-queue --dry-run          # preview the queue entry without writing

The entry is added disabled=false (ready to run tonight). Edit agent-queue.yaml to disable.
"""

import sys
import re
from pathlib import Path
from datetime import datetime
import yaml

EXPERIMENTS_DIR = Path.home() / "notes" / "Experiments"
QUEUE_FILE = Path.home() / "notes" / "agent-queue.yaml"

PEIRA_PROMPT_TEMPLATE = """You are running an autonomous peira experiment campaign.

Campaign brief:
---
{brief}
---

Your job:
1. Read the brief above — understand the target, metric, baseline, and budget.
2. Run the peira loop: hypothesize → run → measure → keep/discard → log → repeat.
3. After each experiment, append to: {log_path}
   Format:
   ## Experiment N — [one-line description]
   - Hypothesis: [what and why]
   - Change: [exact change made]
   - Metric: [value] (baseline: X, prev best: Y)
   - Decision: KEEP / DISCARD
   - Notes: [anything surprising]
4. Stop when budget is exhausted. Write a ## Wrap section with: best config, delta vs baseline, cross-experiment patterns.

Rules:
- One variable per experiment. Never vary two things simultaneously.
- Lock the metric — do not change it mid-campaign.
- Budget is a hard stop. Do not exceed without explicit approval.
- Write results to the log file after every experiment — the log is the deliverable.
"""


def find_campaign(topic: str | None) -> Path:
    campaigns = sorted(EXPERIMENTS_DIR.glob("peira-*"), reverse=True)
    if not campaigns:
        sys.exit("No peira campaigns found in ~/notes/Experiments/")
    if topic:
        matches = [c for c in campaigns if topic.lower() in c.name.lower()]
        if not matches:
            sys.exit(f"No campaign matching '{topic}'. Available:\n" + "\n".join(c.name for c in campaigns[:5]))
        return matches[0]
    return campaigns[0]


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Add peira campaign to overnight queue")
    parser.add_argument("topic", nargs="?", help="Campaign name substring (default: most recent)")
    parser.add_argument("--list", action="store_true", help="List available campaigns")
    parser.add_argument("--dry-run", action="store_true", help="Preview without writing")
    args = parser.parse_args()

    if args.list:
        campaigns = sorted(EXPERIMENTS_DIR.glob("peira-*"), reverse=True)
        for c in campaigns[:10]:
            brief = (c / "brief.md").read_text()[:80].replace("\n", " ")
            print(f"  {c.name}  —  {brief}...", flush=True)
        return

    campaign = find_campaign(args.topic)
    brief_path = campaign / "brief.md"
    log_path = campaign / "log.md"

    if not brief_path.exists():
        sys.exit(f"No brief.md in {campaign}")

    brief = brief_path.read_text()
    prompt = PEIRA_PROMPT_TEMPLATE.format(brief=brief, log_path=str(log_path))

    task_name = re.sub(r"peira-\d{4}-\d{2}-\d{2}-", "", campaign.name)
    task = {
        "name": f"peira-{task_name}",
        "enabled": True,
        "title": f"Peira: {task_name.replace('-', ' ').title()}",
        "backend": "claude",
        "working_dir": str(campaign),
        "timeout": 1800,
        "prompt": prompt,
    }

    if args.dry_run:
        print(f"Campaign: {campaign.name}")
        print(f"Queue entry (dry run):\n{yaml.dump([task], default_flow_style=False, allow_unicode=True)}")
        return

    queue_data = yaml.safe_load(QUEUE_FILE.read_text()) or {}
    tasks = queue_data.get("tasks", [])

    # Avoid duplicates
    existing = [t for t in tasks if t.get("name") == task["name"]]
    if existing:
        print(f"Task '{task['name']}' already in queue. Remove it first to re-add.")
        sys.exit(1)

    tasks.append(task)
    queue_data["tasks"] = tasks
    QUEUE_FILE.write_text(yaml.dump(queue_data, default_flow_style=False, allow_unicode=True, sort_keys=False))

    print(f"✓ Added '{task['name']}' to overnight queue ({campaign.name})")
    print(f"  Backend: claude | Timeout: 30min | Log: {log_path}")
    print(f"  Run tonight: uv run ~/scripts/opencode-queue.py --task peira-{task_name}")


if __name__ == "__main__":
    main()

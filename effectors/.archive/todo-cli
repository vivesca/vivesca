"""
todo-cli — Deterministic Praxis.md operations for the /todo skill.
"""

import argparse
import json
import os
import re
import sys
from datetime import datetime, timedelta
from pathlib import Path

# Add lib to path so we can import gather
sys.path.insert(0, str(Path.home() / "reticulum/lib"))
try:
    from gather import read_todo, read_todo_today, get_date
except ImportError as e:
    print(f"Error importing gather lib: {e}", file=sys.stderr)
    sys.exit(1)

# ── Paths ────────────────────────────────────────────────────────────────────
HOME = Path.home()
NOTES = HOME / "notes"
PRAXIS = NOTES / "Praxis.md"
PRAXIS_ARCHIVE = NOTES / "Praxis Archive.md"

# ── Colours ──────────────────────────────────────────────────────────────────
RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"

WARN = f"{YELLOW}⚠{RESET}"
OK = f"{GREEN}✓{RESET}"


def _parse_date(date_str: str | None):
    if not date_str: return None
    try:
        return datetime.strptime(date_str.strip(), "%Y-%m-%d").date()
    except ValueError:
        return None

def is_overdue(item, today_date):
    d = _parse_date(item.get("due"))
    if d and d < today_date:
        return True
    return False

def format_item_text(item):
    raw_stripped = item["raw"].strip()
    if re.match(r"^- \[[xX ]\] ", raw_stripped):
        raw_stripped = raw_stripped[6:]
    return raw_stripped

def output_list(title, items, today_date, as_json=False, total_label="tasks"):
    overdue_items = [i for i in items if is_overdue(i, today_date)]
    other_items = [i for i in items if not is_overdue(i, today_date)]
    
    sections = {}
    for item in other_items:
        sec = item.get("section") or "Uncategorized"
        sections.setdefault(sec, []).append(item)
        
    if as_json:
        out = {
            "date": today_date.isoformat(),
            "items": items,
            "overdue_count": len(overdue_items),
            "sections": sections
        }
        if title == "Praxis Today":
            out["today_count"] = len(items)
        else:
            out["total_count"] = len(items)
        print(json.dumps(out, indent=2))
        return

    print(f"{BOLD}─── {title} {'─' * max(0, 48 - 4 - len(title))}{RESET}")
    
    for item in overdue_items:
        due_str = item.get("due", "unknown")
        print(f"  {WARN}  {RED}OVERDUE:{RESET} {item['text']} {DIM}(due: {due_str}){RESET}")

    if overdue_items and other_items:
        print()
        
    first = True
    for sec, sec_items in sections.items():
        if not first: print()
        first = False
        if sec != "Uncategorized":
            print(f"  {BOLD}{sec}:{RESET}")
        else:
            print(f"  {BOLD}Uncategorized:{RESET}")
        for item in sec_items:
            print(f"    • {format_item_text(item)}")

    print()
    if title == "Praxis Today":
        print(f"  {len(items)} tasks today, {len(overdue_items)} overdue")
    else:
        print(f"  {len(items)} {total_label}, {len(overdue_items)} overdue")
    print(f"{BOLD}──────────────────────────────────────────────────{RESET}")


def cmd_today(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    
    data = read_todo_today()
    if not data["available"]:
        if args.json:
            print(json.dumps({"error": data["error"]}))
        else:
            print(f"Error: {data['error']}", file=sys.stderr)
        return
        
    output_list("Praxis Today", data["items"], today_date, args.json)


def cmd_upcoming(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    end_date = today_date + timedelta(days=14)
    
    data = read_todo()
    if not data["available"]:
        if args.json: print(json.dumps({"error": data["error"]}))
        else: print(f"Error: {data['error']}", file=sys.stderr)
        return
    
    items = []
    for item in data["items"]:
        if item.get("done"): continue
        if "`someday`" in item.get("raw", ""): continue
        
        d = _parse_date(item.get("due"))
        w = _parse_date(item.get("when"))
        
        earliest = None
        for cand in (d, w):
            if cand and today_date <= cand <= end_date:
                if earliest is None or cand < earliest:
                    earliest = cand
        if earliest is not None:
            item["_sort_date"] = earliest
            items.append(item)
            
    items.sort(key=lambda x: x["_sort_date"])
    for i in items:
        del i["_sort_date"]
        
    output_list("Upcoming", items, today_date, args.json)


def cmd_overdue(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    
    data = read_todo()
    if not data["available"]:
        if args.json: print(json.dumps({"error": data["error"]}))
        else: print(f"Error: {data['error']}", file=sys.stderr)
        return
        
    items = []
    for item in data["items"]:
        if item.get("done"): continue
        d = _parse_date(item.get("due"))
        if d and d < today_date:
            item["_sort_date"] = d
            items.append(item)
            
    items.sort(key=lambda x: x["_sort_date"])
    for i in items: del i["_sort_date"]
    
    output_list("Overdue", items, today_date, args.json)


def cmd_someday(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    
    data = read_todo()
    if not data["available"]:
        if args.json: print(json.dumps({"error": data["error"]}))
        else: print(f"Error: {data['error']}", file=sys.stderr)
        return
        
    items = [i for i in data["items"] if not i.get("done") and "`someday`" in i.get("raw", "")]
    output_list("Someday", items, today_date, args.json)


def cmd_all(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    
    data = read_todo()
    if not data["available"]:
        if args.json: print(json.dumps({"error": data["error"]}))
        else: print(f"Error: {data['error']}", file=sys.stderr)
        return
        
    items = [i for i in data["items"] if not i.get("done")]
    output_list("All Items", items, today_date, args.json)


def cmd_spare(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    
    data = read_todo(sections=["Spare Capacity"])
    if not data["available"]:
        if args.json: print(json.dumps({"error": data["error"]}))
        else: print(f"Error: {data['error']}", file=sys.stderr)
        return
        
    items = [i for i in data["items"] if not i.get("done")]
    output_list("Spare Capacity", items, today_date, args.json)


def cmd_clean(args):
    if not PRAXIS.exists():
        if args.json: print(json.dumps({"error": "No Praxis.md found"}))
        else: print("No Praxis.md found.", file=sys.stderr)
        return

    lines = PRAXIS.read_text(encoding="utf-8").splitlines(keepends=True)
    today = datetime.now().strftime("%Y-%m-%d")
    month_header = datetime.now().strftime("%B %Y")

    completed = []
    remaining = []
    skip_children = False

    for line in lines:
        stripped = line.rstrip()
        if re.match(r"^- \[[xX]\]", stripped):
            entry = stripped
            if "done:" not in entry:
                entry += f" `done:{today}`"
            completed.append(entry)
            skip_children = True
            continue

        if skip_children:
            if re.match(r"^  +- ", stripped):
                continue
            else:
                skip_children = False

        remaining.append(line)

    if not completed:
        if args.json: print(json.dumps({"archived": 0, "items": []}))
        else: print(f"  {OK}  No completed items to archive")
        return

    archive_text = PRAXIS_ARCHIVE.read_text(encoding="utf-8") if PRAXIS_ARCHIVE.exists() else ""

    month_pattern = f"## {month_header}"
    if month_pattern in archive_text:
        idx = archive_text.index(month_pattern) + len(month_pattern)
        nl = archive_text.find("\n", idx)
        if nl == -1: nl = len(archive_text)
        insert_text = "\n" + "\n".join(completed)
        archive_text = archive_text[:nl] + insert_text + archive_text[nl:]
    else:
        first_section = archive_text.find("\n## ")
        if first_section >= 0:
            insert_text = f"\n{month_pattern}\n\n" + "\n".join(completed) + "\n"
            archive_text = archive_text[:first_section] + insert_text + archive_text[first_section:]
        else:
            if archive_text and not archive_text.endswith("\n"): archive_text += "\n"
            archive_text += f"\n{month_pattern}\n\n" + "\n".join(completed) + "\n"

    PRAXIS.write_text("".join(remaining), encoding="utf-8")
    PRAXIS_ARCHIVE.write_text(archive_text, encoding="utf-8")

    if args.json:
        print(json.dumps({"archived": len(completed), "items": completed}))
        return

    print(f"  {OK}  Archived {len(completed)} completed item(s)")
    for c in completed:
        print(f"       {DIM}{c[:80]}{RESET}")


def cmd_stats(args):
    iso_today = get_date()["iso"]
    today_date = _parse_date(iso_today)
    week_end = today_date + timedelta(days=7)
    
    data = read_todo()
    if not data["available"]:
        if args.json: print(json.dumps({"error": data["error"]}))
        else: print(f"Error: {data['error']}", file=sys.stderr)
        return
        
    items = [i for i in data["items"] if not i.get("done")]
    
    stats = {
        "total": len(items),
        "overdue": 0,
        "due_this_week": 0,
        "someday": 0,
        "agent_claude": 0,
        "agent_terry": 0,
        "recurring": 0
    }
    
    for i in items:
        d = _parse_date(i.get("due"))
        if d:
            if d < today_date: stats["overdue"] += 1
            if today_date <= d <= week_end: stats["due_this_week"] += 1
            
        if "`someday`" in i.get("raw", ""): stats["someday"] += 1
        if i.get("agent") == "claude": stats["agent_claude"] += 1
        if i.get("agent") == "terry": stats["agent_terry"] += 1
        if i.get("recurring"): stats["recurring"] += 1
        
    if args.json:
        print(json.dumps(stats, indent=2))
        return
        
    print(f"{BOLD}─── Praxis Stats ──────────────────────────────────{RESET}")
    print(f"  Total unchecked: {stats['total']}")
    print(f"  Overdue:         {stats['overdue']}")
    print(f"  Due this week:   {stats['due_this_week']}")
    print(f"  Someday:         {stats['someday']}")
    print(f"  Agent:claude:    {stats['agent_claude']}")
    print(f"  Agent:terry:     {stats['agent_terry']}")
    print(f"  Recurring:       {stats['recurring']}")
    print(f"{BOLD}─────────────────────────────────────────────────{RESET}")


def main():
    parser = argparse.ArgumentParser(
        prog="todo-cli",
        description="Deterministic Praxis.md operations.",
    )
    
    parser.add_argument("--json", action="store_true", help="Machine-readable output")
    sub = parser.add_subparsers(dest="command")

    cmd_funcs = {
        "today": cmd_today,
        "upcoming": cmd_upcoming,
        "overdue": cmd_overdue,
        "someday": cmd_someday,
        "all": cmd_all,
        "spare": cmd_spare,
        "clean": cmd_clean,
        "stats": cmd_stats
    }

    for name in cmd_funcs:
        p = sub.add_parser(name)
        # Allow --json on subcommands as well
        p.add_argument("--json", action="store_true", help="Machine-readable output")

    args = parser.parse_args()

    # If --json was passed globally, propagate to args.json
    global_json = args.json
    
    if not args.command:
        args.command = "today"
        args.json = global_json
    else:
        # If passed globally or specifically
        args.json = global_json or getattr(args, "json", False)

    if args.command in cmd_funcs:
        cmd_funcs[args.command](args)
    else:
        parser.print_help()
        sys.exit(1)

if __name__ == "__main__":
    main()

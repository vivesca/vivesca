#!/usr/bin/env python3
"""todo -- CRUD operations on ~/notes/Praxis.md.

Pure program, no LLM. Called by kairos-gather, commute-gather, auspex-gather,
and any other skill that needs to read or mutate the praxis list.

Usage:
    todo list                              # incomplete items only
    todo list --all                        # all items including completed
    todo list --section "GARP"             # filter by section header
    todo list --tag "agent:claude"         # filter by inline tag
    todo list --due today                  # due today or overdue
    todo list --due week                   # due within 7 days
    todo add "Task description" [options]  # add item to section
    todo check "partial match"             # mark item complete (fuzzy)
    todo remove "partial match"            # remove item entirely (fuzzy)
    todo overdue                           # items past due date
    todo count                             # count by section / tag / status

Options for `add`:
    --section SECTION   section to add under (default: first section found)
    --tag TAG           inline tag to append (e.g. agent:terry)
    --due DATE          due date in YYYY-MM-DD format

Global options:
    --file PATH         override Praxis.md path (default: ~/notes/Praxis.md)
    --first             for check/remove: pick first match without prompting
"""

import argparse
import re
import sys
from datetime import date, timedelta
from pathlib import Path

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

DEFAULT_PRAXIS = Path.home() / "notes" / "Praxis.md"
DISMISSED_PATH = Path.home() / "notes" / "Praxis Dismissed.md"

# Matches `due:YYYY-MM-DD` anywhere in a line
DUE_RE = re.compile(r"\bdue:(\d{4}-\d{2}-\d{2})\b")

# Matches any inline tag token: word chars, colon, more word chars / hyphens
TAG_RE = re.compile(r"\b([a-zA-Z][a-zA-Z0-9_-]*:[a-zA-Z0-9_+:/-]+)\b")

# Matches a markdown section header (any level of #)
SECTION_RE = re.compile(r"^(#{1,6})\s+(.+)$")

# Matches a checkbox line: optional leading spaces/tabs, then - [ ] or - [x]
CHECKBOX_RE = re.compile(r"^(\s*)-\s+\[([ xX])\]\s+(.*)$")


# ---------------------------------------------------------------------------
# Data structures
# ---------------------------------------------------------------------------


class Item:
    """A single checkbox line in Praxis.md."""

    def __init__(self, line_no: int, raw: str, indent: str, done: bool, text: str):
        self.line_no = line_no  # 0-based index in the lines list
        self.raw = raw  # verbatim line from file
        self.indent = indent  # leading whitespace
        self.done = done  # True if [x]
        self.text = text  # everything after `- [x] ` or `- [ ] `
        self.section = ""  # populated by load()
        self.due: date | None = None  # populated by load()

        m = DUE_RE.search(text)
        if m:
            try:
                self.due = date.fromisoformat(m.group(1))
            except ValueError:
                pass

    @property
    def tags(self) -> list[str]:
        return TAG_RE.findall(self.text)

    def mark_done(self) -> str:
        """Return a new raw line with the checkbox ticked."""
        return re.sub(r"\[ \]", "[x]", self.raw, count=1)

    def __repr__(self):
        status = "x" if self.done else " "
        return f"[{status}] (L{self.line_no + 1}) {self.text[:80]}"


# ---------------------------------------------------------------------------
# Load / save
# ---------------------------------------------------------------------------


def load(path: Path) -> tuple[list[str], list[Item]]:
    """Read Praxis.md; return (raw_lines, items)."""
    if not path.exists():
        sys.exit(f"todo: file not found: {path}")
    raw = path.read_text(encoding="utf-8")
    lines = raw.splitlines(keepends=True)

    items: list[Item] = []
    current_section = ""

    for i, line in enumerate(lines):
        stripped = line.rstrip("\n\r")
        sm = SECTION_RE.match(stripped)
        if sm:
            current_section = sm.group(2)
            continue
        cm = CHECKBOX_RE.match(stripped)
        if cm:
            indent, mark, text = cm.group(1), cm.group(2), cm.group(3)
            done = mark.lower() == "x"
            item = Item(i, stripped, indent, done, text)
            item.section = current_section
            items.append(item)

    return lines, items


def save(path: Path, lines: list[str]) -> None:
    """Write lines back, preserving line endings."""
    # Ensure every line ends with newline; last line gets one too.
    out = []
    for line in lines:
        s = line.rstrip("\n\r")
        out.append(s + "\n")
    path.write_text("".join(out), encoding="utf-8")


# ---------------------------------------------------------------------------
# Filtering helpers
# ---------------------------------------------------------------------------


def _today() -> date:
    return date.today()


def filter_items(
    items: list[Item],
    *,
    include_done: bool = False,
    section_filter: str | None = None,
    tag_filter: str | None = None,
    due_filter: str | None = None,
) -> list[Item]:
    """Apply all active filters and return matching items."""
    today = _today()
    result = []
    for item in items:
        if not include_done and item.done:
            continue
        if section_filter and section_filter.lower() not in item.section.lower():
            continue
        if tag_filter and not any(tag_filter.lower() in t.lower() for t in item.tags):
            # also allow matching raw text for bare tokens like `someday`
            if tag_filter.lower() not in item.text.lower():
                continue
        if due_filter == "today":
            if item.due is None or item.due > today:
                continue
        elif due_filter == "week":
            if item.due is None or item.due > today + timedelta(days=7):
                continue
        result.append(item)
    return result


# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------


def format_item(item: Item) -> str:
    status = "[x]" if item.done else "[ ]"
    due_str = f"  due:{item.due}" if item.due else ""
    return f"  {status} (§ {item.section}) {item.text}{due_str}"


def print_items(items: list[Item], verbose: bool = False) -> None:
    if not items:
        print("(no matching items)")
        return
    current_section = None
    for item in items:
        if item.section != current_section:
            print(f"\n## {item.section}")
            current_section = item.section
        status = "[x]" if item.done else "[ ]"
        print(f"  {item.indent}{status} {item.text}")


# ---------------------------------------------------------------------------
# Fuzzy match helpers
# ---------------------------------------------------------------------------


def fuzzy_match(items: list[Item], query: str) -> list[Item]:
    """Case-insensitive substring match against item text."""
    q = query.lower()
    return [item for item in items if q in item.text.lower()]


def resolve_match(items: list[Item], query: str, first: bool) -> Item | None:
    """
    Find items matching query. If exactly one match, return it.
    If multiple and --first, return the first. Otherwise print all and exit.
    """
    matches = fuzzy_match(items, query)
    if not matches:
        print(f"todo: no item matching '{query}'")
        return None
    if len(matches) == 1:
        return matches[0]
    if first:
        return matches[0]
    print(f"todo: {len(matches)} items match '{query}' — refine your query or use --first:")
    for m in matches:
        print(f"  L{m.line_no + 1}: {m.text}")
    return None


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_list(args, path: Path) -> None:
    _, items = load(path)
    filtered = filter_items(
        items,
        include_done=args.all,
        section_filter=args.section,
        tag_filter=args.tag,
        due_filter=args.due,
    )
    print_items(filtered)


def _is_dismissed(text: str) -> str | None:
    """Check if text matches any entry in Praxis Dismissed.md. Returns the matching entry or None."""
    if not DISMISSED_PATH.exists():
        return None
    for line in DISMISSED_PATH.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line.startswith("- ") and len(line) > 2:
            entry = line[2:].strip().lower()
            if entry and entry in text.lower():
                return line[2:].strip()
    return None


def cmd_add(args, path: Path) -> None:
    lines, items = load(path)
    text = args.text.strip()

    # Check suppress list
    dismissed = _is_dismissed(text)
    if dismissed:
        print(f"todo: BLOCKED — matches dismissed item '{dismissed}' (see Praxis Dismissed.md)")
        return

    # Build inline tags
    extra_tags = []
    if args.tag:
        # Only append if not already in text
        if args.tag not in text:
            extra_tags.append(args.tag)
    if args.due:
        due_token = f"due:{args.due}"
        if due_token not in text:
            extra_tags.append(due_token)
    if extra_tags:
        text = text + "  " + "  ".join(f"`{t}`" for t in extra_tags)
        # Actually match the existing style: bare tokens without backticks
        text = args.text.strip()
        tag_suffix = "  " + "  ".join(extra_tags)
        text = text + tag_suffix

    new_line = f"- [ ] {text}"

    if args.section:
        # Find the section and insert after its header, before next section or EOF
        target = args.section.lower()
        insert_at = None
        in_target = False
        for i, raw in enumerate(lines):
            stripped = raw.rstrip("\n\r")
            sm = SECTION_RE.match(stripped)
            if sm:
                sec_title = sm.group(2)
                if sec_title.lower().find(target) != -1 and not in_target:
                    in_target = True
                    # Find end of this section: next header or EOF
                    for j in range(i + 1, len(lines)):
                        ns = lines[j].rstrip("\n\r")
                        if SECTION_RE.match(ns):
                            insert_at = j
                            break
                    else:
                        insert_at = len(lines)
                    break
        if insert_at is None:
            # Section not found — append at end
            print(f"todo: section '{args.section}' not found, appending at end")
            insert_at = len(lines)
    else:
        # No section specified — append at end
        insert_at = len(lines)

    # Insert before a blank line at the boundary if there is one
    if insert_at < len(lines):
        adjusted = insert_at
        while adjusted > 0 and lines[adjusted - 1].strip() == "":
            adjusted -= 1
        insert_at = adjusted

    lines.insert(insert_at, new_line + "\n")
    save(path, lines)
    print(f"todo: added — {new_line}")


def cmd_check(args, path: Path) -> None:
    lines, items = load(path)
    incomplete = [i for i in items if not i.done]
    item = resolve_match(incomplete, args.query, args.first)
    if item is None:
        sys.exit(1)
    lines[item.line_no] = item.mark_done() + "\n"
    save(path, lines)
    print(f"todo: marked done — {item.text}")


def cmd_remove(args, path: Path) -> None:
    lines, items = load(path)
    item = resolve_match(items, args.query, args.first)
    if item is None:
        sys.exit(1)
    removed = lines.pop(item.line_no)
    save(path, lines)
    print(f"todo: removed — {removed.strip()}")


def cmd_overdue(args, path: Path) -> None:
    _, items = load(path)
    today = _today()
    overdue = [i for i in items if not i.done and i.due is not None and i.due < today]
    overdue.sort(key=lambda i: i.due)
    if not overdue:
        print("(no overdue items)")
        return
    print(f"Overdue ({len(overdue)} items):")
    for item in overdue:
        days = (today - item.due).days
        print(f"  [ ] {item.text}  [{days}d overdue — due:{item.due}]  (§ {item.section})")


def cmd_count(args, path: Path) -> None:
    _, items = load(path)
    today = _today()

    # By status
    done = sum(1 for i in items if i.done)
    incomplete = sum(1 for i in items if not i.done)
    overdue = sum(1 for i in items if not i.done and i.due is not None and i.due < today)
    print(f"Status:  {incomplete} incomplete  {done} done  {overdue} overdue")

    # By section
    from collections import Counter

    sec_counts: Counter = Counter()
    for item in items:
        if not item.done:
            sec_counts[item.section] += 1
    print("\nIncomplete by section:")
    for sec, count in sec_counts.most_common():
        label = sec if sec else "(no section)"
        print(f"  {count:3d}  {label}")

    # By tag
    tag_counts: Counter = Counter()
    for item in items:
        if not item.done:
            for tag in item.tags:
                tag_counts[tag] += 1
    if tag_counts:
        print("\nIncomplete by tag (top 20):")
        for tag, count in tag_counts.most_common(20):
            print(f"  {count:3d}  {tag}")


# ---------------------------------------------------------------------------
# CLI entry point
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="todo",
        description="CRUD operations on ~/notes/Praxis.md.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--file", metavar="PATH", help="override Praxis.md path")

    sub = p.add_subparsers(dest="command", metavar="COMMAND")
    sub.required = True

    # list
    ls = sub.add_parser("list", help="list items")
    ls.add_argument("--all", action="store_true", help="include completed items")
    ls.add_argument("--section", metavar="TEXT", help="filter by section header")
    ls.add_argument("--tag", metavar="TAG", help="filter by inline tag")
    ls.add_argument(
        "--due",
        metavar="PERIOD",
        choices=["today", "week"],
        help="filter by due date (today = due today or overdue, week = due within 7 days)",
    )

    # add
    add = sub.add_parser("add", help="add a new item")
    add.add_argument("text", help="task description")
    add.add_argument("--section", metavar="TEXT", help="section to add under")
    add.add_argument("--tag", metavar="TAG", help="inline tag to append")
    add.add_argument("--due", metavar="YYYY-MM-DD", help="due date")

    # check
    chk = sub.add_parser("check", help="mark an item as complete (fuzzy match)")
    chk.add_argument("query", help="substring of the task to match")
    chk.add_argument("--first", action="store_true", help="pick first match if multiple")

    # remove
    rm = sub.add_parser("remove", help="remove an item entirely (fuzzy match)")
    rm.add_argument("query", help="substring of the task to match")
    rm.add_argument("--first", action="store_true", help="pick first match if multiple")

    # overdue
    sub.add_parser("overdue", help="list items past their due date")

    # count
    sub.add_parser("count", help="count items by section, tag, and status")

    return p


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    path = Path(args.file).expanduser() if args.file else DEFAULT_PRAXIS

    dispatch = {
        "list": cmd_list,
        "add": cmd_add,
        "check": cmd_check,
        "remove": cmd_remove,
        "overdue": cmd_overdue,
        "count": cmd_count,
    }

    dispatch[args.command](args, path)


if __name__ == "__main__":
    main()

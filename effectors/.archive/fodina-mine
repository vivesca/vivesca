#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# ///
"""Cross-model specimen mining. Fires probe prompt at multiple LLMs in parallel."""

import argparse
import concurrent.futures
import datetime
import os
import re
import sys
import textwrap

sys.path.insert(0, os.path.expanduser("~/code/vivesca/lib"))
from llm import list_models, load_models, query_safe

DEFAULT_PROMPT = textwrap.dedent("""\
You are a knowledge miner. I'm going to name a specimen (a thinker, tradition, failure, fiction, or discipline). Extract 5-6 distinctive cognitive MOVES — not biography, not theory, but the specific thinking techniques embedded in this specimen that transfer to other domains. For each move, state: (1) what it is in one sentence, (2) one concrete example, (3) a transferable heuristic starting with a verb. Be sharp and specific, not generic. Avoid well-known platitudes — dig for the non-obvious. The specimen:""")


def get_prompt(prompt_file: str | None = None) -> str:
    """Load prompt from file, or fall back to vault template, or use default."""
    if prompt_file:
        path = os.path.expanduser(prompt_file)
        if not os.path.exists(path):
            print(f"Error: prompt file not found: {path}", file=sys.stderr)
            sys.exit(1)
        with open(path, encoding="utf-8") as f:
            return f.read().strip()

    vault_file = os.path.expanduser("~/notes/Fodina Mining Prompt.md")
    if os.path.exists(vault_file):
        try:
            with open(vault_file, encoding="utf-8") as f:
                content = f.read()
            match = re.search(r"```(?:markdown|text)?\n(.*?)\n```", content, re.DOTALL)
            if match:
                return match.group(1).strip()
        except Exception:
            pass
    return DEFAULT_PROMPT.strip()


def save_results(results: list[tuple[str, str]], topic: str, model_names: list[str]) -> str:
    date_str = datetime.datetime.now().strftime("%Y-%m-%d")
    safe_name = re.sub(r"[^a-zA-Z0-9_\-]", "_", topic.replace(" ", "_"))[:80]
    save_dir = os.path.expanduser("~/notes/Fodina")
    os.makedirs(save_dir, exist_ok=True)
    save_path = os.path.join(save_dir, f"{date_str}-{safe_name}.md")

    with open(save_path, "w", encoding="utf-8") as f:
        f.write(f"# {topic} — Fodina Mining\n\n")
        f.write(f"Date: {date_str}\n")
        f.write(f"Models: {', '.join(model_names)}\n\n")

        for name, output in sorted(results, key=lambda x: x[0]):
            f.write(f"## {name.upper()}\n\n")
            f.write(f"{output}\n\n")

    return save_path


def main():
    parser = argparse.ArgumentParser(
        description="Cross-model specimen mining.",
        epilog=textwrap.dedent("""\
            examples:
              fodina-mine Einstein                          # default probe, all models
              fodina-mine --models gemini,deepseek Stoicism # specific models
              fodina-mine --prompt-file probe.txt           # custom probe (no specimen needed)
              fodina-mine --prompt "Extract..." --save      # inline custom probe, save results
        """),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "specimen", nargs="*", help="The specimen to mine (appended to probe prompt)"
    )
    parser.add_argument("--list", action="store_true", help="List available backends")
    parser.add_argument(
        "--models", help="Comma-separated list of models to use (or 'all')", default="all"
    )
    parser.add_argument("--save", action="store_true", help="Save results to ~/notes/Fodina/")
    parser.add_argument(
        "--timeout", type=int, default=180, help="Timeout in seconds (default 180)"
    )
    parser.add_argument("--prompt", help="Custom probe prompt (replaces default template)")
    parser.add_argument(
        "--prompt-file", help="Read probe prompt from file (replaces default template)"
    )

    args = parser.parse_args()

    if args.list:
        print("Available backends:")
        for name, desc in list_models().items():
            print(f"  {name:10} : {desc}")
        sys.exit(0)

    # Build the full prompt
    if args.prompt:
        full_prompt = args.prompt
    elif args.prompt_file:
        full_prompt = get_prompt(args.prompt_file)
    elif args.specimen:
        prompt_base = get_prompt()
        full_prompt = f"{prompt_base} {' '.join(args.specimen)}"
    else:
        parser.print_help()
        sys.exit(1)

    # If specimen provided with custom prompt, append it
    if (args.prompt or args.prompt_file) and args.specimen:
        full_prompt = f"{full_prompt} {' '.join(args.specimen)}"

    # Derive topic name for display/save
    topic = " ".join(args.specimen) if args.specimen else "custom-probe"

    # Select models
    all_models = load_models()
    selected_names = []
    if args.models == "all":
        selected_names = list(all_models.keys())
    else:
        for m in (m.strip() for m in args.models.split(",")):
            if m in all_models or m.startswith("openrouter/"):
                selected_names.append(m)
            else:
                print(
                    f"Warning: unknown model '{m}' (use 'openrouter/<model>' for custom OpenRouter models)"
                )

    if not selected_names:
        print("Error: no valid models selected.")
        sys.exit(1)

    print(f"Mining: {topic}")
    print(f"Models: {', '.join(selected_names)}")
    print(f"Timeout: {args.timeout}s\n")

    results = []

    with concurrent.futures.ThreadPoolExecutor(max_workers=len(selected_names)) as pool:
        futures = {
            pool.submit(query_safe, name, full_prompt, args.timeout): name
            for name in selected_names
        }
        for future in concurrent.futures.as_completed(futures):
            name, output = future.result()
            results.append((name, output))
            print(f"{'=' * 60}")
            print(f"  {name.upper()}")
            print(f"{'=' * 60}")
            print(output)
            print()

    if args.save:
        save_path = save_results(results, topic, selected_names)
        print(f"Saved results to: {save_path}")


if __name__ == "__main__":
    main()

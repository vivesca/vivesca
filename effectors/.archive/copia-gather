"""
copia-gather — deterministic pre-flight and state management for the /copia skill.
"""

import argparse
import concurrent.futures
import json
import sys
from datetime import datetime
from pathlib import Path

# Add lib to path
sys.path.insert(0, str(Path.home() / "reticulum/lib"))
import gather

# Paths
HOME = Path.home()
TMP_DIR = HOME / "tmp"
GUARD_FILE = TMP_DIR / ".copia-guard-active"
MANIFEST_FILE = TMP_DIR / "copia-session.md"
PRAXIS_MD = HOME / "notes" / "Praxis.md"
NORTH_STAR_MD = HOME / "notes" / "North Star.md"

def check_consumption(todo_path: Path):
    count = 0
    items = []
    if todo_path.exists():
        for line in todo_path.read_text(encoding="utf-8").splitlines():
            clean_line = line.strip()
            if "agent:terry" in clean_line and "review" in clean_line.lower() and not clean_line.startswith("- [x]"):
                count += 1
                if clean_line.startswith("- [ ] "):
                    clean_line = clean_line[6:]
                items.append(clean_line)
    
    if count <= 3:
        signal = "green"
    elif count <= 8:
        signal = "yellow"
    else:
        signal = "red"
        
    return {"count": count, "signal": signal, "items": items}

def get_north_stars(path: Path):
    stars = []
    if path.exists():
        for line in path.read_text(encoding="utf-8").splitlines():
            if line.startswith("## "):
                stars.append(line[3:].strip())
    return stars

def get_manifest_status(path: Path):
    if not path.exists():
        return {"exists": False}
    
    completed = 0
    in_progress = 0
    current_section = None
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.startswith("## Completed"):
            current_section = "completed"
        elif line.startswith("## In Progress"):
            current_section = "in_progress"
        elif line.startswith("## "):
            current_section = "other"
        elif current_section == "completed" and line.strip() and not line.startswith("#"):
            completed += 1
        elif current_section == "in_progress" and line.strip() and not line.startswith("#"):
            in_progress += 1
    return {"exists": True, "completed": completed, "in_progress": in_progress}


def cmd_preflight(args):
    consumption = check_consumption(PRAXIS_MD)
    
    with concurrent.futures.ThreadPoolExecutor(max_workers=4) as pool:
        f_now = pool.submit(gather.read_now)
        f_todo = pool.submit(gather.read_todo)
        f_date = pool.submit(gather.get_date)
        f_budget = pool.submit(gather.check_budget)
        
        now_data = f_now.result()
        todo_data = f_todo.result()
        date_data = f_date.result()
        budget_data = f_budget.result()

    claude_items = []
    if todo_data.get("available"):
        for item in todo_data.get("items", []):
            if item.get("agent") == "claude" and not item.get("done"):
                claude_items.append(item)
                
    north_stars = get_north_stars(NORTH_STAR_MD)
    guard_active = GUARD_FILE.exists()
    manifest = get_manifest_status(MANIFEST_FILE)
    
    if getattr(args, "json", False):
        out = {
            "consumption": consumption,
            "budget": budget_data,
            "guard": {"active": guard_active},
            "manifest": manifest,
            "north_stars": north_stars,
            "todo_agent_claude": {
                "count": len(claude_items),
                "items": claude_items
            },
            "now": now_data
        }
        print(json.dumps(out, indent=2))
        return

    print("─── Copia Preflight ─────────────────────────────")
    
    q_count = consumption["count"]
    q_sig = consumption["signal"]
    q_desc = "produce freely" if q_sig == "green" else "self-sufficient only" if q_sig == "yellow" else "triage"
    print(f"  Review queue: {q_count} items ({q_sig} — {q_desc})")
    
    budget_sum = budget_data.get("summary", "unknown") if budget_data.get("available") and budget_data.get("summary") else "unknown"
    print(f"  Budget:       {budget_sum}")
    
    print(f"  Guard:        {'active' if guard_active else 'inactive'}")
    
    if manifest["exists"]:
        print(f"  Manifest:     {manifest['completed']} completed, {manifest['in_progress']} in progress")
    else:
        print(f"  Manifest:     none (will create)")
        
    print(f"  North Stars:  {len(north_stars)} loaded")
    print(f"  Praxis agent:claude items: {len(claude_items)}")
    
    now_open = len([i for i in now_data.get("progress", []) if i.get("state") != "done"])
    print(f"  Tonus:        {now_open} open items")
    
    print("──────────────────────────────────────────────────")


def cmd_guard(args):
    action = args.action
    if action == "on":
        TMP_DIR.mkdir(parents=True, exist_ok=True)
        GUARD_FILE.touch()
        print("Guard activated.")
    elif action == "off":
        if GUARD_FILE.exists():
            GUARD_FILE.unlink()
        print("Guard deactivated.")
    elif action == "status":
        if GUARD_FILE.exists():
            print("Guard is active.")
        else:
            print("Guard is inactive.")


def cmd_manifest_init():
    TMP_DIR.mkdir(parents=True, exist_ok=True)
    now_str = datetime.now().strftime("%Y-%m-%d %H:%M")
    content = f"# Copia Session — {now_str}\n## Completed\n## In Progress\n## Not Started\n"
    MANIFEST_FILE.write_text(content, encoding="utf-8")
    print(f"Manifest created at {MANIFEST_FILE}")

def cmd_manifest(args):
    action = args.action
    if action == "init":
        cmd_manifest_init()
    elif action == "update":
        if not MANIFEST_FILE.exists():
            cmd_manifest_init()
        
        lines = MANIFEST_FILE.read_text(encoding="utf-8").splitlines()
        out = []
        in_completed = False
        inserted = False
        for line in lines:
            if line.startswith("## "):
                if in_completed and not inserted and args.text:
                    out.append(args.text)
                    inserted = True
                in_completed = line.startswith("## Completed")
            out.append(line)
        if in_completed and not inserted and args.text:
            out.append(args.text)
            
        MANIFEST_FILE.write_text("\n".join(out) + "\n", encoding="utf-8")
        print("Manifest updated.")
    elif action == "show":
        if MANIFEST_FILE.exists():
            print(MANIFEST_FILE.read_text(encoding="utf-8"))
        else:
            print("No manifest exists.")

def main():
    parser = argparse.ArgumentParser(prog="copia-gather", description="Copia pre-flight and state management.")
    subparsers = parser.add_subparsers(dest="command", required=False)
    
    p_pre = subparsers.add_parser("preflight", help="run consumption check + context load")
    p_pre.add_argument("--json", action="store_true", help="JSON output")
    
    p_guard = subparsers.add_parser("guard", help="manage the stop guard file")
    p_guard.add_argument("action", choices=["on", "off", "status"], help="Guard action")
    
    p_manifest = subparsers.add_parser("manifest", help="manage the session manifest")
    p_manifest.add_argument("action", choices=["init", "update", "show"], help="Manifest action")
    p_manifest.add_argument("text", nargs="?", default="", help="Text to append for update action")
    
    # Pre-parse magic for default preflight
    argv = sys.argv[1:]
    if not argv:
        argv = ["preflight"]
    elif argv[0] == "--json":
        argv = ["preflight", "--json"]
        
    args = parser.parse_args(argv)
    
    if args.command == "preflight":
        cmd_preflight(args)
    elif args.command == "guard":
        cmd_guard(args)
    elif args.command == "manifest":
        cmd_manifest(args)

if __name__ == "__main__":
    main()

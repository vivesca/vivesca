#!/usr/bin/env python3
"""queue-gen — generate translation-queue.md entries for untested files.

Scans a directory, finds files without corresponding tests in assays/,
and generates formatted queue entries with smart batching by size.

Usage:
    queue-gen effectors/                    # generate entries for effectors
    queue-gen metabolon/ --max-turns 40     # custom turn limit
    queue-gen effectors/ --provider zhipu   # specific provider
    queue-gen effectors/ --dry-run          # just print, don't write

Smart batching:
    - Large files (>500 lines): solo task with higher turn limit
    - Medium files (200-500 lines): batch of 2-3
    - Small files (<200 lines): batch of 3-5
"""

import argparse
import re
import sys
from collections import namedtuple
from pathlib import Path

FileEntry = namedtuple("FileEntry", ["path", "lines", "test_name"])

GERMLINE = Path.home() / "germline"
QUEUE_PATH = GERMLINE / "loci" / "translation-queue.md"
ASSAYS_DIR = GERMLINE / "assays"

# Size thresholds
LARGE = 500
MEDIUM = 200


def get_file_lines(path: Path) -> int:
    """Count non-empty lines in a file."""
    try:
        return sum(1 for line in path.read_text().splitlines() if line.strip())
    except Exception:
        return 0


def file_to_test_name(path: Path) -> str:
    """Convert a file path to its expected test name.

    effectors/foo-bar -> test_foo_bar.py
    effectors/foo_bar.py -> test_foo_bar.py
    metabolon/organelles/baz.py -> test_baz.py
    """
    stem = path.stem if path.suffix else path.name
    # Normalize hyphens to underscores
    normalized = stem.replace("-", "_")
    return f"test_{normalized}.py"


def has_test(test_name: str) -> bool:
    """Check if a test file exists in assays/."""
    return (ASSAYS_DIR / test_name).exists()


def scan_directory(directory: Path, exclude_patterns: list[str] | None = None) -> list[FileEntry]:
    """Scan directory for untested files.

    Returns list of FileEntry for files without tests, sorted by size descending.
    """
    exclude_patterns = exclude_patterns or [
        r"^__pycache__",
        r"\.pyc$",
        r"\.md$",
        r"\.json$",
        r"\.txt$",
        r"\.sh$",  # Shell scripts typically don't need tests
        r"^test_",
        r"^conftest",
    ]
    exclude_re = re.compile("|".join(exclude_patterns))

    entries = []
    for path in directory.rglob("*"):
        if not path.is_file():
            continue
        rel = path.relative_to(directory)
        if exclude_re.search(str(rel)):
            continue

        test_name = file_to_test_name(path)
        if has_test(test_name):
            continue

        lines = get_file_lines(path)
        if lines == 0:
            continue

        entries.append(FileEntry(path, lines, test_name))

    # Sort by size descending for batching
    return sorted(entries, key=lambda e: e.lines, reverse=True)


def batch_entries(entries: list[FileEntry]) -> list[list[FileEntry]]:
    """Group entries into batches by size."""
    batches = []
    current_batch = []

    for entry in entries:
        if entry.lines >= LARGE:
            # Large file gets its own batch
            if current_batch:
                batches.append(current_batch)
                current_batch = []
            batches.append([entry])
        elif entry.lines >= MEDIUM:
            # Medium files: batch of 2-3
            current_batch.append(entry)
            if len(current_batch) >= 2:
                batches.append(current_batch)
                current_batch = []
        else:
            # Small files: batch of 3-5
            current_batch.append(entry)
            if len(current_batch) >= 4:
                batches.append(current_batch)
                current_batch = []

    if current_batch:
        batches.append(current_batch)

    return batches


def generate_entry(batch: list[FileEntry], provider: str, max_turns: int) -> str:
    """Generate a translation-queue entry for a batch."""
    if len(batch) == 1:
        entry = batch[0]
        rel_path = entry.path.relative_to(GERMLINE)
        lines_str = f"({entry.lines} lines)" if entry.lines >= MEDIUM else ""

        # Determine turn limit based on size
        turns = max_turns
        if entry.lines >= LARGE:
            turns = min(max_turns + 20, 60)

        title = f"Write tests for {rel_path}"
        test_file = f"assays/{entry.test_name}"
        modules = str(rel_path)

        return f"""#### {title} {lines_str}
- [ ] `ribosome --provider {provider} --max-turns {turns} "Write tests for {modules}. Write {test_file}. Mock external calls, subprocess, file I/O. Run pytest. Fix failures."`"""

    # Multiple files in batch
    rel_paths = [str(e.path.relative_to(GERMLINE)) for e in batch]
    test_files = [f"assays/{e.test_name}" for e in batch]
    total_lines = sum(e.lines for e in batch)

    title = f"Write tests for {len(batch)} modules ({total_lines} lines total)"
    modules_str = " ".join(rel_paths)
    tests_str = " ".join(test_files)

    return f"""#### {title}
- [ ] `ribosome --provider {provider} --max-turns {max_turns} "Write tests: {tests_str}. Run pytest. Fix failures. Modules: {modules_str}"`"""


def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "directory",
        type=Path,
        help="Directory to scan for untested files",
    )
    parser.add_argument(
        "--provider",
        default="volcano",
        choices=["zhipu", "infini", "volcano"],
        help="Ribosome provider to use (default: volcano)",
    )
    parser.add_argument(
        "--max-turns",
        type=int,
        default=30,
        help="Maximum turns for ribosome tasks (default: 30)",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print entries without writing to queue",
    )
    parser.add_argument(
        "--output",
        type=Path,
        help="Write to this file instead of translation-queue.md",
    )

    args = parser.parse_args()

    if not args.directory.exists():
        print(f"Error: directory not found: {args.directory}", file=sys.stderr)
        sys.exit(1)

    entries = scan_directory(args.directory)
    if not entries:
        print(f"No untested files found in {args.directory}", file=sys.stderr)
        sys.exit(0)

    batches = batch_entries(entries)

    output_lines = [
        f"### Generated by queue-gen ({len(entries)} untested files, {len(batches)} batches)\n",
    ]

    for batch in batches:
        output_lines.append(generate_entry(batch, args.provider, args.max_turns))
        output_lines.append("")

    output_text = "\n".join(output_lines)

    if args.dry_run:
        print(output_text)
        return

    output_path = args.output or QUEUE_PATH
    if output_path.exists():
        # Append to existing file
        with open(output_path, "a") as f:
            f.write("\n" + output_text)
        print(f"Appended {len(batches)} entries to {output_path}", file=sys.stderr)
    else:
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(output_text)
        print(f"Wrote {len(batches)} entries to {output_path}", file=sys.stderr)


if __name__ == "__main__":
    main()

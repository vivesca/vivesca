"""methylation — weekly crystallization effector for the vivesca organism.

Reads the three signal sources from the past 7 days:
  - ~/.cache/inflammasome/methylation-candidates.jsonl  (successful repairs)
  - ~/.local/share/vivesca/infections.jsonl             (infection patterns)
  - ~/logs/inflammasome.log                             (probe results)

Groups failures and repairs by pattern (probe name, repair label).
If any pattern appears >= 2 times, dispatches channel sonnet -p for one
synthesis call that proposes either:
  a. A new probe function for inflammasome.py
  b. A new _REPAIR_PATTERNS entry
  c. A systemic architectural observation

Writes proposal to ~/tmp/methylation-proposal-YYYY-MM-DD.md.
Logs to ~/logs/methylation.log.
Always exits 0.
"""

from __future__ import annotations

import json
import subprocess
import sys
import time
from collections import Counter
from datetime import UTC, datetime, timedelta
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

METHYLATION_CANDIDATES = Path.home() / ".cache" / "inflammasome" / "methylation-candidates.jsonl"
INFECTION_LOG = Path.home() / ".local" / "share" / "vivesca" / "infections.jsonl"
INFLAMMASOME_LOG = Path.home() / "logs" / "inflammasome.log"
INFLAMMASOME_PY = Path.home() / "germline" / "metabolon" / "organelles" / "inflammasome.py"
CHANNEL = Path.home() / "germline" / "effectors" / "channel"
LOG_FILE = Path.home() / "logs" / "methylation.log"
TMP_DIR = Path.home() / "tmp"

MAX_ENTRIES = 100
MIN_PATTERN_COUNT = 2
WINDOW_DAYS = 7

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def log(msg: str) -> None:
    ts = datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")
    line = f"[{ts}] {msg}"
    print(line, flush=True)
    try:
        LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a") as f:
            f.write(line + "\n")
    except Exception:
        pass

# ---------------------------------------------------------------------------
# Signal reading
# ---------------------------------------------------------------------------

def _cutoff() -> datetime:
    return datetime.now(UTC) - timedelta(days=WINDOW_DAYS)


def _parse_ts(ts_str: str) -> datetime | None:
    """Parse ISO-8601 timestamp; return None on failure."""
    try:
        dt = datetime.fromisoformat(ts_str)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=UTC)
        return dt
    except Exception:
        return None


def read_methylation_candidates() -> list[dict]:
    """Read successful repairs from the methylation candidates log."""
    if not METHYLATION_CANDIDATES.exists():
        return []
    cutoff = _cutoff()
    events = []
    try:
        lines = METHYLATION_CANDIDATES.read_text().splitlines()
        for line in lines[-MAX_ENTRIES:]:
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
                ts = _parse_ts(ev.get("ts", ""))
                if ts and ts >= cutoff:
                    events.append(ev)
            except Exception:
                continue
    except Exception as exc:
        log(f"WARN: could not read methylation candidates: {exc}")
    return events


def read_infections() -> list[dict]:
    """Read infection events from the past 7 days, max 100."""
    if not INFECTION_LOG.exists():
        return []
    cutoff = _cutoff()
    events = []
    try:
        lines = INFECTION_LOG.read_text().splitlines()
        for line in lines[-MAX_ENTRIES:]:
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
                ts = _parse_ts(ev.get("ts", ""))
                if ts and ts >= cutoff:
                    events.append(ev)
            except Exception:
                continue
    except Exception as exc:
        log(f"WARN: could not read infection log: {exc}")
    return events


def read_inflammasome_log() -> list[dict]:
    """Parse inflammasome.log for FAIL lines in the past 7 days.

    Each FAIL line looks like:
      [2026-03-26T09:10:30Z] [FAIL] probe_name — message (123ms)

    Returns list of {ts, probe, message}.
    """
    if not INFLAMMASOME_LOG.exists():
        return []
    cutoff = _cutoff()
    failures = []
    try:
        lines = INFLAMMASOME_LOG.read_text().splitlines()
        for line in lines:
            line = line.strip()
            if "[FAIL]" not in line:
                continue
            # Extract timestamp
            ts_str = None
            if line.startswith("["):
                end = line.find("]")
                if end > 0:
                    ts_str = line[1:end]
            ts = _parse_ts(ts_str) if ts_str else None
            if ts and ts < cutoff:
                continue
            # Extract probe name and message
            # Format: [...] [FAIL] probe_name — message (Xms)
            after_fail = line.split("[FAIL]", 1)[-1].strip()
            if " — " in after_fail:
                probe, rest = after_fail.split(" — ", 1)
                probe = probe.strip()
                # strip trailing (Xms)
                message = rest.rsplit("(", 1)[0].strip() if "(" in rest else rest.strip()
            else:
                probe = after_fail.strip()
                message = ""
            failures.append({"ts": ts_str or "", "probe": probe, "message": message})
    except Exception as exc:
        log(f"WARN: could not parse inflammasome log: {exc}")
    return failures


# ---------------------------------------------------------------------------
# Pattern extraction
# ---------------------------------------------------------------------------

def extract_probe_names() -> list[str]:
    """Extract _PROBES names from inflammasome.py without importing."""
    try:
        src = INFLAMMASOME_PY.read_text()
        probes = []
        in_probes = False
        for line in src.splitlines():
            if "_PROBES" in line and "list[" in line:
                in_probes = True
            if in_probes:
                if line.strip().startswith('("') or line.strip().startswith("(\""):
                    # Line like:    ("chromatin", probe_chromatin),
                    parts = line.strip().strip("(").strip(")").split(",")
                    if parts:
                        name = parts[0].strip().strip('"').strip("'")
                        if name and not name.startswith("#"):
                            probes.append(name)
                if line.strip() == "]":
                    in_probes = False
        return probes
    except Exception:
        return []


def extract_repair_pattern_labels() -> list[str]:
    """Extract _REPAIR_PATTERNS labels from inflammasome.py without importing."""
    try:
        src = INFLAMMASOME_PY.read_text()
        labels = []
        in_patterns = False
        for line in src.splitlines():
            if "_REPAIR_PATTERNS" in line and "list[" in line:
                in_patterns = True
            if in_patterns:
                # Label is 4th element: ("rss_state", lambda..., _repair_fn, "label"),
                stripped = line.strip()
                if stripped.startswith('"') and stripped.endswith('",'):
                    # Could be a label line (4th element on its own line)
                    candidate = stripped.strip('",')
                    if candidate and "_" in candidate and " " not in candidate:
                        labels.append(candidate)
                if line.strip() == "]":
                    in_patterns = False
        return labels
    except Exception:
        return []


def summarize_repairs(candidates: list[dict]) -> str:
    """Build a text summary of methylation candidates (successful repairs)."""
    if not candidates:
        return "No successful repairs logged in the past 7 days."
    # Group by probe/tool name
    counts: Counter = Counter()
    for ev in candidates:
        key = ev.get("probe") or ev.get("tool") or ev.get("repair_label") or "unknown"
        counts[key] += 1
    lines = ["Successful repairs (last 7 days):"]
    for name, count in counts.most_common(10):
        lines.append(f"  {name}: {count}x")
    # Add a sample of raw entries
    lines.append("\nSample entries:")
    for ev in candidates[:5]:
        lines.append(f"  {json.dumps(ev)}")
    return "\n".join(lines)


def summarize_infections(events: list[dict], failures: list[dict]) -> str:
    """Build a text summary of infection events and log failures."""
    lines = []
    if events:
        tool_counts: Counter = Counter(ev.get("tool", "unknown") for ev in events)
        lines.append("Infection log patterns (last 7 days):")
        for tool, count in tool_counts.most_common(10):
            # Count healed vs unhealed
            healed = sum(1 for ev in events if ev.get("tool") == tool and ev.get("healed"))
            lines.append(f"  {tool}: {count}x ({healed} healed)")
    else:
        lines.append("No infection events in the past 7 days.")

    if failures:
        probe_counts: Counter = Counter(f["probe"] for f in failures)
        lines.append("\nProbe failures from inflammasome.log (last 7 days):")
        for probe, count in probe_counts.most_common(10):
            lines.append(f"  {probe}: {count}x")
    else:
        lines.append("\nNo probe failures in inflammasome.log in the past 7 days.")

    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Pattern qualification — only crystallize patterns seen >= MIN_PATTERN_COUNT
# ---------------------------------------------------------------------------

def find_crystallizable_patterns(
    candidates: list[dict],
    infections: list[dict],
    log_failures: list[dict],
) -> dict:
    """Return patterns that cross the MIN_PATTERN_COUNT threshold.

    Returns dict with keys:
      'repair_candidates': {name: count} — repairs done >= N times
      'probe_failures': {probe: count}   — probes that failed >= N times
      'infection_tools': {tool: count}   — infection tools >= N times
    """
    repair_counts: Counter = Counter()
    for ev in candidates:
        key = ev.get("probe") or ev.get("tool") or ev.get("repair_label") or "unknown"
        repair_counts[key] += 1

    probe_fail_counts: Counter = Counter(f["probe"] for f in log_failures)

    infection_counts: Counter = Counter(ev.get("tool", "unknown") for ev in infections)

    return {
        "repair_candidates": {k: v for k, v in repair_counts.items() if v >= MIN_PATTERN_COUNT},
        "probe_failures": {k: v for k, v in probe_fail_counts.items() if v >= MIN_PATTERN_COUNT},
        "infection_tools": {k: v for k, v in infection_counts.items() if v >= MIN_PATTERN_COUNT},
    }



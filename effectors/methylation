def write_proposal(response: str, patterns: dict, date_str: str) -> Path:
    """Write methylation proposal to ~/tmp/methylation-proposal-YYYY-MM-DD.md."""
    TMP_DIR.mkdir(parents=True, exist_ok=True)
    proposal_path = TMP_DIR / f"methylation-proposal-{date_str}.md"

    crystallizable = []
    for k, v in patterns["repair_candidates"].items():
        crystallizable.append(f"- repair `{k}` seen {v}x")
    for k, v in patterns["probe_failures"].items():
        crystallizable.append(f"- probe failure `{k}` seen {v}x")
    for k, v in patterns["infection_tools"].items():
        crystallizable.append(f"- infection tool `{k}` seen {v}x")

    content = f"""# Methylation Proposal — {date_str}

Generated by the weekly methylation effector.
Review and apply manually; architectural changes require human judgment.

## Crystallizable patterns this week

{chr(10).join(crystallizable) if crystallizable else "- (none above threshold)"}

## Sonnet synthesis

{response}

---
*Auto-apply rule: safe mechanical probes (path/import checks) only.*
*All other changes require manual review and edit to inflammasome.py.*
"""
    proposal_path.write_text(content)
    return proposal_path


# ---------------------------------------------------------------------------
# Self-hybridization — discover new subsystem designs from observed gaps
# ---------------------------------------------------------------------------

HYBRIDIZATION_PROMPT_TEMPLATE = """\
You are the organism's hybridization layer. You observe a functional gap and must name it using cell biology.

## Observed gap
{gap_description}

## Current subsystems (for reference)
inflammasome (self-test probes), angiogenesis (connection detection), entrainment (schedule sync), \
poiesis (agent production), endocytosis (content intake), rheotaxis (search), perfusion (routing)

## Task
1. Name a cell biology mechanism that handles this exact function
2. Describe the mechanism in 2-3 sentences (the REAL biology, not a metaphor)
3. Map it: what would this mechanism do in the organism?
4. Where does the analogy BREAK? (The break IS the design insight)
5. Propose: one Python module, one function, what it does

Output format:
MECHANISM: <name>
BIOLOGY: <description>
MAPPING: <what it does in vivesca>
BREAK: <where the analogy fails and what that reveals>
PROPOSAL: <module name, function, purpose>
"""

KNOWN_SUBSYSTEMS = {
    "inflammasome", "angiogenesis", "entrainment", "poiesis",
    "endocytosis", "rheotaxis", "perfusion",
}


def hybridization_pass(
    patterns: dict,
    candidates: list[dict],
    infections: list[dict],
    log_failures: list[dict],
) -> str | None:
    """Look for gaps that don't match existing subsystems.

    A 'gap' is a repeated pattern that:
    - Wasn't caught by existing probes (novel failure)
    - Wasn't fixed by existing repair patterns
    - Involves interaction between 2+ subsystems

    Returns a gap description string, or None if no gap qualifies.
    """
    # Collect all tools/probes that appear in failures
    failing_tools = set(patterns["probe_failures"].keys()) | set(patterns["infection_tools"].keys())

    # Find unhealed infections — these were not fixed by repair patterns
    unhealed: list[dict] = [ev for ev in infections if not ev.get("healed")]
    unhealed_tools = {ev.get("tool", "unknown") for ev in unhealed if ev.get("tool")}

    # Find probe failures that also appear as infection tools — cross-subsystem failures
    # These are failures that span more than one layer (probe layer + infection layer)
    cross_subsystem = failing_tools & unhealed_tools

    # Also look for failure sequences: probe X fails AND tool Y infects within the same window
    # as a proxy for inter-subsystem causality
    if not cross_subsystem and len(failing_tools) < 2 and len(unhealed_tools) < 1:
        return None  # No gap evidence

    # Build gap description
    gap_parts: list[str] = []

    if cross_subsystem:
        for name in sorted(cross_subsystem):
            count_fail = patterns["probe_failures"].get(name, 0)
            count_infect = patterns["infection_tools"].get(name, 0)
            gap_parts.append(
                f"'{name}' appears as both a probe failure ({count_fail}x) and an unhealed "
                f"infection ({count_infect}x) — the self-test layer and the infection layer "
                f"both see this failure, but neither resolves it."
            )

    if not gap_parts and failing_tools and unhealed_tools:
        # Different names but multiple subsystems both registering failures
        gap_parts.append(
            f"Probe failures ({', '.join(sorted(failing_tools))}) and unhealed infections "
            f"({', '.join(sorted(unhealed_tools))}) co-occur in the same 7-day window. "
            f"No existing repair pattern bridged them — they interacted but the organism "
            f"had no mechanism to coordinate their resolution."
        )

    if not gap_parts:
        return None

    # Check that none of these map cleanly to an existing subsystem name
    all_names = failing_tools | unhealed_tools
    novel = all_names - KNOWN_SUBSYSTEMS
    if not novel and all_names:
        # All failing components are already known subsystems — this is coverage, not a gap
        return None

    return "\n".join(gap_parts)


def write_hybridization_proposal(response: str, gap_description: str, date_str: str) -> Path:
    """Write hybridization proposal to ~/tmp/hybridization-proposals-YYYY-MM-DD.md.

    Appends if the file already exists (multiple gaps possible across runs,
    though max 1 dispatch per methylation cycle).
    """
    TMP_DIR.mkdir(parents=True, exist_ok=True)
    proposal_path = TMP_DIR / f"hybridization-proposals-{date_str}.md"

    header = f"# Hybridization Proposals — {date_str}\n\n" if not proposal_path.exists() else ""
    entry = f"""{header}## Gap observed
{gap_description}

## Sonnet hybridization output
{response}

---
*Proposals are for human review only. Never auto-implement new subsystems.*
*To act: create a new module in ~/germline/metabolon/organelles/ and wire via MCP.*
"""
    with proposal_path.open("a") as f:
        f.write(entry)
    return proposal_path


# ---------------------------------------------------------------------------
# Auto-apply gate — only probe functions that are pure path/import checks
# ---------------------------------------------------------------------------

def is_safe_to_autoapply(response: str) -> bool:
    """Return True only if the proposal is a probe that checks a path or import.

    Conservative gate: the code must:
      - Be TYPE: probe
      - Contain only Path.home(), .exists(), import/shutil.which checks
      - Not modify any file, run subprocesses, or write to disk
    """
    if "TYPE: probe" not in response:
        return False
    unsafe_patterns = [
        "subprocess", "open(", "write(", ".unlink", ".rmdir", "os.remove",
        "shutil.copy", "shutil.move", "Popen", "check_call", "check_output",
        "run(", ".mkdir(", "chmod", "symlink",
    ]
    code_section = ""
    in_code = False
    for line in response.splitlines():
        if line.startswith("CODE:"):
            in_code = True
            code_section += line[5:] + "\n"
        elif in_code and line.startswith(("TYPE:", "NAME:", "RATIONALE:")):
            in_code = False
        elif in_code:
            code_section += line + "\n"

    for pat in unsafe_patterns:
        if pat in code_section:
            return False

    # Must contain .exists() or shutil.which or import check
    safe_indicators = [".exists()", "shutil.which", "import ", "Path.home()"]
    return any(ind in code_section for ind in safe_indicators)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    date_str = datetime.now(UTC).strftime("%Y-%m-%d")
    log(f"methylation starting — date={date_str}, window={WINDOW_DAYS}d, threshold={MIN_PATTERN_COUNT}")

    # Read signals
    candidates = read_methylation_candidates()
    infections = read_infections()
    log_failures = read_inflammasome_log()

    log(f"signals read — candidates={len(candidates)}, infections={len(infections)}, log_failures={len(log_failures)}")

    # Find patterns worth crystallizing
    patterns = find_crystallizable_patterns(candidates, infections, log_failures)
    has_patterns = any(patterns[k] for k in patterns)

    if not has_patterns:
        log("no patterns above threshold — no crystallization needed this week")
        return

    log(f"crystallizable patterns: {patterns}")

    # Build summaries
    repairs_summary = summarize_repairs(candidates)
    infection_summary = summarize_infections(infections, log_failures)
    probe_names = extract_probe_names()
    repair_labels = extract_repair_pattern_labels()

    probe_names_str = "\n".join(f"  - {n}" for n in probe_names) if probe_names else "  (could not extract)"
    repair_labels_str = "\n".join(f"  - {l}" for l in repair_labels) if repair_labels else "  (could not extract)"

    prompt = PROMPT_TEMPLATE.format(
        repairs_summary=repairs_summary,
        infection_summary=infection_summary,
        probe_names=probe_names_str,
        repair_labels=repair_labels_str,
    )

    log("dispatching channel sonnet for synthesis...")
    response = dispatch_sonnet(prompt)

    if not response:
        log("ERROR: no response from sonnet — aborting proposal")
        return

    log(f"sonnet response received ({len(response)} chars)")

    # Write proposal
    proposal_path = write_proposal(response, patterns, date_str)
    log(f"proposal written: {proposal_path}")

    # Auto-apply gate
    if is_safe_to_autoapply(response):
        log("NOTICE: proposal passes auto-apply gate — but auto-apply is not implemented")
        log("  Manual review still required. Apply via: edit inflammasome.py directly.")
    else:
        log("proposal requires human review before application")

    # ---------------------------------------------------------------------------
    # Hybridization pass — discover new subsystem designs from observed gaps
    # ---------------------------------------------------------------------------
    log("running hybridization pass...")
    gap_description = hybridization_pass(patterns, candidates, infections, log_failures)

    if gap_description is None:
        log("hybridization pass: no gaps found — all failures map to known subsystems or below threshold")
    else:
        log(f"hybridization pass: gap identified ({len(gap_description)} chars) — dispatching sonnet")
        hybridization_prompt = HYBRIDIZATION_PROMPT_TEMPLATE.format(gap_description=gap_description)
        hybridization_response = dispatch_sonnet(hybridization_prompt, task_type="hybridization")

        if not hybridization_response:
            log("ERROR: no response from sonnet for hybridization — skipping proposal")
        else:
            log(f"hybridization response received ({len(hybridization_response)} chars)")
            hybridization_path = write_hybridization_proposal(hybridization_response, gap_description, date_str)
            log(f"hybridization proposal written: {hybridization_path}")
            log("hybridization complete — review proposal before implementing any new subsystem")

    log("methylation complete")


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:
        log(f"FATAL: unhandled exception: {exc}")
    sys.exit(0)

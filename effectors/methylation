def _tissue_route(task_type: str, fallback: str = "sonnet") -> str:
    """Return tissue-routed model for task_type; falls back to fallback on any error."""
    try:
        import sys as _sys
        _germline = str(Path.home() / "germline")
        if _germline not in _sys.path:
            _sys.path.insert(0, _germline)
        from metabolon.organelles.tissue_routing import route
        model = route(task_type)
        if model != fallback:
            log(f"tissue routing: {task_type} -> {model} (overrides {fallback})")
        return model
    except Exception:
        return fallback


def _record_mitophagy(model: str, task_type: str, success: bool, duration_ms: int) -> None:
    """Record LLM outcome to mitophagy. Silently skips on any error."""
    try:
        import sys as _sys
        from pathlib import Path as _Path
        _sys.path.insert(0, str(_Path.home() / "germline"))
        from metabolon.organelles.mitophagy import record_outcome
        record_outcome(model=model, task_type=task_type, success=success, duration_ms=duration_ms)
    except Exception:
        pass


def dispatch_sonnet(prompt: str, task_type: str = "methylation") -> str | None:
    """Call channel with tissue-routed model and the prompt. Return output or None on failure."""
    if not CHANNEL.exists():
        log(f"ERROR: channel effector not found at {CHANNEL}")
        return None
    model = _tissue_route(task_type)
    t0 = time.monotonic()
    try:
        result = subprocess.run(
            [str(CHANNEL), model, "-p", prompt],
            capture_output=True,
            text=True,
            timeout=120,
        )
        duration_ms = int((time.monotonic() - t0) * 1000)
        output = result.stdout.strip()
        success = result.returncode == 0 and bool(output)
        _record_mitophagy(model, task_type, success, duration_ms)
        if result.returncode != 0:
            log(f"WARN: channel {model} exited {result.returncode}: {result.stderr.strip()[:200]}")
            return None
        return output or None
    except subprocess.TimeoutExpired:
        duration_ms = int((time.monotonic() - t0) * 1000)
        _record_mitophagy(model, task_type, False, duration_ms)
        log(f"WARN: channel {model} timed out (120s)")
        return None
    except Exception as exc:
        duration_ms = int((time.monotonic() - t0) * 1000)
        _record_mitophagy(model, task_type, False, duration_ms)
        log(f"ERROR: channel dispatch failed: {exc}")
        return None



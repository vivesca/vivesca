#!/usr/bin/env python3
"""gemmule-clean — remove stale temp files and caches.

Removes:
  - /tmp/claude-*/ entries older than 24 h
  - ~/.cache/uv/archive-v0/ entries older than 7 days
  - __pycache__ dirs inside ~/germline/

Reports total bytes freed. Never touches germline source or epigenome.
"""
from __future__ import annotations

import os
import shutil
import sys
import time
from pathlib import Path

HOME = Path.home()
GERMLINE = HOME / "germline"
EPIGENOME = HOME / "epigenome"

# Age thresholds in seconds
TMP_CUTOFF = 24 * 60 * 60        # 24 hours
UV_CACHE_CUTOFF = 7 * 24 * 60 * 60  # 7 days


def _dir_size(path: Path) -> int:
    """Return total bytes consumed by a directory tree."""
    total = 0
    try:
        for entry in os.scandir(path):
            if entry.is_dir(follow_symlinks=False):
                total += _dir_size(Path(entry.path))
            elif entry.is_file(follow_symlinks=False):
                total += entry.stat(follow_symlinks=False).st_size
    except (PermissionError, FileNotFoundError, OSError):
        pass
    return total


def _safe_path(path: Path) -> bool:
    """Return False if path is inside germline source or epigenome."""
    try:
        resolved = path.resolve()
        if resolved.is_relative_to(GERMLINE):
            # Only __pycache__ dirs are allowed under germline
            if resolved.name != "__pycache__":
                return False
            # Must not be under epigenome-equivalent within germline
        if resolved.is_relative_to(EPIGENOME):
            return False
    except (OSError, ValueError):
        return False
    return True


def clean_tmp_claude(now: float, dry_run: bool = False) -> int:
    """Remove /tmp/claude-*/ entries older than 24 h. Return bytes freed."""
    freed = 0
    tmp = Path("/tmp")
    for entry in tmp.glob("claude-*"):
        try:
            mtime = entry.stat(follow_symlinks=False).st_mtime
        except (FileNotFoundError, PermissionError, OSError):
            continue
        if now - mtime < TMP_CUTOFF:
            continue
        if not _safe_path(entry):
            continue
        size = _dir_size(entry) if entry.is_dir() else entry.stat(follow_symlinks=False).st_size
        if dry_run:
            print(f"  [dry-run] would remove {entry} ({_fmt_bytes(size)})")
        else:
            try:
                if entry.is_dir():
                    shutil.rmtree(entry)
                else:
                    entry.unlink()
            except (PermissionError, FileNotFoundError, OSError) as exc:
                print(f"  skip {entry}: {exc}", file=sys.stderr)
                continue
        freed += size
    return freed


def clean_uv_archive(now: float, dry_run: bool = False) -> int:
    """Remove ~/.cache/uv/archive-v0/ entries older than 7 days. Return bytes freed."""
    freed = 0
    uv_dir = HOME / ".cache" / "uv" / "archive-v0"
    if not uv_dir.is_dir():
        return 0
    for entry in uv_dir.iterdir():
        try:
            mtime = entry.stat(follow_symlinks=False).st_mtime
        except (FileNotFoundError, PermissionError, OSError):
            continue
        if now - mtime < UV_CACHE_CUTOFF:
            continue
        if not _safe_path(entry):
            continue
        size = _dir_size(entry) if entry.is_dir() else entry.stat(follow_symlinks=False).st_size
        if dry_run:
            print(f"  [dry-run] would remove {entry} ({_fmt_bytes(size)})")
        else:
            try:
                if entry.is_dir():
                    shutil.rmtree(entry)
                else:
                    entry.unlink()
            except (PermissionError, FileNotFoundError, OSError) as exc:
                print(f"  skip {entry}: {exc}", file=sys.stderr)
                continue
        freed += size
    return freed


def clean_pycache(dry_run: bool = False) -> int:
    """Remove __pycache__ dirs inside ~/germline/. Return bytes freed."""
    freed = 0
    for pycache in GERMLINE.rglob("__pycache__"):
        if not pycache.is_dir():
            continue
        # Double-check we don't touch epigenome
        try:
            if pycache.resolve().is_relative_to(EPIGENOME):
                continue
        except (OSError, ValueError):
            continue
        size = _dir_size(pycache)
        if dry_run:
            print(f"  [dry-run] would remove {pycache} ({_fmt_bytes(size)})")
        else:
            try:
                shutil.rmtree(pycache)
            except (PermissionError, FileNotFoundError, OSError) as exc:
                print(f"  skip {pycache}: {exc}", file=sys.stderr)
                continue
        freed += size
    return freed


def _fmt_bytes(n: int) -> str:
    """Human-readable byte count."""
    for unit in ("B", "KB", "MB", "GB"):
        if abs(n) < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024  # type: ignore[assignment]
    return f"{n:.1f} TB"


def main(dry_run: bool = False) -> None:
    """Run all cleaning tasks and report total bytes freed."""
    now = time.time()
    total = 0

    print("Cleaning /tmp/claude-* (older than 24h)...")
    freed = clean_tmp_claude(now, dry_run=dry_run)
    total += freed
    print(f"  freed: {_fmt_bytes(freed)}")

    print("Cleaning ~/.cache/uv/archive-v0/ (older than 7d)...")
    freed = clean_uv_archive(now, dry_run=dry_run)
    total += freed
    print(f"  freed: {_fmt_bytes(freed)}")

    print("Cleaning __pycache__ under ~/germline/...")
    freed = clean_pycache(dry_run=dry_run)
    total += freed
    print(f"  freed: {_fmt_bytes(freed)}")

    print(f"\nTotal freed: {_fmt_bytes(total)}")


if __name__ == "__main__":
    _dry_run = "--dry-run" in sys.argv
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__.strip())
        sys.exit(0)
    main(dry_run=_dry_run)

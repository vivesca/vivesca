#!/usr/bin/env bash
# Read-only wacli wrapper - blocks send command

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "wacli-ro — read-only wacli wrapper (send is blocked for safety)"
    echo "Usage: wacli-ro [wacli-args...]"
    exit 0
fi

if [[ "$1" == "send" ]] || [[ "$*" == *"send"* ]]; then
    echo "ERROR: wacli-ro is read-only. Send is disabled for safety."
    exit 1
fi

exec wacli "$@"

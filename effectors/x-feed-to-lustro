#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# ///
"""Fetch X/Twitter 'For You' feed via bird CLI and save to lustro article cache."""

import hashlib
import json
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

CACHE_DIR = Path.home() / ".cache" / "lustro-articles"
COUNT = 20
MIN_TEXT_LENGTH = 100


def main():
    # Fetch home feed as JSON
    result = subprocess.run(
        ["bird", "home", "--count", str(COUNT), "--json"],
        capture_output=True,
        text=True,
        timeout=60,
    )
    if result.returncode != 0:
        print(f"bird home failed: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    tweets = json.loads(result.stdout)
    if not isinstance(tweets, list):
        tweets = [tweets]

    saved = 0
    skipped = 0
    for tweet in tweets:
        text = tweet.get("text", "")
        # Include quoted tweet text if present
        if tweet.get("quoted_tweet", {}).get("text"):
            text += "\n\n" + tweet["quoted_tweet"]["text"]

        if len(text) < MIN_TEXT_LENGTH:
            skipped += 1
            continue

        author = tweet.get("author", {})
        handle = author.get("handle", "unknown")
        name = author.get("name", handle)
        url = tweet.get("url", "")
        date_str = tweet.get("date", "")

        # Parse date to YYYY-MM-DD
        try:
            dt = datetime.strptime(date_str, "%a %b %d %H:%M:%S %z %Y")
            article_date = dt.strftime("%Y-%m-%d")
        except (ValueError, TypeError):
            article_date = datetime.now(UTC).strftime("%Y-%m-%d")

        title_hash = hashlib.sha256(text[:200].encode()).hexdigest()[:8]
        filename = f"{article_date}_x-feed_{title_hash}.json"
        filepath = CACHE_DIR / filename

        if filepath.exists():
            continue

        record = {
            "title": f"{name} (@{handle}): {text[:80]}...",
            "date": article_date,
            "source": "X Feed (For You)",
            "tier": 1,
            "link": url,
            "summary": text[:200],
            "text": text,
            "fetched_at": datetime.now(UTC).isoformat(),
        }

        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        filepath.write_text(json.dumps(record, ensure_ascii=False, indent=2))
        saved += 1

    print(
        f"x-feed-to-lustro: {saved} saved, {skipped} skipped (too short), {len(tweets)} total",
        file=sys.stderr,
    )


if __name__ == "__main__":
    main()

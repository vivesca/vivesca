#!/usr/bin/env python3
"""Reliable web content extractor with fallback chain.

Usage: browse URL
Outputs clean markdown to stdout.
Fallback chain:
1. defuddle parse URL --md
2. If empty: curl + html2text
3. If still empty: print NEEDS_BROWSER
"""

import sys
import subprocess
from typing import Optional


def run_command(cmd: list[str]) -> Optional[str]:
    """Run a command and return its stdout, stripped.

    Returns None if command fails or output is empty.
    """
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=True,
            timeout=60,
        )
        output = result.stdout.strip()
        return output if output else None
    except (subprocess.CalledProcessError, Exception):
        return None


def main() -> None:
    """Main entry point."""
    if len(sys.argv) != 2:
        print(__doc__)
        sys.exit(1)

    if sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    url = sys.argv[1]
    
    # Step 1: Try defuddle
    output = run_command(["defuddle", "parse", url, "--md"])
    if output:
        print(output)
        sys.exit(0)
    
    # Step 2: Try curl + html2text
    html = run_command(["curl", "-sL", url])
    if html:
        try:
            result = subprocess.run(
                ["html2text"],
                input=html,
                capture_output=True,
                text=True,
                check=True,
                timeout=60,
            )
            output = result.stdout.strip()
            if output:
                print(output)
                sys.exit(0)
        except (subprocess.CalledProcessError, Exception):
            pass
    
    # Step 3: Still empty, needs browser
    print("NEEDS_BROWSER")
    sys.exit(1)


if __name__ == "__main__":
    main()

#!/usr/bin/env bash
# golem — headless CC + GLM-5.1 via ZhiPu. Faithful instruction executor.
#
# Usage:
#   golem "Write tests for metabolon/foo.py"        # bare (default, fast)
#   golem --full "Task needing MCP/skills/context"   # full organism access
#   golem --batch metabolon/bar.py metabolon/baz.py  # sequential test gen
#   golem --max-turns 30 "Complex task"
set -euo pipefail

MAX_TURNS="${GOLEM_MAX_TURNS:-20}"
BARE=true
BATCH=false

while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --batch) BATCH=true; shift ;;
    --max-turns) MAX_TURNS="$2"; shift 2 ;;
    --full) BARE=false; shift ;;
    --bare) BARE=true; shift ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

GOLEM_LOG="${GOLEM_LOG:-$HOME/.local/share/vivesca/golem.jsonl}"
mkdir -p "$(dirname "$GOLEM_LOG")"

_run_golem() {
  local prompt="$1"
  local args=(--print --max-turns "$MAX_TURNS")
  $BARE && args+=(--bare)
  local start_ts=$(date +%s)
  local output
  output=$(CLAUDECODE= \
  ANTHROPIC_AUTH_TOKEN="${ZHIPU_API_KEY:?ZHIPU_API_KEY not set}" \
  ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic" \
  ANTHROPIC_DEFAULT_OPUS_MODEL="GLM-5.1" \
  ANTHROPIC_DEFAULT_SONNET_MODEL="GLM-5.1" \
  ANTHROPIC_DEFAULT_HAIKU_MODEL="GLM-4.5-air" \
  API_TIMEOUT_MS=3000000 \
  CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
  claude "${args[@]}" -p "$prompt" 2>&1)
  local exit_code=$?
  local duration=$(( $(date +%s) - start_ts ))
  local short_prompt="${prompt:0:100}"
  # Log result
  printf '{"ts":"%s","duration":%d,"exit":%d,"turns":%d,"prompt":"%s","tail":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$duration" "$exit_code" "$MAX_TURNS" \
    "$(echo "$short_prompt" | tr '"' "'")" \
    "$(echo "${output: -200}" | tr '"' "'" | tr '\n' ' ')" >> "$GOLEM_LOG"
  echo "$output"
}

if $BATCH; then
  for mod in "$@"; do
    echo ">>> golem: $mod"
    _run_golem "Read $mod. Write comprehensive tests to assays/test_$(basename "${mod%.py}").py. Mock external calls and file I/O. Run: uv run pytest assays/test_$(basename "${mod%.py}").py -v --tb=short. Fix any failures." || true
    echo
  done
else
  _run_golem "$*"
fi

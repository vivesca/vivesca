#!/usr/bin/env bash
# golem — headless CC + GLM-5.1 via ZhiPu. Faithful instruction executor.
#
# Usage:
#   golem "Write tests for metabolon/foo.py"        # bare (default, fast)
#   golem --full "Task needing MCP/skills/context"   # full organism access
#   golem --batch metabolon/bar.py metabolon/baz.py  # sequential test gen
#   golem --max-turns 30 "Complex task"
#   golem --quiet "Task"                            # suppress all output, exit code only
#   golem --json "Task"                             # output result as JSON
#   golem summary [--recent N] [--json]              # show provider stats
set -euo pipefail

MAX_TURNS="${GOLEM_MAX_TURNS:-50}"
BARE=true
BATCH=false
TEST=false
QUIET=false
JSON_OUTPUT=false
SUMMARY=false
RECENT=0
PROVIDER="${GOLEM_PROVIDER:-zhipu}"
FALLBACK=false
FALLBACK_PROVIDER=""

GOLEM_LOG="${GOLEM_LOG:-$HOME/.local/share/vivesca/golem.jsonl}"
mkdir -p "$(dirname "$GOLEM_LOG")"

COACHING_FILE="$HOME/epigenome/marks/feedback_golem_coaching.md"

# Summary subcommand - show provider stats from JSONL log
_run_summary() {
  python3 - "$@" << 'PYTHON_SCRIPT'
import json
import sys
import os
from collections import defaultdict

recent = 0
log_file = None
json_output = False

# Parse args
args = sys.argv[1:]
i = 0
while i < len(args):
    if args[i] == '--recent' and i + 1 < len(args):
        recent = int(args[i + 1])
        i += 2
    elif args[i].startswith('--log='):
        log_file = args[i][6:]
        i += 1
    elif args[i] == '--json':
        json_output = True
        i += 1
    else:
        i += 1

if not log_file:
    log_file = os.environ.get('GOLEM_LOG', os.path.expanduser('~/.local/share/vivesca/golem.jsonl'))

stats = defaultdict(lambda: {'runs': 0, 'pass': 0, 'fail': 0, 'total_duration': 0, 'tests_created': 0})

try:
    with open(log_file, 'r') as f:
        lines = f.readlines()

    if recent > 0:
        lines = lines[-recent:]

    for line in lines:
        line = line.strip()
        if not line:
            continue
        try:
            data = json.loads(line)
            provider = data.get('provider', 'unknown')
            stats[provider]['runs'] += 1
            exit_code = data.get('exit', -1)
            if exit_code == 0:
                stats[provider]['pass'] += 1
            else:
                stats[provider]['fail'] += 1
            stats[provider]['total_duration'] += data.get('duration', 0)
            stats[provider]['tests_created'] += data.get('tests_passed', 0) + data.get('tests_failed', 0)
        except json.JSONDecodeError:
            continue

    # Print output
    if json_output:
        result = {}
        for provider in sorted(stats.keys()):
            s = stats[provider]
            result[provider] = {
                'runs': s['runs'],
                'pass': s['pass'],
                'fail': s['fail'],
                'avg_duration': s['total_duration'] // s['runs'] if s['runs'] > 0 else 0,
                'tests_created': s['tests_created'],
            }
        print(json.dumps(result))
    else:
        print(f"{'Provider':<12} | {'Runs':>4} | {'Pass':>4} | {'Fail':>4} | {'Avg Duration':>12} | {'Tests Created':>13}")
        print('-' * 63)
        for provider in sorted(stats.keys()):
            s = stats[provider]
            avg_dur = s['total_duration'] // s['runs'] if s['runs'] > 0 else 0
            print(f"{provider:<12} | {s['runs']:>4} | {s['pass']:>4} | {s['fail']:>4} | {avg_dur:>10}s | {s['tests_created']:>13}")
except FileNotFoundError:
    print(f"No log file found: {log_file}", file=sys.stderr)
    sys.exit(1)
PYTHON_SCRIPT
}

# Handle subcommands first
if [[ "${1:-}" == "summary" ]]; then
  shift
  summary_args=()
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --recent) summary_args+=("--recent" "$2"); shift 2 ;;
      --json) summary_args+=("--json"); JSON_OUTPUT=true; shift ;;
      --log=*) summary_args+=("$1"); shift ;;
      --quiet) QUIET=true; shift ;;
      -h|--help) head -10 "$0" | tail -9 | sed 's/^# */  /'; exit 0 ;;
      *) echo "Unknown flag: $1" >&2; exit 1 ;;
    esac
  done
  if $QUIET; then
    _run_summary "${summary_args[@]+"${summary_args[@]}"}" >/dev/null
  else
    _run_summary "${summary_args[@]+"${summary_args[@]}"}"
  fi
  exit 0
fi

# Parse regular flags
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --batch) BATCH=true; shift ;;
    --test) TEST=true; shift ;;
    --max-turns) MAX_TURNS="$2"; shift 2 ;;
    --full) BARE=false; shift ;;
    --bare) BARE=true; shift ;;
    --quiet) QUIET=true; shift ;;
    --json) JSON_OUTPUT=true; shift ;;
    --provider) PROVIDER="$2"; shift 2 ;;
    --fallback) FALLBACK=true; shift ;;
    -h|--help) head -9 "$0" | tail -8 | sed 's/^# */  /'; exit 0 ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

# Provider config: KEY_VAR, BASE_URL, OPUS_MODEL, SONNET_MODEL, HAIKU_MODEL
case "$PROVIDER" in
  zhipu)
    _KEY="${ZHIPU_API_KEY:?ZHIPU_API_KEY not set}"
    _URL="https://open.bigmodel.cn/api/anthropic"
    _OPUS="GLM-5.1"; _SONNET="GLM-5.1"; _HAIKU="GLM-4.5-air" ;;
  volcano)
    _KEY="${VOLCANO_API_KEY:?VOLCANO_API_KEY not set}"
    _URL="https://ark.cn-beijing.volces.com/api/coding"
    # volcano accepts x-api-key header (same as ANTHROPIC_API_KEY)
    _OPUS="ark-code-latest"; _SONNET="ark-code-latest"; _HAIKU="ark-code-latest" ;;
  infini)
    # WARNING: Infini API does NOT support CC tool-use. Models ask for permission
    # instead of invoking tools. Only usable for text-only tasks, not golem.
    _KEY="${INFINI_API_KEY:?INFINI_API_KEY not set}"
    _URL="https://cloud.infini-ai.com/maas/coding"
    _OPUS="glm-5"; _SONNET="glm-5"; _HAIKU="glm-4.5-air" ;;
  *) echo "Unknown provider: $PROVIDER (zhipu|volcano|infini)" >&2; exit 1 ;;
esac

# Fallback provider mapping: zhipu->infini, infini->zhipu, volcano->infini
_fallback_provider() {
  case "$1" in
    zhipu) echo "infini" ;;
    infini) echo "zhipu" ;;
    volcano) echo "infini" ;;
    *) echo "" ;;
  esac
}

_run_golem() {
  local prompt="$1"

  # Prepend coaching notes (same file all providers get)
  if [[ -f "$COACHING_FILE" ]]; then
    local _coaching_tmp
    _coaching_tmp="$(mktemp)"
    printf '%s\n' "<coaching-notes>" > "$_coaching_tmp"
    cat "$COACHING_FILE" >> "$_coaching_tmp"
    printf '\n%s\n\n' "</coaching-notes>" >> "$_coaching_tmp"
    printf '%s' "$prompt" >> "$_coaching_tmp"
    prompt="$(cat "$_coaching_tmp")"
    rm -f "$_coaching_tmp"
  fi
  local args=(--print --dangerously-skip-permissions --max-turns "$MAX_TURNS")
  $BARE && args+=(--bare)
  local start_ts=$(date +%s)
  local output
  local exit_code=0
  # All providers use ANTHROPIC_API_KEY (x-api-key header). Volcano accepts it too.
  unset ANTHROPIC_AUTH_TOKEN  # prevent inheritance from parent env

  # Retry loop with exponential backoff for rate limits (429)
  local _max_retries=3
  local _attempt=0
  local _backoff=30  # initial backoff in seconds

  while [[ $_attempt -lt $_max_retries ]]; do
    output=$(
    CLAUDECODE= \
    ANTHROPIC_API_KEY="$_KEY" \
    ANTHROPIC_BASE_URL="$_URL" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="$_OPUS" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="$_SONNET" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="$_HAIKU" \
    API_TIMEOUT_MS=3000000 \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
    claude "${args[@]}" -p "$prompt" < /dev/null 2>&1
    )
    exit_code=$?

    # Success — break immediately
    [[ $exit_code -eq 0 ]] && break

    # Detect rate-limiting in output (429 / AccountQuotaExceeded / rate limit)
    if echo "$output" | grep -qiE '429|AccountQuotaExceeded|rate.limit|quota.*exceeded'; then
      _attempt=$(( _attempt + 1 ))
      if [[ $_attempt -lt $_max_retries ]]; then
        # Try to extract reset time from error message (e.g. "reset at 2026-04-01 11:05:30")
        local _reset_time
        _reset_time=$(echo "$output" | grep -oE 'reset at [0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1)
        $QUIET || echo "[retry] $PROVIDER rate-limited (attempt $_attempt/$_max_retries), backoff ${_backoff}s${_reset_time:+, $_reset_time}" >&2
        sleep "$_backoff"
        _backoff=$(( _backoff * 2 ))  # exponential: 30 → 60 → 120
      fi
    else
      # Non-rate-limit failure — don't retry
      break
    fi
  done

  local duration=$(( $(date +%s) - start_ts ))
  local short_prompt="${prompt:0:100}"

  # Enriched logging: count files and run pytest on new test files
  local files_created=0
  local tests_passed=0
  local tests_failed=0
  local pytest_exit=0

  # Count new/modified files
  files_created=$(git diff --name-only --diff-filter=AM HEAD 2>/dev/null | wc -l | tr -d ' ')

  # Find new test files and run pytest
  local new_tests=$(git diff --name-only --diff-filter=A HEAD 2>/dev/null | grep '^assays/test_.*\.py$' || true)
  if [[ -n "$new_tests" ]]; then
    local pytest_output
    pytest_output=$(uv run pytest $new_tests -q --tb=no 2>&1 || true)
    pytest_exit=$?
    # Parse pass/fail from pytest output (e.g., "3 passed, 1 failed" or "5 passed")
    tests_passed=$(echo "$pytest_output" | grep -oE '[0-9]+ passed' | grep -oE '[0-9]+' || echo "0")
    tests_failed=$(echo "$pytest_output" | grep -oE '[0-9]+ failed' | grep -oE '[0-9]+' || echo "0")
    [[ -z "$tests_passed" ]] && tests_passed=0
    [[ -z "$tests_failed" ]] && tests_failed=0
  fi

  # Log result with enriched fields
  local task_id="${GOLEM_TASK_ID:-}"
  printf '{"ts":"%s","provider":"%s","duration":%d,"exit":%d,"turns":%d,"prompt":"%s","tail":"%s","files_created":%d,"tests_passed":%d,"tests_failed":%d,"pytest_exit":%d,"task_id":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$PROVIDER" "$duration" "$exit_code" "$MAX_TURNS" \
    "$(echo "$short_prompt" | tr '"' "'")" \
    "$(echo "${output: -200}" | tr '"' "'" | tr '\n' ' ')" \
    "$files_created" "$tests_passed" "$tests_failed" "$pytest_exit" "$task_id" >> "$GOLEM_LOG"
  if $JSON_OUTPUT; then
    local _json_tmp
    _json_tmp="$(mktemp)"
    printf '%s' "$output" > "$_json_tmp"
    python3 -c "
import json, sys
output_text = open(sys.argv[1]).read()
result = {
    'output': output_text,
    'exit_code': int(sys.argv[2]),
    'duration': int(sys.argv[3]),
    'provider': sys.argv[4],
    'files_created': int(sys.argv[5]),
    'tests_passed': int(sys.argv[6]),
    'tests_failed': int(sys.argv[7]),
}
print(json.dumps(result))
" "$_json_tmp" "$exit_code" "$duration" "$PROVIDER" "$files_created" "$tests_passed" "$tests_failed"
    rm -f "$_json_tmp"
  elif ! $QUIET; then
    echo "$output"
  fi

  # Auto-capture: if prompt mentions "Write to ~/...md", save output there
  local _target
  _target=$(echo "$1" | grep -oE 'Write to ~/[^ "]+' | head -1 | sed 's/^Write to //')
  if [[ -n "$_target" && ${#output} -gt 200 ]]; then
    _target="${_target/#~/$HOME}"
    mkdir -p "$(dirname "$_target")"
    printf '%s\n' "$output" > "$_target"
  fi

  return $exit_code
}

# _configure_provider: set _KEY, _URL, _OPUS, _SONNET, _HAIKU for given provider
_configure_provider() {
  local prov="$1"
  case "$prov" in
    zhipu)
      _KEY="${ZHIPU_API_KEY:?ZHIPU_API_KEY not set}"
      _URL="https://open.bigmodel.cn/api/anthropic"
      _OPUS="GLM-5.1"; _SONNET="GLM-5.1"; _HAIKU="GLM-4.5-air" ;;
    volcano)
      _KEY="${VOLCANO_API_KEY:?VOLCANO_API_KEY not set}"
      _URL="https://ark.cn-beijing.volces.com/api/coding"
      _OPUS="ark-code-latest"; _SONNET="ark-code-latest"; _HAIKU="ark-code-latest" ;;
    infini)
      _KEY="${INFINI_API_KEY:?INFINI_API_KEY not set}"
      _URL="https://cloud.infini-ai.com/maas/coding"
      _OPUS="glm-5"; _SONNET="glm-5"; _HAIKU="glm-4.5-air" ;;
    *) echo "Unknown provider: $prov (zhipu|volcano|infini)" >&2; return 1 ;;
  esac
}

# _run_with_fallback: run _run_golem, retry on fallback provider if primary fails
_run_with_fallback() {
  local prompt="$1"
  local final_exit=0
  _run_golem "$prompt" || final_exit=$?

  if $FALLBACK && [[ $final_exit -ne 0 ]]; then
    FALLBACK_PROVIDER="$(_fallback_provider "$PROVIDER")"
    if [[ -n "$FALLBACK_PROVIDER" ]]; then
      $QUIET || echo "[fallback] primary provider '$PROVIDER' failed (exit=$final_exit), retrying on '$FALLBACK_PROVIDER'..." >&2
      PROVIDER="$FALLBACK_PROVIDER"
      _configure_provider "$PROVIDER"
      _run_golem "$prompt" || final_exit=$?
    fi
  fi
  return $final_exit
}

if $BATCH; then
  for mod in "$@"; do
    $QUIET || echo ">>> golem: $mod"
    _run_with_fallback "Read $mod. Write comprehensive tests to assays/test_$(basename "${mod%.py}").py. NOTE: Effectors are scripts, not importable modules. Load via exec(open(path).read(), {\"__name__\": \"test_module\"}) or test via subprocess.run. NEVER use import <effector_name>. Mock external calls and file I/O. Run: uv run pytest assays/test_$(basename "${mod%.py}").py -v --tb=short. Fix any failures. Then git add the test file and git commit -m 'golem: tests for $(basename "${mod%.py}")'." || true
    $QUIET || echo
  done
elif $TEST; then
  mod="$1"
  _run_with_fallback "Read $mod. Write comprehensive tests to assays/test_$(basename "${mod%.py}").py. NOTE: Effectors are scripts, not importable modules. Load via exec(open(path).read(), {\"__name__\": \"test_module\"}) or test via subprocess.run. NEVER use import <effector_name>. Mock external calls and file I/O. Run: uv run pytest assays/test_$(basename "${mod%.py}").py -v --tb=short. Fix any failures. Then git add the test file and git commit -m 'golem: tests for $(basename "${mod%.py}")'."
else
  _run_with_fallback "$*"
fi

#!/usr/bin/env python3
"""Generate sortase-ready test specs with embedded source code.

Solves two GLM exploration problems:
1. Goose wastes turns reading source files → embed source in spec
2. write_file chokes on large payloads → instruct shell redirect

Usage:
    test-spec-gen metabolon/organelles/chromatin.py metabolon/perfusion.py
    test-spec-gen --wave 6 metabolon/pore.py metabolon/pulse.py

Produces one plan file per module at ~/germline/loci/plans/test-<name>.md
"""

from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

GERMLINE = Path.home() / "germline"
PLANS_DIR = GERMLINE / "loci" / "plans"


def _test_filename(module_path: str) -> str:
    """Derive test filename from module path."""
    parts = Path(module_path).with_suffix("").parts
    name = parts[-1]
    if len(parts) > 2:
        subdir = parts[1]
        if subdir == "enzymes":
            return f"test_{name}_actions.py"
        elif subdir == "sortase":
            return f"test_sortase_{name}.py"
        elif subdir == "organelles":
            return f"test_{name}.py"
        elif subdir == "metabolism" and len(parts) > 3:
            return f"test_{name}_substrate.py"
    return f"test_{name}.py"


def _read_imports(source: str) -> list[str]:
    """Extract metabolon imports from source code."""
    imports = []
    for line in source.splitlines():
        if line.strip().startswith(("from metabolon", "import metabolon")):
            imports.append(line.strip())
    return imports


def generate_spec(module_path: str, wave: int | None = None) -> Path:
    """Generate a test spec with embedded source for one module."""
    full_path = GERMLINE / module_path
    if not full_path.exists():
        print(f"ERROR: {full_path} does not exist", file=sys.stderr)
        sys.exit(1)

    source = full_path.read_text()
    lines = len(source.splitlines())
    name = Path(module_path).stem
    test_file = _test_filename(module_path)
    imports = _read_imports(source)

    # Extract public API (def/class names)
    public_api = []
    for match in re.finditer(r"^(?:def|class)\s+(\w+)", source, re.MULTILINE):
        fn = match.group(1)
        if not fn.startswith("_"):
            public_api.append(fn)

    wave_label = f"wave-{wave}-" if wave else ""
    plan_name = f"{wave_label}test-{name}"
    plan_path = PLANS_DIR / f"{plan_name}.md"

    # For large modules (>200 lines), embed only API signatures + docstrings
    # to avoid exceeding goose's prompt limit (~8K tokens effective)
    MAX_EMBED_LINES = 200
    if lines <= MAX_EMBED_LINES:
        source_block = (
            f"## Source code (DO NOT MODIFY — read-only reference)\n\n```python\n{source}\n```"
        )
    else:
        # Extract signatures and docstrings only
        sig_lines = []
        in_docstring = False
        for line in source.splitlines():
            stripped = line.strip()
            # Keep imports, class/def lines, and docstrings
            if stripped.startswith(("import ", "from ")):
                sig_lines.append(line)
            elif stripped.startswith(("def ", "class ", "@")):
                sig_lines.append(line)
                in_docstring = False
            elif '"""' in stripped and not in_docstring:
                sig_lines.append(line)
                if stripped.count('"""') == 1:
                    in_docstring = True
            elif in_docstring:
                sig_lines.append(line)
                if '"""' in stripped:
                    in_docstring = False
        source_block = (
            f"## API signatures (module is {lines} lines — read `{module_path}` for full source)\n\n"
            f"```python\n" + "\n".join(sig_lines) + "\n```"
        )

    spec = f"""# Test: {module_path}

{source_block}

## Task

Write `assays/{test_file}` that tests the module above.

### What to test

Public API: {", ".join(public_api) or "(read source above)"}

For each public function/class:
- Test with valid input → expected output
- Test with empty/missing input → graceful handling
- Test edge cases (empty strings, None, missing files)

### Dependencies to mock

These imports appear in the source:
{chr(10).join(f"- `{imp}`" for imp in imports) or "- (no metabolon imports)"}

Mock any external calls (subprocess, file I/O, LLM calls). Use `tmp_path` for file-based tests. Use `unittest.mock.patch` for subprocess/external deps.

### CRITICAL: Write via shell redirect

Do NOT use the write_file tool. Instead:

```bash
cat << 'PYEOF' > assays/{test_file}
# your test code here
PYEOF
```

This avoids the -32602 tool argument parsing error.

### Verification

```bash
cd ~/germline && uv run pytest assays/{test_file} -v --tb=short
```

Fix any failures before finishing.
"""

    plan_path.write_text(spec)
    print(
        f"Generated: {plan_path.name} ({lines} source lines, {len(public_api)} public functions)"
    )
    return plan_path


def main():
    parser = argparse.ArgumentParser(description="Generate test specs with embedded source")
    parser.add_argument("modules", nargs="+", help="Module paths relative to germline/")
    parser.add_argument("--wave", type=int, help="Wave number for plan naming")
    parser.add_argument(
        "--dispatch", action="store_true", help="Auto-dispatch via sortase after generating"
    )
    args = parser.parse_args()

    plans = []
    for mod in args.modules:
        plans.append(generate_spec(mod, args.wave))

    if args.dispatch:
        import subprocess

        for plan in plans:
            print(f"\nDispatching: {plan.name}")
            subprocess.run(
                [
                    "sortase",
                    "exec",
                    str(plan),
                    "-p",
                    str(GERMLINE),
                    "-b",
                    "goose",
                    "--timeout",
                    "180",
                ],
                cwd=str(GERMLINE),
                timeout=300,
            )


if __name__ == "__main__":
    main()

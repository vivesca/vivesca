#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["firecrawl-py>=4"]
# ///
"""Fetch the latest Evident Banking Brief and output as markdown.

Usage:
    evident-brief              # fetch latest, print markdown to stdout
    evident-brief --save       # also save to ~/.cache/lustro-articles/
    evident-brief --list       # list available briefs (title, date, slug)
    evident-brief --slug X     # fetch a specific brief by slug

Extraction chain: Firecrawl (richest) → Jina Reader (fast/free) → agent-browser (last resort).
"""

import argparse
import json
import os
import re
import subprocess
import sys
import time
import urllib.request
from datetime import UTC, datetime
from pathlib import Path

INDEX_URL = "https://evidentinsights.com/bankingbrief/"
BASE_URL = "https://evidentinsights.com/bankingbrief/"
JINA_PREFIX = "https://r.jina.ai/"
CACHE_DIR = Path.home() / ".cache" / "lustro-articles"

# Firecrawl API key — env > 1Password (Agents vault)
FIRECRAWL_KEY = os.environ.get("FIRECRAWL_API_KEY", "")


def _get_firecrawl_key() -> str:
    """Resolve Firecrawl API key: env var, then 1Password."""
    if FIRECRAWL_KEY:
        return FIRECRAWL_KEY
    try:
        r = subprocess.run(
            ["op", "item", "get", "Firecrawl", "--vault", "Agents", "--fields", "credential", "--reveal"],
            capture_output=True, text=True, timeout=10,
        )
        key = r.stdout.strip()
        if key and key.startswith("fc-"):
            return key
    except Exception:
        pass
    print("No Firecrawl API key found (set FIRECRAWL_API_KEY or add to 1Password Agents vault).", file=sys.stderr)
    return ""


# ---------------------------------------------------------------------------
# Tier 1: Firecrawl (richest output — links, bold, date, metadata)
# ---------------------------------------------------------------------------

def firecrawl_fetch(url: str) -> str:
    """Fetch a URL via Firecrawl. Returns markdown string."""
    key = _get_firecrawl_key()
    if not key:
        raise RuntimeError("No Firecrawl API key")
    from firecrawl import FirecrawlApp
    fc = FirecrawlApp(api_key=key)
    doc = fc.scrape(url, formats=["markdown"])
    return doc.markdown or ""


# ---------------------------------------------------------------------------
# Tier 2: Jina Reader (fast, free, good quality)
# ---------------------------------------------------------------------------

def jina_fetch(url: str, timeout: int = 30) -> str:
    """Fetch a URL via Jina Reader API. Returns markdown string."""
    req = urllib.request.Request(
        f"{JINA_PREFIX}{url}",
        headers={"Accept": "text/markdown", "User-Agent": "evident-brief/1.0"},
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.read().decode("utf-8")


# ---------------------------------------------------------------------------
# Tier 3: agent-browser (last resort — plain text, slow)
# ---------------------------------------------------------------------------

def _ab(cmd: str, timeout: int = 15) -> str:
    r = subprocess.run(
        ["agent-browser"] + cmd.split(),
        capture_output=True, text=True, timeout=timeout,
    )
    return r.stdout.strip()


def browser_fetch(url: str) -> str:
    """Fetch page text via agent-browser."""
    try:
        _ab(f"open {url}", timeout=20)
        time.sleep(3)
        snap = _ab("snapshot")
        for line in snap.splitlines():
            if "Accept all" in line:
                m = re.search(r'ref=(\w+)', line)
                if m:
                    _ab(f"click @{m.group(1)}")
                    time.sleep(1)
                break
        return _ab("get text main", timeout=10) or _ab("get text body", timeout=10)
    finally:
        subprocess.run(["agent-browser", "close"], capture_output=True, timeout=5)


# ---------------------------------------------------------------------------
# Unified fetch with fallback chain
# ---------------------------------------------------------------------------

def fetch_markdown(url: str) -> str:
    """Fetch URL as markdown. Firecrawl → Jina → agent-browser."""
    for name, fn in [("firecrawl", lambda: firecrawl_fetch(url)),
                     ("jina", lambda: jina_fetch(url)),
                     ("agent-browser", lambda: browser_fetch(url))]:
        try:
            result = fn()
            if result and len(result) > 100:
                print(f"[{name}] OK", file=sys.stderr)
                return result
        except Exception as e:
            print(f"[{name}] failed: {e}", file=sys.stderr)
    print("All extraction methods failed.", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Index parsing: Firecrawl map() → agent-browser fallback
# ---------------------------------------------------------------------------

def _parse_index_firecrawl() -> list[dict]:
    """Use Firecrawl map() to discover all brief URLs (1 credit)."""
    key = _get_firecrawl_key()
    if not key:
        return []
    from firecrawl import FirecrawlApp
    fc = FirecrawlApp(api_key=key)
    result = fc.map(INDEX_URL, limit=50)
    briefs = []
    slug_re = re.compile(r'/bankingbrief/([a-z0-9][-a-z0-9]+)$')
    for item in (result.links or []) if hasattr(result, 'links') else []:
        url = item.url if hasattr(item, 'url') else str(item)
        m = slug_re.search(url)
        if m:
            slug = m.group(1)
            title = (item.title or slug.replace("-", " ").title()) if hasattr(item, 'title') else slug.replace("-", " ").title()
            # Clean Evident prefix from title
            title = re.sub(r'^Evident\s*-\s*', '', title)
            title = re.sub(r'\s*\|.*$', '', title).strip()
            briefs.append({"title": title, "slug": slug, "url": url, "date": ""})
    return briefs


def _parse_index_browser() -> list[dict]:
    """Fallback: use agent-browser to parse index (handles cookie wall)."""
    try:
        _ab(f"open {INDEX_URL}", timeout=20)
        time.sleep(2)

        snap = _ab("snapshot")
        for line in snap.splitlines():
            if "Accept all" in line:
                m = re.search(r'ref=(\w+)', line)
                if m:
                    _ab(f"click @{m.group(1)}")
                    time.sleep(1)
                break

        snap = _ab("snapshot")
        briefs = []
        seen = set()
        date_re = re.compile(
            r'(\d{1,2}\s+(?:JANUARY|FEBRUARY|MARCH|APRIL|MAY|JUNE|JULY|AUGUST|SEPTEMBER|OCTOBER|NOVEMBER|DECEMBER)\s+\d{4})',
            re.IGNORECASE,
        )
        skip = {
            "Read more", "SIGN IN", "Sign up to our newsletter", "privacy policy",
            "Learn more about Membership", "Show more", "Register here", "Apply here",
        }

        current_date = None
        for line in snap.splitlines():
            dm = date_re.search(line)
            if dm:
                current_date = dm.group(1).title()

            if 'link "' in line and 'bankingbrief' not in line.lower():
                title_m = re.search(r'link "([^"]+)"', line)
                if title_m and title_m.group(1) not in skip:
                    title = title_m.group(1)
                    slug = title.lower().strip()
                    slug = re.sub(r'[^a-z0-9\s-]', '', slug)
                    slug = re.sub(r'\s+', '-', slug).strip('-')
                    if slug and slug not in seen:
                        seen.add(slug)
                        briefs.append({
                            "title": title, "slug": slug,
                            "url": f"{BASE_URL}{slug}", "date": current_date or "",
                        })
                        current_date = None

        return [b for b in briefs if b.get("date")]
    finally:
        subprocess.run(["agent-browser", "close"], capture_output=True, timeout=5)


def parse_index() -> list[dict]:
    """Parse the brief index. Firecrawl map → agent-browser fallback."""
    try:
        briefs = _parse_index_firecrawl()
        if briefs:
            print(f"[map] {len(briefs)} briefs found", file=sys.stderr)
            return briefs
    except Exception as e:
        print(f"[map] failed: {e}", file=sys.stderr)
    return _parse_index_browser()


# ---------------------------------------------------------------------------
# Brief fetching & formatting
# ---------------------------------------------------------------------------

def fetch_brief(slug: str, index_meta: dict | None = None) -> dict:
    """Fetch a single brief. Returns {title, date, slug, url, markdown}."""
    url = f"{BASE_URL}{slug}"
    raw = fetch_markdown(url)

    # Extract title
    title = slug.replace("-", " ").title()
    title_match = re.search(r'^Title:\s*(.+)', raw, re.MULTILINE)
    if title_match:
        t = title_match.group(1).strip()
        t = re.sub(r'^Evident\s*-\s*', '', t)
        t = re.sub(r'\s*\|.*$', '', t)
        if t:
            title = t
    # Firecrawl uses H1 directly
    h1_match = re.search(r'^# (.+)', raw, re.MULTILINE)
    if h1_match and len(h1_match.group(1)) < 80:
        title = h1_match.group(1).strip()

    # Extract date
    date = ""
    date_match = re.search(
        r'(\d{1,2}\s+(?:January|February|March|April|May|June|July|August|September|October|November|December)\s+\d{4})',
        raw,
    )
    if date_match:
        date = date_match.group(1)
    elif index_meta and index_meta.get("date"):
        date = index_meta["date"]

    # Clean markdown
    md = raw
    md = re.sub(r'^(?:Title|URL Source|Markdown Content):.*\n?', '', md, flags=re.MULTILINE)

    for marker in ["TOP OF THE NEWS", "Welcome back to the Banking Brief"]:
        idx = md.find(marker)
        if idx != -1:
            md = md[idx:]
            break

    for marker in ["Explore the archive", "MORE NEWS", "You are receiving this"]:
        idx = md.find(marker)
        if idx != -1:
            md = md[:idx].rstrip()

    header = (
        f"# Evident Banking Brief: {title}\n\n"
        f"**Date:** {date}\n"
        f"**Source:** [Evident Banking Brief]({url})\n\n"
        f"---\n\n"
    )

    return {
        "title": title,
        "date": date,
        "slug": slug,
        "url": url,
        "markdown": header + md,
    }


def save_to_cache(brief: dict) -> Path:
    """Save brief to lustro article cache as JSON."""
    CACHE_DIR.mkdir(parents=True, exist_ok=True)

    date_str = datetime.now(UTC).strftime("%Y-%m-%d")
    if brief["date"]:
        for fmt in ("%d %B %Y", "%d %b %Y"):
            try:
                dt = datetime.strptime(brief["date"], fmt)
                date_str = dt.strftime("%Y-%m-%d")
                break
            except ValueError:
                continue

    filename = f"{date_str}_evident-brief_{brief['slug']}.json"
    filepath = CACHE_DIR / filename

    record = {
        "title": f"Evident Banking Brief: {brief['title']}",
        "date": date_str,
        "source": "Evident Banking Brief",
        "tier": 1,
        "link": brief["url"],
        "summary": brief["markdown"][:300].strip().replace("\n", " "),
        "text": brief["markdown"],
        "fetched_at": datetime.now(UTC).isoformat(),
    }

    filepath.write_text(json.dumps(record, ensure_ascii=False, indent=2))
    return filepath


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="Fetch the latest Evident Banking Brief.")
    parser.add_argument("--save", action="store_true", help="Save to lustro article cache")
    parser.add_argument("--list", action="store_true", help="List available briefs")
    parser.add_argument("--slug", type=str, help="Fetch a specific brief by URL slug")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    args = parser.parse_args()

    if args.list:
        briefs = parse_index()
        for b in briefs:
            print(f"  {b.get('date', '?'):<22} {b['title']:<45} {b['slug']}")
        print(f"\n{len(briefs)} briefs found.", file=sys.stderr)
        return

    briefs = parse_index()
    brief_meta = {b["slug"]: b for b in briefs}

    if args.slug:
        slug = args.slug
    else:
        if not briefs:
            print("No briefs found on index page.", file=sys.stderr)
            sys.exit(1)
        slug = briefs[0]["slug"]
        print(f"Latest: {briefs[0]['title']}", file=sys.stderr)

    brief = fetch_brief(slug, index_meta=brief_meta.get(slug))

    if args.json:
        out = {k: v for k, v in brief.items() if k != "markdown"}
        out["text"] = brief["markdown"]
        json.dump(out, sys.stdout, ensure_ascii=False, indent=2)
    else:
        print(brief["markdown"])

    if args.save:
        path = save_to_cache(brief)
        print(f"Saved to {path}", file=sys.stderr)


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""queue-balance — report task distribution by provider from golem-queue.md.

Reads a golem-queue.md file, counts dispatched tasks per provider,
counts unassigned tasks, and suggests rebalancing if any provider
has more than 2x the count of another.

Usage: queue-balance <path-to-golem-queue.md>
"""
from __future__ import annotations

import re
import sys
from collections import Counter
from pathlib import Path


def parse_queue(text: str) -> tuple[Counter[str], int]:
    """Parse queue text, return (provider_counts, unassigned_count).

    Only counts tasks in sections above '## Done'.
    Dispatched tasks have --provider X.
    Unassigned tasks are #### headings without a provider dispatch line.
    """
    # Split at Done section — only consider content before it
    done_match = re.search(r"^## Done", text, re.MULTILINE)
    active_text = text[: done_match.start()] if done_match else text

    provider_counts: Counter[str] = Counter()

    # Match dispatched task lines: - [ ] `golem --provider <name> ...`
    dispatched = re.findall(r"--provider\s+(\S+)", active_text)
    for provider in dispatched:
        provider_counts[provider] += 1

    # Count unassigned tasks: #### headings (task titles without dispatch)
    # Exclude lines that are just section headers like "### Pending"
    unassigned = 0
    in_pending = False
    for line in active_text.splitlines():
        stripped = line.strip()
        # Track whether we're in a pending/active section
        if re.match(r"^##+(?: Pending| Builds| Retries| Fixes| Compound)", stripped):
            in_pending = True
            continue
        if re.match(r"^##+(?: Done)", stripped):
            in_pending = False
            continue
        if not in_pending:
            # Still count #### lines even outside explicit sections
            pass
        # #### lines that are NOT section categories and NOT followed by
        # a dispatched task on the same or next line
        if re.match(r"^####\s+\S", stripped):
            # Check if there's a --provider dispatch on this or nearby lines
            # Simple approach: count #### as unassigned unless the heading
            # itself contains --provider (it won't)
            # But some #### are just category labels under "###" sections.
            # Only count if it looks like a task description.
            heading_text = re.sub(r"^####\s+", "", stripped)
            # Skip generic section labels (single word, all caps, etc.)
            if heading_text and not re.match(r"^(?:IMPORTANT|Pending|Done|Builds|Retries|Fixes|Compound)", heading_text, re.IGNORECASE):
                unassigned += 1

    # Don't double-count: dispatched tasks under #### headings should not
    # also count as unassigned. We count #### headings as unassigned only
    # if there's no --provider dispatch for them.
    # Since dispatched tasks use - [ ] lines (not ####), they don't overlap.
    # But we should subtract: if a section has both #### and - [ ], the ####
    # is the title and - [ ] is the dispatch. For simplicity, if any dispatched
    # task exists, we assume #### headings are just titles for dispatched tasks
    # within the same section and don't count them separately.
    # Better approach: only count #### headings that have NO - [ ] dispatch
    # line in the block between this #### and the next heading.

    return provider_counts, unassigned


def parse_queue_v2(text: str) -> tuple[Counter[str], int]:
    """Parse queue text, return (provider_counts, unassigned_count).

    Walks line by line. Tracks current heading depth.
    A #### heading starts a task block. If that block contains a --provider
    dispatch line, it's assigned. Otherwise it's unassigned.
    Also counts bare - [ ] dispatched lines (not under a ####).
    """
    done_match = re.search(r"^## Done", text, re.MULTILINE)
    active_text = text[: done_match.start()] if done_match else text

    provider_counts: Counter[str] = Counter()
    unassigned = 0

    lines = active_text.splitlines()
    i = 0
    while i < len(lines):
        line = lines[i]
        stripped = line.strip()

        # Check for #### heading — a potential task
        if re.match(r"^####\s+\S", stripped):
            heading = re.sub(r"^####\s+", "", stripped)
            # Look for dispatched task in the block until next heading
            found_dispatch = False
            j = i + 1
            while j < len(lines):
                next_stripped = lines[j].strip()
                # Stop at next heading of any level
                if re.match(r"^#{1,4}\s", next_stripped):
                    break
                if "--provider" in next_stripped:
                    providers = re.findall(r"--provider\s+(\S+)", next_stripped)
                    for p in providers:
                        provider_counts[p] += 1
                    found_dispatch = True
                j += 1
            if not found_dispatch:
                unassigned += 1
            i += 1
            continue

        # Bare dispatched task line (not under a ####)
        if re.match(r"^-\s+\[", stripped) and "--provider" in stripped:
            providers = re.findall(r"--provider\s+(\S+)", stripped)
            for p in providers:
                provider_counts[p] += 1

        i += 1

    return provider_counts, unassigned


def format_report(provider_counts: Counter[str], unassigned: int) -> str:
    """Format human-readable distribution report."""
    total_dispatched = sum(provider_counts.values())
    total = total_dispatched + unassigned

    lines: list[str] = []
    lines.append("=" * 50)
    lines.append("Golem Queue — Task Distribution by Provider")
    lines.append("=" * 50)
    lines.append("")

    if not provider_counts and unassigned == 0:
        lines.append("No tasks found in queue.")
        lines.append("")
        return "\n".join(lines)

    # Provider table
    lines.append(f"{'Provider':<15} {'Tasks':>6} {'Share':>8}")
    lines.append("-" * 31)
    for provider, count in sorted(provider_counts.items(), key=lambda x: -x[1]):
        share = f"{count / total_dispatched * 100:.1f}%" if total_dispatched else "0%"
        lines.append(f"{provider:<15} {count:>6} {share:>8}")
    if unassigned:
        share = f"{unassigned / total * 100:.1f}%"
        lines.append(f"{'(unassigned)':<15} {unassigned:>6} {share:>8}")
    lines.append("-" * 31)
    lines.append(f"{'Total':<15} {total:>6}")
    lines.append("")

    # Rebalancing check
    if len(provider_counts) >= 2:
        counts = list(provider_counts.values())
        providers = list(provider_counts.keys())
        max_count = max(counts)
        min_count = min(counts)
        if max_count > 2 * min_count:
            max_provider = providers[counts.index(max_count)]
            min_provider = providers[counts.index(min_count)]
            imbalance_ratio = max_count / min_count
            lines.append(f"⚠ Imbalance detected: {max_provider} has "
                         f"{imbalance_ratio:.1f}x tasks of {min_provider}")
            move = (max_count - min_count) // 2
            if move > 0:
                lines.append(f"  Suggestion: move {move} task(s) from "
                             f"{max_provider} to {min_provider}")
        else:
            lines.append("✓ Distribution is balanced (no provider >2x another)")
    elif len(provider_counts) == 1:
        lines.append("ℹ Only one provider has dispatched tasks")

    if unassigned > 0:
        lines.append("")
        lines.append(f"ℹ {unassigned} unassigned task(s) — consider dispatching")

    lines.append("")
    return "\n".join(lines)


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: queue-balance <path-to-golem-queue.md>", file=sys.stderr)
        sys.exit(1)

    queue_path = Path(sys.argv[1])
    if not queue_path.exists():
        print(f"Error: {queue_path} not found", file=sys.stderr)
        sys.exit(1)

    text = queue_path.read_text()
    provider_counts, unassigned = parse_queue_v2(text)
    report = format_report(provider_counts, unassigned)
    print(report)


if __name__ == "__main__":
    main()

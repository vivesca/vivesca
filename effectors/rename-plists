#!/usr/bin/env python3
"""Rename all com.terry.* LaunchAgents to com.vivesca.*.

Dry run by default. Pass --execute to actually perform the rename.
"""

from __future__ import annotations

import argparse
import glob
import os
import plistlib
import subprocess
import sys
from pathlib import Path

OSCILLATORS_DIR = Path("~/epigenome/oscillators").expanduser()
LAUNCH_AGENTS_DIR = Path("~/Library/LaunchAgents").expanduser()
OLD_PREFIX = "com.terry"
NEW_PREFIX = "com.vivesca"


def deep_replace(obj: object) -> object:
    """Replace com.terry with com.vivesca in all string values recursively."""
    if isinstance(obj, str):
        return obj.replace(OLD_PREFIX, NEW_PREFIX)
    if isinstance(obj, list):
        return [deep_replace(item) for item in obj]
    if isinstance(obj, dict):
        return {
            deep_replace(k) if isinstance(k, str) else k: deep_replace(v) for k, v in obj.items()
        }
    return obj


def run_cmd(cmd: list[str], dry_run: bool) -> tuple[int, str]:
    """Run a command or print it in dry-run mode."""
    if dry_run:
        print(f"  + {' '.join(cmd)}")
        return 0, ""
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    return result.returncode, result.stderr


def rename_one(old_plist: Path, dry_run: bool) -> list[str]:
    """Rename a single plist through the full pipeline. Returns list of errors."""
    errors: list[str] = []
    stem = old_plist.stem  # e.g. com.terry.blog-sync
    suffix = old_plist.suffix  # .plist
    new_stem = stem.replace(OLD_PREFIX, NEW_PREFIX)
    new_plist = old_plist.parent / f"{new_stem}{suffix}"

    old_label = stem
    new_label = new_stem

    old_symlink = LAUNCH_AGENTS_DIR / old_plist.name
    new_symlink = LAUNCH_AGENTS_DIR / new_plist.name

    uid = os.getuid()
    domain = f"gui/{uid}"

    print(f"\n{'[DRY RUN] ' if dry_run else ''}{old_label} -> {new_label}")

    # Step 1: Boot out old agent
    old_target = str(old_symlink) if old_symlink.exists() else str(old_plist)
    rc, err = run_cmd(["launchctl", "bootout", domain, old_target], dry_run)
    if not dry_run and rc != 0 and "Could not find service" not in err:
        errors.append(f"bootout failed for {old_label}: {err.strip()}")
        # Non-fatal: agent might not be loaded; continue

    # Step 2: Read plist, update label and any com.terry references in values
    if not dry_run:
        with open(old_plist, "rb") as f:
            data = plistlib.load(f)
    else:
        with open(old_plist, "rb") as f:
            data = plistlib.load(f)

    data.get("Label", "")
    data["Label"] = new_label
    data = deep_replace(data)

    if dry_run:
        # Show what changed
        changed_keys: list[str] = []
        with open(old_plist, "rb") as f:
            orig_data = plistlib.load(f)
        for k, v in data.items():
            orig_v = orig_data.get(k)
            if v != orig_v:
                changed_keys.append(f"    {k}: {orig_v!r} -> {v!r}")
        if changed_keys:
            print("  Changes in plist values:")
            for ck in changed_keys:
                print(ck)
    else:
        with open(old_plist, "wb") as f:
            plistlib.dump(data, f)

    # Step 3: Rename the plist file in oscillators/
    if dry_run:
        print(f"  + mv {old_plist} -> {new_plist}")
    else:
        old_plist.rename(new_plist)

    # Step 4: Remove old symlink (or file) in LaunchAgents
    if old_symlink.exists() or old_symlink.is_symlink():
        if dry_run:
            kind = "symlink" if old_symlink.is_symlink() else "file"
            print(f"  + rm {kind} {old_symlink}")
        else:
            os.remove(old_symlink)

    # Step 5: Create new symlink
    if dry_run:
        print(f"  + ln -s {new_plist} {new_symlink}")
    else:
        os.symlink(new_plist, new_symlink)

    # Step 6: Bootstrap new agent
    rc, err = run_cmd(["launchctl", "bootstrap", domain, str(new_symlink)], dry_run)
    if not dry_run and rc != 0:
        errors.append(f"bootstrap failed for {new_label}: {err.strip()}")

    return errors


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Rename com.terry.* LaunchAgents to com.vivesca.*"
    )
    parser.add_argument(
        "--execute",
        action="store_true",
        help="Actually perform the rename (default is dry run)",
    )
    args = parser.parse_args()
    dry_run = not args.execute

    pattern = str(OSCILLATORS_DIR / f"{OLD_PREFIX}.*.plist")
    plists = sorted(Path(p) for p in glob.glob(pattern))

    if not plists:
        print(f"No plists found matching {pattern}")
        sys.exit(1)

    mode = "DRY RUN" if dry_run else "EXECUTING"
    print(f"{mode}: Renaming {len(plists)} plists from {OLD_PREFIX} to {NEW_PREFIX}")

    all_errors: list[tuple[str, list[str]]] = []

    for plist_path in plists:
        errors = rename_one(plist_path, dry_run)
        if errors:
            all_errors.append((plist_path.name, errors))

    print(f"\n{'=' * 60}")
    if all_errors:
        print("Errors encountered:")
        for name, errs in all_errors:
            for e in errs:
                print(f"  {name}: {e}")
        sys.exit(1)
    else:
        print(f"Done. {len(plists)} plists {'would be ' if dry_run else ''}renamed successfully.")

    if dry_run:
        print("\nRun with --execute to perform the rename.")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""twin — CC+model collaborative dialogue on a shared scratchpad.

Two models work the same task via turn-based markdown dialogue.
Claude (via CC) writes first, the twin responds, back and forth.

Usage:
  twin "task description"                    # interactive — CC prompts, twin responds
  twin --auto "task" --rounds 3              # autonomous — runs N rounds without human
  twin --model gemini "task"                 # pick the twin model (default: haiku)
  twin --scratchpad path.md "task"           # resume from existing scratchpad
"""

import argparse
import os
import pty
import re
import select
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

HOME = Path.home()
DEFAULT_MODEL = "haiku"

# Models that need direct CLI invocation (not via channel)
DIRECT_MODELS = {
    "gemini": ["gemini", "-p"],
    "opencode": ["opencode", "--prompt"],
    "codex": ["codex", "--dangerously-bypass-approvals-and-sandbox", "-q", "--skip-git-repo-check"],
}
# Models needing PTY wrapper (TUI-based CLIs)
PTY_MODELS = {"opencode", "codex"}
# Per-model timeout overrides
MODEL_TIMEOUT_FLOOR = {
    "gemini": 120,
    "opencode": 120,
    "codex": 120,
}

_ANSI_RE = re.compile(r'\x1b\[[^a-zA-Z]*[a-zA-Z]|\x1b\][^\x07]*\x07|\x1b[()][^a-zA-Z]*[a-zA-Z]?')
_CTRL_RE = re.compile(r'[\x00-\x09\x0b-\x1f\x7f]')
_TUI_CHROME_RE = re.compile(r'[█▀▄▐░▌▍▎▏╹╸╺╻┃■⬝]+')  # TUI progress/box chars


def _pty_query(cmd: list[str], timeout: int) -> str:
    """Run a TUI command with a pseudo-TTY and extract clean text."""
    master, slave = pty.openpty()
    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    proc = subprocess.Popen(
        cmd, stdin=slave, stdout=slave, stderr=slave,
        close_fds=True, env=env, cwd=str(HOME / "germline"),
    )
    os.close(slave)
    output = b''
    deadline = time.time() + timeout
    while time.time() < deadline:
        r, _, _ = select.select([master], [], [], 1)
        if r:
            try:
                chunk = os.read(master, 4096)
                if not chunk:
                    break
                output += chunk
            except OSError:
                break
        if proc.poll() is not None:
            # drain
            while True:
                r, _, _ = select.select([master], [], [], 0.5)
                if not r:
                    break
                try:
                    chunk = os.read(master, 4096)
                    if not chunk:
                        break
                    output += chunk
                except OSError:
                    break
            break
    try:
        os.close(master)
    except OSError:
        pass
    if proc.poll() is None:
        proc.kill()

    # Clean ANSI + control chars + TUI chrome
    clean = _ANSI_RE.sub('', output.decode('utf-8', errors='replace'))
    clean = _CTRL_RE.sub('', clean)
    clean = _TUI_CHROME_RE.sub(' ', clean)  # replace TUI chrome with spaces

    # OpenCode/Codex: streaming "Thinking:" lines repeat and accumulate.
    # Find the LAST "Thinking:" block — that has the final thought + response.
    thinking_parts = clean.split('Thinking:')
    if len(thinking_parts) > 1:
        # Take the last thinking block — it has the final accumulated content
        last = thinking_parts[-1]
        # Strip metadata: token counts, timing, model labels
        last = re.sub(r'\d+,\d+\s+\d+%\s+\(\$[\d.]+\)', '', last)
        last = re.sub(r'·\s*[\d.]+s', '', last)
        last = re.sub(r'Build\s+·\s+\S+', '', last)
        last = re.sub(r'~\s*(Reading file|Finding files)\.\.\.', '', last)
        last = re.sub(r'[→✱]\s*\w+\s+"[^"]*"[^)]*\)', '', last)  # tool calls
        last = re.sub(r'[→✱]\s*\w+\s+\S+', '', last)  # simpler tool calls
        last = re.sub(r'\s+', ' ', last).strip()
        # The response is typically after the last period of thinking
        # Find substantial text (>20 chars) that isn't thinking prefix
        sentences = [s.strip() for s in last.split('.') if len(s.strip()) > 15]
        if sentences:
            return '. '.join(sentences[-3:]).strip()
        return last[:500] if last else "[twin: thinking but no response extracted]"

    # Fallback: last substantial text block
    lines = [s.strip() for s in clean.splitlines() if s.strip() and len(s.strip()) > 3]
    return "\n".join(lines[-10:]).strip() if lines else ""


def query_twin(model: str, prompt: str, timeout: int = 120) -> str:
    """Query the twin model. PTY for TUI apps, direct for others, channel as default."""
    effective_timeout = max(timeout, MODEL_TIMEOUT_FLOOR.get(model, 0))

    if model in PTY_MODELS:
        cmd_base = DIRECT_MODELS.get(model, [model])
        cmd = [*cmd_base, prompt]
        try:
            result = _pty_query(cmd, effective_timeout)
            return result if result else "[twin error: empty response after PTY extraction]"
        except Exception as e:
            return f"[twin error: {e}]"

    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    cmd = DIRECT_MODELS.get(model, ["channel", model, "-p"])
    try:
        r = subprocess.run(
            [*cmd, prompt],
            capture_output=True, text=True, timeout=effective_timeout,
            env=env,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
        return f"[twin error: {r.stderr.strip() or 'empty response'}]"
    except subprocess.TimeoutExpired:
        return "[twin error: timeout]"
    except Exception as e:
        return f"[twin error: {e}]"


def init_scratchpad(path: Path, task: str, model: str) -> None:
    """Create a new scratchpad with task header."""
    header = f"""# Twin Session — {datetime.now().strftime('%Y-%m-%d %H:%M')}

**Task:** {task}
**Models:** Claude (CC) ↔ {model}

---

"""
    path.write_text(header, encoding="utf-8")


def append_turn(path: Path, role: str, content: str) -> None:
    """Append a turn to the scratchpad."""
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### {role}\n\n{content}\n")


def read_scratchpad(path: Path) -> str:
    """Read full scratchpad content."""
    return path.read_text(encoding="utf-8") if path.exists() else ""


def twin_prompt(scratchpad_content: str, task: str) -> str:
    """Build the prompt for the twin model."""
    return f"""You are one half of a multi-model collaboration. You and other AIs are working together on a task.
Read the conversation so far and add your contribution — code, analysis, disagreement, or refinement.
Be direct. If you disagree, say why. If you see a better approach, propose it.
Don't repeat what's already been said. Advance the work.

If you need input from the human operator to proceed, start your response with QUESTION: followed by what you need to know.

{scratchpad_content}

Continue the conversation. Your turn."""


def _needs_human(response: str) -> bool:
    """Check if a model's response requests human input."""
    first_line = response.strip().split('\n')[0] if response.strip() else ""
    return first_line.startswith("QUESTION:") or first_line.startswith("**QUESTION:**")


def _ask_human(model: str, response: str) -> str:
    """Prompt the human for input and return their answer."""
    print(f"\n  💬 {model} asks: {response.strip().split(chr(10))[0]}")
    try:
        answer = input("  → Your answer (Enter to skip): ").strip()
    except (EOFError, KeyboardInterrupt):
        answer = ""
    return answer if answer else "[no answer — continue without]"


def run_interactive(args):
    """Multi-model collaboration on a shared scratchpad."""
    models = args.model if isinstance(args.model, list) else [args.model]
    scratchpad = Path(args.scratchpad) if args.scratchpad else HOME / "tmp" / f"twin-{datetime.now().strftime('%H%M%S')}.md"
    scratchpad.parent.mkdir(parents=True, exist_ok=True)

    task = args.task
    model_label = " + ".join(models)

    if not scratchpad.exists() or not read_scratchpad(scratchpad):
        init_scratchpad(scratchpad, task, model_label)
        append_turn(scratchpad, "Claude (CC)", f"**Task received:** {task}\n\nLet me start by framing the problem...")

    print(f"Scratchpad: {scratchpad}")
    print(f"Models: CC ↔ {model_label}")
    print(f"Task: {task}")
    print()

    for round_num in range(1, args.rounds + 1):
        print(f"--- Round {round_num}/{args.rounds} ---")

        # Each twin model gets a turn
        for model in models:
            content = read_scratchpad(scratchpad)
            prompt = twin_prompt(content, task)
            print(f"  {model}...", end=" ", flush=True)
            response = query_twin(model, prompt, timeout=args.timeout)
            append_turn(scratchpad, f"{model}", response)
            print("done")

            # Human interrupt: if any model asks a question, pause for input
            if _needs_human(response):
                answer = _ask_human(model, response)
                append_turn(scratchpad, "Human (Terry)", answer)

        # CC synthesises after all twins have spoken
        content = read_scratchpad(scratchpad)
        cc_prompt = f"""You are Claude, collaborating with {model_label} on a task. Read the full scratchpad.
Review what everyone said this round. Synthesise, disagree, or advance. Don't repeat — build on the strongest point.

{content}

Your turn as Claude. Be specific and constructive."""

        print(f"  CC (sonnet)...", end=" ", flush=True)
        cc_response = query_twin("sonnet", cc_prompt, timeout=args.timeout)
        append_turn(scratchpad, "Claude (CC)", cc_response)
        print("done")

    print(f"\nScratchpad: {scratchpad}")
    print("Review with: Read tool or cat")


def main():
    parser = argparse.ArgumentParser(prog="twin", description="CC+model collaborative dialogue")
    parser.add_argument("task", help="Task description")
    parser.add_argument("--model", default=DEFAULT_MODEL, nargs="+", help=f"Twin model(s), space-separated (default: {DEFAULT_MODEL})")
    parser.add_argument("--rounds", type=int, default=2, help="Number of rounds (default: 2)")
    parser.add_argument("--scratchpad", type=str, help="Path to existing scratchpad (resume)")
    parser.add_argument("--timeout", type=int, default=120, help="Per-query timeout in seconds (default: 120)")

    args = parser.parse_args()
    run_interactive(args)


if __name__ == "__main__":
    main()

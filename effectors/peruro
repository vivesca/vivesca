#!/usr/bin/env -S uv run --script --python 3.13
# /// script
# requires-python = ">=3.13"
# dependencies = ["requests"]
# ///
"""
peruro — burn through bot protection and JS rendering, return clean markdown.

Usage:
  peruro <url>             scrape a URL → markdown
  peruro search <query>    web search + scrape results → markdown
"""

import json
import os
import subprocess
import sys

import requests


def get_api_key() -> str:
    try:
        result = subprocess.run(
            ["security", "find-generic-password", "-s", "peruro", "-a", os.environ.get("USER", "terry"), "-w"],
            capture_output=True, text=True, check=True,
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        key = os.environ.get("FIRECRAWL_API_KEY", "")
        if key:
            return key
        print("No API key found. Store with:", file=sys.stderr)
        print("  security add-generic-password -s peruro -a $USER -w fc-...", file=sys.stderr)
        sys.exit(1)


def scrape(url: str, key: str) -> None:
    resp = requests.post(
        "https://api.firecrawl.dev/v1/scrape",
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
        json={"url": url, "formats": ["markdown"]},
        timeout=30,
    )
    resp.raise_for_status()
    data = resp.json()
    md = data.get("data", {}).get("markdown", "")
    if data.get("success") and md:
        print(md)
    else:
        print(json.dumps(data, indent=2), file=sys.stderr)
        sys.exit(1)


def search(query: str, key: str) -> None:
    resp = requests.post(
        "https://api.firecrawl.dev/v1/search",
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"},
        json={"query": query, "limit": 5, "scrapeOptions": {"formats": ["markdown"]}},
        timeout=30,
    )
    resp.raise_for_status()
    data = resp.json()
    if not data.get("success"):
        print(json.dumps(data, indent=2), file=sys.stderr)
        sys.exit(1)
    for i, result in enumerate(data.get("data", []), 1):
        print(f"## {i}. {result.get('title', 'Untitled')}")
        print(f"**URL:** {result.get('url', '')}\n")
        md = result.get("markdown", "").strip()
        if md:
            print(md[:3000])
        print("\n---\n")


def main() -> None:
    args = sys.argv[1:]
    if not args:
        print(__doc__, file=sys.stderr)
        sys.exit(1)
    key = get_api_key()
    if args[0] == "search":
        if len(args) < 2:
            print("Usage: peruro search <query>", file=sys.stderr)
            sys.exit(1)
        search(" ".join(args[1:]), key)
    else:
        scrape(args[0], key)


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""log-summary — Summarize golem-daemon.log activity.

Parses the daemon log and reports task counts, failure rates, and top errors
over sliding time windows.

Usage:
    log-summary           # Full report (1h / 6h / 24h windows)
    log-summary --window 1h   # Single window
    log-summary --window 6h
    log-summary --window 24h
    log-summary --json    # Machine-readable output
"""
from __future__ import annotations

import json
import re
import sys
from collections import Counter
from datetime import datetime, timedelta
from pathlib import Path

LOGFILE = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log"
ROTATED_LOGFILE = Path.home() / ".local" / "share" / "vivesca" / "golem-daemon.log.1"

# Regex for timestamped log lines: [2026-03-31 10:53:29] message
RE_TS = re.compile(r"^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] (.+)$")

# Task lifecycle patterns
RE_STARTING = re.compile(r"^Starting: (.+)")
RE_FINISHED = re.compile(r"^Finished \((\d+)s, exit=(\d+)\): (.+)")
RE_FAILED = re.compile(r"^FAILED \(exit=(\d+)\): (.+)")
RE_TIMEOUT = re.compile(r"^TIMEOUT \((\d+)s\): (.+)")
RE_ERROR = re.compile(r"^ERROR: (.+)")
RE_QUEUED = re.compile(r"^Queued \[(\w+)\]: (.+)")
RE_RUNNING = re.compile(r"^Running: (\d+) tasks(?: \((.+)\))?, (\d+) pending")
RE_IDLE = re.compile(r"^Idle: (\d+) pending")
RE_DAEMON = re.compile(r"^Daemon (started|stopped)")
RE_AUTOCOMMIT = re.compile(r"^auto-commit \((\d+) tasks\): (.+)")
RE_DISK_WARNING = re.compile(r"^WARNING: (.+)")
RE_FATAL = re.compile(r"^Fatal error: (.+)")


def parse_timestamp(ts_str: str) -> datetime:
    """Parse 'YYYY-MM-DD HH:MM:SS' into datetime."""
    return datetime.strptime(ts_str, "%Y-%m-%d %H:%M:%S")


def read_log_lines() -> list[tuple[datetime, str]]:
    """Read log lines from main + rotated log files, return (timestamp, message) pairs."""
    entries: list[tuple[datetime, str]] = []
    for path in (ROTATED_LOGFILE, LOGFILE):
        if not path.exists():
            continue
        for line in path.read_text().splitlines():
            m = RE_TS.match(line)
            if m:
                try:
                    ts = parse_timestamp(m.group(1))
                    entries.append((ts, m.group(2)))
                except ValueError:
                    continue
    entries.sort(key=lambda x: x[0])
    return entries


def classify_events(
    entries: list[tuple[datetime, str]],
) -> dict:
    """Classify all log entries into structured events."""
    events: dict[str, list] = {
        "starts": [],       # (ts, cmd)
        "finishes": [],     # (ts, duration_s, exit_code, cmd)
        "failures": [],     # (ts, exit_code, cmd)
        "timeouts": [],     # (ts, duration_s, cmd)
        "errors": [],       # (ts, message)
        "queued": [],       # (ts, provider, cmd)
        "running": [],      # (ts, n_tasks, provider_str, n_pending)
        "idle": [],         # (ts, n_pending)
        "daemon": [],       # (ts, action)
        "autocommits": [],  # (ts, n_tasks, hash)
        "warnings": [],     # (ts, message)
        "fatals": [],       # (ts, message)
    }

    for ts, msg in entries:
        if m := RE_STARTING.match(msg):
            events["starts"].append((ts, m.group(1)))
        elif m := RE_FINISHED.match(msg):
            events["finishes"].append((ts, int(m.group(1)), int(m.group(2)), m.group(3)))
        elif m := RE_FAILED.match(msg):
            events["failures"].append((ts, int(m.group(1)), m.group(2)))
        elif m := RE_TIMEOUT.match(msg):
            events["timeouts"].append((ts, int(m.group(1)), m.group(2)))
        elif m := RE_ERROR.match(msg):
            events["errors"].append((ts, m.group(1)))
        elif m := RE_QUEUED.match(msg):
            events["queued"].append((ts, m.group(1), m.group(2)))
        elif m := RE_RUNNING.match(msg):
            events["running"].append((ts, int(m.group(1)), m.group(2) or "", int(m.group(3))))
        elif m := RE_IDLE.match(msg):
            events["idle"].append((ts, int(m.group(1))))
        elif m := RE_DAEMON.match(msg):
            events["daemon"].append((ts, m.group(1)))
        elif m := RE_AUTOCOMMIT.match(msg):
            events["autocommits"].append((ts, int(m.group(1)), m.group(2)))
        elif m := RE_DISK_WARNING.match(msg):
            events["warnings"].append((ts, m.group(1)))
        elif m := RE_FATAL.match(msg):
            events["fatals"].append((ts, m.group(1)))

    return events


def window_filter(
    items: list[tuple], ts_index: int, cutoff: datetime
) -> list[tuple]:
    """Filter items to those with timestamp >= cutoff."""
    return [item for item in items if item[ts_index] >= cutoff]


def compute_window_stats(
    events: dict, window_name: str, cutoff: datetime
) -> dict:
    """Compute statistics for a single time window."""
    starts = window_filter(events["starts"], 0, cutoff)
    finishes = window_filter(events["finishes"], 0, cutoff)
    failures = window_filter(events["failures"], 0, cutoff)
    timeouts = window_filter(events["timeouts"], 0, cutoff)
    errors = window_filter(events["errors"], 0, cutoff)
    autocommits = window_filter(events["autocommits"], 0, cutoff)
    warnings = window_filter(events["warnings"], 0, cutoff)
    fatals = window_filter(events["fatals"], 0, cutoff)

    # Successes = finishes with exit=0
    successes = [f for f in finishes if f[2] == 0]
    finish_fails = [f for f in finishes if f[2] != 0]

    total_finished = len(finishes)
    total_success = len(successes)
    total_fail = len(failures) + len(finish_fails)
    total_timeout = len(timeouts)

    failure_rate = (total_fail / total_finished * 100) if total_finished > 0 else 0.0

    # Duration stats from successful finishes
    durations = [f[1] for f in successes]
    avg_duration = sum(durations) / len(durations) if durations else 0

    # Top errors: count by exit code + truncated command
    error_counter: Counter[str] = Counter()
    for _, exit_code, cmd in failures:
        error_counter[f"exit={exit_code}: {cmd[:80]}"] += 1
    for _, _, exit_code, cmd in finish_fails:
        error_counter[f"exit={exit_code}: {cmd[:80]}"] += 1
    for _, duration, cmd in timeouts:
        error_counter[f"timeout ({duration}s): {cmd[:80]}"] += 1
    for _, message in errors:
        error_counter[f"error: {message[:80]}"] += 1
    for _, message in fatals:
        error_counter[f"fatal: {message[:80]}"] += 1

    # Provider breakdown from queued entries
    queued = window_filter(events["queued"], 0, cutoff)
    provider_counter: Counter[str] = Counter()
    for _, provider, _ in queued:
        provider_counter[provider] += 1

    return {
        "window": window_name,
        "cutoff": cutoff.isoformat(),
        "tasks_started": len(starts),
        "tasks_finished": total_finished,
        "tasks_succeeded": total_success,
        "tasks_failed": total_fail,
        "tasks_timed_out": total_timeout,
        "failure_rate_pct": round(failure_rate, 1),
        "avg_duration_s": round(avg_duration, 1),
        "autocommits": len(autocommits),
        "autocommit_tasks": sum(a[1] for a in autocommits),
        "warnings": len(warnings),
        "top_errors": error_counter.most_common(10),
        "providers": dict(provider_counter.most_common()),
    }


def format_report(stats_list: list[dict]) -> str:
    """Format window stats into a human-readable report."""
    lines: list[str] = []
    lines.append("=" * 60)
    lines.append("GOLEM DAEMON LOG SUMMARY")
    lines.append("=" * 60)

    for stats in stats_list:
        w = stats["window"]
        lines.append("")
        lines.append(f"── {w} ──")
        lines.append(f"  Tasks started:    {stats['tasks_started']}")
        lines.append(f"  Tasks finished:   {stats['tasks_finished']}")
        lines.append(f"    succeeded:      {stats['tasks_succeeded']}")
        lines.append(f"    failed:         {stats['tasks_failed']}")
        lines.append(f"    timed out:      {stats['tasks_timed_out']}")
        lines.append(f"  Failure rate:     {stats['failure_rate_pct']}%")
        lines.append(f"  Avg duration:     {stats['avg_duration_s']}s")
        lines.append(f"  Auto-commits:     {stats['autocommits']} ({stats['autocommit_tasks']} tasks)")
        lines.append(f"  Warnings:         {stats['warnings']}")

        if stats["providers"]:
            prov_parts = [f"{p}:{n}" for p, n in stats["providers"].items()]
            lines.append(f"  Providers:        {', '.join(prov_parts)}")

        if stats["top_errors"]:
            lines.append("  Top errors:")
            for desc, count in stats["top_errors"][:5]:
                lines.append(f"    {count}x  {desc}")

    # Failure rate trend
    if len(stats_list) >= 2:
        lines.append("")
        lines.append("── Failure rate trend ──")
        for stats in stats_list:
            bar_len = int(stats["failure_rate_pct"] / 2)
            bar = "█" * bar_len + "░" * (50 - bar_len)
            lines.append(f"  {stats['window']:>4s} |{bar}| {stats['failure_rate_pct']:5.1f}%")

    lines.append("")
    lines.append("=" * 60)
    return "\n".join(lines)


def run(
    logpath: Path | None = None,
    window: str | None = None,
    as_json: bool = False,
) -> str:
    """Main entry point. Returns formatted report or JSON string.

    Args:
        logpath: Override default log file path (for testing).
        window: Single window to report ('1h', '6h', '24h'), or None for all.
        as_json: Return JSON instead of human-readable report.
    """
    global LOGFILE, ROTATED_LOGFILE
    if logpath is not None:
        LOGFILE = logpath
        ROTATED_LOGFILE = Path(str(logpath) + ".1")

    entries = read_log_lines()
    if not entries:
        msg = "No log entries found."
        return json.dumps({"error": msg}) if as_json else msg

    events = classify_events(entries)
    now = entries[-1][0]  # Use last log entry time as "now"

    windows = {
        "1h": now - timedelta(hours=1),
        "6h": now - timedelta(hours=6),
        "24h": now - timedelta(hours=24),
    }

    if window:
        if window not in windows:
            return f"Unknown window: {window}. Use: 1h, 6h, 24h"
        cutoff = windows[window]
        stats = compute_window_stats(events, window, cutoff)
        stats_list = [stats]
    else:
        stats_list = [
            compute_window_stats(events, name, cutoff)
            for name, cutoff in windows.items()
        ]

    if as_json:
        # Convert Counter tuples to dicts for JSON serialization
        for s in stats_list:
            s["top_errors"] = [
                {"error": desc, "count": count}
                for desc, count in s["top_errors"]
            ]
        return json.dumps(stats_list, indent=2)

    return format_report(stats_list)


def main():
    args = sys.argv[1:]
    as_json = "--json" in args
    window = None

    for arg in args:
        if arg.startswith("--window="):
            window = arg.split("=", 1)[1]
        elif arg == "--window" and args.index(arg) + 1 < len(args):
            window = args[args.index(arg) + 1]

    if window and window not in ("1h", "6h", "24h"):
        print(f"Unknown window: {window}. Use: 1h, 6h, 24h")
        return 1

    output = run(window=window, as_json=as_json)
    print(output)
    return 0


if __name__ == "__main__":
    sys.exit(main())

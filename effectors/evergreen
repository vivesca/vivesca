#!/usr/bin/env bash
# evergreen — keep the entire stack at latest stable versions.
# Runs daily via supercronic. Personal repos only.
#
# Covers: Python version, all pip deps, ganglion worker sync,
# CC, uv, Rust toolchain, npm globals, Go binaries,
# pyproject.toml target-version, vivesca restart.
set -euo pipefail

REPO_ROOT="${1:-$HOME/germline}"
LOG="$HOME/tmp/evergreen.log"
GANGLION="ganglion"
mkdir -p "$(dirname "$LOG")"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG"; }

cd "$REPO_ROOT"
log "=== evergreen start ==="

# ── 1. Python version ──────────────────────────────────────────────────────

LATEST=$(uv python list 2>/dev/null \
    | grep -E '^cpython-[0-9]+\.[0-9]+\.[0-9]+-linux-x86_64-gnu' \
    | grep -v freethreaded | grep -v 'a\|b\|rc' \
    | head -1 | awk '{print $1}' | sed 's/cpython-//;s/-linux.*//')
CURRENT=$(uv run python --version 2>/dev/null | awk '{print $2}')

if [ -z "$LATEST" ]; then
    log "WARN: could not determine latest Python, skipping version check"
else
    log "Python: current=$CURRENT latest=$LATEST"
    if [ "$CURRENT" != "$LATEST" ]; then
        MINOR=$(echo "$LATEST" | cut -d. -f1,2)
        log "Upgrading Python to $MINOR"
        uv python install "$MINOR" 2>>"$LOG"
        uv venv --python "$MINOR" .venv 2>>"$LOG"
        uv sync 2>>"$LOG"

        # Update pyproject.toml target-version
        RUFF_TARGET="py${MINOR//./}"
        if grep -q "target-version" pyproject.toml; then
            sed -i "s/target-version = \"py[0-9]*\"/target-version = \"$RUFF_TARGET\"/" pyproject.toml
            log "Updated ruff target-version to $RUFF_TARGET"
        fi
        log "Python upgraded to $LATEST"
    fi
fi

# ── 2. Dependency upgrade ──────────────────────────────────────────────────

log "Upgrading all dependencies"
uv lock --upgrade 2>>"$LOG"
uv sync 2>>"$LOG"

# ── 3. Test ────────────────────────────────────────────────────────────────

log "Running tests"
SKIP_TESTS=(
    "assays/test_organelles_circadian_clock.py"
    "assays/test_resources_circadian.py"
    "assays/test_soma_watchdog_observability.py"
)
IGNORE_ARGS=""
for skip in "${SKIP_TESTS[@]}"; do
    [ -f "$skip" ] && IGNORE_ARGS="$IGNORE_ARGS --ignore=$skip"
done

if uv run pytest assays/ -x -q $IGNORE_ARGS 2>>"$LOG"; then
    log "Tests pass"
else
    log "Tests FAILED — rolling back"
    git checkout uv.lock pyproject.toml 2>/dev/null || true
    uv sync 2>>"$LOG"
    log "Rolled back"
    exit 1
fi

# ── 4. Commit changes ─────────────────────────────────────────────────────

CHANGED_FILES=""
for check_file in uv.lock pyproject.toml; do
    if ! git diff --quiet "$check_file" 2>/dev/null; then
        CHANGED_FILES="$CHANGED_FILES $check_file"
    fi
done

if [ -n "$CHANGED_FILES" ]; then
    git add $CHANGED_FILES
    git commit -m "evergreen: update stack $(date '+%Y-%m-%d') (Python $CURRENT)"
    git push 2>>"$LOG"
    log "Committed and pushed: $CHANGED_FILES"
else
    log "No changes to commit"
fi

# ── 5. Sync ganglion ─────────────────────────────────────��────────────────

if ssh -o ConnectTimeout=5 "$GANGLION" true 2>/dev/null; then
    log "Syncing ganglion"
    ssh "$GANGLION" 'export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH" && cd ~/germline && git pull --ff-only && cd effectors/polysome && uv sync' 2>>"$LOG"
    ssh "$GANGLION" 'sudo systemctl restart temporal-worker' 2>>"$LOG"
    # Update Temporal Docker images
    ssh "$GANGLION" 'cd ~/germline/effectors/polysome && docker compose pull && docker compose up -d' 2>>"$LOG" || true
    log "Ganglion synced, worker restarted, Docker updated"
else
    log "WARN: ganglion unreachable, skipping sync"
fi

# ── A. Claude Code ────────────────────────────────────────────────────────
# `claude update` drops new binaries in ~/.local/share/claude/versions/ but does
# not flip ~/.local/bin/claude. claude-reconcile repoints and prunes.
update_cc() {
    claude update 2>>"$LOG" && log "CC updated" || log "WARN: CC update failed"
    ~/germline/effectors/claude-reconcile >>"$LOG" 2>&1 && log "CC reconciled" || log "WARN: CC reconcile failed"
    if ssh -o ConnectTimeout=5 "$GANGLION" true 2>/dev/null; then
        ssh "$GANGLION" '~/.local/bin/claude update && ~/germline/effectors/claude-reconcile' 2>>"$LOG" && log "Ganglion CC updated+reconciled" || true
    fi
}

# ── B. uv ─────────────────────────────────────────────────────────────────
update_uv() {
    curl -LsSf https://astral.sh/uv/install.sh | sh 2>>"$LOG" && log "uv updated" || log "WARN: uv update failed"
}

# ── C. Rust toolchain ─────────────────────────────────────────────────────
update_rust() {
    rustup update stable 2>>"$LOG" && log "Rust updated" || log "WARN: rustup failed"
}

# ── D. npm globals ────────────────────────────────────────────────────────
update_npm() {
    for pkg in agent-browser @google/gemini-cli @openai/codex pnpm agnix promptfoo ccusage; do
        npm install -g "$pkg@latest" 2>>"$LOG" && log "Updated $pkg" || log "WARN: $pkg failed"
    done
}

update_qmd() {
    # qmd lives on Mac (Tailscale-reachable). Reinstall from GitHub HEAD.
    ssh -o ConnectTimeout=10 mac \
        'export PATH=$HOME/.bun/bin:$PATH; bun install -g https://github.com/tobi/qmd' \
        2>>"$LOG" && log "Updated qmd on mac" || log "WARN: qmd update failed"
}

# ── Tool updates (fault-isolated) ────────────────────────────────────────
for fn in update_cc update_uv update_rust update_npm update_qmd; do
    $fn || log "WARN: $fn failed, continuing"
done

# ── 7. Update supercronic ─────────────────────────────────────────────────

CRONIC_LATEST=$(curl -sf https://api.github.com/repos/aptible/supercronic/releases/latest 2>/dev/null | grep -o '"tag_name":"[^"]*"' | head -1 | cut -d'"' -f4)
if [ -n "$CRONIC_LATEST" ]; then
    CRONIC_CURRENT=$(supercronic --version 2>/dev/null | awk '{print $NF}' || echo "unknown")
    if [ "$CRONIC_CURRENT" != "$CRONIC_LATEST" ]; then
        ARCH=$(uname -m | sed 's/x86_64/amd64/')
        curl -sfL "https://github.com/aptible/supercronic/releases/download/${CRONIC_LATEST}/supercronic-linux-${ARCH}" -o /tmp/supercronic-new 2>>"$LOG"
        if [ -s /tmp/supercronic-new ]; then
            chmod +x /tmp/supercronic-new
            mv /tmp/supercronic-new "$HOME/.local/bin/supercronic"
            log "Supercronic updated to $CRONIC_LATEST"
        fi
    fi
fi

# ── 6. Restart vivesca ──────────────────────────────────────���─────────────

if command -v supervisorctl >/dev/null 2>&1; then
    supervisorctl -s unix:///tmp/supervisor.sock restart vivesca 2>>"$LOG" || true
    log "Vivesca restarted"
fi

log "=== evergreen done ==="

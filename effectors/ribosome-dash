def build_json_snapshot(window_minutes: int = 60) -> dict:
    """Build a JSON-serializable snapshot of the dashboard state.

    Used by --json output mode for programmatic consumption.
    """
    window_records = load_jsonl(window_minutes)
    running = load_running()
    pending_by_provider = count_pending_by_provider()
    total_pending = sum(pending_by_provider.values())
    total_completed_queue = count_total_completed()

    update_task_first_seen(running)
    all_records = load_all_jsonl()

    stats = compute_provider_stats(window_records, running)
    eta_seconds = compute_eta(stats, pending_by_provider, all_records)
    drain_rate = compute_drain_rate(all_records, window_minutes=10)
    recent_events = compute_recent_events(all_records, n=10)

    # Build per-task progress for running tasks
    avg_durs = compute_avg_duration_by_provider(all_records)
    running_tasks = []
    for task in running:
        tid = task.get("task_id", "")
        prov = task.get("provider", "")
        elapsed = compute_elapsed(tid)
        avg = avg_durs.get(prov, 0)
        remaining = estimate_task_completion(elapsed, avg)
        running_tasks.append(
            {
                "task_id": tid,
                "provider": prov,
                "elapsed": elapsed,
                "progress": estimate_task_progress(elapsed, avg),
                "eta_remaining": remaining,
            }
        )

    return {
        "pending": total_pending,
        "completed": total_completed_queue,
        "eta_seconds": eta_seconds if eta_seconds != float("inf") else None,
        "drain_rate": drain_rate,
        "providers": stats,
        "pending_by_provider": dict(pending_by_provider),
        "recent_events": recent_events,
        "running_tasks": running_tasks,
    }


def build_running_tasks_table(
    running: list[dict],
    avg_duration_by_provider: dict[str, float] | None = None,
    provider_stats: dict[str, dict] | None = None,
) -> Table:
    """Build a table showing each running task with elapsed time, progress, and health."""
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title="[bold]Running Tasks[/bold]",
    )
    table.add_column("TaskID", style="cyan", min_width=9)
    table.add_column("Provider", min_width=8)
    table.add_column("Health", min_width=9)
    table.add_column("Progress", justify="right", min_width=14)
    table.add_column("ETA", justify="right", min_width=7)
    table.add_column("Finishes", justify="right", min_width=8)
    table.add_column("Elapsed", justify="right", min_width=7)
    table.add_column("Through", style="dim", min_width=10)
    table.add_column("Prompt", style="dim", min_width=30, max_width=50, no_wrap=True)

    avg_map = avg_duration_by_provider or {}
    pstats = provider_stats or {}

    for task in running:
        tid = task.get("task_id", "?")
        prov = task.get("provider", "?")
        dispatch = task.get("dispatch_provider", "")
        elapsed = compute_elapsed(tid)
        cmd = task.get("cmd", "")

        # Extract prompt snippet from cmd
        prompt_match = re.search(r'"(.+)', cmd)
        prompt = prompt_match.group(0).rstrip('"')[:48] if prompt_match else cmd[:48]

        through_str = f"→ {dispatch}" if dispatch and dispatch != prov else ""

        elapsed_str = fmt_duration(elapsed)
        if elapsed > 600:
            elapsed_str = f"[red]{elapsed_str}[/red]"
        elif elapsed > 300:
            elapsed_str = f"[yellow]{elapsed_str}[/yellow]"

        # Progress bar based on avg duration for this provider
        avg_dur = avg_map.get(prov, 0)
        pct = estimate_task_progress(elapsed, avg_dur)
        bar_w = 8
        filled = int(pct * bar_w)
        bar_str = "█" * filled + "░" * (bar_w - filled)
        if pct >= 1.0:
            progress_str = f"[yellow]{bar_str} {pct:.0%}[/yellow]"
        elif pct >= 0.5:
            progress_str = f"[cyan]{bar_str} {pct:.0%}[/cyan]"
        else:
            progress_str = f"[dim]{bar_str} {pct:.0%}[/dim]"

        # Per-task ETA (estimated time to complete)
        remaining = estimate_task_completion(elapsed, avg_dur)
        if remaining < 0:
            eta_str = "[dim]?[/dim]"
        elif remaining == 0:
            eta_str = "[yellow]soon[/yellow]"
        else:
            eta_str = fmt_duration(remaining)

        # Wall-clock finish time
        finishes_str = fmt_wallclock_completion(remaining)

        # Task health
        ps = pstats.get(prov, {})
        total_count = ps.get("total_count", 0)
        success_count = ps.get("success_count", 0)
        prov_success_rate = success_count / total_count if total_count > 0 else 1.0
        health = compute_task_health(elapsed, avg_dur, prov_success_rate)
        health_styles = {
            "on-track": "[green]on-track[/green]",
            "slow": "[yellow]slow[/yellow]",
            "stalled": "[red]stalled[/red]",
        }
        health_str = health_styles.get(health, health)

        table.add_row(
            tid,
            prov,
            health_str,
            progress_str,
            eta_str,
            finishes_str,
            elapsed_str,
            through_str,
            prompt,
        )

    return table


def build_drain_progress(
    total_pending: int,
    total_completed: int,
    eta_seconds: float,
    drain_rate: float = 0.0,
    eta_bounds: tuple[float, float, float] | None = None,
    acceleration: float | str = 0.0,
) -> Text:
    """Build drain progress bar with ETA, rate, bounds, and wall-clock time."""
    total = total_pending + total_completed
    if total == 0:
        return Text("  No tasks in queue", style="dim")

    pct = total_completed / total
    bar_width = 30
    filled = int(pct * bar_width)
    bar_str = "█" * filled + "░" * (bar_width - filled)

    line = Text()
    line.append("  Drain: ", style="bold")
    line.append(f"[{bar_str}] ", style="cyan")
    line.append(f"{pct:.0%} ", style="bold cyan")
    line.append(f"({total_completed}/{total}) ", style="dim")

    # Drain rate
    if drain_rate > 0:
        line.append(f"rate: {drain_rate:.1f}/min ", style="green")
    else:
        line.append("rate: —/min ", style="dim")

    # Acceleration indicator (supports both string and float)
    if isinstance(acceleration, str):
        if "accelerating" in acceleration:
            line.append(f"▲ {acceleration} ", style="green")
        elif "slowing" in acceleration:
            line.append(f"▼ {acceleration} ", style="red")
        elif "stable" in acceleration:
            line.append(f"→ {acceleration} ", style="dim")
        else:
            line.append(f"· {acceleration} ", style="dim")
    elif acceleration > 0.05:
        line.append("▲ ", style="green")
    elif acceleration < -0.05:
        line.append("▼ ", style="red")
    else:
        line.append("· ", style="dim")

    # ETA with bounds
    line.append(f"ETA: {fmt_eta(eta_seconds)} ", style="bold yellow")
    wallclock = fmt_wallclock_eta(eta_seconds)
    line.append(f"(~{wallclock})", style="cyan")

    if eta_bounds:
        optimistic, _, pessimistic = eta_bounds
        if optimistic != float("inf") and pessimistic != float("inf"):
            opt_wc = fmt_wallclock_eta(optimistic)
            pess_wc = fmt_wallclock_eta(pessimistic)
            line.append(f" [{opt_wc}-{pess_wc}]", style="dim")

    return line


def build_dashboard(
    window_minutes: int = 60,
    all_records_cache: list[dict] | None = None,
) -> Panel:
    """Build the full dashboard as a Rich renderable."""
    window_records = load_jsonl(window_minutes)
    running = load_running()
    cooldowns = load_cooldowns()
    pending_by_provider = count_pending_by_provider()
    total_pending = sum(pending_by_provider.values())
    total_completed_queue = count_total_completed()

    # Track first-seen for running tasks
    update_task_first_seen(running)

    # Use cached all-records for ETA if provided (avoids re-reading on every refresh)
    all_records = all_records_cache if all_records_cache is not None else load_all_jsonl()

    stats = compute_provider_stats(window_records, running)
    eta_seconds = compute_eta(stats, pending_by_provider, all_records)
    per_provider_eta = compute_per_provider_eta(stats, pending_by_provider, all_records)
    trend = compute_throughput_trend(all_records)
    spark = sparkline(trend)
    drain_velocity = compute_drain_velocity(all_records, pending_by_provider)
    utilization = compute_provider_utilization(stats, PROVIDER_LIMITS)
    drain_rate = compute_drain_rate(all_records, window_minutes=10)
    acceleration = compute_throughput_acceleration(all_records, window_minutes=60)
    time_since_last = compute_time_since_last_event(all_records, exit_code=0)
    eta_bounds = compute_drain_eta_bounds(stats, pending_by_provider, all_records)

    # === Header ===
    now_str = datetime.now().strftime("%H:%M:%S")
    header = Text()
    header.append("⬡ Ribosome Dashboard", style="bold cyan")
    header.append(f"  {now_str}", style="dim")
    header.append(f"  window={window_minutes}m", style="dim")
    header.append(
        f"  queue={total_pending} pending / {total_completed_queue} done", style="yellow"
    )
    header.append(f"  drain: {drain_rate:.1f}/min", style="green" if drain_rate > 0 else "dim")
    if time_since_last >= 0:
        header.append(f"  last✓: {fmt_duration(time_since_last)}", style="dim")
    header.append(f"  throughput: {spark}", style="green")
    header.append(f"  {drain_velocity}", style="bold")

    # === Provider table ===
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title=None,
    )
    table.add_column("Provider", style="bold", min_width=10)
    table.add_column("Active", justify="right", min_width=6)
    table.add_column("Cap", justify="right", min_width=8)
    table.add_column("✓", justify="right", style="green", min_width=5)
    table.add_column("✗", justify="right", style="red", min_width=5)
    table.add_column("⏳", justify="right", style="yellow", min_width=5)
    table.add_column("☠", justify="right", style="dim red", min_width=5)
    table.add_column("Rate", justify="right", min_width=8)
    table.add_column("AvgDur", justify="right", min_width=7)
    table.add_column("tasks/hr", justify="right", min_width=8)
    table.add_column("Queue", justify="right", style="cyan", min_width=6)
    table.add_column("Drain ETA", justify="right", min_width=9)
    table.add_column("Status", min_width=10)

    provider_order = ["zhipu", "infini", "volcano", "codex", "gemini"]
    for prov in sorted(
        stats.keys(), key=lambda p: provider_order.index(p) if p in provider_order else 99
    ):
        s = stats[prov]
        total = s["completed"] + s["failed"] + s["rate_limited"] + s["killed"]
        rate = s["success_count"] / total * 100 if total > 0 else 0.0

        avg_dur = s["total_duration"] / s["total_count"] if s["total_count"] > 0 else 0
        queue = pending_by_provider.get(prov, 0)
        prov_eta = per_provider_eta.get(prov, 0.0)

        # Rate coloring
        if rate >= 80:
            rate_str = f"[green]{rate:.0f}%[/green]"
        elif rate >= 50:
            rate_str = f"[yellow]{rate:.0f}%[/yellow]"
        elif total > 0:
            rate_str = f"[red]{rate:.0f}%[/red]"
        else:
            rate_str = "[dim]—[/dim]"

        # Status
        if prov in cooldowns:
            status = "[red]COOLDOWN[/red]"
        elif s["active"] > 0:
            status = f"[green]running ({s['active']})[/green]"
        elif queue > 0:
            status = "[yellow]queued[/yellow]"
        else:
            status = "[dim]idle[/dim]"

        eta_str = fmt_eta(prov_eta) if queue > 0 else "[dim]—[/dim]"
        throughput = compute_throughput_per_hour(all_records, provider=prov)
        throughput_str = f"{throughput:.0f}" if throughput > 0 else "[dim]—[/dim]"

        # Capacity utilization
        util = utilization.get(prov, 0.0)
        util_str = fmt_utilization_bar(util, width=4)

        table.add_row(
            prov,
            str(s["active"]),
            util_str,
            str(s["completed"]),
            str(s["failed"]),
            str(s["rate_limited"]),
            str(s["killed"]),
            rate_str,
            fmt_duration(avg_dur),
            throughput_str,
            str(queue),
            eta_str,
            status,
        )

    # === Summary line ===
    total_active = sum(s["active"] for s in stats.values())
    total_completed_window = sum(s["completed"] for s in stats.values())
    total_failed_window = sum(s["failed"] for s in stats.values())
    total_rl_window = sum(s["rate_limited"] for s in stats.values())
    window_total = total_completed_window + total_failed_window + total_rl_window
    window_rate = (total_completed_window / window_total * 100) if window_total > 0 else 0.0

    summary = Text()
    summary.append(f"  Workers: {total_active}  ", style="bold")
    summary.append(f"Done(window): {total_completed_window}  ", style="green")
    summary.append(f"Failed: {total_failed_window}  ", style="red")
    summary.append(f"RateLimited: {total_rl_window}  ", style="yellow")
    summary.append(
        f"Success: {window_rate:.0f}%  ",
        style="bold green" if window_rate >= 80 else "bold yellow",
    )

    # ETA with wall-clock time and confidence
    confidence = compute_eta_confidence(all_records)
    conf_style = {"high": "green", "medium": "yellow", "low": "red"}[confidence]
    wallclock = fmt_wallclock_eta(eta_seconds)
    summary.append(f"ETA: {fmt_eta(eta_seconds)} ", style="bold cyan")
    summary.append(f"(~{wallclock}) ", style="cyan")
    summary.append(f"[{confidence}]", style=conf_style)

    # === Drain progress ===
    drain_progress = build_drain_progress(
        total_pending,
        total_completed_queue,
        eta_seconds,
        drain_rate=drain_rate,
        eta_bounds=eta_bounds,
        acceleration=acceleration,
    )

    # === Running tasks table ===
    components = [header, table, summary, drain_progress]
    avg_durs = compute_avg_duration_by_provider(all_records)
    if running:
        # Sort running tasks by soonest completion
        sorted_running = sort_running_by_completion(running, avg_durs)
        components.append(build_running_tasks_table(sorted_running, avg_durs, stats))

        # === Stale task warnings ===
        stale = detect_stale_tasks(running, avg_durs)
        if stale:
            stale_text = Text()
            stale_text.append("  Stale tasks:\n", style="bold red")
            for s in stale:
                stale_text.append(
                    f"    {s['task_id']} ({s['provider']}) "
                    f"elapsed={fmt_duration(s['elapsed'])} vs avg={fmt_duration(s['avg'])}\n",
                    style="red",
                )
            components.append(stale_text)

    # === Drain timeline (per-provider) ===
    drain_timeline = build_drain_timeline(per_provider_eta, pending_by_provider)
    if drain_timeline is not None:
        components.append(drain_timeline)

    # === Recent events ===
    recent_events = compute_recent_events(all_records, n=8)
    if recent_events:
        components.append(build_recent_events_table(recent_events))

    # === Cooldown info ===
    cooldown_lines = []
    now_utc = datetime.now(UTC)
    for prov, expires_str in cooldowns.items():
        if expires_str:
            exp = parse_ts(expires_str)
            remaining = (exp - now_utc).total_seconds()
            if remaining > 0:
                cooldown_lines.append(f"  {prov}: cooldown {fmt_duration(remaining)} remaining")

    cooldown_text = Text()
    if cooldown_lines:
        cooldown_text.append("Cooldowns:\n", style="bold yellow")
        for cl in cooldown_lines:
            cooldown_text.append(cl + "\n", style="yellow")
        components.append(cooldown_text)

    return Panel(
        Group(*components),
        title="[bold]Ribosome Task Monitor[/bold]",
        border_style="blue",
        padding=(1, 2),
    )


def tail_jsonl(file_path: Path, from_byte: int = 0):
    """Yield new lines from jsonl file as they appear (tail -f style)."""
    try:
        with open(file_path) as f:
            f.seek(from_byte)
            while True:
                line = f.readline()
                if line:
                    yield line.strip()
                else:
                    time.sleep(0.5)
    except (OSError, KeyboardInterrupt):
        return


def main():
    import argparse

    parser = argparse.ArgumentParser(description="Ribosome task queue dashboard")
    parser.add_argument("--once", action="store_true", help="Single snapshot, no live refresh")
    parser.add_argument(
        "--window", type=int, default=60, help="Rolling window in minutes (default: 60)"
    )
    args = parser.parse_args()

    if not JSONL_PATH.exists():
        print(f"No data file found at {JSONL_PATH}", file=sys.stderr)
        print("Start ribosome-daemon first.", file=sys.stderr)
        sys.exit(1)

    if args.once:
        panel = build_dashboard(window_minutes=args.window)
        from rich.console import Console

        Console().print(panel)
        return

    # Live mode: pre-load all records once for ETA caching, then tail for new entries
    all_records_cache = load_all_jsonl()
    initial_byte = JSONL_PATH.stat().st_size if JSONL_PATH.exists() else 0

    with Live(
        build_dashboard(window_minutes=args.window, all_records_cache=all_records_cache),
        refresh_per_second=0.5,
        screen=False,
    ) as live:
        # Refresh from tail -f
        current_byte = initial_byte
        while True:
            try:
                # Check if file was rotated (truncated)
                if JSONL_PATH.exists():
                    new_size = JSONL_PATH.stat().st_size
                    if new_size < current_byte:
                        # File was rotated
                        all_records_cache = load_all_jsonl()
                        current_byte = 0
                    elif new_size > current_byte:
                        # Read new records
                        with open(JSONL_PATH, errors="replace") as f:
                            f.seek(current_byte)
                            new_lines = f.readlines()
                        for line in new_lines:
                            line = line.strip()
                            if line:
                                with contextlib.suppress(json.JSONDecodeError, ValueError):
                                    all_records_cache.append(json.loads(line))
                        current_byte = new_size
                        # Periodically trim cache to prevent unbounded growth (keep last 10k)
                        if len(all_records_cache) > 10000:
                            all_records_cache = all_records_cache[-5000:]

                live.update(
                    build_dashboard(
                        window_minutes=args.window,
                        all_records_cache=all_records_cache,
                    )
                )
                time.sleep(2)
            except KeyboardInterrupt:
                break


if __name__ == "__main__":
    main()



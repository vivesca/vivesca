# Rate-limit detection
RATE_LIMIT_PATTERNS = re.compile(
    r"429|AccountQuotaExceeded|rate.?limit|quota.?exceeded|20013|"
    r"request.?limit.?exceeded|API Error.*429|too many requests|TooManyRequests|"
    r"usage.?limit|hit your.*limit|quota will reset",
    re.IGNORECASE,
)

# Thresholds
SHORT_DURATION_LIMIT = 10  # seconds — fast exits are likely rate-limits

# Global: track when we first saw each running task_id (for elapsed time)
_task_first_seen: dict[str, float] = {}


def parse_ts(ts_str: str) -> datetime:
    """Parse a timestamp string (flexible formats)."""
    # Strip trailing timezone offset like +00:00 so strptime can handle it
    ts_str = re.sub(r"[+-]\d{2}:\d{2}$", "", ts_str)
    # Strip fractional seconds like .123456
    ts_str = re.sub(r"\.\d+", "", ts_str)
    for fmt in (
        "%Y-%m-%dT%H:%M:%SZ",
        "%Y-%m-%dT%H:%M:%S",
        "%Y-%m-%d %H:%M:%S",
    ):
        try:
            return datetime.strptime(ts_str, fmt).replace(tzinfo=UTC)
        except ValueError:
            continue
    return datetime.min.replace(tzinfo=UTC)


def is_rate_limited(record: dict) -> bool:
    """Detect rate-limit from exit code + duration + tail."""
    exit_code = record.get("exit", -1)
    duration = record.get("duration", 0)
    tail = record.get("tail", "")
    if exit_code == 0:
        return False
    if RATE_LIMIT_PATTERNS.search(tail):
        return True
    # Fast exit with no output is a rate-limit signal
    return bool(exit_code == 1 and duration <= SHORT_DURATION_LIMIT and tail.strip() in ("", " "))


def load_jsonl(window_minutes: int = 60) -> list[dict]:
    """Load ribosome.jsonl records within the rolling window."""
    if not JSONL_PATH.exists():
        return []
    cutoff = datetime.now(UTC) - timedelta(minutes=window_minutes)
    records = []
    try:
        with open(JSONL_PATH, errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                    ts = parse_ts(rec.get("ts", ""))
                    if ts >= cutoff:
                        records.append(rec)
                except (json.JSONDecodeError, ValueError):
                    continue
    except OSError:
        pass
    return records


def load_all_jsonl() -> list[dict]:
    """Load all ribosome.jsonl records."""
    if not JSONL_PATH.exists():
        return []
    records = []
    try:
        with open(JSONL_PATH, errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    records.append(json.loads(line))
                except (json.JSONDecodeError, ValueError):
                    continue
    except OSError:
        pass
    return records


def load_running() -> list[dict]:
    """Load currently running tasks."""
    if not RUNNING_JSON_PATH.exists():
        return []
    try:
        return json.loads(RUNNING_JSON_PATH.read_text())
    except (json.JSONDecodeError, OSError):
        return []


def load_cooldowns() -> dict[str, str]:
    """Load provider cooldowns: {provider: expires_at_str}."""
    if not COOLDOWNS_PATH.exists():
        return {}
    try:
        entries = json.loads(COOLDOWNS_PATH.read_text())
        if isinstance(entries, list):
            return {
                e.get("provider", ""): e.get("expires_at", "")
                for e in entries
                if isinstance(e, dict)
            }
        return {}
    except (json.JSONDecodeError, OSError):
        return {}


def count_pending_by_provider() -> dict[str, int]:
    """Count pending tasks in queue by provider."""
    counts: dict[str, int] = defaultdict(int)
    if not QUEUE_PATH.exists():
        return counts
    try:
        text = QUEUE_PATH.read_text()
    except OSError:
        return counts
    for line in text.splitlines():
        line = line.strip()
        if line.startswith("- [ ]"):
            # Extract --provider X
            m = re.search(r"--provider\s+(\w+)", line)
            if m:
                counts[m.group(1)] += 1
            else:
                counts["unassigned"] += 1
    return counts


def count_total_pending() -> int:
    """Count total pending tasks."""
    if not QUEUE_PATH.exists():
        return 0
    try:
        text = QUEUE_PATH.read_text()
    except OSError:
        return 0
    return sum(1 for line in text.splitlines() if line.strip().startswith("- [ ]"))


def count_total_completed() -> int:
    """Count total completed tasks in queue."""
    if not QUEUE_PATH.exists():
        return 0
    try:
        text = QUEUE_PATH.read_text()
    except OSError:
        return 0
    return sum(1 for line in text.splitlines() if line.strip().startswith("- [x]"))


def fmt_duration(seconds: float) -> str:
    """Format seconds as compact duration."""
    if seconds < 60:
        return f"{seconds:.0f}s"
    elif seconds < 3600:
        return f"{seconds / 60:.1f}m"
    else:
        h = seconds / 3600
        return f"{h:.1f}h"


def fmt_eta(seconds: float) -> str:
    """Format ETA in human-friendly form."""
    if seconds <= 0:
        return "—"
    if seconds < 60:
        return f"{seconds:.0f}s"
    elif seconds < 3600:
        return f"{seconds / 60:.0f}m"
    elif seconds < 86400:
        h = seconds / 3600
        return f"{h:.1f}h"
    else:
        return f"{seconds / 86400:.1f}d"


def compute_avg_duration_by_provider(records: list[dict]) -> dict[str, float]:
    """Compute average duration of successful tasks per provider."""
    totals: dict[str, list[float]] = {}
    for rec in records:
        if rec.get("exit") == 0 and rec.get("duration", 0) > 0:
            prov = rec.get("provider", "unknown")
            totals.setdefault(prov, []).append(rec["duration"])
    return {prov: sum(durs) / len(durs) for prov, durs in totals.items()}


def compute_ema_duration(records: list[dict], provider: str, alpha: float = 0.3) -> float:
    """Compute exponential moving average of task duration for a provider.

    Weights recent completions more heavily for better predictions.
    Records are sorted by timestamp (oldest first) so alpha applies
    to newer values.
    Returns 0.0 if no successful completions found.
    """
    successful = [
        rec
        for rec in records
        if rec.get("exit") == 0 and rec.get("duration", 0) > 0 and rec.get("provider") == provider
    ]
    if not successful:
        return 0.0
    successful.sort(key=lambda r: parse_ts(r.get("ts", "")))
    ema = float(successful[0]["duration"])
    for rec in successful[1:]:
        ema = alpha * rec["duration"] + (1 - alpha) * ema
    return ema


def compute_ema_duration_by_provider(records: list[dict], alpha: float = 0.3) -> dict[str, float]:
    """Compute EMA duration per provider from records."""
    providers = set()
    for rec in records:
        if rec.get("exit") == 0 and rec.get("duration", 0) > 0:
            providers.add(rec.get("provider", "unknown"))
    return {prov: compute_ema_duration(records, prov, alpha) for prov in providers}


def estimate_task_progress(elapsed: float, avg_duration: float) -> float:
    """Estimate task progress as a fraction [0.0, 1.0].

    Based on elapsed time vs average task duration for the provider.
    Returns 0.0 if avg_duration is 0 (no data).
    """
    if avg_duration <= 0:
        return 0.0
    return min(elapsed / avg_duration, 1.0)


def estimate_task_completion(elapsed: float, avg_duration: float) -> float:
    """Estimate seconds remaining until task completes.

    Returns avg_duration - elapsed, clamped to 0.0 if over.
    Returns -1.0 if avg_duration is 0 (no data available).
    """
    if avg_duration <= 0:
        return -1.0
    return max(0.0, avg_duration - elapsed)


def compute_completions_per_minute(records: list[dict], window_minutes: int = 30) -> float:
    """Compute completions per minute over the given window."""
    if not records:
        return 0.0
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    count = 0
    for rec in records:
        ts = parse_ts(rec.get("ts", ""))
        if ts >= cutoff and rec.get("exit") == 0:
            count += 1
    return count / window_minutes


def compute_throughput_per_hour(
    records: list[dict],
    provider: str | None = None,
    window_minutes: int = 60,
) -> float:
    """Compute completions per hour, optionally filtered by provider."""
    if not records:
        return 0.0
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    count = 0
    for rec in records:
        if rec.get("exit") != 0:
            continue
        if provider and rec.get("provider") != provider:
            continue
        ts = parse_ts(rec.get("ts", ""))
        if ts >= cutoff:
            count += 1
    return count / (window_minutes / 60)


def detect_stale_tasks(
    running: list[dict],
    avg_duration_by_provider: dict[str, float],
) -> list[dict]:
    """Return list of stale running tasks (elapsed > 2x avg duration)."""
    stale = []
    for task in running:
        tid = task.get("task_id", "")
        prov = task.get("provider", "")
        avg = avg_duration_by_provider.get(prov, 0)
        if avg <= 0:
            continue
        elapsed = compute_elapsed(tid)
        if elapsed > avg * 2:
            stale.append({"task_id": tid, "provider": prov, "elapsed": elapsed, "avg": avg})
    return stale


def fmt_wallclock_eta(eta_seconds: float) -> str:
    """Format ETA as a wall-clock completion time (HH:MM)."""
    if eta_seconds <= 0:
        return "—"
    if eta_seconds == float("inf"):
        return "∞"
    target = datetime.now() + timedelta(seconds=eta_seconds)
    return target.strftime("%H:%M")


def fmt_wallclock_completion(remaining_seconds: float) -> str:
    """Format per-task completion as wall-clock time (HH:MM).

    Returns "now" if remaining is 0, "—" if negative (unknown).
    """
    if remaining_seconds < 0:
        return "—"
    if remaining_seconds == 0:
        return "now"
    target = datetime.now() + timedelta(seconds=remaining_seconds)
    return target.strftime("%H:%M")


def compute_eta_confidence(records: list[dict], window_minutes: int = 60) -> str:
    """Assess ETA confidence: high/medium/low.

    high: >=10 successful completions in window with <30% rate-limited.
    medium: >=2 completions.
    low: <2 completions or >50% rate-limited.
    """
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    success = 0
    rl = 0
    for rec in records:
        ts = parse_ts(rec.get("ts", ""))
        if ts < cutoff:
            continue
        if rec.get("exit") == 0:
            success += 1
        elif is_rate_limited(rec):
            rl += 1
    total = success + rl
    if total == 0:
        return "low"
    rl_ratio = rl / total
    if success >= 10 and rl_ratio < 0.3:
        return "high"
    if success >= 2 and rl_ratio < 0.5:
        return "medium"
    return "low"


# Provider capacity limits (mirrored from ribosome-daemon)
PROVIDER_LIMITS = {
    "zhipu": 8,
    "infini": 2,
    "volcano": 16,
    "gemini": 4,
    "codex": 4,
}
DEFAULT_PROVIDER_LIMIT = 4


def compute_drain_velocity(
    all_records: list[dict],
    pending_by_provider: dict[str, int],
    window_minutes: int = 60,
) -> str:
    """Assess whether queue is growing, draining, stable, or done.

    Compares recent completion rate against pending count.
    Returns a human-readable indicator string.
    """
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return "✓ empty"

    if not all_records:
        return "↑ ? pending"

    # Count completions in window
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    completions = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= cutoff and r.get("exit") == 0
    )
    completion_rate = completions / window_minutes  # per minute

    if completion_rate <= 0:
        return f"↑ {total_pending} pending"

    # Time to drain at current rate
    drain_minutes = total_pending / completion_rate

    # Heuristic: if drain time < window, we're clearly draining
    if drain_minutes < window_minutes * 0.5:
        return f"↓ draining {completion_rate:.1f}/min"
    elif drain_minutes < window_minutes:
        return f"↘ slow {completion_rate:.1f}/min"
    else:
        return f"↑ growing ({total_pending} left, {completion_rate:.1f}/min)"


def compute_throughput_acceleration(
    all_records: list[dict],
    recent_minutes: int = 10,
    baseline_minutes: int = 30,
    window_minutes: int | None = None,
) -> str | float:
    """Compare recent throughput vs baseline. Returns a trend indicator.

    When window_minutes is given, returns a human-readable string:
    "→stable", "↑accelerating", "↓slowing", or "—".
    Otherwise returns the raw rate difference (float).
    """
    if not all_records:
        return "—" if window_minutes is not None else 0.0
    now = datetime.now(UTC)

    # When window_minutes is given, use it as baseline; scale recent proportionally
    effective_recent = recent_minutes
    effective_baseline = baseline_minutes
    if window_minutes is not None:
        effective_baseline = window_minutes
        effective_recent = max(window_minutes // 6, 5)

    recent_cutoff = now - timedelta(minutes=effective_recent)
    baseline_cutoff = now - timedelta(minutes=effective_baseline)

    recent_count = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= recent_cutoff and r.get("exit") == 0
    )
    baseline_count = sum(
        1
        for r in all_records
        if parse_ts(r.get("ts", "")) >= baseline_cutoff and r.get("exit") == 0
    )

    recent_rate = recent_count / effective_recent if effective_recent > 0 else 0.0
    baseline_rate = baseline_count / effective_baseline if effective_baseline > 0 else 0.0

    raw_diff = recent_rate - baseline_rate

    if window_minutes is not None:
        total = baseline_count
        if total < 3:
            return "—"
        if raw_diff > 0.02:
            return "↑accelerating"
        elif raw_diff < -0.02:
            return "↓slowing"
        else:
            return "→stable"

    return raw_diff


def compute_time_since_last_event(
    all_records: list[dict],
    exit_code: int = 0,
) -> float:
    """Seconds since the most recent record with the given exit code.

    Returns -1.0 if no matching record found.
    """
    now = datetime.now(UTC)
    latest_ts = None
    for rec in all_records:
        if rec.get("exit") != exit_code:
            continue
        ts = parse_ts(rec.get("ts", ""))
        if ts != datetime.min.replace(tzinfo=UTC) and (latest_ts is None or ts > latest_ts):
            latest_ts = ts
    if latest_ts is None:
        return -1.0
    delta = (now - latest_ts).total_seconds()
    return max(0.0, delta)


def compute_task_health(
    elapsed: float,
    avg_duration: float,
    provider_success_rate: float = 1.0,
) -> str:
    """Categorize running task health.

    Returns one of: "on-track", "slow", "stalled".
    - on-track: elapsed < 1.5x avg duration and provider success rate >= 50%
    - slow: elapsed >= 1.5x avg but < 2.5x avg
    - stalled: elapsed >= 2.5x avg, or provider success rate < 50% and elapsed > avg
    """
    if avg_duration <= 0:
        return "on-track"  # no data to judge against
    ratio = elapsed / avg_duration
    if ratio >= 2.5:
        return "stalled"
    if ratio >= 1.5:
        return "slow"
    if provider_success_rate < 0.5 and ratio >= 1.0:
        return "stalled"
    return "on-track"


def compute_drain_rate(
    all_records: list[dict],
    window_minutes: int = 10,
) -> float:
    """Compute current drain rate in tasks/min over the given window."""
    if not all_records:
        return 0.0
    now = datetime.now(UTC)
    cutoff = now - timedelta(minutes=window_minutes)
    count = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= cutoff and r.get("exit") == 0
    )
    return count / window_minutes if window_minutes > 0 else 0.0


def compute_drain_eta_bounds(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> tuple[float, float, float]:
    """Compute optimistic/median/pessimistic drain ETA in seconds.

    Returns (optimistic, median, pessimistic) where:
    - optimistic: assumes fastest recent throughput sustained
    - median: same as compute_eta (baseline throughput)
    - pessimistic: assumes half the baseline throughput
    """
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return (0.0, 0.0, 0.0)

    now = datetime.now(UTC)

    # Recent (10min) throughput for optimistic
    recent_cutoff = now - timedelta(minutes=10)
    recent_count = sum(
        1 for r in all_records if parse_ts(r.get("ts", "")) >= recent_cutoff and r.get("exit") == 0
    )

    # Baseline (60min) throughput for median
    baseline_cutoff = now - timedelta(hours=1)
    baseline_count = sum(
        1
        for r in all_records
        if parse_ts(r.get("ts", "")) >= baseline_cutoff and r.get("exit") == 0
    )

    # Optimistic: use recent rate (10min window), at least 1 completion
    if recent_count > 0:
        optimistic_rate = recent_count / 10.0  # per minute
        optimistic = total_pending / optimistic_rate * 60  # to seconds
    else:
        optimistic = float("inf")

    # Median: use baseline rate (60min window)
    if baseline_count > 0:
        median = (total_pending / baseline_count) * 3600
    else:
        # Fallback to avg duration
        durations = [
            r.get("duration", 0)
            for r in all_records
            if r.get("exit") == 0 and r.get("duration", 0) > 0
        ]
        if durations:
            avg_duration = sum(durations) / len(durations)
            total_active = sum(s.get("active", 0) for s in stats.values())
            if total_active > 0:
                median = (total_pending / total_active) * avg_duration
            else:
                median = float("inf")
        else:
            median = float("inf")

    # Pessimistic: half the baseline rate
    pessimistic = median * 2.0 if baseline_count > 0 else float("inf")

    return (optimistic, median, pessimistic)


def compute_provider_utilization(
    stats: dict[str, dict],
    limits: dict[str, int],
) -> dict[str, float]:
    """Compute active/limit ratio per provider."""
    result: dict[str, float] = {}
    for prov, s in stats.items():
        active = s.get("active", 0)
        limit = limits.get(prov, DEFAULT_PROVIDER_LIMIT)
        if limit > 0:
            result[prov] = active / limit
        else:
            result[prov] = 0.0
    return result


def fmt_utilization_bar(ratio: float, width: int = 6) -> str:
    """Format utilization as a mini progress bar with percentage."""
    filled = min(int(ratio * width), width)
    bar_str = "█" * filled + "░" * (width - filled)
    return f"{bar_str} {ratio:.0%}"


def update_task_first_seen(running: list[dict]) -> None:
    """Track first-seen timestamps for running tasks to compute elapsed time."""
    global _task_first_seen
    now = time.time()
    current_ids = set()
    for task in running:
        tid = task.get("task_id", "")
        current_ids.add(tid)
        if tid and tid not in _task_first_seen:
            _task_first_seen[tid] = now
    # Prune tasks no longer running
    _task_first_seen = {k: v for k, v in _task_first_seen.items() if k in current_ids}


def compute_elapsed(task_id: str) -> float:
    """Return elapsed seconds since we first saw this task_id."""
    first = _task_first_seen.get(task_id)
    if first is None:
        return 0.0
    return time.time() - first


def compute_provider_stats(
    window_records: list[dict],
    running: list[dict],
) -> dict[str, dict]:
    """Compute per-provider statistics from window records and running tasks."""
    stats: dict[str, dict] = {}

    # Initialize from running tasks
    for task in running:
        prov = task.get("provider", "unknown")
        if prov not in stats:
            stats[prov] = {
                "active": 0,
                "completed": 0,
                "failed": 0,
                "rate_limited": 0,
                "killed": 0,
                "total_duration": 0.0,
                "success_count": 0,
                "total_count": 0,
            }
        stats[prov]["active"] += 1

    # Aggregate from jsonl records
    for rec in window_records:
        prov = rec.get("provider", "unknown")
        if prov not in stats:
            stats[prov] = {
                "active": 0,
                "completed": 0,
                "failed": 0,
                "rate_limited": 0,
                "killed": 0,
                "total_duration": 0.0,
                "success_count": 0,
                "total_count": 0,
            }
        exit_code = rec.get("exit", -1)
        duration = rec.get("duration", 0)
        stats[prov]["total_count"] += 1
        stats[prov]["total_duration"] += duration

        if exit_code == 0:
            stats[prov]["completed"] += 1
            stats[prov]["success_count"] += 1
        elif exit_code == 137:
            stats[prov]["killed"] += 1
        elif is_rate_limited(rec):
            stats[prov]["rate_limited"] += 1
        else:
            stats[prov]["failed"] += 1

    return stats


def compute_per_provider_eta(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> dict[str, float]:
    """Estimate time to drain per-provider queue."""
    now = datetime.now(UTC)
    one_hour_ago = now - timedelta(hours=1)
    result: dict[str, float] = {}

    for prov in set(list(stats.keys()) + list(pending_by_provider.keys())):
        queue = pending_by_provider.get(prov, 0)
        if queue == 0:
            result[prov] = 0.0
            continue

        # Count completions for this provider in last hour
        recent = sum(
            1
            for r in all_records
            if parse_ts(r.get("ts", "")) >= one_hour_ago
            and r.get("exit") == 0
            and r.get("provider") == prov
        )

        if recent > 0:
            result[prov] = (queue / recent) * 3600
        else:
            # Fallback: avg duration * queue / active workers
            s = stats.get(prov, {})
            total_count = s.get("total_count", 0)
            total_duration = s.get("total_duration", 0)
            active = s.get("active", 0)
            if total_count > 0 and active > 0:
                avg_dur = total_duration / total_count
                result[prov] = (queue / active) * avg_dur
            else:
                result[prov] = float("inf")

    return result


def compute_eta(
    stats: dict[str, dict],
    pending_by_provider: dict[str, int],
    all_records: list[dict],
) -> float:
    """Estimate overall time to drain the queue based on recent throughput."""
    total_pending = sum(pending_by_provider.values())
    if total_pending == 0:
        return 0.0

    # Count completions in the last hour across all providers
    now = datetime.now(UTC)
    one_hour_ago = now - timedelta(hours=1)
    recent_completed = 0
    for rec in all_records:
        ts = parse_ts(rec.get("ts", ""))
        if ts >= one_hour_ago and rec.get("exit") == 0:
            recent_completed += 1

    if recent_completed == 0:
        # No completions in the last hour; use avg duration from all records
        durations = [
            r.get("duration", 0)
            for r in all_records
            if r.get("exit") == 0 and r.get("duration", 0) > 0
        ]
        if durations:
            avg_duration = sum(durations) / len(durations)
            total_active = sum(s["active"] for s in stats.values())
            if total_active > 0:
                return (total_pending / total_active) * avg_duration
        return float("inf")

    throughput_per_hour = recent_completed
    return (total_pending / throughput_per_hour) * 3600


def compute_throughput_trend(all_records: list[dict], bucket_minutes: int = 10) -> list[int]:
    """Compute completions per time bucket for sparkline."""
    now = datetime.now(UTC)
    buckets: list[int] = []
    for i in range(6):
        bucket_end = now - timedelta(minutes=bucket_minutes * i)
        bucket_start = bucket_end - timedelta(minutes=bucket_minutes)
        count = sum(
            1
            for r in all_records
            if bucket_start <= parse_ts(r.get("ts", "")) < bucket_end and r.get("exit") == 0
        )
        buckets.append(count)
    buckets.reverse()
    return buckets


def sparkline(values: list[int]) -> str:
    """Render a Unicode sparkline from a list of ints."""
    chars = "▁▂▃▄▅▆▇█"
    if not values or max(values) == 0:
        return "▁" * len(values) if values else ""
    mx = max(values)
    return "".join(chars[min(int(v / mx * (len(chars) - 1)), len(chars) - 1)] for v in values)


def spinner_char() -> str:
    """Return a braille spinner character that cycles based on current time."""
    chars = "⠁⠂⠃⠄⠅⠆⠇⠈⠉⠊⠋⠌⠍⠎⠏"
    idx = int(time.time() * 2) % len(chars)
    return chars[idx]


def compute_recent_events(records: list[dict], n: int = 5) -> list[dict]:
    """Classify the last N records as recent events with outcome, age, and task_id.

    Returns list of dicts sorted oldest-first, each with:
      - outcome: "success" | "failed" | "rate_limited" | "killed"
      - provider: str
      - age_seconds: float (seconds since event)
      - task_id: str (if present in record)
    """
    if not records:
        return []
    now = datetime.now(UTC)
    events: list[dict] = []
    for rec in records:
        ts = parse_ts(rec.get("ts", ""))
        if ts == datetime.min.replace(tzinfo=UTC):
            age = 0.0
        else:
            age = max(0.0, (now - ts).total_seconds())
        exit_code = rec.get("exit", -1)
        if exit_code == 0:
            outcome = "success"
        elif exit_code == 137:
            outcome = "killed"
        elif is_rate_limited(rec):
            outcome = "rate_limited"
        else:
            outcome = "failed"
        ev: dict = {
            "outcome": outcome,
            "provider": rec.get("provider", "unknown"),
            "age_seconds": age,
        }
        if "task_id" in rec:
            ev["task_id"] = rec["task_id"]
        events.append(ev)
    return events[-n:]


def sort_running_by_completion(
    running: list[dict],
    avg_durs: dict[str, float],
) -> list[dict]:
    """Sort running tasks by estimated remaining time (soonest first).

    Tasks with no avg duration for their provider are sorted last.
    """
    if not running:
        return []

    def _remaining(task: dict) -> float:
        tid = task.get("task_id", "")
        prov = task.get("provider", "")
        avg = avg_durs.get(prov, 0)
        if avg <= 0:
            return float("inf")
        elapsed = compute_elapsed(tid)
        return max(0.0, avg - elapsed)

    return sorted(running, key=_remaining)


def build_drain_timeline(
    per_provider_eta: dict[str, float],
    pending: dict[str, int],
) -> Table | None:
    """Build a per-provider drain timeline table.

    Returns None if no pending tasks.
    """
    if not pending or sum(pending.values()) == 0:
        return None
    table = Table(
        show_header=True,
        header_style="bold",
        border_style="dim",
        padding=(0, 1),
        title="[bold]Drain Timeline[/bold]",
    )
    table.add_column("Provider", style="bold", min_width=10)
    table.add_column("Queue", justify="right", style="cyan", min_width=6)
    table.add_column("ETA", justify="right", min_width=9)
    table.add_column("Finishes", justify="right", min_width=8)

    for prov in sorted(pending.keys(), key=lambda p: per_provider_eta.get(p, float("inf"))):
        queue = pending[prov]
        if queue == 0:
            continue
        eta = per_provider_eta.get(prov, float("inf"))
        eta_str = fmt_eta(eta) if eta != float("inf") else "∞"
        finishes_str = fmt_wallclock_eta(eta)
        table.add_row(prov, str(queue), eta_str, finishes_str)

    return table


def build_recent_events_table(events: list[dict]) -> Table:

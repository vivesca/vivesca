#!/usr/bin/env python3
"""replisome — multi-model collaborative dialogue via LangGraph.

Models work a shared scratchpad with human-in-the-loop interrupt.
LangGraph provides: state machine, conditional routing, checkpointing.

Usage:
  twin "task description"
  twin --model haiku gemini opencode "task"
  twin --rounds 3 "task"
  twin --scratchpad path.md "task"              # resume
"""

import argparse
import os
import pty
import re
import select
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path
from typing import Annotated, TypedDict

from langgraph.graph import StateGraph, END
from langgraph.checkpoint.memory import InMemorySaver

HOME = Path.home()
DEFAULT_MODEL = "haiku"

# ── Model dispatch config ──────────────────────────────────────────────

DIRECT_MODELS = {
    "gemini": ["gemini", "-p"],
    "opencode": ["opencode", "--prompt"],
    "codex": ["codex", "--dangerously-bypass-approvals-and-sandbox", "-q", "--skip-git-repo-check"],
}
PTY_MODELS = {"opencode", "codex"}
MODEL_TIMEOUT_FLOOR = {"gemini": 120, "opencode": 120, "codex": 120}

_ANSI_RE = re.compile(r'\x1b\[[^a-zA-Z]*[a-zA-Z]|\x1b\][^\x07]*\x07|\x1b[()][^a-zA-Z]*[a-zA-Z]?')
_CTRL_RE = re.compile(r'[\x00-\x09\x0b-\x1f\x7f]')
_TUI_CHROME_RE = re.compile(r'[█▀▄▐░▌▍▎▏╹╸╺╻┃■⬝]+')


# ── PTY wrapper for TUI models ────────────────────────────────────────

def _pty_query(cmd: list[str], timeout: int) -> str:
    """Run a TUI command with a pseudo-TTY and extract clean text."""
    master, slave = pty.openpty()
    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    proc = subprocess.Popen(
        cmd, stdin=slave, stdout=slave, stderr=slave,
        close_fds=True, env=env, cwd=str(HOME / "germline"),
    )
    os.close(slave)
    output = b''
    deadline = time.time() + timeout
    while time.time() < deadline:
        r, _, _ = select.select([master], [], [], 1)
        if r:
            try:
                chunk = os.read(master, 4096)
                if not chunk:
                    break
                output += chunk
            except OSError:
                break
        if proc.poll() is not None:
            while True:
                r, _, _ = select.select([master], [], [], 0.5)
                if not r:
                    break
                try:
                    chunk = os.read(master, 4096)
                    if not chunk:
                        break
                    output += chunk
                except OSError:
                    break
            break
    try:
        os.close(master)
    except OSError:
        pass
    if proc.poll() is None:
        proc.kill()

    clean = _ANSI_RE.sub('', output.decode('utf-8', errors='replace'))
    clean = _CTRL_RE.sub('', clean)
    clean = _TUI_CHROME_RE.sub(' ', clean)

    # Extract from streaming "Thinking:" blocks
    thinking_parts = clean.split('Thinking:')
    if len(thinking_parts) > 1:
        last = thinking_parts[-1]
        last = re.sub(r'\d+,\d+\s+\d+%\s+\(\$[\d.]+\)', '', last)
        last = re.sub(r'·\s*[\d.]+s', '', last)
        last = re.sub(r'Build\s+·\s+\S+', '', last)
        last = re.sub(r'~\s*(Reading file|Finding files)\.\.\.', '', last)
        last = re.sub(r'[→✱]\s*\w+\s+"[^"]*"[^)]*\)', '', last)
        last = re.sub(r'[→✱]\s*\w+\s+\S+', '', last)
        last = re.sub(r'\s+', ' ', last).strip()
        sentences = [s.strip() for s in last.split('.') if len(s.strip()) > 15]
        if sentences:
            return '. '.join(sentences[-3:]).strip()
        return last[:500] if last else ""

    lines = [s.strip() for s in clean.splitlines() if s.strip() and len(s.strip()) > 3]
    return "\n".join(lines[-10:]).strip() if lines else ""


def query_model(model: str, prompt: str, timeout: int = 120) -> str:
    """Query any model. PTY for TUI apps, direct CLI for some, channel for others."""
    effective_timeout = max(timeout, MODEL_TIMEOUT_FLOOR.get(model, 0))

    if model in PTY_MODELS:
        cmd = [*DIRECT_MODELS.get(model, [model]), prompt]
        try:
            result = _pty_query(cmd, effective_timeout)
            return result if result else f"[{model}: empty response]"
        except Exception as e:
            return f"[{model} error: {e}]"

    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    cmd = DIRECT_MODELS.get(model, ["channel", model, "-p"])
    try:
        r = subprocess.run(
            [*cmd, prompt], capture_output=True, text=True,
            timeout=effective_timeout, env=env,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
        return f"[{model} error: {r.stderr.strip() or 'empty'}]"
    except subprocess.TimeoutExpired:
        return f"[{model}: timeout after {effective_timeout}s]"
    except Exception as e:
        return f"[{model} error: {e}]"


# ── Scratchpad ─────────────────────────────────────────────────────────

def scratchpad_text(turns: list[dict]) -> str:
    """Render turns as markdown."""
    lines = []
    for t in turns:
        lines.append(f"\n### {t['role']}\n\n{t['content']}\n")
    return "\n".join(lines)


def model_prompt(scratchpad: str) -> str:
    """Build the prompt any model sees."""
    return f"""You are part of a multi-model collaboration. Read the conversation and contribute.
Be direct. Disagree if you see a better approach. Don't repeat what's been said.
If you need input from the human operator, start with QUESTION: followed by what you need.

{scratchpad}

Your turn."""


# ── LangGraph state ───────────────────────────────────────────────────

def _append(a: list, b: list) -> list:
    return a + b


class ReplisomeState(TypedDict):
    task: str
    models: list[str]
    turns: Annotated[list[dict], _append]
    current_model_idx: int
    current_round: int
    max_rounds: int
    timeout: int
    scratchpad_path: str
    needs_human: bool
    human_question: str
    done: bool
    # Work mode: models code on worktrees
    phase: str  # "discuss" | "code" | "review"
    worktrees: dict  # model -> worktree path
    diffs: dict  # model -> git diff output


# ── Worktree management ───────────────────────────────────────────────

def create_worktrees(models: list[str], repo: Path) -> dict:
    """Create a git worktree for each model."""
    worktrees = {}
    for model in models:
        wt_path = HOME / "tmp" / f"replisome-{model}-{int(time.time())}"
        branch = f"replisome/{model}-{int(time.time())}"
        try:
            subprocess.run(
                ["git", "worktree", "add", "-b", branch, str(wt_path), "HEAD"],
                capture_output=True, text=True, timeout=15, cwd=repo,
            )
            worktrees[model] = str(wt_path)
            print(f"  worktree: {model} → {wt_path}")
        except Exception as e:
            print(f"  worktree failed for {model}: {e}")
    return worktrees


def get_worktree_diff(wt_path: str) -> str:
    """Get git diff from a worktree."""
    try:
        r = subprocess.run(
            ["git", "diff", "HEAD"],
            capture_output=True, text=True, timeout=10, cwd=wt_path,
        )
        return r.stdout.strip() if r.stdout.strip() else "(no changes)"
    except Exception:
        return "(diff failed)"


def cleanup_worktrees(worktrees: dict, repo: Path):
    """Remove worktrees after merge."""
    for model, wt_path in worktrees.items():
        try:
            subprocess.run(
                ["git", "worktree", "remove", "--force", wt_path],
                capture_output=True, timeout=10, cwd=repo,
            )
        except Exception:
            pass


def run_model_in_worktree(model: str, task: str, context: str, wt_path: str, timeout: int) -> str:
    """Run a model CLI in its worktree to do actual coding work."""
    coding_prompt = f"""You are working on a coding task in a git repository at {wt_path}.

Task: {task}

Context from the discussion so far:
{context[-2000:]}

Read the relevant files, make the changes, and describe what you did.
Do NOT just discuss — actually modify files to implement the solution."""

    effective_timeout = max(timeout, MODEL_TIMEOUT_FLOOR.get(model, 0))

    if model in PTY_MODELS:
        cmd = [*DIRECT_MODELS.get(model, [model]), coding_prompt]
        # Override CWD to worktree
        master, slave = pty.openpty()
        env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
        proc = subprocess.Popen(
            cmd, stdin=slave, stdout=slave, stderr=slave,
            close_fds=True, env=env, cwd=wt_path,
        )
        os.close(slave)
        output = b''
        deadline = time.time() + effective_timeout
        while time.time() < deadline:
            r, _, _ = select.select([master], [], [], 1)
            if r:
                try:
                    chunk = os.read(master, 4096)
                    if not chunk:
                        break
                    output += chunk
                except OSError:
                    break
            if proc.poll() is not None:
                while True:
                    r, _, _ = select.select([master], [], [], 0.5)
                    if not r:
                        break
                    try:
                        chunk = os.read(master, 4096)
                        if not chunk:
                            break
                        output += chunk
                    except OSError:
                        break
                break
        try:
            os.close(master)
        except OSError:
            pass
        if proc.poll() is None:
            proc.kill()
        return f"[{model} ran in worktree — check diff for changes]"
    else:
        env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
        cmd = DIRECT_MODELS.get(model, ["channel", model, "-p"])
        try:
            r = subprocess.run(
                [*cmd, coding_prompt], capture_output=True, text=True,
                timeout=effective_timeout, env=env, cwd=wt_path,
            )
            return r.stdout.strip() if r.returncode == 0 else f"[{model} error]"
        except Exception as e:
            return f"[{model} error: {e}]"


# ── Graph nodes ───────────────────────────────────────────────────────

def node_model_turn(state: ReplisomeState) -> dict:
    """One model speaks."""
    idx = state["current_model_idx"]
    model = state["models"][idx]
    scratchpad = scratchpad_text(state["turns"])
    prompt = model_prompt(scratchpad)

    print(f"  {model}...", end=" ", flush=True)
    response = query_model(model, prompt, timeout=state["timeout"])
    print("done")

    # Save to scratchpad file
    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### {model}\n\n{response}\n")

    # Check for human interrupt
    first_line = response.strip().split('\n')[0] if response.strip() else ""
    wants_human = first_line.startswith("QUESTION:") or first_line.startswith("**QUESTION:**")

    return {
        "turns": [{"role": model, "content": response}],
        "current_model_idx": idx + 1,
        "needs_human": wants_human,
        "human_question": first_line if wants_human else "",
    }


def node_human(state: ReplisomeState) -> dict:
    """Pause for human input."""
    question = state.get("human_question", "")
    print(f"\n  ? {question}")
    try:
        answer = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        answer = "[skipped]"
    if not answer:
        answer = "[skipped]"

    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### Human (Terry)\n\n{answer}\n")

    return {
        "turns": [{"role": "Human (Terry)", "content": answer}],
        "needs_human": False,
        "human_question": "",
    }


def node_code(state: ReplisomeState) -> dict:
    """Each model codes in its worktree."""
    idx = state["current_model_idx"]
    model = state["models"][idx]
    wt_path = state.get("worktrees", {}).get(model)

    if not wt_path:
        return {
            "turns": [{"role": model, "content": "[no worktree — skipping code phase]"}],
            "current_model_idx": idx + 1,
        }

    scratchpad = scratchpad_text(state["turns"])
    print(f"  {model} coding...", end=" ", flush=True)
    summary = run_model_in_worktree(model, state["task"], scratchpad, wt_path, state["timeout"])
    diff = get_worktree_diff(wt_path)
    print("done")

    path = Path(state["scratchpad_path"])
    diff_preview = diff[:1500] if len(diff) > 1500 else diff
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### {model} (code)\n\n{summary}\n\n```diff\n{diff_preview}\n```\n")

    diffs = dict(state.get("diffs", {}))
    diffs[model] = diff

    return {
        "turns": [{"role": f"{model} (code)", "content": f"{summary}\n\n```diff\n{diff_preview}\n```"}],
        "current_model_idx": idx + 1,
        "diffs": diffs,
    }


def node_review(state: ReplisomeState) -> dict:
    """CC reviews all diffs and decides: merge, iterate, or discard."""
    diffs = state.get("diffs", {})
    model_label = " + ".join(state["models"])

    diff_summary = ""
    for model, diff in diffs.items():
        diff_summary += f"\n--- {model} ---\n{diff[:2000]}\n"

    prompt = f"""You are Claude reviewing code from {model_label}. Each model worked on the same task in separate worktrees.

Task: {state['task']}

Diffs:
{diff_summary}

Review each diff. For each:
1. Does it solve the task correctly?
2. Any bugs, security issues, or style problems?
3. Which approach is best? Can they be combined?

End with a VERDICT: one of
- MERGE <model> — accept this model's changes
- COMBINE — manually combine the best parts (describe how)
- ITERATE — need another round of discussion + coding
- DISCARD — none of the approaches work, restart discussion"""

    print(f"  CC reviewing diffs...", end=" ", flush=True)
    response = query_model("sonnet", prompt, timeout=state["timeout"])
    print("done")

    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### Claude (CC) — Review\n\n{response}\n")

    # Parse verdict
    verdict_line = ""
    for line in response.splitlines():
        if line.strip().upper().startswith("VERDICT:"):
            verdict_line = line.strip()
            break

    needs_iterate = "ITERATE" in verdict_line.upper() if verdict_line else False

    rnd = state["current_round"] + 1
    return {
        "turns": [{"role": "Claude (CC) — Review", "content": response}],
        "current_round": rnd,
        "current_model_idx": 0,
        "phase": "discuss" if needs_iterate else "done",
        "done": not needs_iterate or rnd > state["max_rounds"],
    }


def node_synthesise(state: ReplisomeState) -> dict:
    """CC synthesises discussion. Decides: keep discussing or start coding."""
    model_label = " + ".join(state["models"])
    scratchpad = scratchpad_text(state["turns"])
    has_worktrees = bool(state.get("worktrees"))

    code_instruction = ""
    if has_worktrees:
        code_instruction = """

If the group has converged on an approach and is ready to implement, end with:
READY TO CODE

If more discussion is needed, do NOT include that line."""

    prompt = f"""You are Claude, collaborating with {model_label}. Read the full scratchpad.
Synthesise this round. Agree, disagree, or advance. Build on the strongest point.
If the group is converging, state the conclusion. If not, sharpen the disagreement.{code_instruction}

{scratchpad}

Your turn as Claude."""

    print(f"  CC (sonnet)...", end=" ", flush=True)
    response = query_model("sonnet", prompt, timeout=state["timeout"])
    print("done")

    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### Claude (CC)\n\n{response}\n")

    ready_to_code = "READY TO CODE" in response.upper() and has_worktrees
    rnd = state["current_round"] + 1

    return {
        "turns": [{"role": "Claude (CC)", "content": response}],
        "current_round": rnd,
        "current_model_idx": 0,
        "phase": "code" if ready_to_code else "discuss",
        "done": (not ready_to_code) and rnd > state["max_rounds"],
    }


# ── Routing ───────────────────────────────────────────────────────────

def route_after_model(state: ReplisomeState) -> str:
    if state.get("needs_human"):
        return "human"
    if state["current_model_idx"] < len(state["models"]):
        return "model_turn"
    return "synthesise"


def route_after_human(state: ReplisomeState) -> str:
    if state["current_model_idx"] < len(state["models"]):
        return "model_turn"
    return "synthesise"


def route_after_synth(state: ReplisomeState) -> str:
    if state.get("done"):
        return END
    if state.get("phase") == "code":
        return "code"
    return "model_turn"


def route_after_code(state: ReplisomeState) -> str:
    if state["current_model_idx"] < len(state["models"]):
        return "code"
    return "review"


def route_after_review(state: ReplisomeState) -> str:
    if state.get("done"):
        return END
    return "model_turn"  # back to discussion if ITERATE


# ── Build graph ───────────────────────────────────────────────────────

def build_graph():
    g = StateGraph(ReplisomeState)

    g.add_node("model_turn", node_model_turn)
    g.add_node("human", node_human)
    g.add_node("synthesise", node_synthesise)
    g.add_node("code", node_code)
    g.add_node("review", node_review)

    g.set_entry_point("model_turn")

    g.add_conditional_edges("model_turn", route_after_model, {
        "human": "human",
        "model_turn": "model_turn",
        "synthesise": "synthesise",
    })
    g.add_conditional_edges("human", route_after_human, {
        "model_turn": "model_turn",
        "synthesise": "synthesise",
    })
    g.add_conditional_edges("synthesise", route_after_synth, {
        "model_turn": "model_turn",
        "code": "code",
        END: END,
    })
    g.add_conditional_edges("code", route_after_code, {
        "code": "code",
        "review": "review",
    })
    g.add_conditional_edges("review", route_after_review, {
        "model_turn": "model_turn",
        END: END,
    })

    checkpointer = InMemorySaver()
    return g.compile(checkpointer=checkpointer)


# ── Main ──────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="replisome",
        description="Multi-model council with human-in-the-loop (LangGraph)",
    )
    parser.add_argument("task", help="Task description")
    parser.add_argument("--model", default=[DEFAULT_MODEL], nargs="+",
                        help=f"Model(s) to collaborate (default: {DEFAULT_MODEL})")
    parser.add_argument("--rounds", type=int, default=2, help="Rounds (default: 2)")
    parser.add_argument("--scratchpad", type=str, help="Scratchpad path (resume)")
    parser.add_argument("--timeout", type=int, default=120, help="Per-query timeout (default: 120s)")
    parser.add_argument("--work", action="store_true",
                        help="Enable work mode: models code in git worktrees, CC reviews diffs")
    parser.add_argument("--repo", type=str, default=str(HOME / "germline"),
                        help="Repo for worktrees (default: ~/germline)")

    args = parser.parse_args()
    models = args.model
    task = args.task
    model_label = " + ".join(models)
    work_mode = args.work

    scratchpad = Path(args.scratchpad) if args.scratchpad else HOME / "tmp" / f"replisome-{datetime.now().strftime('%H%M%S')}.md"
    scratchpad.parent.mkdir(parents=True, exist_ok=True)

    mode_label = "discuss + code" if work_mode else "discuss"
    header = f"""# Replisome Session — {datetime.now().strftime('%Y-%m-%d %H:%M')}

**Task:** {task}
**Models:** CC ↔ {model_label}
**Mode:** {mode_label}
**Engine:** LangGraph

---
"""
    scratchpad.write_text(header, encoding="utf-8")

    # Create worktrees if work mode
    worktrees = {}
    if work_mode:
        repo = Path(args.repo)
        print(f"Work mode: creating worktrees in ~/tmp/")
        worktrees = create_worktrees(models, repo)

    print(f"Scratchpad: {scratchpad}")
    print(f"Models: CC ↔ {model_label}")
    print(f"Mode: {mode_label}")
    print(f"Rounds: {args.rounds}")
    print(f"Task: {task}")
    print()

    graph = build_graph()

    initial_state = {
        "task": task,
        "models": models,
        "turns": [{"role": "Claude (CC)", "content": f"**Task:** {task}"}],
        "current_model_idx": 0,
        "current_round": 1,
        "max_rounds": args.rounds,
        "timeout": args.timeout,
        "scratchpad_path": str(scratchpad),
        "needs_human": False,
        "human_question": "",
        "done": False,
        "phase": "discuss",
        "worktrees": worktrees,
        "diffs": {},
    }

    with open(scratchpad, "a", encoding="utf-8") as f:
        f.write(f"\n### Claude (CC)\n\n**Task:** {task}\n")

    config = {"configurable": {"thread_id": scratchpad.stem}}

    try:
        for event in graph.stream(initial_state, config=config):
            pass
    finally:
        if worktrees:
            print("\nWorktree diffs saved in scratchpad.")
            print("To merge: git -C <worktree> diff HEAD | git apply")
            for model, wt in worktrees.items():
                print(f"  {model}: {wt}")

    print(f"\nScratchpad: {scratchpad}")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""replisome — multi-model deliberation with codebase awareness (LangGraph).

Consilium for CLI agents. Models read files and discuss — they don't write.
When the council converges, CC Teams or a single agent executes.

Usage:
  replisome "design question"
  replisome --model haiku gemini "should we refactor X?"
  replisome --model glm gemini "should we refactor X?"
  replisome --model haiku opencode --rounds 3 "review this approach"
"""

import argparse
import contextlib
import os
import pty
import re
import select
import subprocess
import time
from datetime import datetime
from pathlib import Path
from typing import Annotated, TypedDict

from langgraph.checkpoint.memory import InMemorySaver
from langgraph.graph import END, StateGraph

HOME = Path.home()
DEFAULT_MODEL = "glm"

# ── Model dispatch config ──────────────────────────────────────────────

DIRECT_MODELS = {
    "gemini": ["gemini", "-p"],
    "opencode": ["opencode", "--prompt"],
    "codex": [
        "codex",
        "--dangerously-bypass-approvals-and-sandbox",
        "-q",
        "--skip-git-repo-check",
    ],
}
PTY_MODELS = {"opencode", "codex"}
MODEL_TIMEOUT_FLOOR = {"gemini": 120, "opencode": 120, "codex": 120}

_ANSI_RE = re.compile(r"\x1b\[[^a-zA-Z]*[a-zA-Z]|\x1b\][^\x07]*\x07|\x1b[()][^a-zA-Z]*[a-zA-Z]?")
_CTRL_RE = re.compile(r"[\x00-\x09\x0b-\x1f\x7f]")
_TUI_CHROME_RE = re.compile(r"[█▀▄▐░▌▍▎▏╹╸╺╻┃■⬝]+")


# ── PTY wrapper for TUI models ────────────────────────────────────────


def _pty_query(cmd: list[str], timeout: int) -> str:
    """Run a TUI command with a pseudo-TTY and extract clean text."""
    master, slave = pty.openpty()
    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    proc = subprocess.Popen(
        cmd,
        stdin=slave,
        stdout=slave,
        stderr=slave,
        close_fds=True,
        env=env,
        cwd=str(HOME / "germline"),
    )
    os.close(slave)
    output = b""
    deadline = time.time() + timeout
    while time.time() < deadline:
        r, _, _ = select.select([master], [], [], 1)
        if r:
            try:
                chunk = os.read(master, 4096)
                if not chunk:
                    break
                output += chunk
            except OSError:
                break
        if proc.poll() is not None:
            while True:
                r, _, _ = select.select([master], [], [], 0.5)
                if not r:
                    break
                try:
                    chunk = os.read(master, 4096)
                    if not chunk:
                        break
                    output += chunk
                except OSError:
                    break
            break
    with contextlib.suppress(OSError):
        os.close(master)
    if proc.poll() is None:
        proc.kill()

    clean = _ANSI_RE.sub("", output.decode("utf-8", errors="replace"))
    clean = _CTRL_RE.sub("", clean)
    clean = _TUI_CHROME_RE.sub(" ", clean)

    # Extract from streaming "Thinking:" blocks
    thinking_parts = clean.split("Thinking:")
    if len(thinking_parts) > 1:
        last = thinking_parts[-1]
        last = re.sub(r"\d+,\d+\s+\d+%\s+\(\$[\d.]+\)", "", last)
        last = re.sub(r"·\s*[\d.]+s", "", last)
        last = re.sub(r"Build\s+·\s+\S+", "", last)
        last = re.sub(r"~\s*(Reading file|Finding files)\.\.\.", "", last)
        last = re.sub(r'[→✱]\s*\w+\s+"[^"]*"[^)]*\)', "", last)
        last = re.sub(r"[→✱]\s*\w+\s+\S+", "", last)
        last = re.sub(r"\s+", " ", last).strip()
        sentences = [s.strip() for s in last.split(".") if len(s.strip()) > 15]
        if sentences:
            return ". ".join(sentences[-3:]).strip()
        return last[:500] if last else ""

    lines = [s.strip() for s in clean.splitlines() if s.strip() and len(s.strip()) > 3]
    return "\n".join(lines[-10:]).strip() if lines else ""


def query_model(model: str, prompt: str, timeout: int = 120) -> str:
    """Query any model. PTY for TUI apps, direct CLI for some, channel for others."""
    effective_timeout = max(timeout, MODEL_TIMEOUT_FLOOR.get(model, 0))

    if model in PTY_MODELS:
        cmd = [*DIRECT_MODELS.get(model, [model]), prompt]
        try:
            result = _pty_query(cmd, effective_timeout)
            return result if result else f"[{model}: empty response]"
        except Exception as e:
            return f"[{model} error: {e}]"

    env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
    cmd = DIRECT_MODELS.get(model, ["channel", model, "-p"])
    try:
        r = subprocess.run(
            [*cmd, prompt],
            capture_output=True,
            text=True,
            timeout=effective_timeout,
            env=env,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
        return f"[{model} error: {r.stderr.strip() or 'empty'}]"
    except subprocess.TimeoutExpired:
        return f"[{model}: timeout after {effective_timeout}s]"
    except Exception as e:
        return f"[{model} error: {e}]"


# ── Scratchpad ─────────────────────────────────────────────────────────


def scratchpad_text(turns: list[dict]) -> str:
    """Render turns as markdown."""
    lines = []
    for t in turns:
        lines.append(f"\n### {t['role']}\n\n{t['content']}\n")
    return "\n".join(lines)


def model_prompt(scratchpad: str, repo: str) -> str:
    """Build the prompt any model sees."""
    return f"""You are part of a multi-model deliberation council. Your job is to THINK, not act.

Before forming your opinion, READ the relevant files in {repo}. Ground your argument in actual code, not assumptions. Cite file paths and line numbers.

Rules:
- Read before speaking. Check the actual implementation, don't guess.
- Be direct. Disagree if you see a better approach.
- Don't repeat what's been said. Advance the discussion.
- If you need input from the human operator, start with QUESTION:

{scratchpad}

Your turn. Read the code first, then contribute."""


# ── LangGraph state ───────────────────────────────────────────────────


def _append(a: list, b: list) -> list:
    return a + b


class ReplisomeState(TypedDict):
    task: str
    models: list[str]
    turns: Annotated[list[dict], _append]
    current_model_idx: int
    current_round: int
    max_rounds: int
    timeout: int
    repo: str
    scratchpad_path: str
    needs_human: bool
    human_question: str
    done: bool


# ── Graph nodes ───────────────────────────────────────────────────────


def node_model_turn(state: ReplisomeState) -> dict:
    """One model speaks — after reading the code."""
    idx = state["current_model_idx"]
    model = state["models"][idx]
    scratchpad = scratchpad_text(state["turns"])
    prompt = model_prompt(scratchpad, state.get("repo", "~/germline"))

    print(f"  {model}...", end=" ", flush=True)
    response = query_model(model, prompt, timeout=state["timeout"])
    print("done")

    # Save to scratchpad file
    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### {model}\n\n{response}\n")

    # Check for human interrupt
    first_line = response.strip().split("\n")[0] if response.strip() else ""
    wants_human = first_line.startswith("QUESTION:") or first_line.startswith("**QUESTION:**")

    return {
        "turns": [{"role": model, "content": response}],
        "current_model_idx": idx + 1,
        "needs_human": wants_human,
        "human_question": first_line if wants_human else "",
    }


def node_human(state: ReplisomeState) -> dict:
    """Pause for human input."""
    question = state.get("human_question", "")
    print(f"\n  ? {question}")
    try:
        answer = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        answer = "[skipped]"
    if not answer:
        answer = "[skipped]"

    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### Human (Terry)\n\n{answer}\n")

    return {
        "turns": [{"role": "Human (Terry)", "content": answer}],
        "needs_human": False,
        "human_question": "",
    }


def node_synthesise(state: ReplisomeState) -> dict:
    """CC synthesises the round."""
    model_label = " + ".join(state["models"])
    scratchpad = scratchpad_text(state["turns"])

    prompt = f"""You are Claude, collaborating with {model_label}. Read the full scratchpad.
Synthesise this round. Agree, disagree, or advance. Build on the strongest point.
If the group is converging, state the conclusion clearly.
If not, sharpen the disagreement so the next round is productive.

{scratchpad}

Your turn as Claude."""

    print("  CC (sonnet)...", end=" ", flush=True)
    response = query_model("sonnet", prompt, timeout=state["timeout"])
    print("done")

    path = Path(state["scratchpad_path"])
    with open(path, "a", encoding="utf-8") as f:
        f.write(f"\n### Claude (CC)\n\n{response}\n")

    rnd = state["current_round"] + 1
    return {
        "turns": [{"role": "Claude (CC)", "content": response}],
        "current_round": rnd,
        "current_model_idx": 0,
        "done": rnd > state["max_rounds"],
    }


# ── Routing ───────────────────────────────────────────────────────────


def route_after_model(state: ReplisomeState) -> str:
    if state.get("needs_human"):
        return "human"
    if state["current_model_idx"] < len(state["models"]):
        return "model_turn"
    return "synthesise"


def route_after_human(state: ReplisomeState) -> str:
    if state["current_model_idx"] < len(state["models"]):
        return "model_turn"
    return "synthesise"


def route_after_synth(state: ReplisomeState) -> str:
    if state.get("done"):
        return END
    return "model_turn"


# ── Build graph ───────────────────────────────────────────────────────


def build_graph():
    g = StateGraph(ReplisomeState)

    g.add_node("model_turn", node_model_turn)
    g.add_node("human", node_human)
    g.add_node("synthesise", node_synthesise)

    g.set_entry_point("model_turn")

    g.add_conditional_edges(
        "model_turn",
        route_after_model,
        {
            "human": "human",
            "model_turn": "model_turn",
            "synthesise": "synthesise",
        },
    )
    g.add_conditional_edges(
        "human",
        route_after_human,
        {
            "model_turn": "model_turn",
            "synthesise": "synthesise",
        },
    )
    g.add_conditional_edges(
        "synthesise",
        route_after_synth,
        {
            "model_turn": "model_turn",
            END: END,
        },
    )

    checkpointer = InMemorySaver()
    return g.compile(checkpointer=checkpointer)


# ── Main ──────────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="replisome",
        description="Multi-model council with human-in-the-loop (LangGraph)",
    )
    parser.add_argument("task", help="Task description")
    parser.add_argument(
        "--model",
        default=[DEFAULT_MODEL],
        nargs="+",
        help=f"Model(s) to collaborate (default: {DEFAULT_MODEL})",
    )
    parser.add_argument("--rounds", type=int, default=2, help="Rounds (default: 2)")
    parser.add_argument("--scratchpad", type=str, help="Scratchpad path (resume)")
    parser.add_argument(
        "--timeout", type=int, default=120, help="Per-query timeout (default: 120s)"
    )
    parser.add_argument(
        "--repo",
        type=str,
        default=str(HOME / "germline"),
        help="Repo models should read (default: ~/germline)",
    )

    args = parser.parse_args()
    models = args.model
    task = args.task
    repo = args.repo
    model_label = " + ".join(models)

    scratchpad = (
        Path(args.scratchpad)
        if args.scratchpad
        else HOME / "tmp" / f"replisome-{datetime.now().strftime('%H%M%S')}.md"
    )
    scratchpad.parent.mkdir(parents=True, exist_ok=True)

    header = f"""# Replisome Session — {datetime.now().strftime("%Y-%m-%d %H:%M")}

**Task:** {task}
**Models:** CC ↔ {model_label}
**Repo:** {repo}
**Engine:** LangGraph

---
"""
    scratchpad.write_text(header, encoding="utf-8")

    print(f"Scratchpad: {scratchpad}")
    print(f"Models: CC ↔ {model_label}")
    print(f"Rounds: {args.rounds}")
    print(f"Task: {task}")
    print()

    graph = build_graph()

    initial_state = {
        "task": task,
        "models": models,
        "turns": [{"role": "Claude (CC)", "content": f"**Task:** {task}"}],
        "current_model_idx": 0,
        "current_round": 1,
        "max_rounds": args.rounds,
        "timeout": args.timeout,
        "repo": repo,
        "scratchpad_path": str(scratchpad),
        "needs_human": False,
        "human_question": "",
        "done": False,
    }

    with open(scratchpad, "a", encoding="utf-8") as f:
        f.write(f"\n### Claude (CC)\n\n**Task:** {task}\n")

    config = {"configurable": {"thread_id": scratchpad.stem}}

    for _event in graph.stream(initial_state, config=config):
        pass

    print(f"\nScratchpad: {scratchpad}")


if __name__ == "__main__":
    main()

@app.command
def flush() -> None:
    """Warn about dirty repos — atomic commits mean nothing to flush."""
    dirty = []
    for label, path in sorted(DEFAULT_REPOS.items()):
        status = git_status(path)
        if status is None or not status:
            continue
        count = len([line for line in status.splitlines() if line.strip()])
        dirty.append({"repo": label, "count": count, "status": status.splitlines()[:5]})
    if not dirty:
        _ok("cytokinesis flush", {"dirty": [], "clean": True})
        return
    _ok(
        "cytokinesis flush",
        {"dirty": dirty, "clean": False},
        [action("cytokinesis gather", "Re-run gather after committing")],
    )



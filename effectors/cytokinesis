# ── Helpers ──────────────────────────────────────────────────────────────────
def git_status(path: Path) -> str | None:
    """Return git short status, or None if not a repo."""
    try:
        r = subprocess.run(
            ["git", "-C", str(path), "status", "--short"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def now_age() -> tuple[str, int]:
    """Return (label, seconds) for Tonus.md age."""
    try:
        mtime = os.path.getmtime(NOW_MD)
        age = int(time.time() - mtime)
        if age < 900:  # 15 min
            return "fresh", age
        elif age < 3600:
            return "recent", age
        elif age < 86400:
            return "stale", age
        else:
            return "very stale", age
    except FileNotFoundError:
        return "missing", -1


def memory_lines() -> int:
    """Count lines in MEMORY.md."""
    try:
        return sum(1 for _ in open(MEMORY))
    except FileNotFoundError:
        return 0


def skill_gaps() -> list[str]:
    """Skills in receptors/ without a symlink in ~/.claude/skills/. Auto-links them."""
    try:
        a = {f for f in os.listdir(SKILLS) if not f.startswith(".")}
        b = {f for f in os.listdir(claude_skills) if not f.startswith(".")}
        gaps = sorted(a - b)
        for name in gaps:
            os.symlink(os.path.join(SKILLS, name), os.path.join(claude_skills, name))
        return gaps
    except FileNotFoundError:
        return []


def cli_gaps() -> list[str]:
    """Skills declaring cli: in frontmatter where the CLI is missing from PATH."""
    import shutil

    gaps = []
    try:
        for d in Path(SKILLS).iterdir():
            skill_md = d / "SKILL.md"
            if not skill_md.exists():
                continue
            for line in skill_md.read_text().splitlines():
                if line.startswith("cli:"):
                    cli_name = line.split(":", 1)[1].strip()
                    if cli_name and not shutil.which(cli_name):
                        gaps.append(f"{d.name} -> {cli_name}")
                    break
    except Exception:
        pass
    return gaps


def rfts_verify() -> list[dict]:
    """RFTS gate: verify methylation marks still have valid referents.

    Like DNMT1's RFTS domain, which only copies marks when it detects
    ubiquitinated histones at hemimethylated sites. If the substrate is
    gone, the mark shouldn't propagate.

    Checks: file paths mentioned in memory files still exist,
    project references aren't stale, tool names are still valid.
    """
    import shutil

    memory_dir = MEMORY.parent
    stale = []

    for f in sorted(memory_dir.iterdir()):
        if f.name == "MEMORY.md" or f.suffix != ".md":
            continue
        try:
            content = f.read_text(encoding="utf-8")
        except Exception:
            continue

        # QSER1 protection: skip marks tagged protected
        if "protected: true" in content[:500]:
            continue

        issues = []

        # Check file path references (~/path/to/thing or absolute home path)
        # Must have at least 2 path segments to avoid matching skill names like /ecphory
        _home_prefixes = (str(home),)
        _home_re = "|".join(re.escape(p) for p in _home_prefixes)
        for m in re.finditer(rf"[`~]((?:/[\w.-]+){{2,}})|({_home_re}(?:/[\w.-]+){{2,}})", content):
            ref_path = m.group(1) or m.group(2)
            full = Path(ref_path) if ref_path.startswith("/") else home / ref_path.lstrip("/")
            # Skip glob patterns, templates, and generic examples
            if "*" in str(full) or "YYYY" in str(full) or "<" in str(full):
                continue
            if not full.exists() and not full.with_suffix(".md").exists():
                issues.append(f"path: {ref_path}")

        # Check CLI tool references (backtick-wrapped single words that look like commands)
        for m in re.finditer(r"`([a-z][\w-]{2,20})`", content):
            cmd = m.group(1)
            # Skip common non-command words
            if cmd in (
                "true",
                "false",
                "none",
                "null",
                "done",
                "info",
                "type",
                "hits",
                "last",
                "name",
                "date",
                "feedback",
                "finding",
                "project",
                "user",
                "reference",
                "memory",
                "debug",
                "plan",
                "build",
                "evaluate",
                "monitor",
                "research",
                "learn",
                "reflect",
                "decide",
                "negotiate",
                "communicate",
                "brainstorm",
                "delegate",
                "unstuck",
                "protected",
            ):
                continue
            # Only flag if it looks like it was a CLI tool (in a command context)
            if (
                "search" in content[max(0, m.start() - 20) : m.start()]
                or "run" in content[max(0, m.start() - 20) : m.start()]
                or cmd.endswith("-scan")
                or cmd.endswith("-check")
            ) and not shutil.which(cmd):
                issues.append(f"cli missing: {cmd}")

        if issues:
            stale.append({"file": f.name, "issues": issues[:3]})  # cap per file

    return stale


def dep_check() -> list[str]:
    """Run proteostasis, return warnings."""
    try:
        r = subprocess.run(
            ["proteostasis"],
            capture_output=True,
            text=True,
            timeout=5,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip().splitlines()
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return []


def peira_status() -> str | None:
    """Return peira active experiment info, or None."""
    try:
        r = subprocess.run(
            ["peira", "status"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return None


# ── Gather ───────────────────────────────────────────────────────────────────
def latest_session_id() -> str | None:
    """Get the most recent session ID from engram."""
    try:
        r = subprocess.run(
            ["engram", "today"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if r.returncode != 0:
            return None
        # Parse last line matching session pattern: [id] N prompts (time) - Model
        for line in reversed(r.stdout.splitlines()):
            m = re.search(r"\[([a-f0-9]+)\]", line)
            if m:
                return m.group(1)
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return None


def run_reflect(session_id: str) -> tuple[list[dict], dict]:
    """Run reflection scan, return (parsed candidates, usage stats)."""
    usage = {"input_tokens": 0, "output_tokens": 0}
    try:
        r = subprocess.run(
            ["engram", "search", ".", "--session", session_id, "--json"],
            capture_output=True,
            text=True,
            timeout=30,
        )
        if r.returncode != 0 or not r.stdout.strip():
            return [], usage
        messages = json.loads(r.stdout)
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError):
        return [], usage

    if not messages:
        return [], usage

    transcript_lines = []
    for msg in messages:
        role = msg.get("role", "?")
        snippet = msg.get("snippet", "").strip()
        time_str = msg.get("time", "")
        if snippet:
            if role != "you" and len(snippet) > 500:
                snippet = snippet[:500] + "..."
            transcript_lines.append(f"[{time_str}] {role}: {snippet}")

    transcript = "\n".join(transcript_lines)
    prompt = REFLECT_PROMPT + transcript
    usage["input_tokens"] = len(prompt) // 4  # rough estimate

    try:
        r = subprocess.run(
            ["synthase", "--model", "glm", prompt],
            capture_output=True,
            text=True,
            timeout=15,
            env={k: v for k, v in os.environ.items() if k != "CLAUDECODE"},
        )
        if r.returncode != 0:
            return [], usage
        result = r.stdout.strip()
        usage["output_tokens"] = len(result) // 4
    except Exception:
        return [], usage

    findings = []
    current = {}
    for line in result.splitlines():
        line = line.strip()
        if line == "---":
            if current:
                findings.append(current)
            current = {}
        elif ":" in line:
            key, _, val = line.partition(":")
            key = key.strip().lower()
            val = val.strip()
            if key in ("category", "quote", "lesson", "memory_type"):
                current[key] = val
    if current:
        findings.append(current)
    return findings, usage


@app.command
def gather(
    mode: Literal["full", "fast"] = "full",
    *,
    semantic: Annotated[bool, Parameter(name=["-s", "--semantic"])] = False,
    repos: Annotated[str | None, Parameter(name=["--repos"])] = None,
) -> None:
    """Run all deterministic pre-wrap checks + reflection scan."""
    results = {
        "repos": {},
        "skills": {"gaps": []},
        "memory": {"lines": 0, "limit": MEMORY_LIMIT},
        "now": {"age_label": "", "age_seconds": 0},
        "deps": [],
        "peira": None,
        "reflect": [],
        "rfts": [],
    }

    # Repos
    all_repos = dict(DEFAULT_REPOS)
    if repos:
        for r in repos.split(","):
            r = r.strip()
            p = Path(r).expanduser()
            all_repos[p.name] = p

    for label, path in sorted(all_repos.items()):
        status = git_status(path)
        if status is None:
            results["repos"][label] = {"clean": None, "status": "unavailable"}
        elif status:
            results["repos"][label] = {"clean": False, "status": status}
        else:
            results["repos"][label] = {"clean": True, "status": ""}

    # Skills
    results["skills"]["gaps"] = skill_gaps()
    results["skills"]["cli_gaps"] = cli_gaps()

    # Memory
    lines = memory_lines()
    results["memory"]["lines"] = lines

    # Tonus
    label, secs = now_age()
    results["now"]["age_label"] = label
    results["now"]["age_seconds"] = secs

    # RFTS gate + Deps, Peira, Reflect, Methylation — parallelize all slow checks
    import concurrent.futures

    fast_mode = mode == "fast"

    with concurrent.futures.ThreadPoolExecutor(max_workers=5) as pool:
        rfts_fut = pool.submit(rfts_verify)
        deps_fut = pool.submit(dep_check)
        peira_fut = pool.submit(peira_status)
        # LLM calls — skip in fast mode
        if not fast_mode:
            sid = latest_session_id()
            reflect_fut = pool.submit(run_reflect, sid) if sid else None
            methyl_fut = pool.submit(run_methylation_audit)
        else:
            sid = None
            reflect_fut = None
            methyl_fut = None

        _futures = [
            ("rfts", rfts_fut, "rfts", []),
            ("deps", deps_fut, "deps", []),
            ("peira", peira_fut, "peira", None),
        ]
        if methyl_fut:
            _futures.append(("methylation", methyl_fut, "methylation", {}))
        for _name, fut, key, default in _futures:
            try:
                results[key] = fut.result(timeout=10)
            except (concurrent.futures.TimeoutError, Exception):
                results[key] = default

        if reflect_fut:
            try:
                candidates, reflect_usage = reflect_fut.result(timeout=20)
                results["reflect"] = candidates
                results["reflect_session"] = sid
                results["reflect_usage"] = reflect_usage
            except (concurrent.futures.TimeoutError, Exception):
                results["reflect"] = []

    # --- Phase 2: wait for LLM calls, append results ---
    if methyl_fut:
        try:
            results["methylation"] = methyl_fut.result(timeout=20)
        except (concurrent.futures.TimeoutError, Exception):
            results["methylation"] = {}
    if reflect_fut:
        try:
            candidates, reflect_usage = reflect_fut.result(timeout=20)
            results["reflect"] = candidates
            results["reflect_session"] = sid
            results["reflect_usage"] = reflect_usage
        except (concurrent.futures.TimeoutError, Exception):
            results["reflect"] = []

    # Hard gates — deterministic where possible, PENDING where LLM judgment needed
    gates = {}
    chromatin_dir = Path.home() / "epigenome" / "chromatin"
    epigenome_dir = Path.home() / "epigenome"
    CHROMATIN_DIR = chromatin_dir
    EPIGENOME_DIR = epigenome_dir

    # Gate 1: Publish — check if secretome/ was modified in last 4 hours
    secretome = CHROMATIN_DIR / "secretome"
    recent_posts = []
    if secretome.is_dir():
        cutoff = time.time() - 4 * 3600
        for post_file in secretome.glob("*.md"):
            if post_file.stat().st_mtime > cutoff:
                recent_posts.append(post_file.stem)
    if recent_posts:
        gates["publish_check"] = f"DONE — published: {', '.join(recent_posts)}"
    else:
        gates["publish_check"] = (
            "PENDING — no posts published this session. Scan for publishable insights. If none, state explicitly."
        )

    # Gate 2: Corrections — check if feedback_*.md was modified in last 4 hours
    marks_dir = EPIGENOME_DIR / "marks"
    recent_feedback = []
    if marks_dir.is_dir():
        cutoff = time.time() - 4 * 3600
        for mark_file in marks_dir.glob("feedback_*.md"):
            if mark_file.stat().st_mtime > cutoff:
                recent_feedback.append(mark_file.stem)
    if recent_feedback:
        gates["corrections_filed"] = (
            f"DONE — filed {len(recent_feedback)}: {', '.join(recent_feedback[:5])}"
        )
    else:
        gates["corrections_filed"] = (
            "PENDING — no feedback memories filed this session. Scan for corrections from Terry."
        )

    # Gate 3: Tonus — check freshness (already computed above)
    if secs < 1800:  # updated in last 30 min
        gates["tonus_updated"] = "DONE — updated within 30 min"
    else:
        gates["tonus_updated"] = f"PENDING — Tonus is {label} ({secs // 60}m old). Update now."

    # Gate 4: Process audit — always requires LLM judgment
    gates["process_audit"] = (
        "PENDING — 5 questions: repeated patterns, misallocated work, lazy avoidance, branch discipline, best practices."
    )

    # Gate 5: Repos flushed — check if any dirty
    dirty_repos = [
        name
        for name, info in results["repos"].items()
        if not info.get("clean") and info.get("clean") is not None
    ]
    if dirty_repos:
        gates["repos_flushed"] = (
            f"WARNING — dirty: {', '.join(dirty_repos)}. Commit atomically with meaningful messages."
        )
    else:
        gates["repos_flushed"] = "DONE — all repos clean"

    # Gate 6: Daily note — check if today's note has a completed session entry
    today_str = datetime.now().strftime("%Y-%m-%d")
    daily_file = DAILY_DIR / f"{today_str}.md"
    if daily_file.exists():
        daily_content = daily_file.read_text(encoding="utf-8")
        if "[LLM:" in daily_content:
            gates["daily_note"] = "PENDING — daily note has unfilled template. Run `cytokinesis daily` and fill sections."
        else:
            gates["daily_note"] = "DONE — daily note written"
    else:
        gates["daily_note"] = "PENDING — no daily note for today. Run `cytokinesis daily`."

    # Gate 7: Memory budget — MEMORY.md must stay under limit
    mem_lines = results.get("memory", {}).get("lines", 0)
    mem_limit = results.get("memory", {}).get("limit", 150)
    if mem_lines >= mem_limit:
        gates["memory_budget"] = (
            f"PENDING — MEMORY.md at {mem_lines}/{mem_limit} lines. Downregulate stale entries."
        )
    else:
        gates["memory_budget"] = f"DONE — {mem_lines}/{mem_limit} lines"

    results["gates"] = gates

    # Output: wrap in porin envelope
    if not semantic:
        # Summarize rfts for token efficiency — full list only with --semantic
        raw_rfts = results.get("rfts", [])
        sorted_rfts = sorted(raw_rfts, key=lambda r: len(r.get("issues", [])), reverse=True)
        results["rfts"] = {
            "count": len(raw_rfts),
            "top": [{"file": r["file"], "issues": len(r["issues"])} for r in sorted_rfts[:5]],
        }

    _ok("cytokinesis gather", results)


# ── Archive ──────────────────────────────────────────────────────────────────
@app.command
def archive() -> None:
    """Move completed [x] items from Praxis.md to Praxis Archive.md."""
    if not praxis.exists():
        sys.exit(
            _err(
                "cytokinesis archive",
                "No Praxis.md found",
                "FILE_NOT_FOUND",
                "Create Praxis.md or check path",
            )
        )

    lines = praxis.read_text(encoding="utf-8").splitlines(keepends=True)
    today = datetime.now().strftime("%Y-%m-%d")
    month_header = datetime.now().strftime("%B %Y")  # e.g. "March 2026"

    completed = []
    remaining = []
    skip_children = False

    for line in lines:
        stripped = line.rstrip()

        # Detect completed top-level items: "- [x]"
        if re.match(r"^- \[x\]", stripped):
            # Add done tag if not already present
            entry = stripped
            if "done:" not in entry:
                entry += f" `done:{today}`"
            completed.append(entry)
            skip_children = True
            continue

        # Skip indented children of completed items
        if skip_children:
            if re.match(r"^  +- ", stripped):
                # Child of completed item — skip (don't archive sub-items)
                continue
            else:
                skip_children = False

        remaining.append(line)

    if not completed:
        _ok("cytokinesis archive", {"archived": 0, "items": []})
        return

    # Read archive
    archive_text = praxis_archive.read_text(encoding="utf-8") if praxis_archive.exists() else ""

    # Find or create month section
    month_pattern = f"## {month_header}"
    if month_pattern in archive_text:
        # Insert after the month header
        idx = archive_text.index(month_pattern) + len(month_pattern)
        # Find end of line
        nl = archive_text.index("\n", idx)
        insert_text = "\n" + "\n".join(completed)
        archive_text = archive_text[:nl] + insert_text + archive_text[nl:]
    else:
        # Add new month section after the intro paragraph
        # Find the first "## " header to insert before it
        first_section = archive_text.find("\n## ")
        if first_section >= 0:
            insert_text = f"\n{month_pattern}\n\n" + "\n".join(completed) + "\n"
            archive_text = (
                archive_text[:first_section] + insert_text + archive_text[first_section:]
            )
        else:
            archive_text += f"\n{month_pattern}\n\n" + "\n".join(completed) + "\n"

    # Write back
    praxis.write_text("".join(remaining), encoding="utf-8")
    praxis_archive.write_text(archive_text, encoding="utf-8")

    _ok("cytokinesis archive", {"archived": len(completed), "items": completed})


# ── Daily ────────────────────────────────────────────────────────────────────
def _since_flag(hours: int = 2) -> str:
    """Return ISO timestamp for N hours ago (session window approximation)."""
    from datetime import timedelta

    return (datetime.now() - timedelta(hours=hours)).strftime("%Y-%m-%dT%H:%M:%S")


def _gather_filed(hours: int = 2) -> list[str]:
    """List memory files created/modified in the last N hours."""
    mem_dir = (
        home
        / ".claude"
        / "projects"
        / ("-" + str(germline).lstrip("/").replace("/", "-"))
        / "memory"
    )
    since = _since_flag(hours)
    try:
        # Committed today
        r = subprocess.run(
            [
                "git",
                "log",
                "--since",
                since,
                "--diff-filter=AM",
                "--name-only",
                "--pretty=format:",
            ],
            capture_output=True,
            text=True,
            timeout=10,
            cwd=mem_dir,
        )
        files = {f for f in r.stdout.strip().splitlines() if f and not f.startswith("MEMORY")}
        # Also uncommitted
        r2 = subprocess.run(
            ["git", "diff", "--name-only", "HEAD"],
            capture_output=True,
            text=True,
            timeout=10,
            cwd=mem_dir,
        )
        files |= {f for f in r2.stdout.strip().splitlines() if f and not f.startswith("MEMORY")}
        r3 = subprocess.run(
            ["git", "ls-files", "--others", "--exclude-standard"],
            capture_output=True,
            text=True,
            timeout=10,
            cwd=mem_dir,
        )
        files |= {f for f in r3.stdout.strip().splitlines() if f and not f.startswith("MEMORY")}
        return sorted(f"memory/{f}" for f in files) if files else []
    except Exception:
        return []


def _gather_mechanised(hours: int = 2) -> list[str]:
    """List skills, hooks, and genome modified in the last N hours."""
    since = _since_flag(hours)
    hits = set()
    for repo_path in [germline]:
        try:
            # Committed today
            r = subprocess.run(
                [
                    "git",
                    "log",
                    "--since",
                    since,
                    "--diff-filter=AM",
                    "--name-only",
                    "--pretty=format:",
                ],
                capture_output=True,
                text=True,
                timeout=10,
                cwd=repo_path,
            )
            for f in r.stdout.strip().splitlines():
                if any(
                    k in f
                    for k in ["SKILL.md", "genome.md", "synapse.py", "axon.py", "dendrite.py"]
                ):
                    hits.add(f)
            # Uncommitted
            r2 = subprocess.run(
                ["git", "diff", "--name-only", "HEAD"],
                capture_output=True,
                text=True,
                timeout=10,
                cwd=repo_path,
            )
            for f in r2.stdout.strip().splitlines():
                if any(
                    k in f
                    for k in ["SKILL.md", "genome.md", "synapse.py", "axon.py", "dendrite.py"]
                ):
                    hits.add(f)
        except Exception:
            pass
    return sorted(hits)


def _gather_published() -> list[str]:
    """Check session log for published artifacts (best-effort)."""
    # Look for recent emit_tweet/emit_spark in logs
    log_dir = home / "logs"
    published = []
    try:
        for log_name in ["cron-exocytosis.log"]:
            log_path = log_dir / log_name
            if log_path.exists():
                lines = log_path.read_text().splitlines()[-20:]
                today = datetime.now().strftime("%Y-%m-%d")
                for line in lines:
                    if today in line and ("tweet" in line.lower() or "published" in line.lower()):
                        published.append(line.strip()[:120])
    except Exception:
        pass
    return published


@app.command
def daily(
    title: str | None = None,
    *,
    hours: Annotated[int, Parameter(name=["--hours"])] = 2,
) -> None:
    """Append pre-filled session log to today's daily note."""
    today = datetime.now().strftime("%Y-%m-%d")
    weekday = datetime.now().strftime("%A")
    datetime.now().strftime("%H:%M")
    daily_path = DAILY_DIR / f"{today}.md"

    session_title = title if title else "Session"

    # Gather deterministic sections
    filed = _gather_filed(hours=hours)
    mechanised = _gather_mechanised(hours=hours)
    published = _gather_published()
    residual_n = len(filed)

    filed_str = "\n".join(f"- `{f}`" for f in filed) if filed else "- none"
    mech_str = "\n".join(f"- `{f}`" for f in mechanised) if mechanised else "- none"
    pub_str = "\n".join(f"- {p}" for p in published) if published else "- none"

    template = f"""
## Session: {session_title}

### Outcomes
- [LLM: what was done — outcomes, not process]

### Filed
{filed_str}

### Published
{pub_str}

### Publishable?
[LLM: did this session produce a publishable insight? If yes, draft and publish now. If no, state what was checked and why nothing qualifies.]

### Mechanised
{mech_str}

### Parked
- [LLM: unfinished items with context to resume, or "none"]

### Residual
filed={residual_n}, skipped=?

### Arc
[LLM: 1-2 sentence session narrative]
"""

    if daily_path.exists():
        content = daily_path.read_text(encoding="utf-8")
        content += template
    else:
        header = f"# {today} — {weekday}\n"
        content = header + template

    daily_path.write_text(content, encoding="utf-8")
    _ok(
        "cytokinesis daily",
        {
            "path": str(daily_path),
            "title": session_title,
            "filed": len(filed),
            "mechanised": len(mechanised),
            "published": len(published),
        },
    )


# ── Methylation: genome audit ────────────────────────────────────────────────

METHYLATION_PROMPT = """You are auditing a system's constitution (genome.md) to find rules that are now REDUNDANT because they're enforced elsewhere.

For each rule in the genome, check if it's already enforced by:
- A hook (synapse.py, axon.py, dendrite.py)
- A skill (SKILL.md files)
- A lint rule or pre-commit check
- A CLI tool

Only flag rules that are CLEARLY redundant — fully enforced elsewhere with no judgment gap.
Do NOT flag rules that require LLM judgment (design principles, meta-rules, behavioral guidance).

For each candidate, output:
---
RULE: <the rule, first 80 chars>
ENFORCED_BY: <what enforces it now>
VERDICT: DEMOTE (move to reference) | TRIM (remove, fully redundant) | KEEP (still needs to be in prompt)
---

Be conservative. When in doubt, KEEP.

GENOME:
{genome}

HOOKS (function names):
{hooks}

SKILLS:
{skills}
"""


def run_methylation_audit():
    """Scan genome for rules now enforced by hooks/skills. Returns candidates."""
    genome_path = germline / "genome.md"
    if not genome_path.exists():
        return []

    genome_text = genome_path.read_text(encoding="utf-8")

    # Gather hook function names
    hook_funcs = []
    for hook_file in ["synapse.py", "axon.py", "dendrite.py"]:
        hook_path = germline / "membrane" / "cytoskeleton" / hook_file
        if hook_path.exists():
            for line in hook_path.read_text().splitlines():
                if (
                    line.startswith("def mod_")
                    or line.startswith("def check_")
                    or line.startswith("def guard_")
                ):
                    hook_funcs.append(f"{hook_file}:{line.strip()}")

    # Gather skill names
    skill_names = []
    skill_dir = germline / "membrane" / "receptors"
    if skill_dir.exists():
        for d in sorted(skill_dir.iterdir()):
            if d.is_dir() and (d / "SKILL.md").exists():
                skill_names.append(d.name)

    prompt = METHYLATION_PROMPT.format(
        genome=genome_text[:8000],  # cap to keep haiku cost low
        hooks="\n".join(hook_funcs[:30]),
        skills=", ".join(skill_names[:40]),
    )

    try:
        result = subprocess.run(
            ["synthase", "--model", "glm", prompt],
            capture_output=True,
            text=True,
            timeout=15,
            env={k: v for k, v in os.environ.items() if k != "CLAUDECODE"},
        )
        if result.returncode != 0:
            return []

        # Parse candidates
        candidates = []
        current = {}
        for line in result.stdout.splitlines():
            line = line.strip()
            if line == "---":
                if current and current.get("verdict") in ("DEMOTE", "TRIM"):
                    candidates.append(current)
                current = {}
            elif line.startswith("RULE:"):
                current["rule"] = line[5:].strip()
            elif line.startswith("ENFORCED_BY:"):
                current["enforced_by"] = line[12:].strip()
            elif line.startswith("VERDICT:"):
                current["verdict"] = line[8:].strip().split()[0]
        if current and current.get("verdict") in ("DEMOTE", "TRIM"):
            candidates.append(current)
        return candidates
    except Exception:
        return []


# ── Reflect ─────────────────────────────────────────────────────────────────
REFLECT_PROMPT = """You are scanning a conversation transcript for learning opportunities.
The transcript is between Terry (user) and Claude (assistant).

Find instances of these six categories:

1. **TASTE CALIBRATION** — Terry corrected Claude's judgment, approach, or framing.
   Signals: "no not that", "you sure?", repeated pushback, steering toward a different solution.

2. **POSITIVE FEEDBACK** — Terry confirmed a non-obvious approach (often quiet signals).
   Signals: "yes exactly", "perfect", accepting an unusual choice, building on it.

3. **DISCOVERY** — Something surprising was learned about a system, tool, or process.
   Must be non-obvious and useful for future sessions.

4. **ARCHITECTURE DECISION** — A design choice with reasoning worth recording.
   Not the code, but WHY this approach over alternatives.

5. **PROCESS GAP** — Wrong order, wrong tool, or fumbled approach when the right one
   was available. "Should have done X first", trying three approaches before finding
   the right one, not knowing a tool existed. Workflow lessons.

6. **ASSUMPTION VIOLATION** — Something believed true that turned out false.
   "I thought we already implemented X", "I assumed Y existed". Gaps between
   mental model and reality.

7. **ORGANISM IMPROVEMENT** — Something that happened in this session that reveals
   how vivesca (the system itself) could be stronger. Examples:
   - A manual step that should be a hook or skill
   - A rule in genome.md that Claude didn't follow (needs enforcement, not just instruction)
   - A skill that didn't trigger when it should have (bad description)
   - A tool that's missing (had to work around its absence)
   - A pattern that recurred across the session (candidate for methylation)
   The test: "if this session replayed tomorrow, what would make it go better?"

8. **EMERGING NEED** — A capability that doesn't exist yet but the session revealed
   it's needed. Not "this broke" (process_gap) or "this should be a hook" (organism_improvement),
   but "we needed something that doesn't exist." The organism grows toward what's
   actually needed, not what looks architecturally clean.

Selection criteria (from memory consolidation biology):
- **Novelty** — first time this came up. New information worth encoding.
- **Prediction error** — something believed true turned out false, or Claude was corrected.
  These are the HIGHEST priority — the organism learns most from corrections.
- **Emotional weight** — Terry pushed back strongly, repeated insistence, or strong reaction.
  Intensity signals importance.
- **Pattern completion** — connects to an existing memory or reinforces a known principle.
  Update existing memory, don't create new.
- **Routine/expected** — SKIP. Already known, unsurprising, no new information.

For each finding, output EXACTLY this format (one per finding):

---
CATEGORY: <one of: taste_calibration, positive_feedback, discovery, architecture_decision, process_gap, assumption_violation, organism_improvement, emerging_need>
QUOTE: <the key user message or exchange, verbatim, max 2 lines>
LESSON: <1-2 sentences: what should be remembered and why>
MEMORY_TYPE: <feedback, finding, or project>
CONSOLIDATION: <novelty, prediction_error, emotional_weight, or pattern_completion>
---

If nothing found for a category, skip it. Quality over quantity — only include
findings that would genuinely help a future session. No cap — surface everything real.

TRANSCRIPT:
"""


@app.command
def reflect(
    session: str,
    *,
    json_output: Annotated[bool, Parameter(name=["--json"])] = False,
) -> None:
    """Scan session transcript for reflection candidates."""
    findings, _usage = run_reflect(session)

    if not findings:
        _ok("cytokinesis reflect", {"session": session, "findings": [], "count": 0})
        return

    _ok(
        "cytokinesis reflect",
        {"session": session, "findings": findings, "count": len(findings)},
    )



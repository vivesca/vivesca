def _ok(command: str, result: dict[str, Any], next_actions: list[dict] | None = None) -> None:
    """Emit success envelope to stdout."""
    emit_ok(command, result, next_actions)


def _err(
    command: str,
    message: str,
    code: str,
    fix: str,
    next_actions: list[dict] | None = None,
    exit_code: int = 1,
) -> int:
    """Emit error envelope to stdout, return exit code for sys.exit()."""
    emit_err(command, message, code, fix, next_actions)
    return exit_code



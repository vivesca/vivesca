@app.command
def verify() -> None:
    """Re-check all gates deterministically. Reports DONE/PENDING for each."""
    gates = {}
    cutoff = time.time() - 4 * 3600
    chromatin_dir = Path.home() / "epigenome" / "chromatin"
    epigenome_dir = Path.home() / "epigenome"

    # Publish
    secretome = chromatin_dir / "secretome"
    recent_posts = []
    if secretome.is_dir():
        for post_file in secretome.glob("*.md"):
            if post_file.stat().st_mtime > cutoff:
                recent_posts.append(post_file.stem)
    gates["publish_check"] = f"DONE ({len(recent_posts)} posts)" if recent_posts else "PENDING"

    # Corrections
    marks_dir = epigenome_dir / "marks"
    recent_fb = (
        sum(
            1
            for mark_file in marks_dir.glob("feedback_*.md")
            if mark_file.stat().st_mtime > cutoff
        )
        if marks_dir.is_dir()
        else 0
    )
    gates["corrections_filed"] = f"DONE ({recent_fb} filed)" if recent_fb else "PENDING"

    # Tonus
    _, secs = now_age()
    gates["tonus_updated"] = "DONE" if secs < 1800 else f"PENDING ({secs // 60}m stale)"

    # Repos
    dirty = []
    for label, path in sorted(DEFAULT_REPOS.items()):
        status = git_status(path)
        if status:
            dirty.append(label)
    gates["repos_flushed"] = "DONE" if not dirty else f"PENDING ({', '.join(dirty)})"

    # Process audit — can't verify deterministically, trust CC
    gates["process_audit"] = "TRUST — requires LLM judgment"

    # Daily note
    today_str = datetime.now().strftime("%Y-%m-%d")
    daily_file = DAILY_DIR / f"{today_str}.md"
    if daily_file.exists():
        daily_content = daily_file.read_text(encoding="utf-8")
        if "[LLM:" in daily_content:
            gates["daily_note"] = "PENDING — unfilled template"
        else:
            gates["daily_note"] = "DONE"
    else:
        gates["daily_note"] = "PENDING — no daily note"

    # Memory budget
    memory_md = Path.home() / "epigenome" / "marks" / "MEMORY.md"
    mem_lines = len(memory_md.read_text().splitlines()) if memory_md.exists() else 0
    mem_limit = 150
    if mem_lines >= mem_limit:
        gates["memory_budget"] = f"PENDING — {mem_lines}/{mem_limit} lines"
    else:
        gates["memory_budget"] = f"DONE — {mem_lines}/{mem_limit}"

    all_done = all("DONE" in v or "TRUST" in v for v in gates.values())
    _ok("cytokinesis verify", {"gates": gates, "all_passed": all_done})
    if not all_done:
        sys.exit(1)



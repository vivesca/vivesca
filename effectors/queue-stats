"""queue-stats — Summary statistics for the golem task queue.

Reads golem-queue.md for pending/done/failed counts and tasks per provider.
Reads golem.jsonl for historical durations to estimate completion time.

Usage:
    queue-stats              # Show full stats
    queue-stats --no-color   # No ANSI colors
    queue-stats --json       # Machine-readable JSON output
"""
from __future__ import annotations

import json
import re
import sys
from collections import defaultdict
from pathlib import Path
from datetime import datetime, timezone

# Paths
VIVESCA_DIR = Path.home() / ".local" / "share" / "vivesca"
JSONL_PATH = VIVESCA_DIR / "golem.jsonl"
QUEUE_PATH = Path.home() / "germline" / "loci" / "golem-queue.md"

# ANSI
GREEN = "\033[32m"
RED = "\033[31m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"


def parse_queue(queue_path: Path) -> dict:
    """Parse golem-queue.md, return counts and per-provider breakdown.

    Returns dict with keys:
        pending, done, failed, total,
        providers: {name: {"pending": n, "done": n, "failed": n, "total": n}},
        sections: {section_name: {"pending": n, "done": n, "failed": n}}
    """
    result = {
        "pending": 0,
        "done": 0,
        "failed": 0,
        "total": 0,
        "providers": defaultdict(lambda: {"pending": 0, "done": 0, "failed": 0, "total": 0}),
        "sections": {},
    }

    if not queue_path.exists():
        return result

    current_section = "(root)"
    section_counts: dict[str, dict] = {}

    for line in queue_path.read_text().splitlines():
        # Track sections (### and #### headers)
        sec_match = re.match(r'^#{2,4}\s+(.+)', line)
        if sec_match:
            current_section = sec_match.group(1).strip()
            if current_section not in section_counts:
                section_counts[current_section] = {"pending": 0, "done": 0, "failed": 0}
            continue

        # Parse task lines
        m = re.match(r'^- \[( |x|!)\] `([^`]+)`', line)
        if not m:
            continue

        status_char = m.group(1)
        command = m.group(2)

        if status_char == ' ':
            status = "pending"
        elif status_char == 'x':
            status = "done"
        else:  # !
            status = "failed"

        result[status] += 1
        result["total"] += 1

        # Track section
        if current_section not in section_counts:
            section_counts[current_section] = {"pending": 0, "done": 0, "failed": 0}
        section_counts[current_section][status] += 1

        # Extract provider from command
        prov_match = re.search(r'--provider\s+(\w+)', command)
        provider = prov_match.group(1) if prov_match else "unknown"

        result["providers"][provider][status] += 1
        result["providers"][provider]["total"] += 1

    result["sections"] = section_counts
    return result


def load_jsonl(path: Path) -> list[dict]:
    """Parse golem.jsonl, return list of record dicts."""
    if not path.exists():
        return []
    records = []
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            records.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return records


def compute_avg_durations(records: list[dict]) -> dict[str, float]:
    """Compute average duration per provider from JSONL records."""
    durations: dict[str, list[float]] = defaultdict(list)
    for r in records:
        provider = r.get("provider", "unknown")
        dur = r.get("duration")
        if dur is not None and isinstance(dur, (int, float)):
            durations[provider].append(float(dur))
    return {
        provider: sum(ds) / len(ds) if ds else 0.0
        for provider, ds in durations.items()
    }


def estimate_completion(queue_data: dict, avg_durations: dict[str, float], concurrency: dict[str, int] | None = None) -> str:
    """Estimate time to complete all pending+failed tasks.

    Uses historical avg duration per provider and assumes concurrent execution.
    Default concurrency: zhipu=4, infini=6, volcano=8 (from queue header).
    """
    if concurrency is None:
        concurrency = {"zhipu": 4, "infini": 6, "volcano": 8}

    pending_per_provider: dict[str, int] = {}
    for provider, counts in queue_data["providers"].items():
        n_pending = counts["pending"] + counts["failed"]
        if n_pending > 0:
            pending_per_provider[provider] = n_pending

    if not pending_per_provider:
        return "No pending tasks."

    # For each provider: time = ceil(tasks / concurrency) * avg_duration
    total_seconds = 0.0
    details: list[str] = []

    for provider in sorted(pending_per_provider):
        n = pending_per_provider[provider]
        avg_dur = avg_durations.get(provider, 0)
        conc = concurrency.get(provider, 1)

        if avg_dur <= 0:
            details.append(f"{provider}: {n} tasks (no duration data)")
            continue

        batches = -(-n // conc)  # ceil division
        est_seconds = batches * avg_dur
        total_seconds = max(total_seconds, est_seconds)  # parallel = max wall time
        details.append(f"{provider}: {n} tasks, ~{format_duration(est_seconds)} est")

    wall_time = format_duration(total_seconds)
    return f"{wall_time} (parallel: {'; '.join(details)})"


def format_duration(seconds: float) -> str:
    """Format seconds into human-readable duration string."""
    if seconds <= 0:
        return "0m"
    hours = int(seconds // 3600)
    minutes = int((seconds % 3600) // 60)
    if hours > 0:
        return f"{hours}h {minutes}m"
    return f"{minutes}m"


def print_stats(queue_path: Path = QUEUE_PATH, jsonl_path: Path = JSONL_PATH,
                use_color: bool = True, json_output: bool = False) -> int:
    """Print queue statistics."""
    queue_data = parse_queue(queue_path)
    records = load_jsonl(jsonl_path)
    avg_durations = compute_avg_durations(records)
    est = estimate_completion(queue_data, avg_durations)

    if json_output:
        output = {
            "pending": queue_data["pending"],
            "done": queue_data["done"],
            "failed": queue_data["failed"],
            "total": queue_data["total"],
            "providers": dict(queue_data["providers"]),
            "sections": queue_data["sections"],
            "estimated_completion": est,
            "avg_durations_sec": avg_durations,
        }
        print(json.dumps(output, indent=2))
        return 0

    # Color helpers
    g = GREEN if use_color else ""
    r = RED if use_color else ""
    y = YELLOW if use_color else ""
    c = CYAN if use_color else ""
    b = BOLD if use_color else ""
    d = DIM if use_color else ""
    rst = RESET if use_color else ""

    # 1. Overall status
    print(f"\n{b}Queue Overview{rst}")
    print(f"  Pending: {c}{queue_data['pending']}{rst}  "
          f"Done: {g}{queue_data['done']}{rst}  "
          f"Failed: {r}{queue_data['failed']}{rst}  "
          f"Total: {b}{queue_data['total']}{rst}")

    pct_done = (queue_data['done'] / queue_data['total'] * 100) if queue_data['total'] else 0
    bar_width = 30
    filled = int(pct_done / 100 * bar_width)
    bar = f"  [{g}{'=' * filled}{rst}{'-' * (bar_width - filled)}] {pct_done:.1f}% done"
    print(bar)

    # 2. Tasks per provider
    print(f"\n{b}Tasks per Provider{rst}")
    header = f"  {'Provider':<10} {'Pending':>7} {'Done':>7} {'Failed':>7} {'Total':>7} {'AvgDur':>8}"
    sep = "  " + "-" * 50
    print(header)
    print(sep)

    for provider in sorted(queue_data["providers"]):
        counts = queue_data["providers"][provider]
        avg_dur = avg_durations.get(provider, 0)
        avg_str = f"{avg_dur:.0f}s" if avg_dur > 0 else "-"

        p_str = f"{c}{counts['pending']}{rst}" if use_color else str(counts["pending"])
        d_str = f"{g}{counts['done']}{rst}" if use_color else str(counts["done"])
        f_str = f"{r}{counts['failed']}{rst}" if use_color else str(counts["failed"])

        print(f"  {provider:<10} {p_str:>7} {d_str:>7} {f_str:>7} {counts['total']:>7} {avg_str:>8}")

    # 3. Estimated completion
    print(f"\n{b}Estimated Completion{rst}")
    print(f"  {est}")

    # 4. Top sections by pending count
    pending_sections = [
        (name, s["pending"]) for name, s in queue_data["sections"].items()
        if s["pending"] > 0
    ]
    if pending_sections:
        pending_sections.sort(key=lambda x: x[1], reverse=True)
        print(f"\n{b}Sections with Pending Tasks{rst}")
        for name, count in pending_sections[:10]:
            sec_data = queue_data["sections"][name]
            total_sec = sec_data["pending"] + sec_data["done"] + sec_data["failed"]
            print(f"  {d}{name}{rst}  {count} pending / {total_sec} total")

    print()
    return 0


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]
    use_color = True
    json_output = "--json" in args
    if "--no-color" in args:
        use_color = False
    return print_stats(use_color=use_color, json_output=json_output)


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""queue-stats — Summarize golem task queue status.

Reads golem-queue.md and golem.jsonl to show:
  - Pending / Done / Failed counts
  - Tasks per provider breakdown
  - Estimated completion time (based on historical avg duration)

Usage:
    queue-stats              # Show stats
    queue-stats --json       # Machine-readable JSON output
    queue-stats --no-color   # Disable ANSI colors
"""
from __future__ import annotations

import json
import re
import sys
from collections import defaultdict
from pathlib import Path

QUEUE_PATH = Path.home() / "germline" / "loci" / "golem-queue.md"
JSONL_PATH = Path.home() / ".local" / "share" / "vivesca" / "golem.jsonl"

# ANSI colors
GREEN = "\033[32m"
RED = "\033[31m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"


def parse_queue(path: Path) -> dict:
    """Parse golem-queue.md and return structured task data.

    Returns dict with keys:
        pending: int
        done: int
        failed: int
        by_provider: dict[str, dict(status -> int)]
        pending_details: list[dict(provider, max_turns, line)]
        failed_details: list[dict(provider, max_turns, line)]
    """
    result = {
        "pending": 0,
        "done": 0,
        "failed": 0,
        "by_provider": defaultdict(lambda: {"pending": 0, "done": 0, "failed": 0}),
        "pending_details": [],
        "failed_details": [],
    }

    if not path.exists():
        return result

    for line in path.read_text().splitlines():
        # Pending: - [ ] `golem ...`
        m = re.match(r"^- \[ \] `([^`]+)`", line)
        if m:
            result["pending"] += 1
            provider, turns = _extract_provider_turns(m.group(1))
            result["by_provider"][provider]["pending"] += 1
            result["pending_details"].append({
                "provider": provider,
                "max_turns": turns,
            })
            continue

        # Done: - [x] `golem ...`
        m = re.match(r"^- \[x\] `([^`]+)`", line)
        if m:
            result["done"] += 1
            provider, turns = _extract_provider_turns(m.group(1))
            result["by_provider"][provider]["done"] += 1
            continue

        # Failed: - [!] `golem ...`
        m = re.match(r"^- \[!\] `([^`]+)`", line)
        if m:
            result["failed"] += 1
            provider, turns = _extract_provider_turns(m.group(1))
            result["by_provider"][provider]["failed"] += 1
            result["failed_details"].append({
                "provider": provider,
                "max_turns": turns,
            })
            continue

    return result


def _extract_provider_turns(cmd: str) -> tuple[str, int]:
    """Extract provider name and max-turns from a golem command string."""
    provider_match = re.search(r"--provider\s+(\S+)", cmd)
    provider = provider_match.group(1) if provider_match else "unknown"

    turns_match = re.search(r"--max-turns\s+(\d+)", cmd)
    turns = int(turns_match.group(1)) if turns_match else 0

    return provider, turns


def load_jsonl(path: Path) -> list[dict]:
    """Parse golem.jsonl, return list of record dicts."""
    if not path.exists():
        return []
    records = []
    for line in path.read_text(errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            records.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return records


def estimate_completion(queue_data: dict, records: list[dict]) -> str:
    """Estimate time to complete all pending + retryable failed tasks.

    Uses average duration per provider from JSONL history.
    Falls back to a rough estimate if no history exists.
    """
    pending = queue_data["pending"]
    failed = queue_data["failed"]
    remaining = pending + failed

    if remaining == 0:
        return "0s (queue empty)"

    # Build avg duration per provider from JSONL
    durations_by_provider: dict[str, list[float]] = defaultdict(list)
    for r in records:
        provider = r.get("provider", "unknown")
        dur = r.get("duration")
        if dur is not None and r.get("exit") == 0:
            durations_by_provider[provider].append(dur)

    avg_by_provider: dict[str, float] = {}
    for provider, durs in durations_by_provider.items():
        avg_by_provider[provider] = sum(durs) / len(durs) if durs else 0

    # Global average fallback
    all_durs = [d for ds in durations_by_provider.values() for d in ds]
    global_avg = sum(all_durs) / len(all_durs) if all_durs else 300  # 5 min guess

    # Estimate total work: sum of avg durations for pending+failed tasks
    total_seconds = 0.0
    for task in queue_data["pending_details"]:
        avg = avg_by_provider.get(task["provider"], global_avg)
        total_seconds += avg
    for task in queue_data["failed_details"]:
        avg = avg_by_provider.get(task["provider"], global_avg)
        total_seconds += avg

    # With concurrent execution: divide by number of concurrent slots
    # From queue header: ZhiPu(4) + Infini(6) + Volcano(8) = 18 concurrent
    concurrent = _count_concurrent_slots()
    if concurrent < 1:
        concurrent = 1
    estimated_seconds = total_seconds / concurrent

    return _format_duration(estimated_seconds)


def _count_concurrent_slots() -> int:
    """Try to extract concurrency from queue header comment."""
    if not QUEUE_PATH.exists():
        return 18
    header = QUEUE_PATH.read_text().split("\n## Pending")[0] if "\n## Pending" in QUEUE_PATH.read_text() else ""
    m = re.search(r"(\d+)\s+concurrent", header)
    if m:
        return int(m.group(1))
    # Default from the queue header pattern
    return 18


def _format_duration(seconds: float) -> str:
    """Format seconds into human-readable duration."""
    if seconds < 60:
        return f"{seconds:.0f}s"
    if seconds < 3600:
        m = seconds / 60
        return f"{m:.0f}m" if m == int(m) else f"{m:.1f}m"
    h = seconds / 3600
    if h < 24:
        return f"{h:.1f}h"
    d = h / 24
    return f"{d:.1f}d"


def format_stats(queue_data: dict, records: list[dict], use_color: bool = True) -> str:
    """Build the full stats report as a string."""
    g = GREEN if use_color else ""
    r = RED if use_color else ""
    y = YELLOW if use_color else ""
    c = CYAN if use_color else ""
    b = BOLD if use_color else ""
    d = DIM if use_color else ""
    rst = RESET if use_color else ""

    pending = queue_data["pending"]
    done = queue_data["done"]
    failed = queue_data["failed"]
    total = pending + done + failed

    lines: list[str] = []

    # Section 1: Overall counts
    lines.append(f"{b}Queue Summary{rst}")
    pct_done = (done / total * 100) if total else 0
    lines.append(
        f"  Pending: {c}{pending}{rst}  "
        f"Done: {g}{done}{rst}  "
        f"Failed: {r}{failed}{rst}  "
        f"Total: {b}{total}{rst}  "
        f"({pct_done:.0f}% complete)"
    )

    # Section 2: Tasks per provider
    lines.append(f"\n{b}Tasks per Provider{rst}")
    lines.append(f"  {'Provider':<10} {'Pending':>8} {'Done':>8} {'Failed':>8} {'Total':>8}")
    lines.append(f"  {'-' * 44}")
    for provider in sorted(queue_data["by_provider"]):
        s = queue_data["by_provider"][provider]
        t = s["pending"] + s["done"] + s["failed"]
        p_str = f"{c}{s['pending']}{rst}" if use_color else str(s["pending"])
        d_str = f"{g}{s['done']}{rst}" if use_color else str(s["done"])
        f_str = f"{r}{s['failed']}{rst}" if use_color else str(s["failed"])
        lines.append(f"  {provider:<10} {p_str:>8} {d_str:>8} {f_str:>8} {t:>8}")

    # Section 3: Estimated completion time
    lines.append(f"\n{b}Estimated Completion{rst}")
    est = estimate_completion(queue_data, records)
    remaining = pending + failed
    lines.append(f"  {remaining} tasks remaining \u2192 ~{est}")

    return "\n".join(lines)


def format_json(queue_data: dict, records: list[dict]) -> str:
    """Build JSON output for machine consumption."""
    pending = queue_data["pending"]
    done = queue_data["done"]
    failed = queue_data["failed"]
    total = pending + done + failed
    remaining = pending + failed

    output = {
        "pending": pending,
        "done": done,
        "failed": failed,
        "total": total,
        "pct_complete": round(done / total * 100, 1) if total else 0,
        "by_provider": {
            provider: dict(stats)
            for provider, stats in sorted(queue_data["by_provider"].items())
        },
        "tasks_remaining": remaining,
        "estimated_completion": estimate_completion(queue_data, records),
    }
    return json.dumps(output, indent=2)


def main(argv: list[str] | None = None) -> int:
    args = argv if argv is not None else sys.argv[1:]
    use_color = True
    use_json = False

    if "--no-color" in args:
        use_color = False
    if "--json" in args:
        use_json = True

    queue_data = parse_queue(QUEUE_PATH)
    records = load_jsonl(JSONL_PATH)

    if use_json:
        print(format_json(queue_data, records))
    else:
        print(format_stats(queue_data, records, use_color))
        print()

    return 0


if __name__ == "__main__":
    sys.exit(main())

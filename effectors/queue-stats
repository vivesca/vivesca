#!/usr/bin/env python3
"""queue-stats — Ribosome task queue statistics.

Reads loci/translation-queue.md and ribosome.jsonl. Shows:
  - Pending / done / failed counts
  - Tasks per provider breakdown
  - Estimated completion time based on historical turn durations

Usage:
    queue-stats
"""

from __future__ import annotations

import contextlib
import json
import re
import sys
from collections import Counter, defaultdict
from pathlib import Path

GERMLINE = Path.home() / "germline"
QUEUE_FILE = GERMLINE / "loci" / "translation-queue.md"
RIBOSOME_LOG = Path.home() / ".local" / "share" / "vivesca" / "ribosome.jsonl"

# Provider concurrency (from translation-queue header line 4)
DEFAULT_CONCURRENCY: dict[str, int] = {
    "zhipu": 4,
    "infini": 6,
    "volcano": 8,
}

STATUS_MARKERS = {
    "done": r"\[x\]",
    "failed": r"\[!\]",
    "pending": r"\[ \]",
}


def parse_concurrency_header(text: str) -> dict[str, int]:
    """Extract provider concurrency from the queue header comment."""
    m = re.search(r"(\w+)\((\d+)\).*?(\w+)\((\d+)\).*?(\w+)\((\d+)\)", text)
    if not m:
        return dict(DEFAULT_CONCURRENCY)
    return {
        m.group(1).lower(): int(m.group(2)),
        m.group(3).lower(): int(m.group(4)),
        m.group(5).lower(): int(m.group(6)),
    }


def parse_task(line: str) -> dict | None:
    """Parse a single task line into {status, provider, max_turns}."""
    # Match status marker
    status = None
    for s, marker in STATUS_MARKERS.items():
        if re.search(rf"^- {marker}\s", line):
            status = s
            break
    if status is None:
        return None

    # Provider
    m = re.search(r"--provider\s+(\w+)", line)
    provider = m.group(1) if m else "unknown"

    # Max turns
    m = re.search(r"--max-turns\s+(\d+)", line)
    max_turns = int(m.group(1)) if m else 20  # default 20 if not specified

    return {"status": status, "provider": provider, "max_turns": max_turns}


def parse_queue(text: str) -> list[dict]:
    """Parse all task lines from queue markdown."""
    tasks = []
    for line in text.splitlines():
        task = parse_task(line)
        if task is not None:
            tasks.append(task)
    return tasks


def read_ribosome_log() -> list[dict]:
    """Read ribosome.jsonl log entries."""
    if not RIBOSOME_LOG.exists():
        return []
    entries = []
    with open(RIBOSOME_LOG, errors="replace") as f:
        for line in f:
            line = line.strip()
            if line:
                with contextlib.suppress(json.JSONDecodeError, ValueError):
                    entries.append(json.loads(line))
    return entries


def compute_turn_durations(entries: list[dict]) -> dict[str, float]:
    """Compute average seconds-per-turn per provider from log."""
    by_provider: dict[str, list[float]] = defaultdict(list)
    for e in entries:
        provider = e.get("provider", "unknown")
        duration = e.get("duration")
        turns = e.get("turns")
        if duration and turns and turns > 0:
            by_provider[provider].append(duration / turns)
    result = {}
    for provider, rates in by_provider.items():
        # Use median for robustness against outliers
        sorted_rates = sorted(rates)
        mid = len(sorted_rates) // 2
        result[provider] = sorted_rates[mid]
    # Fallback if no data
    if not result:
        result = {"zhipu": 15.0, "infini": 12.0, "volcano": 8.0, "unknown": 12.0}
    return result


def estimate_completion(
    tasks: list[dict],
    concurrency: dict[str, int],
    sec_per_turn: dict[str, float],
) -> dict[str, dict]:
    """Estimate completion time per provider.

    For each provider, sum the max-turns of pending+failed tasks,
    divide by concurrency slots to get number of sequential waves,
    multiply by average duration per wave.
    """
    remaining: dict[str, list[int]] = defaultdict(list)
    for t in tasks:
        if t["status"] in ("pending", "failed"):
            remaining[t["provider"]].append(t["max_turns"])

    estimates = {}
    for provider, turns_list in sorted(remaining.items()):
        slots = concurrency.get(provider, 4)
        avg_spt = sec_per_turn.get(provider, sec_per_turn.get("unknown", 12.0))
        total_turns = sum(turns_list)
        num_tasks = len(turns_list)

        # How many sequential waves needed
        waves = (num_tasks + slots - 1) // slots if slots > 0 else num_tasks

        # Average turns per task
        avg_turns_per_task = total_turns / num_tasks if num_tasks > 0 else 0

        # Duration per wave (concurrent tasks, so max of the batch)
        # Approximate: avg_turns_per_task * sec_per_turn
        wave_duration = avg_turns_per_task * avg_spt

        total_seconds = waves * wave_duration

        hours = total_seconds / 3600
        estimates[provider] = {
            "tasks": num_tasks,
            "total_turns": total_turns,
            "slots": slots,
            "waves": waves,
            "est_seconds": total_seconds,
            "est_hours": hours,
        }
    return estimates


def format_duration(seconds: float) -> str:
    """Format seconds into human-readable duration."""
    if seconds < 60:
        return f"{seconds:.0f}s"
    if seconds < 3600:
        return f"{seconds / 60:.1f}min"
    if seconds < 86400:
        return f"{seconds / 3600:.1f}h"
    return f"{seconds / 86400:.1f}d"


def main() -> int:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        return 0

    if not QUEUE_FILE.exists():
        print(f"Error: queue file not found: {QUEUE_FILE}", file=sys.stderr)
        return 1

    text = QUEUE_FILE.read_text()
    tasks = parse_queue(text)
    concurrency = parse_concurrency_header(text)
    entries = read_ribosome_log()
    sec_per_turn = compute_turn_durations(entries)

    # Status counts
    by_status = Counter(t["status"] for t in tasks)
    total = len(tasks)

    # Per-provider breakdown
    by_provider_status: dict[str, Counter] = defaultdict(Counter)
    for t in tasks:
        by_provider_status[t["provider"]][t["status"]] += 1

    # Estimates
    estimates = estimate_completion(tasks, concurrency, sec_per_turn)

    # --- Output ---
    print("=== Ribosome Queue Stats ===\n")

    # Overview
    print(f"Total tasks: {total}")
    print(
        f"  Pending: {by_status.get('pending', 0)}  "
        f"Done: {by_status.get('done', 0)}  "
        f"Failed: {by_status.get('failed', 0)}"
    )

    # Per-provider table
    print("\n--- Tasks per provider ---")
    print(f"{'Provider':<10} {'Pending':>8} {'Done':>8} {'Failed':>8} {'Total':>8}")
    print("-" * 46)
    all_providers = sorted(
        set(t["provider"] for t in tasks),
        key=lambda p: sum(1 for t in tasks if t["provider"] == p),
        reverse=True,
    )
    for p in all_providers:
        c = by_provider_status.get(p, Counter())
        row_total = sum(c.values())
        print(
            f"{p:<10} {c.get('pending', 0):>8} {c.get('done', 0):>8} "
            f"{c.get('failed', 0):>8} {row_total:>8}"
        )
    print("-" * 46)
    print(
        f"{'TOTAL':<10} {by_status.get('pending', 0):>8} {by_status.get('done', 0):>8} "
        f"{by_status.get('failed', 0):>8} {total:>8}"
    )

    # Concurrency info
    print("\n--- Concurrency ---")
    for p, slots in sorted(concurrency.items()):
        print(f"  {p}: {slots} slots")

    # Estimated completion
    print("\n--- Estimated completion ---")
    if estimates:
        print(f"{'Provider':<10} {'Tasks':>6} {'Waves':>6} {'Avg s/turn':>10} {'Est. time':>12}")
        print("-" * 50)
        max_hours = 0.0
        for provider, est in sorted(estimates.items()):
            avg_spt = sec_per_turn.get(provider, sec_per_turn.get("unknown", 12.0))
            print(
                f"{provider:<10} {est['tasks']:>6} {est['waves']:>6} "
                f"{avg_spt:>9.1f}s {format_duration(est['est_seconds']):>12}"
            )
            max_hours = max(max_hours, est["est_hours"])

        # Total time = max across providers (they run in parallel)
        print("-" * 50)
        print(f"  Parallel wall-clock estimate: {format_duration(max_hours * 3600)}")
    else:
        print("  No remaining tasks — queue is empty!")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())

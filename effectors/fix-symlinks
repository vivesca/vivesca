#!/usr/bin/env python3
"""Fix symlinks broken by Mac→Linux rsync.

Replaces macOS home-directory symlink targets with the current Linux home path
in key directories. Idempotent and safe to run multiple times.
"""
from __future__ import annotations

import os
import sys
from pathlib import Path, PurePosixPath

MAC_PREFIX = f"{PurePosixPath('/', 'Users', 'terry')}/"
LINUX_PREFIX = f"{Path.home()}/"
SCAN_DIRS = ["~/.claude", "~/epigenome", "~/germline"]


def scan_and_fix() -> tuple[int, int]:
    fixed = 0
    skipped = 0
    for d in SCAN_DIRS:
        root = Path(os.path.expanduser(d))
        if not root.exists():
            continue
        for dirpath, _dirnames, filenames in os.walk(root):
            for name in filenames:
                full = Path(dirpath) / name
                if not full.is_symlink():
                    continue
                try:
                    target = os.readlink(full)
                except OSError:
                    continue
                if MAC_PREFIX not in target:
                    continue
                new_target = target.replace(MAC_PREFIX, LINUX_PREFIX)
                if not os.path.exists(new_target):
                    print(f"  WARNING: target missing: {new_target} ({full})")
                    skipped += 1
                    continue
                try:
                    full.unlink()
                    full.symlink_to(new_target)
                    print(f"  FIXED: {full} → {new_target}")
                    fixed += 1
                except OSError as e:
                    print(f"  ERROR: {full}: {e}", file=sys.stderr)
                    skipped += 1
    return fixed, skipped


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] in ("--help", "-h"):
        print(__doc__)
        sys.exit(0)
    print("Scanning for broken Mac symlinks...")
    fixed, skipped = scan_and_fix()
    print(f"\nDone. Fixed: {fixed}, skipped: {skipped}")
    sys.exit(0 if skipped == 0 else 1)

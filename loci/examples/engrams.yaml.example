# Instance engrams -- the organism's enzyme catalogue.
# Copy to ~/.config/vivesca/engrams.yaml and customise.
# Each engram defines a metabolic reaction: what triggers it, what it produces,
# and which skills (enzymes) carry it out.
#
# Fields:
#   reaction   - short name for the reaction (used in logs and routing)
#   product    - what this reaction produces; use {user_name} for personalisation
#   substrates - conditions that activate this reaction
#   enzymes    - skill names that execute the reaction
#   expressed  - set to false to transcribe but not translate (dormant)
#   precipitation - "crystallised" if the engram emerged from signal patterns

engrams:
  # Anabolism (building up)
  - reaction: triage
    product: Incoming routed to action, defer, or apoptosis
    substrates:
      - daily period
      - inbox accumulation
    enzymes:
      - period
      - stilus

  - reaction: write
    product: "{user_name}'s idea compressed and shipped as a garden post"
    substrates:
      - idea survives compression
      - explicit request
    enzymes:
      - sarcio
      - exocytosis_text

  - reaction: research
    product: Topic thoroughly researched and synthesised across sources
    precipitation: crystallised
    substrates:
      - question requiring external knowledge
      - unfamiliar domain
    enzymes:
      - chemotaxis_search
      - chemotaxis_ask
      - chemotaxis_research
      - endocytosis_extract

  # Homeostasis (health maintenance)
  - reaction: monitor
    product: Health signals synthesised into picture and recommendation
    substrates:
      - zeitgeber routine
      - symptom reported
    enzymes:
      - circadian_sleep
      - membrane_potential

  # Dormant (transcribed, not translated)
  - reaction: decide
    product: Decision made with trade-offs weighed against constraints
    substrates:
      - explicit decision needed
      - competing options
    enzymes:
      - transcription-factor
    expressed: false

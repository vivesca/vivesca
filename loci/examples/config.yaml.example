# Vivesca instance configuration
# Copy to ~/.config/vivesca/config.yaml and customise.

user:
  name: "Your Name"
  full_name: "Your Full Legal Name"
  handle: "@yourhandle"        # social media handle
  blog: "yourblog.com"         # garden/blog domain

paths:
  vault: "~/notes"             # Obsidian vault or notes directory
  bin: "~/bin"                 # directory containing CLI tools
  memory: ""                   # Claude Code memory dir (auto-detected if empty)

llm:
  backend: openrouter          # openrouter, max20, or anthropic
  default_model: haiku         # haiku, sonnet, or opus
  api_key_env: OPENROUTER_API_KEY  # env var containing API key

financial_notes: []            # vault note filenames for homeostasis_financial
# Example:
#   - "Investing.md"
#   - "Insurance Checklist.md"

email_exclude_senders: []      # email addresses to exclude from sorting
# Example:
#   - "newsletter@example.com"

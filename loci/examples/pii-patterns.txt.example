# PII patterns -- one regex per line.
# Used by scripts/check-pii.sh pre-commit hook.
# Copy to ~/.config/vivesca/pii-patterns.txt and add your patterns.

# Full name variants
# YOUR.FULL.NAME
# YOUR-FULL-NAME

# Address
# Your Street Name
# Your City

# Social handles
# yourhandle

# Employer names
# YourCompany

# Absolute paths
# /Users/yourusername
# /home/yourusername

# env.op — 1Password secret references for op run / op inject
# No secrets here — only op:// URIs. Safe to commit.
# Usage: op run --env-file ~/germline/loci/env.op -- <command>
#
# OP_SERVICE_ACCOUNT_TOKEN must be set in the environment for headless auth.
# That single bootstrap secret lives on disk; everything else resolves from it.

# LLM providers
ANTHROPIC_API_KEY=op://Agents/anthropic-api-key/credential
OPENAI_API_KEY=op://Agents/openai-api-key/credential
ZHIPU_API_KEY=op://Agents/zhipu-api-key/credential
ZHIPUAI_API_KEY=op://Agents/zhipuai-api-key/credential
INFINI_API_KEY=op://Agents/Infini AI Coding Plan/credential
VOLCANO_API_KEY=op://Agents/volcano-api-key/credential
GOOGLE_API_KEY=op://Agents/gemini-api-key/credential
GEMINI_API_KEY=op://Agents/gemini-api-key/credential
OPENROUTER_API_KEY=op://Agents/OpenRouter API Key/credential

# Infrastructure
GITHUB_TOKEN=op://Agents/github-token-ganglion/credential
HATCHET_CLIENT_TOKEN=op://Agents/hatchet-client-token/credential
HATCHET_CLIENT_TLS_STRATEGY=none

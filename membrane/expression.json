{
  "env": {
    "AGENT_BROWSER_PROFILE": "$HOME/.agent-browser-profile",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "deny": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/synapse.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/terminus.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/interoceptor.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/compaction.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/axon.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/dendrite.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/morphogen.py",
            "timeout": 2000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd_full=$(echo \"$input\" | jq -r '.workspace.current_dir'); branch=$(git -C \"$cwd_full\" rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'no-git'); cwd=$(echo \"$cwd_full\" | sed \"s|^$HOME|~|\"); model=$(echo \"$input\" | jq -r '.model.display_name' | sed 's/Claude //'); usage=$(echo \"$input\" | jq '.context_window.current_usage'); ctx=''; if [ \"$usage\" != \"null\" ]; then current=$(echo \"$usage\" | jq '.input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens'); size=$(echo \"$input\" | jq '.context_window.context_window_size'); ctx=$(printf '%d%%' $((current * 100 / size))); fi; rl=$(echo \"$input\" | jq -r '.rate_limits // empty | to_entries[] | select(.value.used_percentage > 50) | \"\\(.value.used_percentage|floor)%\"' 2>/dev/null | head -1); parts=\"$(basename \"$cwd\") ($branch) · $model\"; [ -n \"$ctx\" ] && parts=\"$parts · $ctx\"; [ -n \"$rl\" ] && parts=\"$parts · rl:$rl\"; printf '%s' \"$parts\""
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true,
    "evals-skills@hamelsmu-evals-skills": false,
    "qmd@qmd": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "git",
        "url": "https://github.com/EveryInc/compound-engineering-plugin.git"
      }
    },
    "hamelsmu-evals-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/hamelsmu/evals-skills.git"
      }
    },
    "qmd": {
      "source": {
        "source": "github",
        "repo": "tobi/qmd"
      }
    }
  },
  "outputStyle": "Concise",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "in-process",
  "voiceEnabled": true,
  "thinkingDisplay": "none",
  "feedbackSurveyState": {
    "lastShownTime": 1753941965657
  }
}

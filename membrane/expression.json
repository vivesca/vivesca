{
  "env": {
    "AGENT_BROWSER_PROFILE": "$HOME/.agent-browser-profile",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/synapse.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/terminus.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/interoceptor.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/compaction.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/axon.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/dendrite.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/germline/membrane/cytoskeleton/morphogen.py",
            "timeout": 2000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd_full=$(echo \"$input\" | jq -r '.workspace.current_dir'); branch=$(git -C \"$cwd_full\" rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'no-git'); cwd=$(echo \"$cwd_full\" | sed \"s|^$HOME|~|\"); model=$(echo \"$input\" | jq -r '.model.display_name' | sed 's/Claude //'); usage=$(echo \"$input\" | jq '.context_window.current_usage'); if [ \"$usage\" != \"null\" ]; then current=$(echo \"$usage\" | jq '.input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens'); size=$(echo \"$input\" | jq '.context_window.context_window_size'); pct=$((current * 100 / size)); printf '%s (%s) · %s · %d%%' \"$(basename \"$cwd\")\" \"$branch\" \"$model\" \"$pct\"; else printf '%s (%s) · %s' \"$(basename \"$cwd\")\" \"$branch\" \"$model\"; fi"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "evals-skills@hamelsmu-evals-skills": true,
    "compound-engineering@every-marketplace": false,
    "obsidian@obsidian-skills": true,
    "claude-api@anthropic-agent-skills": true,
    "superpowers@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": true
  },
  "extraKnownMarketplaces": {
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/terry/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "in-process",
  "allowedTools": [
    "Bash"
  ],
  "thinkingDisplay": "none",
  "feedbackSurveyState": {
    "lastShownTime": 1753941965657
  }
}
